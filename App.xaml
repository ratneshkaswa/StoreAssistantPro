<Application x:Class="StoreAssistantPro.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StoreAssistantPro"
             xmlns:helpers="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:shellVm="clr-namespace:StoreAssistantPro.Modules.MainShell.ViewModels"
             xmlns:shellViews="clr-namespace:StoreAssistantPro.Modules.MainShell.Views"
             xmlns:productsVm="clr-namespace:StoreAssistantPro.Modules.Products.ViewModels"
             xmlns:productsViews="clr-namespace:StoreAssistantPro.Modules.Products.Views"
             xmlns:salesVm="clr-namespace:StoreAssistantPro.Modules.Sales.ViewModels"
             xmlns:salesViews="clr-namespace:StoreAssistantPro.Modules.Sales.Views"
             xmlns:settingsVm="clr-namespace:StoreAssistantPro.Modules.SystemSettings.ViewModels"
             xmlns:settingsViews="clr-namespace:StoreAssistantPro.Modules.SystemSettings.Views"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:core="clr-namespace:StoreAssistantPro.Core"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Core/Styles/GlobalStyles.xaml"/>
                <ResourceDictionary Source="Core/Styles/PosStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <helpers:EqualityConverter x:Key="EqualityConverter"/>
            <helpers:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <helpers:PinDotConverter x:Key="PinDotConverter"/>
            <helpers:BoolToActiveTextConverter x:Key="BoolToActiveText"/>

        <!-- ViewModel → View DataTemplates (MainShell module) -->
        <DataTemplate DataType="{x:Type shellVm:MainWorkspaceViewModel}">
            <shellViews:MainWorkspaceView/>
        </DataTemplate>

        <!-- Products module -->
        <DataTemplate DataType="{x:Type productsVm:ProductsViewModel}">
            <productsViews:ProductsView/>
        </DataTemplate>

        <!-- Sales module -->
        <DataTemplate DataType="{x:Type salesVm:SalesViewModel}">
            <salesViews:SalesView/>
        </DataTemplate>

        <!-- SystemSettings module -->
        <DataTemplate DataType="{x:Type settingsVm:GeneralSettingsViewModel}">
            <settingsViews:GeneralSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type settingsVm:SecuritySettingsViewModel}">
            <settingsViews:SecuritySettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type settingsVm:BackupSettingsViewModel}">
            <settingsViews:BackupSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type settingsVm:AppInfoViewModel}">
            <settingsViews:AppInfoView/>
        </DataTemplate>

        <!-- Responsive content host: stretch-to-fill + scroll-on-overflow -->
        <Style TargetType="{x:Type controls:ResponsiveContentControl}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:ResponsiveContentControl}">
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="0">
                            <controls:ViewportConstrainedPanel
                                ViewportWidth="{Binding ViewportWidth, ElementName=PART_ScrollViewer}"
                                ViewportHeight="{Binding ViewportHeight, ElementName=PART_ScrollViewer}">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </controls:ViewportConstrainedPanel>
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base page layout: standard padding, title, error bar, loading overlay -->
        <Style TargetType="{x:Type core:BasePage}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type core:BasePage}">
                        <Grid Margin="{StaticResource PagePadding}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Title bar: page title + optional header content -->
                            <DockPanel x:Name="PART_TitleBar" Grid.Row="0"
                                       Margin="{StaticResource TitleSpacing}">
                                <TextBlock Text="{TemplateBinding PageTitle}"
                                           Style="{StaticResource PageTitleStyle}"
                                           Margin="0"
                                           DockPanel.Dock="Left"
                                           VerticalAlignment="Center"/>
                                <ContentPresenter Content="{TemplateBinding HeaderContent}"
                                                  DockPanel.Dock="Right"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- Error message bar -->
                            <TextBlock x:Name="PART_ErrorMessage" Grid.Row="1"
                                       Text="{Binding ErrorMessage}"
                                       Style="{StaticResource ErrorMessageStyle}"/>

                            <!-- Page content + loading overlay -->
                            <Grid Grid.Row="2">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                                <TextBlock x:Name="PART_Loading"
                                           Text="⏳ Loading..." FontSize="14" Foreground="#888"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Collapse title bar when no title is set -->
                            <Trigger Property="PageTitle" Value="">
                                <Setter TargetName="PART_TitleBar" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <!-- Collapse error bar when empty -->
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter TargetName="PART_ErrorMessage" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter TargetName="PART_ErrorMessage" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <!-- Show loading overlay -->
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter TargetName="PART_Loading" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sidebar navigation button style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                            <Binding Path="DataContext.CurrentPage"
                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
