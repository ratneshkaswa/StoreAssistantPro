<Application x:Class="StoreAssistantPro.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StoreAssistantPro"
             xmlns:helpers="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:shellVm="clr-namespace:StoreAssistantPro.Modules.MainShell.ViewModels"
             xmlns:shellViews="clr-namespace:StoreAssistantPro.Modules.MainShell.Views"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:core="clr-namespace:StoreAssistantPro.Core"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Core/Styles/DesignSystem.xaml"/>
                <ResourceDictionary Source="Core/Styles/FluentTheme.xaml"/>
                <ResourceDictionary Source="Core/Styles/MotionSystem.xaml"/>
                <ResourceDictionary Source="Core/Styles/GlobalStyles.xaml"/>
                <ResourceDictionary Source="Core/Styles/PosStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <helpers:EqualityConverter x:Key="EqualityConverter"/>
            <helpers:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <helpers:PinDotConverter x:Key="PinDotConverter"/>
            <helpers:BoolToActiveTextConverter x:Key="BoolToActiveText"/>
            <helpers:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVisibility"/>
            <helpers:RoleColorConverter x:Key="RoleColorConverter"/>
            <helpers:PinStrengthConverter x:Key="PinStrengthConverter"/>

        <!-- ViewModel → View DataTemplates (MainShell module) -->
        <DataTemplate DataType="{x:Type shellVm:WorkspaceViewModel}">
            <shellViews:WorkspaceView/>
        </DataTemplate>

        <!-- Responsive content host: stretch-to-fill + scroll-on-overflow + slide-fade transition -->
        <Style TargetType="{x:Type controls:ResponsiveContentControl}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:ResponsiveContentControl}">
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      Padding="0">
                            <controls:ViewportConstrainedPanel
                                ViewportWidth="{Binding ViewportWidth, ElementName=PART_ScrollViewer}"
                                ViewportHeight="{Binding ViewportHeight, ElementName=PART_ScrollViewer}">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </controls:ViewportConstrainedPanel>
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base page layout: standard padding, title, error bar, loading overlay -->
        <Style TargetType="{x:Type core:BasePage}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type core:BasePage}">
                        <Grid Margin="{StaticResource PagePadding}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Title bar: page title + optional header content -->
                            <DockPanel x:Name="PART_TitleBar" Grid.Row="0"
                                       Margin="{StaticResource TitleSpacing}">
                                <TextBlock Text="{TemplateBinding PageTitle}"
                                           Style="{StaticResource PageTitleStyle}"
                                           Margin="0"
                                           DockPanel.Dock="Left"
                                           VerticalAlignment="Center"/>
                                <ContentPresenter Content="{TemplateBinding HeaderContent}"
                                                  DockPanel.Dock="Right"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- Error message bar -->
                            <TextBlock x:Name="PART_ErrorMessage" Grid.Row="1"
                                       Text="{Binding ErrorMessage}"
                                       Style="{StaticResource ErrorMessageStyle}"/>

                            <!-- Page content + loading overlay -->
                            <Grid Grid.Row="2">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                                <TextBlock x:Name="PART_Loading"
                                           Text="? Loading..." FontSize="14" Foreground="#888"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Collapse title bar when no title is set -->
                            <Trigger Property="PageTitle" Value="">
                                <Setter TargetName="PART_TitleBar" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <!-- Collapse error bar when empty -->
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter TargetName="PART_ErrorMessage" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter TargetName="PART_ErrorMessage" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <!-- Show loading overlay -->
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter TargetName="PART_Loading" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Enterprise page layout: TipBanner � Toolbar � MainContent � Messages � BottomForm � StatusBar -->
        <Style TargetType="{x:Type controls:EnterprisePageLayout}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:EnterprisePageLayout}">
                        <Grid Margin="{StaticResource PagePadding}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- Row 0: TipBanner   -->
                                <RowDefinition Height="Auto"/>  <!-- Row 1: Toolbar     -->
                                <RowDefinition Height="*"/>     <!-- Row 2: MainContent -->
                                <RowDefinition Height="Auto"/>  <!-- Row 3: Messages    -->
                                <RowDefinition Height="Auto"/>  <!-- Row 4: BottomForm  -->
                                <RowDefinition Height="Auto"/>  <!-- Row 5: StatusBar   -->
                            </Grid.RowDefinitions>

                            <!-- Row 0: Tip Banner -->
                            <ContentPresenter x:Name="PART_TipBanner" Grid.Row="0"
                                              Content="{TemplateBinding TipBannerContent}"/>

                            <!-- Row 1: Toolbar -->
                            <ContentPresenter x:Name="PART_Toolbar" Grid.Row="1"
                                              Content="{TemplateBinding ToolbarContent}"/>

                            <!-- Row 2: Main Content + Loading Overlay -->
                            <Grid Grid.Row="2" MinHeight="100">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                                <TextBlock x:Name="PART_Loading"
                                           Text="? Loading..."
                                           FontSize="{StaticResource FontSizeSectionHeader}"
                                           Foreground="{StaticResource FluentTextTertiary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>

                            <!-- Row 3: Messages (auto-bound to BaseViewModel) -->
                            <StackPanel Grid.Row="3" Margin="{StaticResource MessageBarSpacing}">
                                <TextBlock x:Name="PART_ErrorMessage"
                                           Text="{Binding ErrorMessage}"
                                           Style="{StaticResource ErrorMessageStyle}"/>
                                <TextBlock x:Name="PART_SuccessMessage"
                                           Text="{Binding SuccessMessage}"
                                           Style="{StaticResource SuccessMessageStyle}"
                                           helpers:AutoDismiss.IsEnabled="True"
                                           helpers:AutoDismiss.Seconds="4"/>
                            </StackPanel>

                            <!-- Row 4: Bottom Form -->
                            <ContentPresenter x:Name="PART_BottomForm" Grid.Row="4"
                                              Content="{TemplateBinding BottomFormContent}"/>

                            <!-- Row 5: Status Bar -->
                            <ContentPresenter x:Name="PART_StatusBar" Grid.Row="5"
                                              Content="{TemplateBinding StatusBarContent}"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Collapse empty slots � no wasted vertical space -->
                            <Trigger Property="TipBannerContent" Value="{x:Null}">
                                <Setter TargetName="PART_TipBanner" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="ToolbarContent" Value="{x:Null}">
                                <Setter TargetName="PART_Toolbar" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="BottomFormContent" Value="{x:Null}">
                                <Setter TargetName="PART_BottomForm" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="StatusBarContent" Value="{x:Null}">
                                <Setter TargetName="PART_StatusBar" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <!-- Loading overlay (bound to BaseViewModel.IsLoading) -->
                            <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                <Setter TargetName="PART_Loading" Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                            <!-- Collapse messages when empty -->
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter TargetName="PART_ErrorMessage" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter TargetName="PART_ErrorMessage" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SuccessMessage}" Value="">
                                <Setter TargetName="PART_SuccessMessage" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding SuccessMessage}" Value="{x:Null}">
                                <Setter TargetName="PART_SuccessMessage" Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
