<Application x:Class="StoreAssistantPro.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StoreAssistantPro"
             xmlns:helpers="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:shellVm="clr-namespace:StoreAssistantPro.Modules.MainShell.ViewModels"
             xmlns:shellViews="clr-namespace:StoreAssistantPro.Modules.MainShell.Views"
             xmlns:productsVm="clr-namespace:StoreAssistantPro.Modules.Products.ViewModels"
             xmlns:productsViews="clr-namespace:StoreAssistantPro.Modules.Products.Views"
             xmlns:salesVm="clr-namespace:StoreAssistantPro.Modules.Sales.ViewModels"
             xmlns:salesViews="clr-namespace:StoreAssistantPro.Modules.Sales.Views"
             xmlns:settingsVm="clr-namespace:StoreAssistantPro.Modules.SystemSettings.ViewModels"
             xmlns:settingsViews="clr-namespace:StoreAssistantPro.Modules.SystemSettings.Views"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:EqualityConverter x:Key="EqualityConverter"/>
        <helpers:InverseBoolConverter x:Key="InverseBoolConverter"/>

        <!-- ViewModel → View DataTemplates (MainShell module) -->
        <DataTemplate DataType="{x:Type shellVm:DashboardViewModel}">
            <shellViews:DashboardView/>
        </DataTemplate>

        <!-- Products module -->
        <DataTemplate DataType="{x:Type productsVm:ProductsViewModel}">
            <productsViews:ProductsView/>
        </DataTemplate>

        <!-- Sales module -->
        <DataTemplate DataType="{x:Type salesVm:SalesViewModel}">
            <salesViews:SalesView/>
        </DataTemplate>

        <!-- SystemSettings module -->
        <DataTemplate DataType="{x:Type settingsVm:GeneralSettingsViewModel}">
            <settingsViews:GeneralSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type settingsVm:SecuritySettingsViewModel}">
            <settingsViews:SecuritySettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type settingsVm:BackupSettingsViewModel}">
            <settingsViews:BackupSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type settingsVm:AppInfoViewModel}">
            <settingsViews:AppInfoView/>
        </DataTemplate>

        <!-- Sidebar navigation button style -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Foreground" Value="#B0B0B0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#007ACC"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                            <Binding Path="DataContext.CurrentPage"
                                     RelativeSource="{RelativeSource AncestorType=Window}"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="#007ACC"/>
                    <Setter Property="Foreground" Value="White"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
