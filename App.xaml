<Application x:Class="StoreAssistantPro.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:StoreAssistantPro"
             xmlns:helpers="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:shellVm="clr-namespace:StoreAssistantPro.Modules.MainShell.ViewModels"
             xmlns:shellViews="clr-namespace:StoreAssistantPro.Modules.MainShell.Views"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:core="clr-namespace:StoreAssistantPro.Core"
             xmlns:expVm="clr-namespace:StoreAssistantPro.Modules.Expenses.ViewModels"
             xmlns:expViews="clr-namespace:StoreAssistantPro.Modules.Expenses.Views"
             xmlns:debtVm="clr-namespace:StoreAssistantPro.Modules.Debtors.ViewModels"
             xmlns:debtViews="clr-namespace:StoreAssistantPro.Modules.Debtors.Views"
             xmlns:ordVm="clr-namespace:StoreAssistantPro.Modules.Orders.ViewModels"
             xmlns:ordViews="clr-namespace:StoreAssistantPro.Modules.Orders.Views"
             xmlns:ironVm="clr-namespace:StoreAssistantPro.Modules.Ironing.ViewModels"
             xmlns:ironViews="clr-namespace:StoreAssistantPro.Modules.Ironing.Views"
             xmlns:salVm="clr-namespace:StoreAssistantPro.Modules.Salaries.ViewModels"
             xmlns:salViews="clr-namespace:StoreAssistantPro.Modules.Salaries.Views"
             xmlns:brVm="clr-namespace:StoreAssistantPro.Modules.Branch.ViewModels"
             xmlns:brViews="clr-namespace:StoreAssistantPro.Modules.Branch.Views"
             xmlns:spVm="clr-namespace:StoreAssistantPro.Modules.SalesPurchase.ViewModels"
             xmlns:spViews="clr-namespace:StoreAssistantPro.Modules.SalesPurchase.Views"
             xmlns:payVm="clr-namespace:StoreAssistantPro.Modules.Payments.ViewModels"
             xmlns:payViews="clr-namespace:StoreAssistantPro.Modules.Payments.Views"
             xmlns:taxVm="clr-namespace:StoreAssistantPro.Modules.Tax.ViewModels"
             xmlns:taxViews="clr-namespace:StoreAssistantPro.Modules.Tax.Views"
             xmlns:venVm="clr-namespace:StoreAssistantPro.Modules.Vendors.ViewModels"
             xmlns:venViews="clr-namespace:StoreAssistantPro.Modules.Vendors.Views"
             xmlns:prodVm="clr-namespace:StoreAssistantPro.Modules.Products.ViewModels"
             xmlns:prodViews="clr-namespace:StoreAssistantPro.Modules.Products.Views"
             xmlns:catVm="clr-namespace:StoreAssistantPro.Modules.Categories.ViewModels"
             xmlns:catViews="clr-namespace:StoreAssistantPro.Modules.Categories.Views"
             xmlns:brandVm="clr-namespace:StoreAssistantPro.Modules.Brands.ViewModels"
             xmlns:brandViews="clr-namespace:StoreAssistantPro.Modules.Brands.Views"
             xmlns:invVm="clr-namespace:StoreAssistantPro.Modules.Inventory.ViewModels"
             xmlns:invViews="clr-namespace:StoreAssistantPro.Modules.Inventory.Views"
             xmlns:billVm="clr-namespace:StoreAssistantPro.Modules.Billing.ViewModels"
             xmlns:billViews="clr-namespace:StoreAssistantPro.Modules.Billing.Views"
             xmlns:custVm="clr-namespace:StoreAssistantPro.Modules.Customers.ViewModels"
             xmlns:custViews="clr-namespace:StoreAssistantPro.Modules.Customers.Views"
             xmlns:poVm="clr-namespace:StoreAssistantPro.Modules.PurchaseOrders.ViewModels"
             xmlns:poViews="clr-namespace:StoreAssistantPro.Modules.PurchaseOrders.Views"
             xmlns:fyVm="clr-namespace:StoreAssistantPro.Modules.FinancialYears.ViewModels"
             xmlns:fyViews="clr-namespace:StoreAssistantPro.Modules.FinancialYears.Views"
             xmlns:setVm="clr-namespace:StoreAssistantPro.Modules.Settings.ViewModels"
             xmlns:setViews="clr-namespace:StoreAssistantPro.Modules.Settings.Views"
             xmlns:inwVm="clr-namespace:StoreAssistantPro.Modules.Inward.ViewModels"
             xmlns:inwViews="clr-namespace:StoreAssistantPro.Modules.Inward.Views"
             xmlns:firmVm="clr-namespace:StoreAssistantPro.Modules.Firm.ViewModels"
             xmlns:firmViews="clr-namespace:StoreAssistantPro.Modules.Firm.Views"
             xmlns:usrVm="clr-namespace:StoreAssistantPro.Modules.Users.ViewModels"
             xmlns:usrViews="clr-namespace:StoreAssistantPro.Modules.Users.Views"
             xmlns:authVm="clr-namespace:StoreAssistantPro.Modules.Authentication.ViewModels"
             xmlns:authViews="clr-namespace:StoreAssistantPro.Modules.Authentication.Views"
             xmlns:bkVm="clr-namespace:StoreAssistantPro.Modules.Backup.ViewModels"
             xmlns:bkViews="clr-namespace:StoreAssistantPro.Modules.Backup.Views"
             xmlns:quotVm="clr-namespace:StoreAssistantPro.Modules.Quotations.ViewModels"
             xmlns:quotViews="clr-namespace:StoreAssistantPro.Modules.Quotations.Views"
             xmlns:grnVm="clr-namespace:StoreAssistantPro.Modules.GRN.ViewModels"
             xmlns:grnViews="clr-namespace:StoreAssistantPro.Modules.GRN.Views"
             xmlns:bclVm="clr-namespace:StoreAssistantPro.Modules.BarcodeLabels.ViewModels"
             xmlns:bclViews="clr-namespace:StoreAssistantPro.Modules.BarcodeLabels.Views"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Core/Styles/DesignSystem.xaml"/>
                <ResourceDictionary Source="Core/Styles/FluentTheme.xaml"/>
                <ResourceDictionary Source="Core/Styles/MotionSystem.xaml"/>
                <ResourceDictionary Source="Core/Styles/GlobalStyles.xaml"/>
                <ResourceDictionary Source="Core/Styles/ToggleSwitch.xaml"/>
                <ResourceDictionary Source="Core/Styles/PosStyles.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Global Window background -->
            <Style TargetType="Window">
                <Setter Property="Background" Value="{StaticResource AppBackgroundBrush}"/>
            </Style>

            <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
            <helpers:EqualityConverter x:Key="EqualityConverter"/>
            <helpers:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <helpers:PinDotConverter x:Key="PinDotConverter"/>
            <helpers:BoolToActiveTextConverter x:Key="BoolToActiveText"/>
            <helpers:NonEmptyStringToVisibilityConverter x:Key="NonEmptyStringToVisibility"/>
            <helpers:RoleColorConverter x:Key="RoleColorConverter"/>
            <helpers:PinStrengthConverter x:Key="PinStrengthConverter"/>
            <helpers:BoolToHiddenVisibilityConverter x:Key="BoolToHiddenVisibility"/>
            <helpers:PriceToDisplayConverter x:Key="PriceToDisplayConverter"/>
            <helpers:HintForegroundConverter x:Key="HintForegroundConverter"/>
            <helpers:StatusDisplayTextConverter x:Key="StatusDisplayTextConverter"/>

        <!-- ViewModel → View DataTemplates (MainShell module) -->
        <DataTemplate DataType="{x:Type shellVm:WorkspaceViewModel}">
            <shellViews:WorkspaceView/>
        </DataTemplate>

        <!-- ViewModel → View DataTemplates (Page modules) -->
        <DataTemplate DataType="{x:Type expVm:ExpenseManagementViewModel}">
            <expViews:ExpenseManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type debtVm:DebtorManagementViewModel}">
            <debtViews:DebtorManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type ordVm:OrderManagementViewModel}">
            <ordViews:OrderManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type ironVm:IroningManagementViewModel}">
            <ironViews:IroningManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type salVm:SalaryManagementViewModel}">
            <salViews:SalaryManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type brVm:BranchManagementViewModel}">
            <brViews:BranchManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type spVm:SalesPurchaseViewModel}">
            <spViews:SalesPurchaseView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type payVm:PaymentManagementViewModel}">
            <payViews:PaymentManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type taxVm:TaxManagementViewModel}">
            <taxViews:TaxManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type venVm:VendorManagementViewModel}">
            <venViews:VendorManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type prodVm:ProductManagementViewModel}">
            <prodViews:ProductManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type catVm:CategoryManagementViewModel}">
            <catViews:CategoryManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type brandVm:BrandManagementViewModel}">
            <brandViews:BrandManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type invVm:InventoryViewModel}">
            <invViews:InventoryManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type billVm:BillingViewModel}">
            <billViews:BillingView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type billVm:SaleHistoryViewModel}">
            <billViews:SaleHistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type billVm:CashRegisterViewModel}">
            <billViews:CashRegisterView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type custVm:CustomerManagementViewModel}">
            <custViews:CustomerManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type poVm:PurchaseOrderViewModel}">
            <poViews:PurchaseOrderView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type fyVm:FinancialYearViewModel}">
            <fyViews:FinancialYearView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type setVm:SystemSettingsViewModel}">
            <setViews:SystemSettingsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type inwVm:InwardEntryViewModel}">
            <inwViews:InwardEntryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type firmVm:FirmViewModel}">
            <firmViews:FirmManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type usrVm:UsersViewModel}">
            <usrViews:UserManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type prodVm:VariantManagementViewModel}">
            <prodViews:VariantManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type authVm:LoginViewModel}">
            <authViews:LoginView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type bkVm:BackupRestoreViewModel}">
            <bkViews:BackupRestoreView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type quotVm:QuotationViewModel}">
            <quotViews:QuotationManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type grnVm:GRNViewModel}">
            <grnViews:GRNManagementView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type bclVm:BarcodeLabelViewModel}">
            <bclViews:BarcodeLabelView/>
        </DataTemplate>

        <!-- Responsive content host: stretch-to-fill + scroll-on-overflow + clipped page-exit transition -->
        <Style TargetType="{x:Type controls:ResponsiveContentControl}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:ResponsiveContentControl}">
                        <ScrollViewer x:Name="PART_ScrollViewer"
                                      Focusable="False"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      CanContentScroll="False"
                                      PanningMode="VerticalOnly"
                                      helpers:SmoothScroll.IsEnabled="True"
                                      Padding="0">
                            <controls:ViewportConstrainedPanel
                                ViewportWidth="{Binding ViewportWidth, ElementName=PART_ScrollViewer}"
                                ViewportHeight="{Binding ViewportHeight, ElementName=PART_ScrollViewer}">
                                <Grid x:Name="PART_TransitionHost"
                                      ClipToBounds="True">
                                    <Image x:Name="PART_PreviousSnapshot"
                                           Source="{TemplateBinding PreviousSnapshot}"
                                           Visibility="Collapsed"
                                           IsHitTestVisible="False"
                                           HorizontalAlignment="Stretch"
                                           VerticalAlignment="Stretch"
                                           Stretch="Fill"/>
                                    <ContentPresenter x:Name="PART_CurrentPresenter"
                                                      Content="{TemplateBinding Content}"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                                </Grid>
                            </controls:ViewportConstrainedPanel>
                        </ScrollViewer>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Base page layout: standard padding, title, error bar, loading overlay -->
        <Style TargetType="{x:Type core:BasePage}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type core:BasePage}">
                        <Grid Margin="{StaticResource PagePadding}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Title bar: page title + optional header content -->
                            <DockPanel x:Name="PART_TitleBar" Grid.Row="0"
                                       Margin="{StaticResource TitleSpacing}">
                                <TextBlock Text="{TemplateBinding PageTitle}"
                                           Style="{StaticResource PageTitleStyle}"
                                           Margin="0"
                                           DockPanel.Dock="Left"
                                           VerticalAlignment="Center"/>
                                <ContentPresenter Content="{TemplateBinding HeaderContent}"
                                                  DockPanel.Dock="Right"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"/>
                            </DockPanel>

                            <!-- Error message bar (MinHeight reserves space to prevent layout shift) -->
                            <TextBlock x:Name="PART_ErrorMessage" Grid.Row="1"
                                       Text="{Binding ErrorMessage}"
                                       Style="{StaticResource ErrorMessageStyle}"
                                       MinHeight="{StaticResource ErrorAreaMinHeight}"/>

                            <!-- Page content + loading overlay -->
                            <Grid Grid.Row="2">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                                <controls:LoadingOverlay x:Name="PART_Loading"
                                                         IsActive="{Binding IsLoading}"
                                                         Message="Preparing page content..."/>
                            </Grid>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Collapse title bar when no title is set -->
                            <Trigger Property="PageTitle" Value="">
                                <Setter TargetName="PART_TitleBar" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Enterprise page layout: TipBanner � Toolbar � MainContent � Messages � BottomForm � StatusBar -->
        <Style TargetType="{x:Type controls:EnterprisePageLayout}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="VerticalContentAlignment" Value="Stretch"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type controls:EnterprisePageLayout}">
                        <Grid Margin="{StaticResource PagePadding}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>  <!-- Row 0: TipBanner   -->
                                <RowDefinition Height="Auto"/>  <!-- Row 1: Toolbar     -->
                                <RowDefinition Height="*"/>     <!-- Row 2: MainContent -->
                                <RowDefinition Height="Auto"/>  <!-- Row 3: Messages    -->
                                <RowDefinition Height="Auto"/>  <!-- Row 4: BottomForm  -->
                                <RowDefinition Height="Auto"/>  <!-- Row 5: StatusBar   -->
                            </Grid.RowDefinitions>

                            <!-- Row 0: Tip Banner -->
                            <ContentPresenter x:Name="PART_TipBanner" Grid.Row="0"
                                              Content="{TemplateBinding TipBannerContent}"/>

                            <!-- Row 1: Toolbar -->
                            <ContentPresenter x:Name="PART_Toolbar" Grid.Row="1"
                                              Content="{TemplateBinding ToolbarContent}"/>

                            <!-- Row 2: Main Content + Loading Overlay -->
                            <Grid Grid.Row="2" MinHeight="100">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                                <controls:LoadingOverlay x:Name="PART_Loading"
                                                         IsActive="{Binding IsLoading}"
                                                         Message="Preparing page content..."/>
                            </Grid>

                            <!-- Row 3: Messages (MinHeight reserves space to prevent layout shift) -->
                            <StackPanel Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
                                        Margin="{StaticResource MessageBarSpacing}">
                                <TextBlock x:Name="PART_ErrorMessage"
                                           Text="{Binding ErrorMessage}"
                                           Style="{StaticResource ErrorMessageStyle}"/>
                                <TextBlock x:Name="PART_SuccessMessage"
                                           Text="{Binding SuccessMessage}"
                                           Style="{StaticResource SuccessMessageStyle}"
                                           helpers:AutoDismiss.IsEnabled="True"
                                           helpers:AutoDismiss.Seconds="4"/>
                            </StackPanel>

                            <!-- Row 4: Bottom Form -->
                            <ContentPresenter x:Name="PART_BottomForm" Grid.Row="4"
                                              Content="{TemplateBinding BottomFormContent}"/>

                            <!-- Row 5: Status Bar -->
                            <ContentPresenter x:Name="PART_StatusBar" Grid.Row="5"
                                              Content="{TemplateBinding StatusBarContent}"/>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <!-- Collapse empty slots � no wasted vertical space -->
                            <Trigger Property="TipBannerContent" Value="{x:Null}">
                                <Setter TargetName="PART_TipBanner" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="ToolbarContent" Value="{x:Null}">
                                <Setter TargetName="PART_Toolbar" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="BottomFormContent" Value="{x:Null}">
                                <Setter TargetName="PART_BottomForm" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                            <Trigger Property="StatusBarContent" Value="{x:Null}">
                                <Setter TargetName="PART_StatusBar" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
            </Setter>
        </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
