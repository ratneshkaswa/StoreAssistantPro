<core:BasePage x:Class="StoreAssistantPro.Core.Base.ExampleDerivedPage"
              xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
              xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
              xmlns:core="clr-namespace:StoreAssistantPro.Core"
              xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
              mc:Ignorable="d"
              d:DesignHeight="450" d:DesignWidth="800"
              PageTitle="Example Page">

    <!--
        PAGE-LEVEL KEYBOARD SHORTCUTS
        Use Ctrl+N for "New", Ctrl+E for "Edit", Delete for delete.
        These are scoped to this page — they only fire when this
        UserControl has focus (i.e. it's the active page).
    -->
    <core:BasePage.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding AddCommand}"/>
    </core:BasePage.InputBindings>

    <!--
        HeaderContent places controls in the title bar alongside the title.
        Remove this block if the page needs only a plain title.
    -->
    <core:BasePage.HeaderContent>
        <StackPanel Orientation="Horizontal">
            <Button Content="🔄 Refresh" Padding="12,6" FontSize="13"/>
        </StackPanel>
    </core:BasePage.HeaderContent>

    <!--
        Page-specific content lives here. Use Auto rows for toolbars/forms
        and a single * row for the primary data region so it stretches to
        fill available space and cooperates with the outer ScrollViewer.

        ENTER-KEY FOCUS FLOW (provided globally by KeyboardNav):
          Enter       → moves focus to the next editable input control,
                        skipping disabled and read-only controls.
                        When no editable field follows, executes
                        DefaultCommand (submit) if bound and CanExecute.
          Shift+Enter → moves focus to the previous editable input control
          Tab         → standard WPF tab order (follows TabIndex)

        Controls that participate in Enter-key navigation:
          TextBox (not read-only), PasswordBox, ComboBox, DatePicker.

        Controls that are automatically skipped:
          Disabled controls, read-only TextBoxes, Buttons, TextBlocks,
          DataGrids, and any non-input element.

        ESCAPE BEHAVIOR (tiered, highest priority wins):
          1. EscapeCommand bound on nearest ancestor → executes command
          2. Input control focused (no command)      → clears focus
          3. Nothing to do                           → bubbles to IsCancel buttons

        DEFAULT BUTTON / SUBMIT BEHAVIOR:
          Set h:KeyboardNav.DefaultCommand on a form container.
          Enter walks through editable fields first, then submits
          ONLY when no more editable fields follow the current one.
          The command's CanExecute acts as the final guard.
          Bind the SAME command used on the primary action button.

        GUIDELINES:
        • Set TabIndex when visual layout doesn't match navigation path.
        • Multi-line TextBoxes (AcceptsReturn) — Enter inserts a newline.
        • Buttons — Enter invokes the button's own command, not DefaultCommand.
        • Inner DefaultCommand/EscapeCommand overrides outer (nearest wins).
        • To disable keyboard nav on a specific container:
              h:KeyboardNav.IsEnabled="False"
    -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Example inline form (keyboard-navigable) ─────────────
             Enter from any input  → executes SaveCommand (primary action).
             ESC from any input    → executes CancelFormCommand.
             The commands on this Border override Window-level behavior,
             so the form has its own submit + cancel without closing. -->
        <Border Grid.Row="0" Style="{StaticResource FormCardStyle}"
                h:KeyboardNav.DefaultCommand="{Binding SaveCommand}"
                h:KeyboardNav.EscapeCommand="{Binding CancelFormCommand}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Row 0: Name + Value side by side.
                     TabIndex ensures Enter goes Name→Value→Notes→Save
                     even though the visual layout is two-column. -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="{StaticResource FieldGroupSpacing}">
                    <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox TabIndex="0"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Margin="{StaticResource FieldGroupSpacing}">
                    <TextBlock Text="Value" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox TabIndex="1" h:NumericInput.IsDecimalOnly="True"/>
                </StackPanel>

                <!-- Row 1: Multi-line notes — Enter inserts newline (AcceptsReturn) -->
                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="3" Margin="{StaticResource FieldGroupSpacing}">
                    <TextBlock Text="Notes (multi-line — Enter adds a line)" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox TabIndex="2" AcceptsReturn="True" TextWrapping="Wrap"
                             Height="50" VerticalScrollBarVisibility="Auto"/>
                </StackPanel>

                <!-- Row 2: Buttons — Enter invokes the command, not focus-move -->
                <StackPanel Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="3"
                            Orientation="Horizontal">
                    <Button Content="💾 Save" TabIndex="3"
                            Style="{StaticResource ToolbarButtonStyle}" FontWeight="SemiBold"/>
                    <Button Content="Cancel" TabIndex="4"
                            Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Toolbar / action bar ───────────────────────────────── -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="{StaticResource ToolbarSpacing}">
            <Button Content="➕ Add" Style="{StaticResource ToolbarButtonStyle}"/>
            <Button Content="✏️ Edit" Style="{StaticResource ToolbarButtonStyle}"/>
            <Button Content="🗑 Delete" Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
        </StackPanel>

        <!-- Primary data region — star-sized row auto-resizes with the window -->
        <DataGrid Grid.Row="2"
                  Style="{StaticResource EnterpriseDataGridStyle}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Width="60"/>
                <DataGridTextColumn Header="Name" Width="*"/>
                <DataGridTextColumn Header="Value" Width="120"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</core:BasePage>
