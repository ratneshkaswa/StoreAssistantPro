<core:BaseDialogWindow x:Class="StoreAssistantPro.Core.Printing.PrintPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        Title=""
        Background="{StaticResource AppBackgroundBrush}">
    <core:BaseDialogWindow.Resources>
        <Style TargetType="DocumentViewer">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DocumentViewer">
                        <ScrollViewer x:Name="PART_ContentHost"
                                      CanContentScroll="True"
                                      HorizontalScrollBarVisibility="Auto"
                                      IsTabStop="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </core:BaseDialogWindow.Resources>

    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="{StaticResource TitleSpacing}">
            <Border Style="{StaticResource DialogHeaderBackdropStyle}"/>
            <Border Style="{StaticResource DialogHeaderContentSurfaceStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="TitleText"
                                   Style="{StaticResource PageTitleStyle}"
                                   Margin="0"/>
                        <TextBlock Text="Preview the document before printing."
                                   Style="{StaticResource HintTextStyle}"
                                   Margin="{StaticResource HintTextTopSpacing}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="{StaticResource ToolbarGroupGap}">
                        <Button x:Name="PreviousPageButton"
                                Content="Previous"
                                Style="{StaticResource PaginatorNavButtonStyle}"
                                Click="OnPreviousPageClick"/>
                        <Border Style="{StaticResource InfoBadgePillStyle}"
                                Margin="{StaticResource InlineItemGap}">
                            <TextBlock x:Name="PageStatusText"
                                       Text="Page 1 of 1"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <Button x:Name="NextPageButton"
                                Content="Next"
                                Style="{StaticResource PaginatorNavButtonStyle}"
                                Margin="{StaticResource InlineItemGap}"
                                Click="OnNextPageClick"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Margin="{StaticResource ToolbarSectionGap}">
                        <TextBlock Text="Zoom"
                                   Style="{StaticResource CaptionLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource InlineControlSpacing}"/>
                        <Slider x:Name="ZoomSlider"
                                Width="{StaticResource FieldWidthStandard}"
                                Minimum="80"
                                Maximum="200"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                ValueChanged="OnZoomSliderValueChanged"
                                VerticalAlignment="Center"/>
                        <TextBlock x:Name="ZoomStatusText"
                                   Text="100%"
                                   Style="{StaticResource CaptionLabelStyle}"
                                   VerticalAlignment="Center"
                                   Margin="{StaticResource InlineItemGap}"/>
                        <Button Content="Fit Width"
                                Style="{StaticResource ViewButtonStyle}"
                                Margin="{StaticResource InlineItemGap}"
                                Click="OnFitWidthClick"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="{StaticResource ToolbarSectionGap}">
                        <Button Content="Print"
                                Style="{StaticResource PrintButtonStyle}"
                                IsDefault="True"
                                Click="OnPrintClick"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Background="{StaticResource FluentSurface}"
                BorderBrush="{StaticResource FluentSurfaceStroke}"
                BorderThickness="{StaticResource FluentBorderThicknessThin}"
                CornerRadius="{StaticResource FluentCornerLarge}"
                Padding="{StaticResource CardPadding}"
                Margin="{StaticResource ItemSpacing}">
            <DocumentViewer x:Name="DocViewer"
                            ShowPageBorders="True"
                            HorizontalPageSpacing="24"
                            VerticalPageSpacing="24"/>
        </Border>

        <!-- Close button -->
        <Border Grid.Row="2"
                Style="{StaticResource DialogFooterBarStyle}">
            <StackPanel Style="{StaticResource DialogFooterActionRowStyle}">
                <Button Content="Close"
                        Style="{StaticResource DialogFooterCloseButtonStyle}"
                        IsCancel="True"
                        Click="OnCloseClick"/>
            </StackPanel>
        </Border>
    </Grid>
</core:BaseDialogWindow>
