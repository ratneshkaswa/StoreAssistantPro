<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers">

    <h:EqualityConverter x:Key="EqualityConverter"/>
    <h:DoubleLessThanConverter x:Key="DoubleLessThanConverter"/>

    <!-- ===============================================================
         PIN DOT STYLE

         Ellipse used in the login PIN display.  Adds a subtle scale
         pulse when the dot Fill changes from empty to filled.
         =============================================================== -->
    <Style x:Key="PinDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="{StaticResource PinDotSize}"/>
        <Setter Property="Height" Value="{StaticResource PinDotSize}"/>
        <Setter Property="Margin" Value="6,0"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Binding.TargetUpdated">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                         From="1.3" To="1.0"
                                         Duration="{StaticResource FluentDurationFast}"
                                         EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                         From="1.3" To="1.0"
                                         Duration="{StaticResource FluentDurationFast}"
                                         EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- ===============================================================
         SELECTABLE USER BUTTON

         POS-style role selection button with visual highlight when
         the button's Tag matches the ViewModel's SelectedUserType.

         Uses Fluent tokens for colors, corners, and shadows.

         Usage:
           <Button Style="{StaticResource SelectableUserButtonStyle}"
                   Tag="{x:Static models:UserType.Admin}"
                   Command="{Binding SelectUserCommand}"
                   CommandParameter="{x:Static models:UserType.Admin}"
                   Content="&#xE77B;  Admin"/>
         =============================================================== -->
    <Style x:Key="SelectableUserButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,16"/>
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True"
                            Effect="{StaticResource FluentShadowSmall}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeFocus}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                <Setter Property="BorderBrush" Value="{StaticResource FluentAccentDefault}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource FluentSubtlePressed}"/>
                <Setter Property="BorderBrush" Value="{StaticResource FluentAccentPressed}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ===============================================================
         POS KEYPAD BUTTON

         Large touch-friendly button for POS-style PIN entry.
         Star-sized grid rows ensure buttons scale with the keypad area.
         =============================================================== -->
    <Style x:Key="PosKeypadButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeDialogTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="3"/>
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextSecondary}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeFocus}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===============================================================
         QUICK ACTION BAR BUTTON

         Enterprise POS toolbar button — large touch-friendly hit area
         with vertically stacked icon and title.
         Hover reveals a subtle background + accent bottom indicator
         matching the Fluent 2 tab selection pattern.

         Sizing follows Microsoft's 44 px minimum touch target guideline.
         Spacing uses the project's 4 px base unit grid (see GlobalStyles).

         Usage (inside ItemsControl.ItemTemplate):
           <Button Style="{StaticResource QuickActionButtonStyle}"
                   Command="{Binding Command}"/>
         =============================================================== -->
    <Style x:Key="QuickActionButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="68"/>
        <Setter Property="MinHeight" Value="56"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <!-- SmartTooltip — auto-wired from QuickAction DataContext -->
        <Setter Property="h:SmartTooltip.Header"     Value="{Binding Title}"/>
        <Setter Property="h:SmartTooltip.Text"       Value="{Binding Description}"/>
        <Setter Property="h:SmartTooltip.ContextKey" Value="{Binding HelpKey}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Padding="{TemplateBinding Padding}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="IconText"
                                           Text="{Binding Icon}"
                                           FontSize="{StaticResource FontSizeDialogTitle}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TitleText"
                                           Text="{Binding Title}"
                                           FontFamily="{StaticResource FluentFontFamily}"
                                           FontSize="{StaticResource FontSizeCaption}" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,0"/></StackPanel>
                        </Border>
                        <!-- Accent bottom indicator (Fluent 2 hover highlight) -->
                        <Border x:Name="AccentIndicator"
                                Height="2" VerticalAlignment="Bottom"
                                CornerRadius="1"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0" Margin="8,0,8,2"/>
                    </Grid>
                    <ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextSecondary}"/>
                            <Setter TargetName="AccentIndicator" Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window},
                                                       Path=ActualWidth,
                                                       Converter={StaticResource DoubleLessThanConverter},
                                                       ConverterParameter=1400}"
                                     Value="True">
                            <Setter Property="MinWidth" Value="44"/>
                            <Setter Property="Padding" Value="10,8"/>
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===============================================================
         ENTERPRISE ACTION BUTTON

         Modern flat action button with rounded corners, subtle hover
         animation, and clean Fluent appearance. Suitable for billing
         toggles, toolbar actions, and dialog confirmations.

         Provides filled-accent style by default; override Background
         at the instance level for alternate colors (e.g. danger/stop).

         Usage:
           <Button Style="{StaticResource EnterpriseActionButtonStyle}"
                   Content="? Start Billing"
                   Command="{Binding ToggleBillingModeCommand}"/>
         =============================================================== -->
    <Style x:Key="EnterpriseActionButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.88" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.76"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===============================================================
         DANGER ACTION BUTTON

         Same layout as EnterpriseActionButton but with error/danger
         color. Used for destructive or stop actions (Stop Billing,
         Delete, Cancel operations).
         =============================================================== -->
    <Style x:Key="DangerActionButtonStyle" TargetType="Button"
           BasedOn="{StaticResource EnterpriseActionButtonStyle}">
        <Setter Property="Background" Value="{StaticResource FluentError}"/>
    </Style>

    <!-- ===============================================================
         STATUS BADGE PILL

         Compact rounded pill used in the quick-action bar and status
         bar for mode indicators (MANAGEMENT / BILLING), connectivity
         status, and lock state.

         Background and Foreground are set per-instance or via
         DataTriggers. The style provides the capsule shape only.

         Usage:
           <Border Style="{StaticResource StatusBadgePillStyle}"
                   Background="{StaticResource FluentAccentDefault}">
               <TextBlock Text="MANAGEMENT" .../>
           </Border>
         =============================================================== -->
    <Style x:Key="StatusBadgePillStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="SemanticStatusPillStyle" TargetType="Border"
           BasedOn="{StaticResource StatusBadgePillStyle}">
        <Setter Property="Background" Value="{StaticResource LayerFillColorSecondary}"/>
        <Setter Property="Padding" Value="8,3"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Pending">
                <Setter Property="Background" Value="{StaticResource FluentWarningBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Unpaid">
                <Setter Property="Background" Value="{StaticResource FluentWarningBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                <Setter Property="Background" Value="{StaticResource FluentInfoBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Ordered">
                <Setter Property="Background" Value="{StaticResource FluentInfoBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="PartialReceived">
                <Setter Property="Background" Value="{StaticResource FluentInfoBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="InProgress">
                <Setter Property="Background" Value="{StaticResource FluentInfoBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Delivered">
                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Paid">
                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Cleared">
                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Received">
                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Completed">
                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Connected">
                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Cancelled">
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Offline">
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Disconnected">
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="BooleanWarningSuccessPillStyle" TargetType="Border"
           BasedOn="{StaticResource StatusBadgePillStyle}">
        <Setter Property="Background" Value="{StaticResource FluentWarningBackground}"/>
        <Setter Property="Padding" Value="8,3"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SemanticStatusPillTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Pending">
                <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Unpaid">
                <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Active">
                <Setter Property="Foreground" Value="{StaticResource FluentInfo}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Ordered">
                <Setter Property="Foreground" Value="{StaticResource FluentInfo}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="PartialReceived">
                <Setter Property="Foreground" Value="{StaticResource FluentInfo}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="InProgress">
                <Setter Property="Foreground" Value="{StaticResource FluentInfo}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Delivered">
                <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Paid">
                <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Cleared">
                <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Received">
                <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Completed">
                <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Connected">
                <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Cancelled">
                <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Offline">
                <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="Disconnected">
                <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="PaidStatusPillTextStyle" TargetType="TextBlock"
           BasedOn="{StaticResource SemanticStatusPillTextStyle}">
        <Setter Property="Text" Value="Unpaid"/>
        <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                <Setter Property="Text" Value="Paid"/>
                <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ClearedStatusPillTextStyle" TargetType="TextBlock"
           BasedOn="{StaticResource SemanticStatusPillTextStyle}">
        <Setter Property="Text" Value="Pending"/>
        <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}}" Value="True">
                <Setter Property="Text" Value="Cleared"/>
                <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- ===============================================================
         TOOLBAR LINK BUTTON

         Minimal, borderless, text-only button for status bar and
         toolbar secondary actions (Logout, Clear all, etc.).
         =============================================================== -->
    <Style x:Key="ToolbarLinkButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource FluentCornerSmall}"
                            Padding="{TemplateBinding Padding}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ===============================================================
         CART REMOVE BUTTON

         Inline delete (?) button for cart line items. Transparent at
         rest, subtle hover highlight, error foreground on hover.
         =============================================================== -->
    <Style x:Key="CartRemoveButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="4,1"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource FluentCornerSmall}"
                            Padding="{TemplateBinding Padding}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentError}"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ===============================================================
         SEGMENTED TAB BUTTON

         Win11 Pivot/Tab-style button with an accent underline when
         the button's Tag matches the ViewModel's ActiveTab property.

         Usage:
           <Button Content="Tax Rates"
                   Style="{StaticResource SegmentedButtonStyle}"
                   Tag="0"
                   Command="{Binding SwitchTabCommand}"
                   CommandParameter="0"/>

         The DataTrigger uses EqualityConverter to compare Tag (the
         tab index as string) with ActiveTab (int) via ToString().
         =============================================================== -->
    <Style x:Key="SegmentedButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="16,10"/>
        <Setter Property="Margin" Value="0,0,4,0"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Padding="{TemplateBinding Padding}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <!-- Active tab accent underline — bound to Tag vs ActiveTab -->
                        <Border Height="3" VerticalAlignment="Bottom"
                                Margin="8,0,8,0"
                                CornerRadius="1.5"
                                Background="{StaticResource FluentAccentDefault}">
                            <Border.Visibility>
                                <MultiBinding Converter="{StaticResource EqualityConverter}"
                                              FallbackValue="Collapsed">
                                    <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="Tag"/>
                                    <Binding Path="ActiveTab"/>
                                </MultiBinding>
                            </Border.Visibility>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <!-- When Tag matches ActiveTab ? accent text color -->
            <DataTrigger Value="True">
                <DataTrigger.Binding>
                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                        <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                        <Binding Path="ActiveTab"/>
                    </MultiBinding>
                </DataTrigger.Binding>
                <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SegmentedFilterHostStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource ChromeAltFillColorSecondary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DividerStrokeColorDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="16"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="SegmentedFilterButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="Padding" Value="12,5"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="12"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>

                        <Border x:Name="AccentPill"
                                Height="3"
                                Width="16"
                                VerticalAlignment="Bottom"
                                HorizontalAlignment="Center"
                                CornerRadius="1.5"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0"
                                Margin="0,0,0,-1"/>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource SubtleFillColorSecondary}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource SubtleFillColorTertiary}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="{StaticResource MotionButtonScaleHover}"
                                                         Duration="{StaticResource FluentDurationNormal}"
                                                         EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="{StaticResource MotionButtonScaleHover}"
                                                         Duration="{StaticResource FluentDurationNormal}"
                                                         EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="{StaticResource MotionButtonScaleRest}"
                                                         Duration="{StaticResource FluentDurationNormal}"
                                                         EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="{StaticResource MotionButtonScaleRest}"
                                                         Duration="{StaticResource FluentDurationNormal}"
                                                         EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource SubtleFillColorTertiary}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="{StaticResource MotionButtonScalePressed}"
                                                         Duration="{StaticResource FluentDurationFast}"
                                                         EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="{StaticResource MotionButtonScalePressed}"
                                                         Duration="{StaticResource FluentDurationFast}"
                                                         EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="{StaticResource MotionButtonScaleHover}"
                                                         Duration="{StaticResource FluentDurationFast}"
                                                         EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="{StaticResource MotionButtonScaleHover}"
                                                         Duration="{StaticResource FluentDurationFast}"
                                                         EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>

                        <Trigger Property="Tag" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource LayerFillColorDefault}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource DividerStrokeColorDefault}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="AccentPill" Property="Opacity" Value="1"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>



