<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers">

    <!-- ═══════════════════════════════════════════════════════════════
         PIN DOT STYLE

         Ellipse used in the login PIN display.  Adds a subtle scale
         pulse when the dot Fill changes from empty to filled.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="PinDotStyle" TargetType="Ellipse">
        <Setter Property="Width" Value="16"/>
        <Setter Property="Height" Value="16"/>
        <Setter Property="Margin" Value="6,0"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <ScaleTransform ScaleX="1" ScaleY="1"/>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <EventTrigger RoutedEvent="Binding.TargetUpdated">
                <BeginStoryboard>
                    <Storyboard>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleX">
                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.3"/>
                            <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1.0"
                                                  KeySpline="0.0,0.0 0.2,1"/>
                        </DoubleAnimationUsingKeyFrames>
                        <DoubleAnimationUsingKeyFrames Storyboard.TargetProperty="RenderTransform.ScaleY">
                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="1.3"/>
                            <SplineDoubleKeyFrame KeyTime="0:0:0.2" Value="1.0"
                                                  KeySpline="0.0,0.0 0.2,1"/>
                        </DoubleAnimationUsingKeyFrames>
                    </Storyboard>
                </BeginStoryboard>
            </EventTrigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         SELECTABLE USER BUTTON

         POS-style role selection button with visual highlight when
         the button's Tag matches the ViewModel's SelectedUserType.

         Uses Fluent tokens for colors, corners, and shadows.

         Usage:
           <Button Style="{StaticResource SelectableUserButtonStyle}"
                   Tag="{x:Static models:UserType.Admin}"
                   Command="{Binding SelectUserCommand}"
                   CommandParameter="{x:Static models:UserType.Admin}"
                   Content="👤  Admin"/>
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="SelectableUserButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="15"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="12,16"/>
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            Effect="{StaticResource FluentShadowSmall}">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentAccentDefault}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentAccentPressed}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         POS KEYPAD BUTTON

         Large touch-friendly button for POS-style PIN entry.
         Star-sized grid rows ensure buttons scale with the keypad area.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="PosKeypadButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="22"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="4"/>
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextSecondary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         QUICK ACTION BAR BUTTON

         Enterprise POS toolbar button — large touch-friendly hit area
         with vertically stacked icon, title, and shortcut hint.
         Hover reveals a subtle background + accent bottom indicator
         matching the Fluent 2 tab selection pattern.

         Sizing follows Microsoft's 44 px minimum touch target guideline.
         Spacing uses the project's 4 px base unit grid (see GlobalStyles).

         Usage (inside ItemsControl.ItemTemplate):
           <Button Style="{StaticResource QuickActionButtonStyle}"
                   Command="{Binding Command}"/>
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="QuickActionButtonStyle" TargetType="Button">
        <Setter Property="MinWidth" Value="68"/>
        <Setter Property="MinHeight" Value="56"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <!-- SmartTooltip — auto-wired from QuickAction DataContext -->
        <Setter Property="h:SmartTooltip.Header"     Value="{Binding Title}"/>
        <Setter Property="h:SmartTooltip.Text"       Value="{Binding Description}"/>
        <Setter Property="h:SmartTooltip.Shortcut"   Value="{Binding ShortcutText}"/>
        <Setter Property="h:SmartTooltip.ContextKey" Value="{Binding HelpKey}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="IconText"
                                           Text="{Binding Icon}"
                                           FontSize="20"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TitleText"
                                           Text="{Binding Title}"
                                           FontFamily="{StaticResource FluentFontFamily}"
                                           FontSize="11" FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,0"/>
                                <TextBlock x:Name="ShortcutHint"
                                           Text="{Binding ShortcutText}"
                                           FontFamily="{StaticResource FluentFontFamily}"
                                           FontSize="9"
                                           Foreground="{StaticResource FluentTextTertiary}"
                                           HorizontalAlignment="Center"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- Accent bottom indicator (Fluent 2 hover highlight) -->
                        <Border x:Name="AccentIndicator"
                                Height="2" VerticalAlignment="Bottom"
                                CornerRadius="1"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0" Margin="8,0,8,2"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Empty shortcut → collapse the hint row -->
                        <DataTrigger Binding="{Binding ShortcutText}" Value="">
                            <Setter TargetName="ShortcutHint" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextSecondary}"/>
                            <Setter TargetName="AccentIndicator" Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         ENTERPRISE ACTION BUTTON

         Modern flat action button with rounded corners, subtle hover
         animation, and clean Fluent appearance. Suitable for billing
         toggles, toolbar actions, and dialog confirmations.

         Provides filled-accent style by default; override Background
         at the instance level for alternate colors (e.g. danger/stop).

         Usage:
           <Button Style="{StaticResource EnterpriseActionButtonStyle}"
                   Content="▶ Start Billing"
                   Command="{Binding ToggleBillingModeCommand}"/>
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="EnterpriseActionButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="14,6"/>
        <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.88" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.76"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         DANGER ACTION BUTTON

         Same layout as EnterpriseActionButton but with error/danger
         color. Used for destructive or stop actions (Stop Billing,
         Delete, Cancel operations).
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="DangerActionButtonStyle" TargetType="Button"
           BasedOn="{StaticResource EnterpriseActionButtonStyle}">
        <Setter Property="Background" Value="{StaticResource FluentError}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         STATUS BADGE PILL

         Compact rounded pill used in the quick-action bar and status
         bar for mode indicators (MANAGEMENT / BILLING), connectivity
         status, and lock state.

         Background and Foreground are set per-instance or via
         DataTriggers. The style provides the capsule shape only.

         Usage:
           <Border Style="{StaticResource StatusBadgePillStyle}"
                   Background="{StaticResource FluentAccentDefault}">
               <TextBlock Text="MANAGEMENT" .../>
           </Border>
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="StatusBadgePillStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
        <Setter Property="Padding" Value="10,3"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         TOOLBAR LINK BUTTON

         Minimal, borderless, text-only button for status bar and
         toolbar secondary actions (Logout, Clear all, etc.).
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="ToolbarLinkButtonStyle" TargetType="Button">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="6,2"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource FluentCornerSmall}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CART REMOVE BUTTON

         Inline delete (✕) button for cart line items. Transparent at
         rest, subtle hover highlight, error foreground on hover.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CartRemoveButtonStyle" TargetType="Button">
        <Setter Property="Padding" Value="4,1"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource FluentCornerSmall}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentError}"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
