                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CONTROL TEMPLATES — BUTTON (Fluent Subtle / Transparent)
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentSubtleButtonStyle" TargetType="Button">
        <Setter Property="Background"              Value="Transparent"/>
        <Setter Property="Foreground"              Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderThickness"         Value="0"/>
        <Setter Property="FontFamily"              Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"                Value="13"/>
        <Setter Property="Padding"                 Value="10,6"/>
        <Setter Property="Cursor"                  Value="Hand"/>
        <Setter Property="SnapsToDevicePixels"     Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextSecondary}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CONTROL TEMPLATES — CHECKBOX

         Fluent 2 toggle-style checkbox: 18×18 rounded box with accent
         fill when checked, animated checkmark glyph, subtle hover.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="FontFamily"          Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="Foreground"          Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Background"          Value="{StaticResource FluentSurface}"/>
        <Setter Property="BorderBrush"         Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="Padding"             Value="8,0,0,0"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Check box outline -->
                        <Border x:Name="CheckBorder" Grid.Column="0"
                                Width="18" Height="18"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerSmall}"
                                VerticalAlignment="Center"
                                SnapsToDevicePixels="True">
                            <!-- Checkmark glyph -->
                            <Path x:Name="CheckGlyph"
                                  Data="M 3,8 L 7,12 L 13,4"
                                  Stroke="{StaticResource FluentTextOnAccent}"
                                  StrokeThickness="1.5"
                                  StrokeLineJoin="Round"
                                  StrokeStartLineCap="Round"
                                  StrokeEndLineCap="Round"
                                  Stretch="None"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Opacity="0"/>
                        </Border>

                        <!-- Label content -->
                        <ContentPresenter Grid.Column="1"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          RecognizesAccessKey="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{StaticResource FluentTextTertiary}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="CheckGlyph" Property="Opacity" Value="1"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsChecked" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{StaticResource FluentAccentHover}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{StaticResource FluentAccentHover}"/>
                        </MultiTrigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="CheckGlyph" Property="Data"
                                    Value="M 4,9 L 12,9"/>
                            <Setter TargetName="CheckGlyph" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                            <Setter TargetName="CheckBorder" Property="Background"
                                    Value="{StaticResource FluentSurfaceElevated}"/>
                            <Setter TargetName="CheckBorder" Property="BorderBrush"
                                    Value="{StaticResource FluentSurfaceStroke}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CONTROL TEMPLATES — GROUPBOX

         Fluent card-style GroupBox: rounded container with a subtle
         header region separated by a thin stroke. Replaces WPF's
         default legacy chrome with modern flat appearance.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentGroupBoxStyle" TargetType="GroupBox">
        <Setter Property="FontFamily"          Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="Foreground"          Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Background"          Value="{StaticResource FluentSurface}"/>
        <Setter Property="BorderBrush"         Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="BorderThickness"     Value="1"/>
        <Setter Property="Padding"             Value="12"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupBox">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource FluentSurfaceElevated}"
                                    CornerRadius="{StaticResource FluentCornerMediumTop}"
                                    Padding="12,8">
                                <ContentPresenter ContentSource="Header"
                                                  TextBlock.FontWeight="SemiBold"
                                                  TextBlock.FontSize="13"
                                                  TextBlock.Foreground="{StaticResource FluentTextPrimary}"/>
                            </Border>

                            <!-- Stroke between header and content -->
                            <Border Grid.Row="0" VerticalAlignment="Bottom"
                                    Height="1"
                                    Background="{StaticResource FluentSurfaceStroke}"/>

                            <!-- Content -->
                            <ContentPresenter Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CARD — Fluent elevated container with soft shadow
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentCardStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource FluentSurface}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="{StaticResource FluentCornerMedium}"/>
        <Setter Property="Padding"         Value="16"/>
        <Setter Property="Effect"          Value="{StaticResource FluentShadowSmall}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         ELEVATED CARD — Higher elevation (popups, dialogs)
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentCardElevatedStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource FluentSurface}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="{StaticResource FluentCornerLarge}"/>
        <Setter Property="Padding"         Value="20"/>
        <Setter Property="Effect"          Value="{StaticResource FluentShadowMedium}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         SEPARATOR — subtle horizontal divider
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentSeparatorStyle" TargetType="Separator">
        <Setter Property="Background" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="Height"     Value="1"/>
        <Setter Property="Margin"     Value="0,8"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         MENU BAR — Win11 seamless navigation strip

         Flush with window background, subtle bottom stroke.
         Top-level items show a rounded pill hover.
         Submenu popups use rounded corners + shadow.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentMenuBarStyle" TargetType="Menu">
        <Setter Property="Background"          Value="{StaticResource FluentMenuBarBackground}"/>
        <Setter Property="Foreground"          Value="{StaticResource FluentMenuBarForeground}"/>
        <Setter Property="FontFamily"          Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"            Value="12"/>
        <Setter Property="Padding"             Value="4,3"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Menu">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource FluentSurfaceStroke}"
                            BorderThickness="0,0,0,1"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True" Orientation="Horizontal"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Dropdown menu item (Win11 rounded hover with shortcut) ──── -->
    <Style x:Key="FluentMenuItemStyle" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <Border x:Name="ItemBd"
                                Background="Transparent"
                                CornerRadius="{StaticResource FluentCornerSmall}"
                                Padding="12,8"
                                Margin="4,1"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  ContentSource="Header"
                                                  RecognizesAccessKey="True"
                                                  VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1"
                                           Text="{TemplateBinding InputGestureText}"
                                           Foreground="{StaticResource FluentTextTertiary}"
                                           FontSize="11"
                                           Margin="24,0,0,0"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Nested submenu popup -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Right"
                               Focusable="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               HorizontalOffset="-2">
                            <Border Background="{StaticResource FluentSurface}"
                                    BorderBrush="{StaticResource FluentSurfaceStroke}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource FluentCornerMedium}"
                                    Padding="0,4"
                                    Margin="4,0,4,4"
                                    Effect="{StaticResource FluentShadowMedium}"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ItemBd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ── Menu separator (Win11 thin divider) ─────────────────────── -->
    <Style x:Key="FluentMenuSeparatorStyle" TargetType="Separator">
        <Setter Property="Height" Value="1"/>
        <Setter Property="Background" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="Margin" Value="12,4"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ── Top-level menu bar item (Win11 rounded pill hover) ──────── -->
    <Style x:Key="FluentMenuBarItemStyle" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"   Value="12"/>
        <Setter Property="ItemContainerStyle" Value="{StaticResource FluentMenuItemStyle}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Grid>
                        <!-- Top-level header with rounded hover pill -->
                        <Border x:Name="TopBd"
                                Background="Transparent"
                                CornerRadius="{StaticResource FluentCornerSmall}"
                                Padding="10,5"
                                Margin="1,0"
                                SnapsToDevicePixels="True">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"/>
                        </Border>

                        <!-- Submenu popup (Win11 rounded flyout with shadow) -->
                        <Popup x:Name="PART_Popup"
                               IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                               Placement="Bottom"
                               Focusable="False"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               HorizontalOffset="-2">
                            <Border x:Name="SubMenuBorder"
                                    Background="{StaticResource FluentSurface}"
                                    BorderBrush="{StaticResource FluentSurfaceStroke}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource FluentCornerMedium}"
                                    Padding="0,4"
                                    Margin="4,2,4,4"
                                    Effect="{StaticResource FluentShadowMedium}"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer Style="{DynamicResource {ComponentResourceKey TypeInTargetAssembly={x:Type FrameworkElement}, ResourceId=MenuScrollViewer}}"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Hover: rounded subtle fill -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="TopBd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                        </Trigger>

                        <!-- Submenu open: keep highlight + slightly stronger fill -->
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="TopBd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         TOOLBAR — Win11 seamless command bar

         Blends with the page surface using a subtle bottom stroke
         only — no shadow, no elevation. Clean, modern, flat.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentToolbarStyle" TargetType="Border">
        <Setter Property="Background"         Value="{StaticResource FluentToolbarBackground}"/>
        <Setter Property="BorderBrush"        Value="{StaticResource FluentToolbarBorder}"/>
        <Setter Property="BorderThickness"    Value="0,0,0,1"/>
        <Setter Property="Padding"            Value="12,8"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         STATUS BAR — Win11 seamless chrome strip

         Flush with window background, subtle top stroke only,
         no elevation. Segoe UI Variable 11 px, relaxed padding.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentStatusBarStyle" TargetType="StatusBar">
        <Setter Property="Background"          Value="{StaticResource FluentStatusBarBackground}"/>
        <Setter Property="Foreground"          Value="{StaticResource FluentStatusBarForeground}"/>
        <Setter Property="FontFamily"          Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"            Value="11"/>
        <Setter Property="Padding"             Value="12,6"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="StatusBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource FluentSurfaceStroke}"
                            BorderThickness="0,1,0,0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- StatusBarItem — chromeless container for status bar content -->
    <Style x:Key="FluentStatusBarItemStyle" TargetType="StatusBarItem">
        <Setter Property="Padding"    Value="0"/>
        <Setter Property="Margin"     Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"   Value="11"/>
        <Setter Property="Foreground" Value="{StaticResource FluentStatusBarForeground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="StatusBarItem">
                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="Center"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical divider for status bar item separation -->
    <Style x:Key="FluentStatusBarSeparatorStyle" TargetType="Border">
        <Setter Property="Width"      Value="1"/>
        <Setter Property="Background" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="Margin"     Value="8,3"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         BASE WINDOW — Fluent visual foundation for every Window

         Establishes the modern light appearance, default typography,
         pixel-perfect rendering for fixed-resolution displays, and
         clean borderless content area.  Applied to all windows
         (MainWindow, login/setup windows, and BaseDialogWindow
         subclasses) via the implicit style in GlobalStyles.xaml.

         Rendering settings:
           UseLayoutRounding    = True   eliminates sub-pixel blur
           SnapsToDevicePixels  = True   crisp edges at 100 % DPI
           TextFormattingMode   = Display   sharp small text (11-13 px)
           TextRenderingMode    = ClearType  LCD-optimised glyphs
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentWindowStyle" TargetType="Window">
        <Setter Property="Background"           Value="{StaticResource FluentBackgroundPrimary}"/>
        <Setter Property="Foreground"           Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="FontFamily"           Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"             Value="{StaticResource FontSizeBody}"/>
        <Setter Property="BorderThickness"      Value="0"/>
        <Setter Property="SnapsToDevicePixels"  Value="True"/>
        <Setter Property="UseLayoutRounding"    Value="True"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Ideal"/>
        <Setter Property="TextOptions.TextRenderingMode"  Value="Auto"/>
    </Style>


    <!-- ═══════════════════════════════════════════════════════════════
         SCROLLBAR — Win11 thin overlay track

         Thin 6 px thumb with rounded ends, widens to 8 px on hover.
         Track is transparent. Replaces the chunky WPF default.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Vertical scrollbar thumb -->
    <Style x:Key="FluentScrollBarThumb" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="IsTabStop" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="ThumbBd"
                            Background="#66888888"
                            CornerRadius="3"
                            Margin="1,0"
                            SnapsToDevicePixels="True"/>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ThumbBd" Property="Background" Value="#99888888"/>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="ThumbBd" Property="Background" Value="#BB888888"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Vertical ScrollBar -->
    <Style x:Key="FluentVerticalScrollBar" TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Width" Value="6"/>
        <Setter Property="MinWidth" Value="6"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource FluentScrollBarThumb}"/>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Width" Value="8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Horizontal ScrollBar -->
    <Style x:Key="FluentHorizontalScrollBar" TargetType="ScrollBar">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Height" Value="6"/>
        <Setter Property="MinHeight" Value="6"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollBar">
                    <Grid Background="Transparent" SnapsToDevicePixels="True">
                        <Track x:Name="PART_Track" IsDirectionReversed="False">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource FluentScrollBarThumb}">
                                    <Thumb.Template>
                                        <ControlTemplate TargetType="Thumb">
                                            <Border x:Name="ThumbBd"
                                                    Background="#66888888"
                                                    CornerRadius="3"
                                                    Margin="0,1"
                                                    SnapsToDevicePixels="True"/>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ThumbBd" Property="Background" Value="#99888888"/>
                                                </Trigger>
                                                <Trigger Property="IsDragging" Value="True">
                                                    <Setter TargetName="ThumbBd" Property="Background" Value="#BB888888"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Thumb.Template>
                                </Thumb>
                            </Track.Thumb>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Height" Value="8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ScrollViewer with thin overlay scrollbars -->
    <Style x:Key="FluentScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <ScrollContentPresenter Margin="{TemplateBinding Padding}"
                                                CanContentScroll="{TemplateBinding CanContentScroll}"/>
                        <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Style="{StaticResource FluentVerticalScrollBar}"
                                   HorizontalAlignment="Right"
                                   Orientation="Vertical"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Style="{StaticResource FluentHorizontalScrollBar}"
                                   VerticalAlignment="Bottom"
                                   Orientation="Horizontal"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}"/>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════════════════════════════
         CONTEXT MENU — Win11 rounded flyout

         Rounded corners, subtle shadow, pill-hover items.
         Matches the menu dropdown style.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{StaticResource FluentSurface}"
                            BorderBrush="{StaticResource FluentSurfaceStroke}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="0,4"
                            Margin="4"
                            Effect="{StaticResource FluentShadowMedium}"
                            SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Context menu item — Win11 rounded hover -->
    <Style x:Key="FluentContextMenuItemStyle" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="ItemBd"
                            Background="Transparent"
                            CornerRadius="{StaticResource FluentCornerSmall}"
                            Padding="12,8"
                            Margin="4,1"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ContentPresenter Grid.Column="0"
                                              ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="{TemplateBinding InputGestureText}"
                                       Foreground="{StaticResource FluentTextTertiary}"
                                       FontSize="11"
                                       Margin="24,0,0,0"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


    <!-- ═══════════════════════════════════════════════════════════════
         TOOLTIP — Win11 rounded frosted card

         Rounded corners, subtle shadow, Segoe UI Variable.
         Consumes DesignSystem tooltip tokens.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentToolTipStyle" TargetType="ToolTip">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="MaxWidth" Value="{StaticResource TooltipMaxWidth}"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="{StaticResource TooltipBackground}"
                            BorderBrush="{StaticResource TooltipBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource TooltipCornerRadius}"
                            Padding="{StaticResource TooltipPadding}"
                            Effect="{StaticResource TooltipShadow}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
