    <!-- ═══════════════════════════════════════════════════════════════
         CONTROL TEMPLATES — BUTTON (Fluent Accent / Primary)
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentAccentButtonStyle" TargetType="Button">
        <Setter Property="Background"              Value="{StaticResource FluentAccentDefault}"/>
        <Setter Property="Foreground"              Value="{StaticResource FluentTextOnAccent}"/>
        <Setter Property="BorderThickness"         Value="0"/>
        <Setter Property="FontFamily"              Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"                Value="13"/>
        <Setter Property="FontWeight"              Value="SemiBold"/>
        <Setter Property="Padding"                 Value="16,8"/>
        <Setter Property="Cursor"                  Value="Hand"/>
        <Setter Property="SnapsToDevicePixels"     Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#0067C0" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentAccentPressed}"/>
                            <Setter Property="Foreground" Value="#CCFFFFFF"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentAccentDisabled}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextOnAccent}"/>
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CONTROL TEMPLATES — BUTTON (Fluent Standard / Secondary)
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentStandardButtonStyle" TargetType="Button">
