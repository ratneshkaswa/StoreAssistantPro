<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
                    xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
                    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework">

    <!-- =================================================================
         FLUENT THEME - Control Templates and Chrome Styles
         =================================================================

         All primitive design tokens are defined in DesignSystem.xaml, which
         is loaded before this dictionary. This file provides:

           - Full control templates (Button, TextBox, ComboBox, etc.)
           - Animated hover, press, and focus transitions
           - Chrome styles (Menu, Toolbar, StatusBar)
           - Card and separator primitives
         ================================================================= -->

    <!-- CONTROL TEMPLATES - TEXTBOX -->
    <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background"              Value="{StaticResource FluentControlFillDefault}"/>
        <Setter Property="Foreground"              Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush"             Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness"         Value="0,0,0,1"/>
        <Setter Property="Padding"                 Value="{StaticResource ControlPadding}"/>
        <Setter Property="FontFamily"              Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"                Value="{StaticResource FontSizeBody}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush"              Value="{StaticResource FluentAccentDefault}"/>
        <Setter Property="SelectionBrush"          Value="{StaticResource FluentTextSelectionBrush}"/>
        <Setter Property="UseLayoutRounding"       Value="True"/>
        <Setter Property="SnapsToDevicePixels"     Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Grid UseLayoutRounding="True"
                                  SnapsToDevicePixels="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="PrefixText"
                                           Grid.Column="0"
                                           Margin="12,0,8,0"
                                           Visibility="Collapsed"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource FluentTextTertiary}"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                          Path=(h:TextBoxAdornment.PrefixText)}"/>
                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="{TemplateBinding HorizontalScrollBarVisibility}"
                                              VerticalScrollBarVisibility="{TemplateBinding VerticalScrollBarVisibility}"
                                              Padding="{TemplateBinding Padding}"/>
                                <TextBlock x:Name="SuffixText"
                                           Grid.Column="2"
                                           Margin="8,0,12,0"
                                           Visibility="Collapsed"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource FluentTextTertiary}"
                                           Text="{Binding RelativeSource={RelativeSource TemplatedParent},
                                                          Path=(h:TextBoxAdornment.SuffixText)}"/>
                            </Grid>
                        </Border>
                        <!-- Bottom accent line (Fluent 2 focus indicator) -->
                        <Border x:Name="FocusIndicator"
                                Height="2" VerticalAlignment="Bottom"
                                CornerRadius="{StaticResource FluentCornerMediumBottom}"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0" Margin="2,0,2,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="h:TextBoxAdornment.HasPrefixText" Value="True">
                            <Setter TargetName="PrefixText" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="h:TextBoxAdornment.HasSuffixText" Value="True">
                            <Setter TargetName="SuffixText" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness"
                                    Value="1"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeDefault}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness"
                                    Value="1"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeFocus}"/>
                            <Setter TargetName="FocusIndicator" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background"
                                    Value="{StaticResource FluentControlFillDisabled}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                            <Setter Property="Opacity" Value="0.4"/>
                            <Setter TargetName="Bd" Property="BorderThickness"
                                    Value="0,0,0,1"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource DividerStrokeColorDefault}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type controls:ToastHost}">
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ToastHost}">
                    <ItemsControl ItemsSource="{TemplateBinding Toasts}"
                                  Focusable="False"
                                  UseLayoutRounding="True"
                                  SnapsToDevicePixels="True">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Vertical"
                                            HorizontalAlignment="Right"
                                            UseLayoutRounding="True"
                                            SnapsToDevicePixels="True"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="ToastRoot"
                                        MaxWidth="360"
                                        Margin="0,0,0,12"
                                        Padding="{StaticResource CardContentPadding}"
                                        Background="{StaticResource FluentSurfaceElevated}"
                                        BorderBrush="{StaticResource FluentInfo}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource FluentCornerLarge}"
                                        h:ToastSwipeDismiss.IsEnabled="True"
                                        UseLayoutRounding="True"
                                        SnapsToDevicePixels="True"
                                        Effect="{StaticResource ElevationEffectFlyout}">
                                    <Grid UseLayoutRounding="True"
                                          SnapsToDevicePixels="True">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <Border x:Name="ToastBadge"
                                                Width="28"
                                                Height="28"
                                                Background="{StaticResource FluentInfoBackground}"
                                                CornerRadius="14"
                                                VerticalAlignment="Top"
                                                UseLayoutRounding="True"
                                                SnapsToDevicePixels="True">
                                            <TextBlock x:Name="ToastGlyph"
                                                       Text="i"
                                                       FontFamily="{StaticResource FluentFontFamily}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource FluentInfo}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Message}"
                                                   FontFamily="{StaticResource FluentFontFamily}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Foreground="{StaticResource FluentTextPrimary}"
                                                   TextWrapping="WrapWithOverflow"
                                                   TextTrimming="None"
                                                   MaxWidth="320"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Level}" Value="Success">
                                        <Setter TargetName="ToastRoot" Property="BorderBrush" Value="{StaticResource FluentSuccess}"/>
                                        <Setter TargetName="ToastBadge" Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
                                        <Setter TargetName="ToastGlyph" Property="Text" Value="+"/>
                                        <Setter TargetName="ToastGlyph" Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="Warning">
                                        <Setter TargetName="ToastRoot" Property="BorderBrush" Value="{StaticResource FluentWarning}"/>
                                        <Setter TargetName="ToastBadge" Property="Background" Value="{StaticResource FluentWarningBackground}"/>
                                        <Setter TargetName="ToastGlyph" Property="Text" Value="!"/>
                                        <Setter TargetName="ToastGlyph" Property="Foreground" Value="{StaticResource FluentWarning}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Level}" Value="Error">
                                        <Setter TargetName="ToastRoot" Property="BorderBrush" Value="{StaticResource FluentError}"/>
                                        <Setter TargetName="ToastBadge" Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                                        <Setter TargetName="ToastGlyph" Property="Text" Value="x"/>
                                        <Setter TargetName="ToastGlyph" Property="Foreground" Value="{StaticResource FluentError}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

