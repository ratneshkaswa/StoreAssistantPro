    <Style x:Key="FluentContextMenuStyle" TargetType="ContextMenu">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="HasDropShadow" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{StaticResource LayerFillColorSecondary}"
                            BorderBrush="{StaticResource DividerStrokeColorDefault}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="4"
                            Margin="4"
                            Effect="{StaticResource ElevationEffectFlyout}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <StackPanel IsItemsHost="True"
                                    UseLayoutRounding="True"
                                    SnapsToDevicePixels="True"
                                    KeyboardNavigation.DirectionalNavigation="Cycle"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Context menu item ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â‚¬Å¡Ã‚Â¬ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â Win11 rounded hover -->
    <Style x:Key="FluentContextMenuItemStyle" TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="h:AutomationNameFallback.UseToolTipFallback" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="ItemBd"
                            Background="Transparent"
                            CornerRadius="{StaticResource FluentCornerSmall}"
                            Padding="12,8"
                            Margin="4,0"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <ContentPresenter Grid.Column="0"
                                          ContentSource="Icon"
                                          VerticalAlignment="Center"
                                          Margin="0,0,10,0"/>
                        <ContentPresenter Grid.Column="1"
                                          ContentSource="Header"
                                          RecognizesAccessKey="True"
                                          VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2"
                                   Text="{TemplateBinding InputGestureText}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Margin="24,0,0,0"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="ItemBd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


