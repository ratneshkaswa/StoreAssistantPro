<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         FLUENT THEME — Control Templates & Chrome Styles
         ═══════════════════════════════════════════════════════════════

         All primitive design tokens (colors, radii, shadows, spacing,
         typography, sizing) now live in DesignSystem.xaml which is
         loaded before this dictionary.

         This file provides:
           • Full control templates (Button, TextBox, ComboBox, etc.)
           • Animated hover / press / focus state transitions
           • Chrome styles (Menu, Toolbar, StatusBar)
           • Card and separator primitives
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ═══════════════════════════════════════════════════════════════
         CONTROL TEMPLATES — TEXTBOX
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background"              Value="{StaticResource FluentSurface}"/>
        <Setter Property="Foreground"              Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush"             Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness"         Value="1"/>
        <Setter Property="Padding"                 Value="10,8"/>
        <Setter Property="FontFamily"              Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"                Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush"              Value="{StaticResource FluentAccentDefault}"/>
        <Setter Property="SelectionBrush"          Value="{StaticResource FluentAccentDefault}"/>
        <Setter Property="SnapsToDevicePixels"     Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Padding="{TemplateBinding Padding}"/>
                        </Border>
                        <!-- Bottom accent line (Fluent 2 focus indicator) -->
                        <Border x:Name="FocusIndicator"
                                Height="2" VerticalAlignment="Bottom"
                                CornerRadius="{StaticResource FluentCornerMediumBottom}"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0" Margin="2,0,2,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentTextTertiary}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeFocus}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background"
                                    Value="{StaticResource FluentSurfaceElevated}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentSurfaceStroke}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         CONTROL TEMPLATES — COMBOBOX

         Rounded border with accent focus indicator matching TextBox.
         Drop-down toggle glyph aligned right, chevron rotates.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="FluentComboBoxStyle" TargetType="ComboBox">
        <Setter Property="Background"              Value="{StaticResource FluentSurface}"/>
        <Setter Property="Foreground"              Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush"             Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness"         Value="1"/>
        <Setter Property="Padding"                 Value="10,8"/>
        <Setter Property="FontFamily"              Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"                Value="13"/>
        <Setter Property="MinHeight"               Value="32"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="SnapsToDevicePixels"     Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="32"/>
                        </Grid.ColumnDefinitions>

                        <!-- Main border -->
                        <Border x:Name="Bd" Grid.ColumnSpan="2"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                SnapsToDevicePixels="True"/>

                        <!-- Bottom accent line (focus indicator) -->
                        <Border x:Name="FocusIndicator" Grid.ColumnSpan="2"
                                Height="2" VerticalAlignment="Bottom"
                                CornerRadius="{StaticResource FluentCornerMediumBottom}"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0" Margin="2,0,2,0"/>

                        <!-- Drop-down toggle (covers entire control) -->
                        <ToggleButton x:Name="ToggleButton" Grid.ColumnSpan="2"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                          RelativeSource={RelativeSource TemplatedParent}}"
                                      Focusable="False" ClickMode="Press"
                                      Background="Transparent" BorderThickness="0">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="Transparent"/>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <!-- Chevron glyph -->
                        <Path x:Name="Arrow" Grid.Column="1"
                              Data="M 0,0 L 4,4 L 8,0"
                              Stroke="{StaticResource FluentTextSecondary}"
                              StrokeThickness="1.5" StrokeLineJoin="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              IsHitTestVisible="False"/>

                        <!-- Selected item display -->
                        <ContentPresenter x:Name="ContentSite" Grid.Column="0"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"
                                          IsHitTestVisible="False"/>

                        <!-- Editable TextBox (visible only when IsEditable) -->
                        <TextBox x:Name="PART_EditableTextBox" Grid.Column="0"
                                 Visibility="Hidden" Focusable="True"
                                 Background="Transparent" BorderThickness="0"
                                 Padding="{TemplateBinding Padding}"
                                 FontFamily="{TemplateBinding FontFamily}"
                                 FontSize="{TemplateBinding FontSize}"
                                 Foreground="{TemplateBinding Foreground}"
                                 VerticalContentAlignment="Center"
                                 CaretBrush="{StaticResource FluentAccentDefault}"
                                 SelectionBrush="{StaticResource FluentAccentDefault}"
                                 IsReadOnly="{TemplateBinding IsReadOnly}"/>

                        <!-- Drop-down popup -->
                        <Popup x:Name="PART_Popup" Grid.ColumnSpan="2"
                               Placement="Bottom" AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               Focusable="False" PopupAnimation="Slide">
                            <Border x:Name="DropDownBorder"
                                    MinWidth="{TemplateBinding ActualWidth}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                    Background="{StaticResource FluentSurface}"
                                    BorderBrush="{StaticResource FluentSurfaceStroke}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource FluentCornerMedium}"
                                    Margin="0,2,0,0" Padding="0,4"
                                    Effect="{StaticResource FluentShadowMedium}">
                                <ScrollViewer SnapsToDevicePixels="True">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Contained"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentTextTertiary}"/>
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeFocus}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeFocus}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentTextDisabled}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentSurfaceStroke}"/>
                            <Setter TargetName="Arrow" Property="Stroke"
                                    Value="{StaticResource FluentTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ComboBoxItem — Fluent hover/selection highlight -->
    <Style x:Key="FluentComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Padding"             Value="10,6"/>
        <Setter Property="FontFamily"          Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"            Value="13"/>
        <Setter Property="Foreground"          Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="Bd"
                            Background="Transparent"
                            CornerRadius="{StaticResource FluentCornerSmall}"
                            Padding="{TemplateBinding Padding}"
                            Margin="4,1" SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

