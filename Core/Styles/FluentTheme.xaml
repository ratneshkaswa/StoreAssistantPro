    <Style TargetType="{x:Type controls:InfoBar}">
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:InfoBar}">
                    <Border x:Name="Root"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="12,10"
                            Margin="0,0,0,8"
                            BorderThickness="1"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <Grid UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="Icon" Grid.Column="0"
                                       FontFamily="{StaticResource FluentIconFont}"
                                       FontSize="{StaticResource FontSizeIconSmall}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,0"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock x:Name="TitleText"
                                           Text="{TemplateBinding Title}"
                                           FontWeight="SemiBold"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{TemplateBinding Message}"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           TextWrapping="Wrap" Opacity="0.85"/>
                            </StackPanel>
                            <Button x:Name="PART_CloseButton" Grid.Column="2"
                                    Content="&#xE711;"
                                    FontFamily="{StaticResource FluentIconFont}"
                                    FontSize="10"
                                    Background="Transparent" BorderThickness="0"
                                    AutomationProperties.Name="Dismiss message"
                                    Cursor="Hand" Padding="6"
                                    VerticalAlignment="Top"
                                    Visibility="Collapsed"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Severity" Value="Info">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource InfoBarInfoFill}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource InfoBarInfoBorder}"/>
                            <Setter TargetName="Icon" Property="Text" Value="&#xE946;"/>
                            <Setter TargetName="Icon" Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                        </Trigger>
                        <Trigger Property="Severity" Value="Success">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource InfoBarSuccessFill}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource InfoBarSuccessBorder}"/>
                            <Setter TargetName="Icon" Property="Text" Value="&#xE73E;"/>
                            <Setter TargetName="Icon" Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                        </Trigger>
                        <Trigger Property="Severity" Value="Warning">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource InfoBarWarningFill}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource InfoBarWarningBorder}"/>
                            <Setter TargetName="Icon" Property="Text" Value="&#xE7BA;"/>
                            <Setter TargetName="Icon" Property="Foreground" Value="{StaticResource FluentWarning}"/>
                        </Trigger>
                        <Trigger Property="Severity" Value="Error">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource InfoBarErrorFill}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource InfoBarErrorBorder}"/>
                            <Setter TargetName="Icon" Property="Text" Value="&#xEA39;"/>
                            <Setter TargetName="Icon" Property="Foreground" Value="{StaticResource FluentError}"/>
                        </Trigger>
                        <Trigger Property="Title" Value="">
                            <Setter TargetName="TitleText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="IsClosable" Value="True">
                            <Setter TargetName="PART_CloseButton" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsOpen" Value="False">
                            <Setter TargetName="Root" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
