    <Style x:Key="FluentCalendarButtonStyle" TargetType="{x:Type primitives:CalendarButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarButton}">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SubtleFillColorSecondary}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SubtleFillColorTertiary}"/>
                        </Trigger>
                        <Trigger Property="HasSelectedDays" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SubtleFillColorSecondary}"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextDisabled}"/>
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentCalendarDayButtonStyle" TargetType="{x:Type primitives:CalendarDayButton}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinWidth" Value="32"/>
        <Setter Property="MinHeight" Value="28"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type primitives:CalendarDayButton}">
                    <Border x:Name="Root"
                            Margin="1"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SubtleFillColorSecondary}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SubtleFillColorTertiary}"/>
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SubtleFillColorSecondary}"/>
                        </Trigger>
                        <Trigger Property="IsToday" Value="True">
                            <Setter TargetName="Root" Property="BorderThickness" Value="1"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource FluentAccentDefault}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="Root" Property="BorderThickness" Value="1"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Trigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsMouseOver" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource FluentAccentLight1}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource FluentAccentLight1}"/>
                        </MultiTrigger>
                        <MultiTrigger>
                            <MultiTrigger.Conditions>
                                <Condition Property="IsSelected" Value="True"/>
                                <Condition Property="IsPressed" Value="True"/>
                            </MultiTrigger.Conditions>
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource FluentAccentDark1}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource FluentAccentDark1}"/>
                        </MultiTrigger>
                        <Trigger Property="IsInactive" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                            <Setter Property="Opacity" Value="0.72"/>
                        </Trigger>
                        <Trigger Property="IsBlackedOut" Value="True">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextDisabled}"/>
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextDisabled}"/>
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentCalendarItemStyle" TargetType="{x:Type primitives:CalendarItem}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <Style x:Key="FluentCalendarStyle" TargetType="Calendar">
        <Setter Property="Background" Value="{StaticResource LayerFillColorSecondary}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DividerStrokeColorDefault}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8"/>
        <Setter Property="CalendarButtonStyle" Value="{StaticResource FluentCalendarButtonStyle}"/>
        <Setter Property="CalendarDayButtonStyle" Value="{StaticResource FluentCalendarDayButtonStyle}"/>
        <Setter Property="CalendarItemStyle" Value="{StaticResource FluentCalendarItemStyle}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Calendar">
                    <Border x:Name="Chrome"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerLarge}"
                            Padding="{TemplateBinding Padding}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True"
                            Effect="{StaticResource ElevationEffectFlyout}">
                        <Grid x:Name="PART_Root"
                              ClipToBounds="True"
                              UseLayoutRounding="True"
                              SnapsToDevicePixels="True">
                            <primitives:CalendarItem x:Name="PART_CalendarItem"
                                                     Background="Transparent"
                                                     BorderBrush="Transparent"
                                                     BorderThickness="0"
                                                     Style="{TemplateBinding CalendarItemStyle}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="FluentDatePickerStyle" TargetType="DatePicker">
        <Setter Property="Background"              Value="{StaticResource FluentControlFillDefault}"/>
        <Setter Property="Foreground"              Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush"             Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness"         Value="0,0,0,1"/>
        <Setter Property="Padding"                 Value="{StaticResource ControlPadding}"/>
        <Setter Property="FontFamily"              Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"                Value="{StaticResource FontSizeBody}"/>
        <Setter Property="MinHeight"               Value="{StaticResource ControlHeight}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="IsTodayHighlighted"      Value="True"/>
        <Setter Property="CalendarStyle"           Value="{StaticResource FluentCalendarStyle}"/>
        <Setter Property="FocusVisualStyle"        Value="{StaticResource FluentFocusVisualStyle}"/>
        <Setter Property="UseLayoutRounding"       Value="True"/>
        <Setter Property="SnapsToDevicePixels"     Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePicker">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Grid UseLayoutRounding="True"
                                  SnapsToDevicePixels="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <DatePickerTextBox x:Name="PART_TextBox"
                                                   Grid.Column="0"
                                                   Padding="{TemplateBinding Padding}"
                                                   VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   FontFamily="{TemplateBinding FontFamily}"
                                                   FontSize="{TemplateBinding FontSize}"
                                                   Background="Transparent"
                                                   BorderThickness="0"
                                                   Focusable="{TemplateBinding Focusable}"/>
                                <Button x:Name="PART_Button"
                                        Grid.Column="1"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="4,0"
                                        ToolTip="Open calendar"
                                        AutomationProperties.Name="Open calendar"
                                        Cursor="Hand"
                                        Focusable="False"
                                        VerticalAlignment="Stretch">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="ButtonChrome"
                                                    Margin="2"
                                                    Padding="{TemplateBinding Padding}"
                                                    Background="Transparent"
                                                    CornerRadius="{StaticResource FluentCornerMedium}"
                                                    UseLayoutRounding="True"
                                                    SnapsToDevicePixels="True">
                                                <TextBlock x:Name="ChevronGlyph"
                                                           Text="&#xE787;"
                                                           FontFamily="{StaticResource FluentIconFont}"
                                                           FontSize="{StaticResource FontSizeBody}"
                                                           Foreground="{StaticResource FluentTextSecondary}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource SubtleFillColorSecondary}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="ButtonChrome" Property="Background" Value="{StaticResource SubtleFillColorTertiary}"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="ChevronGlyph" Property="Foreground" Value="{StaticResource FluentTextDisabled}"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                        <Border x:Name="FocusIndicator"
                                Height="2"
                                VerticalAlignment="Bottom"
                                CornerRadius="{StaticResource FluentCornerMediumBottom}"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0"
                                Margin="2,0,2,0"/>
                        <Popup x:Name="PART_Popup"
                               AllowsTransparency="True"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=Bd}"
                               PopupAnimation="Slide"
                               VerticalOffset="4"
                               StaysOpen="False"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness" Value="1"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource FluentStrokeFocus}"/>
                            <Setter TargetName="FocusIndicator" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="{StaticResource FluentControlFillDisabled}"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentTextDisabled}"/>
                            <Setter Property="Opacity" Value="0.4"/>
                            <Setter TargetName="Bd" Property="BorderThickness" Value="0,0,0,1"/>
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource DividerStrokeColorDefault}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>


