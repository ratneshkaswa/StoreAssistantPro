    <Style TargetType="{x:Type controls:FluentExpander}">
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FluentExpander}">
                    <Border Background="{StaticResource FluentSurface}"
                            BorderBrush="{StaticResource FluentSurfaceStroke}"
