                            <Border x:Name="SubMenuBorder"
                                    Background="{StaticResource FluentSurface}"
                                    BorderBrush="{StaticResource FluentSurfaceStroke}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource FluentCornerMedium}"
                                    Padding="0,4"
                                    Margin="4,2,4,4"
                                    Effect="{StaticResource FluentShadowMedium}"
                                    SnapsToDevicePixels="True">
                                <ScrollViewer Style="{DynamicResource {ComponentResourceKey TypeInTargetAssembly={x:Type FrameworkElement}, ResourceId=MenuScrollViewer}}"
                                              VerticalScrollBarVisibility="Auto">
                                    <StackPanel IsItemsHost="True"
                                                KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>

                    <ControlTemplate.Triggers>
                        <!-- Hover: rounded subtle fill -->
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="TopBd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                        </Trigger>

                        <!-- Submenu open: keep highlight + slightly stronger fill -->
                        <Trigger Property="IsSubmenuOpen" Value="True">
                            <Setter TargetName="TopBd" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                            <Setter TargetName="AccentPill" Property="Opacity" Value="1"/>
                        </Trigger>

                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

