    <Style TargetType="{x:Type controls:NumberBox}">
        <Setter Property="FontFamily"              Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"                Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Foreground"              Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Background"              Value="{StaticResource FluentSurface}"/>
        <Setter Property="BorderBrush"             Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="MinHeight"               Value="{StaticResource ControlHeight}"/>
        <Setter Property="h:BringFocusedFieldIntoView.IsEnabled" Value="True"/>
        <Setter Property="UseLayoutRounding"       Value="True"/>
        <Setter Property="SnapsToDevicePixels"     Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:NumberBox}">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition x:Name="SpinCol" Width="0"/>
                                </Grid.ColumnDefinitions>
                                <Grid Grid.Column="0"
                                      Margin="{StaticResource ControlPadding}"
                                      VerticalAlignment="Center">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="PrefixTextPresenter"
                                               Grid.Column="0"
                                               Visibility="Collapsed"
                                               Margin="0,0,8,0"
                                               VerticalAlignment="Center"
                                               FontFamily="{TemplateBinding FontFamily}"
                                               FontSize="{TemplateBinding FontSize}"
                                               Foreground="{StaticResource FluentTextTertiary}"
                                               Text="{TemplateBinding PrefixText}"/>
                                    <TextBox x:Name="PART_TextBox"
                                             Grid.Column="1"
                                             Background="Transparent"
                                             BorderThickness="0"
                                             InputScope="Number"
                                             Padding="0"
                                             VerticalContentAlignment="Center"
                                             FontFamily="{TemplateBinding FontFamily}"
                                             FontSize="{TemplateBinding FontSize}"
                                             Foreground="{TemplateBinding Foreground}"
                                             CaretBrush="{StaticResource FluentAccentDefault}"
                                             SelectionBrush="{StaticResource FluentTextSelectionBrush}"/>
                                    <TextBlock x:Name="SuffixTextPresenter"
                                               Grid.Column="2"
                                               Visibility="Collapsed"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               FontFamily="{TemplateBinding FontFamily}"
                                               FontSize="{TemplateBinding FontSize}"
                                               Foreground="{StaticResource FluentTextTertiary}"
                                               Text="{TemplateBinding SuffixText}"/>
                                </Grid>
                                <StackPanel x:Name="SpinPanel" Grid.Column="1"
                                            Orientation="Vertical" VerticalAlignment="Center"
                                            Visibility="Collapsed" Margin="0,0,2,0">
                                    <Button x:Name="PART_UpButton"
                                            Content="&#xE70E;"
                                            FontFamily="{StaticResource FluentIconFont}"
                                            FontSize="10" Padding="8,4"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTip="Increase value"
                                            AutomationProperties.Name="Increase value"
                                            Focusable="False" Cursor="Hand"/>
                                    <Button x:Name="PART_DownButton"
                                            Content="&#xE70D;"
                                            FontFamily="{StaticResource FluentIconFont}"
                                            FontSize="10" Padding="8,4"
                                            Background="Transparent" BorderThickness="0"
                                            ToolTip="Decrease value"
                                            AutomationProperties.Name="Decrease value"
                                            Focusable="False" Cursor="Hand"/>
                                </StackPanel>
                            </Grid>
                        </Border>
                        <Border x:Name="FocusIndicator"
                                Height="2" VerticalAlignment="Bottom"
                                CornerRadius="{StaticResource FluentCornerMediumBottom}"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0" Margin="2,0,2,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentTextTertiary}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeFocus}"/>
                            <Setter TargetName="FocusIndicator" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="SpinButtonPlacement" Value="Inline">
                            <Setter TargetName="SpinCol" Property="Width" Value="Auto"/>
                            <Setter TargetName="SpinPanel" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="HasPrefixText" Value="True">
                            <Setter TargetName="PrefixTextPresenter" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="HasSuffixText" Value="True">
                            <Setter TargetName="SuffixTextPresenter" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentTextDisabled}"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentSurfaceStroke}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

