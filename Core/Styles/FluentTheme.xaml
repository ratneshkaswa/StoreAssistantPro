¢ÃƒÂ¢Ã¢â€šÂ¬Ã‚Â¢Ãƒâ€šÃ‚Â -->
    <Style x:Key="FluentPasswordBoxStyle" TargetType="PasswordBox">
        <Setter Property="Background"              Value="{StaticResource FluentControlFillDefault}"/>
        <Setter Property="Foreground"              Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush"             Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness"         Value="0,0,0,1"/>
        <Setter Property="Padding"                 Value="{StaticResource ControlPadding}"/>
        <Setter Property="FontFamily"              Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"                Value="{StaticResource FontSizeBody}"/>
        <Setter Property="MinHeight"               Value="{StaticResource ControlHeight}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="CaretBrush"              Value="{StaticResource FluentAccentDefault}"/>
        <Setter Property="SelectionBrush"          Value="{StaticResource FluentTextSelectionBrush}"/>
        <Setter Property="UseLayoutRounding"       Value="True"/>
        <Setter Property="SnapsToDevicePixels"     Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="PasswordBox">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Grid Grid.Column="0">
                                    <ScrollViewer x:Name="PART_ContentHost"
                                                  Focusable="False"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Hidden"
                                                  Padding="{TemplateBinding Padding}"/>
                                    <TextBlock x:Name="RevealTextOverlay"
                                               Visibility="Collapsed"
                                               IsHitTestVisible="False"
                                               Margin="{TemplateBinding Padding}"
                                               VerticalAlignment="Center"
                                               Foreground="{TemplateBinding Foreground}"
                                               Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=(h:PasswordReveal.RevealText)}"
                                               TextTrimming="CharacterEllipsis"/>
                                </Grid>

                                <Button x:Name="PART_RevealButton"
                                        Grid.Column="1"
                                        Margin="0,0,4,0"
                                        Padding="6"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Focusable="False"
                                        Cursor="Hand"
                                        Foreground="{TemplateBinding Foreground}"
                                        ToolTip="Show password while pressed"
                                        AutomationProperties.Name="Show password while pressed"
                                        Visibility="Collapsed">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="RevealChrome"
                                                    Background="Transparent"
                                                    CornerRadius="{StaticResource FluentCornerMedium}"
                                                    Padding="{TemplateBinding Padding}">
                                                <TextBlock Text="&#xE890;"
                                                           FontFamily="{StaticResource FluentIconFont}"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{TemplateBinding Foreground}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="RevealChrome" Property="Background"
                                                            Value="{StaticResource SubtleFillColorSecondary}"/>
                                                </Trigger>
                                                <Trigger Property="IsPressed" Value="True">
                                                    <Setter TargetName="RevealChrome" Property="Background"
                                                            Value="{StaticResource SubtleFillColorTertiary}"/>
                                                </Trigger>
                                                <Trigger Property="IsEnabled" Value="False">
                                                    <Setter TargetName="RevealChrome" Property="Opacity" Value="0.4"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </Grid>
                        </Border>
                        <Border x:Name="FocusIndicator"
                                Height="2" VerticalAlignment="Bottom"
                                CornerRadius="{StaticResource FluentCornerMediumBottom}"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0" Margin="2,0,2,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness"
                                    Value="1"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeDefault}"/>
                        </Trigger>
                        <Trigger Property="h:PasswordReveal.HasRevealText" Value="True">
                            <Setter TargetName="PART_RevealButton" Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>
                        <Trigger Property="h:PasswordReveal.IsRevealActive" Value="True">
                            <Setter TargetName="PART_ContentHost" Property="Opacity"
                                    Value="0"/>
                            <Setter TargetName="RevealTextOverlay" Property="Visibility"
                                    Value="Visible"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness"
                                    Value="1"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeFocus}"/>
                            <Setter TargetName="FocusIndicator" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background"
                                    Value="{StaticResource FluentControlFillDisabled}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                            <Setter Property="Opacity" Value="0.4"/>
                            <Setter TargetName="Bd" Property="BorderThickness"
                                    Value="0,0,0,1"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource DividerStrokeColorDefault}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

