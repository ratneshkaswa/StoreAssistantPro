<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ═══════════════════════════════════════════════════════════════
         DENSITY MODE — COMPACT

         Overrides spacing, padding, and control height tokens from
         DesignSystem.xaml to reduce vertical and horizontal density.
         Roughly 20–25 % tighter than Normal mode.

         This dictionary is merged AFTER DesignSystem.xaml so its
         values win the last-writer-wins resolution. Only tokens
         that change are listed; everything else inherits from
         DesignSystem.xaml.

         Control heights:   32→26   buttons: 34→28   large: 36→30
         Card padding:      16→10   dialog: 24→16    page: 20→14
         Vertical spacing:  shrunk by 4 px uniformly
         Horizontal gaps:   shrunk by 2–4 px where safe
         DataGrid row:      32→26
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Container padding ──────────────────────────────────────── -->
    <Thickness x:Key="PagePadding">14</Thickness>
    <Thickness x:Key="DialogPadding">16</Thickness>
    <Thickness x:Key="CardPadding">10</Thickness>
    <Thickness x:Key="PanelPadding">8</Thickness>

    <!-- ── Vertical spacing (bottom margin) ───────────────────────── -->
    <Thickness x:Key="SectionSpacing">0,0,0,10</Thickness>
    <Thickness x:Key="FieldGroupSpacing">0,0,0,8</Thickness>
    <Thickness x:Key="ItemSpacing">0,0,0,5</Thickness>
    <Thickness x:Key="CompactItemSpacing">0,0,0,3</Thickness>
    <Thickness x:Key="FieldLabelSpacing">0,0,0,2</Thickness>
    <Thickness x:Key="TitleSpacing">0,0,0,10</Thickness>
    <Thickness x:Key="ToolbarSpacing">0,0,0,8</Thickness>

    <!-- ── Horizontal spacing (right margin) ──────────────────────── -->
    <Thickness x:Key="InlineControlSpacing">0,0,6,0</Thickness>
    <Thickness x:Key="FormColumnGap">0,0,8,0</Thickness>
    <Thickness x:Key="WrapFieldGap">0,0,8,0</Thickness>

    <!-- ── Top spacing (top margin) ───────────────────────────────── -->
    <Thickness x:Key="FormActionBarSpacing">0,8,0,0</Thickness>
    <Thickness x:Key="MessageBarSpacing">0,5,0,0</Thickness>
    <Thickness x:Key="KpiValueSpacing">0,2,0,0</Thickness>
    <Thickness x:Key="HintTextSpacing">0,1,0,0</Thickness>
    <Thickness x:Key="SmallCardPadding">6,4</Thickness>

    <!-- ── Uniform gap ────────────────────────────────────────────── -->
    <Thickness x:Key="PanelGap">8</Thickness>
    <Thickness x:Key="EmptyStatePadding">0,16</Thickness>
    <Thickness x:Key="StatCardGap">0,0,6,6</Thickness>
    <Thickness x:Key="SectionCardGap">0,8,0,0</Thickness>
    <Thickness x:Key="DashboardListItemSpacing">0,1,0,1</Thickness>
    <Thickness x:Key="InlineLeftGap">6,0,0,0</Thickness>
    <Thickness x:Key="NotificationDotOffset">0,3,6,0</Thickness>

    <!-- ── Card-internal content padding ──────────────────────────── -->
    <Thickness x:Key="CardContentPadding">8,5</Thickness>

    <!-- ── Grid row height for form layouts ───────────────────────── -->
    <GridLength x:Key="FormRowSpacing">5</GridLength>

    <!-- ── Control heights ────────────────────────────────────────── -->
    <sys:Double x:Key="ControlHeight">26</sys:Double>
    <sys:Double x:Key="ButtonHeight">28</sys:Double>
    <sys:Double x:Key="ButtonHeightLarge">30</sys:Double>
    <sys:Double x:Key="DataGridRowHeight">26</sys:Double>

    <!-- ── Control-internal padding ───────────────────────────────── -->
    <Thickness x:Key="ControlPadding">4</Thickness>
    <Thickness x:Key="ButtonPadding">8,4</Thickness>
    <Thickness x:Key="ButtonPaddingLarge">12,5</Thickness>
    <Thickness x:Key="PagingButtonPadding">6,2</Thickness>
    <Thickness x:Key="ChipPadding">3,1</Thickness>
    <Thickness x:Key="SidebarNavItemPadding">16,8</Thickness>

</ResourceDictionary>
