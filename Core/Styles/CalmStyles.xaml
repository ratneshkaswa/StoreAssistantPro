<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers">

    <!-- ═══════════════════════════════════════════════════════════════
         CALM UI STYLES

         Named styles for secondary / non-active visual zones.
         Consume the Calm* tokens from DesignSystem.xaml to provide
         a subtly quieter rendering without dramatic dimming.

         Architecture:
           DesignSystem.xaml   ← Calm* color / shadow tokens
             ↑ referenced by
           CalmStyles.xaml     ← this file: composited styles
             ↑ consumed by
           Views / Behaviors   ← applied via Style or DataTrigger

         Usage patterns:
           1. Direct style application on secondary panels:
                <Border Style="{StaticResource CalmCardStyle}"/>
           2. DataTrigger swap when CalmUI activates:
                <DataTrigger Binding="{Binding CalmUI.CalmModeEnabled}" Value="True">
                    <Setter Property="Style" Value="{StaticResource CalmCardStyle}"/>
                </DataTrigger>
           3. Programmatic swap via AdaptiveWorkspace / BillingDimBehavior.

         Design principles:
           - No opacity manipulation — colors carry the calm intent.
           - Borders lighten, never disappear — structure preserved.
           - Shadows soften but remain — depth hierarchy preserved.
           - Text is readable (never disabled-grey) — professional.
           - Every calm style has a 1:1 mapping to its standard sibling.
         ═══════════════════════════════════════════════════════════════ -->


    <!-- ═══════════════════════════════════════════════════════════════
         1. CALM CARD — secondary panel card (muted FluentCardStyle)
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmCardStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource CalmSurface}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource CalmStroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="{StaticResource FluentCornerMedium}"/>
        <Setter Property="Padding"         Value="16"/>
        <Setter Property="Effect"          Value="{StaticResource CalmShadowSmall}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         2. CALM SECTION CARD — secondary list / grid panel
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmSectionCardStyle" TargetType="Border"
           BasedOn="{StaticResource CalmCardStyle}">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         3. CALM SECTION CARD HEADER — banner at top of calm cards
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmSectionCardHeaderStyle" TargetType="Border">
        <Setter Property="Background"   Value="{StaticResource CalmHeaderBackground}"/>
        <Setter Property="CornerRadius" Value="8,8,0,0"/>
        <Setter Property="Padding"      Value="12,8"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         4. CALM FORM CARD — secondary add/edit form panel
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmFormCardStyle" TargetType="Border"
           BasedOn="{StaticResource CalmCardStyle}">
        <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
        <Setter Property="Margin"  Value="{StaticResource FieldGroupSpacing}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         5. CALM DETAIL PANEL — secondary bottom detail strip
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmDetailPanelStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource CalmSurfaceElevated}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource CalmStrokeSubtle}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Padding"         Value="12,8"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         6. CALM ELEVATED CARD — secondary popup / overlay card
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmCardElevatedStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource CalmSurface}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource CalmStroke}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="{StaticResource FluentCornerLarge}"/>
        <Setter Property="Padding"         Value="20"/>
        <Setter Property="Effect"          Value="{StaticResource CalmShadowMedium}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         7. CALM OVERLAY — loading / processing overlay (semi-transparent)
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmOverlayCardStyle" TargetType="Border">
        <Setter Property="Background"   Value="#C8FAFBFC"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         8. CALM CHROME STYLES — menu bar, toolbar, status bar
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Calm toolbar strip -->
    <Style x:Key="CalmToolbarStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource CalmChromeBackground}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource CalmChromeBorder}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="Padding"         Value="4,2"/>
    </Style>

    <!-- Calm status bar strip -->
    <Style x:Key="CalmStatusBarStyle" TargetType="Border">
        <Setter Property="Background"      Value="{StaticResource CalmChromeBackground}"/>
        <Setter Property="BorderBrush"     Value="{StaticResource CalmChromeBorder}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Padding"         Value="8,3"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         8b. CALM STATUS BAR SYSTEM — full StatusBar + item + separator

         Subtle background separation from CalmStatusBarBackground.
         Low-contrast CalmStatusBarForeground for all text.
         Important status changes (offline, billing lock, errors)
         retain full-color pill backgrounds via their own DataTriggers;
         routine indicators use CalmPillBackground instead.

         ┌──────────────────────────────────────────────────────────┐
         │ Element         │ Normal (Fluent)      │ Calm            │
         ├─────────────────┼──────────────────────┼─────────────────┤
         │ Background      │ #FAFAFA              │ #F4F5F7         │
         │ Border          │ FluentSurfaceStroke  │ CalmStrokeSubtle│
         │ Foreground      │ #616161              │ #8C8C8C         │
         │ Separator       │ FluentSurfaceStroke  │ #E8E9EB         │
         │ Routine pills   │ FluentAccentDefault  │ CalmPillBg      │
         │ KPI stats       │ Full-sat colors      │ Desaturated     │
         │ Important pills │ FluentError/Success  │ UNCHANGED       │
         └─────────────────┴──────────────────────┴─────────────────┘
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Calm StatusBar container — replaces FluentStatusBarStyle -->
    <Style x:Key="CalmStatusBarContainerStyle" TargetType="StatusBar">
        <Setter Property="Background"          Value="{StaticResource CalmStatusBarBackground}"/>
        <Setter Property="Foreground"          Value="{StaticResource CalmStatusBarForeground}"/>
        <Setter Property="FontFamily"          Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"            Value="{StaticResource FontSizeStatusBar}"/>
        <Setter Property="Padding"             Value="10,5"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="StatusBar">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource CalmStrokeSubtle}"
                            BorderThickness="0,1,0,0"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ItemsPresenter/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Calm StatusBarItem — low-contrast foreground -->
    <Style x:Key="CalmStatusBarItemStyle" TargetType="StatusBarItem">
        <Setter Property="Padding"    Value="0"/>
        <Setter Property="Margin"     Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeStatusBar}"/>
        <Setter Property="Foreground" Value="{StaticResource CalmStatusBarForeground}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="StatusBarItem">
                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                      VerticalAlignment="Center"
                                      SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Calm separator — lighter divider -->
    <Style x:Key="CalmStatusBarSeparatorStyle" TargetType="Border">
        <Setter Property="Width"              Value="1"/>
        <Setter Property="Background"         Value="{StaticResource CalmStatusBarSeparator}"/>
        <Setter Property="Margin"             Value="8,3"/>
        <Setter Property="VerticalAlignment"  Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Calm pill — routine status (mode, lock state when inactive) -->
    <Style x:Key="CalmStatusBadgePillStyle" TargetType="Border">
        <Setter Property="CornerRadius"        Value="{StaticResource FluentCornerSmall}"/>
        <Setter Property="Padding"             Value="10,3"/>
        <Setter Property="Background"          Value="{StaticResource CalmPillBackground}"/>
        <Setter Property="VerticalAlignment"   Value="Center"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- Calm pill text — used inside calm pills -->
    <Style x:Key="CalmStatusPillTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground"     Value="{StaticResource CalmPillForeground}"/>
        <Setter Property="FontSize"       Value="{StaticResource FontSizeStatusBar}"/>
        <Setter Property="FontWeight"     Value="SemiBold"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         9. CALM TEXT STYLES — quieter text for non-active areas
         ═══════════════════════════════════════════════════════════════ -->

    <Style x:Key="CalmTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CalmTextPrimary}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeSectionHeader}"/>
    </Style>

    <Style x:Key="CalmBodyTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CalmTextSecondary}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeBody}"/>
    </Style>

    <Style x:Key="CalmLabelTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{StaticResource CalmTextTertiary}"/>
        <Setter Property="FontSize"   Value="{StaticResource FontSizeLabel}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         10. CALM ACCENT ELEMENTS — muted accent for non-active areas
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Subtle accent strip (e.g., left-edge indicator on calm cards) -->
    <Style x:Key="CalmAccentStripStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource CalmAccentSubtle}"/>
        <Setter Property="Width"      Value="3"/>
        <Setter Property="CornerRadius" Value="2"/>
    </Style>

    <!-- Calm badge pill (status indicators in non-active panels) -->
    <Style x:Key="CalmBadgePillStyle" TargetType="Border">
        <Setter Property="Background"   Value="{StaticResource CalmAccentSubtle}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding"      Value="8,3"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         11. CALM TOOLBAR BUTTON — reduced-weight toolbar action

         Resting state: transparent background, CalmTextSecondary foreground.
         Hover: CalmAccentSubtle background, CalmTextPrimary foreground,
                with subtle accent underline that fades in.
         Pressed: CalmStroke background.
         No accent color at rest — color appears only on interaction.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmToolbarButtonStyle" TargetType="Button">
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="Foreground"          Value="{StaticResource CalmTextSecondary}"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="FontFamily"          Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"            Value="{StaticResource FontSizeBody}"/>
        <Setter Property="MinHeight"           Value="{StaticResource ButtonHeight}"/>
        <Setter Property="Padding"             Value="{StaticResource ButtonPadding}"/>
        <Setter Property="Margin"              Value="0,0,6,0"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Border x:Name="Bd"
                                Background="Transparent"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <!-- Accent underline — visible only on hover/press -->
                        <Border x:Name="AccentLine"
                                Height="2" VerticalAlignment="Bottom"
                                CornerRadius="1" Margin="6,0,6,1"
                                Background="{StaticResource CalmAccent}"
                                Opacity="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource CalmAccentSubtle}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource CalmTextPrimary}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentLine"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentLine"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource CalmStroke}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource CalmTextPrimary}"/>
                            <Setter TargetName="AccentLine" Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         12. CALM QUICK ACTION BUTTON — reduced-weight tile action

         Mirrors QuickActionButtonStyle layout (icon + title + shortcut)
         with calm text colors and accent indicator only on hover.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmQuickActionButtonStyle" TargetType="Button">
        <Setter Property="MinWidth"            Value="68"/>
        <Setter Property="MinHeight"           Value="56"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Foreground"          Value="{StaticResource CalmTextSecondary}"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="Padding"             Value="14,6"/>
        <Setter Property="Margin"              Value="2,0"/>
        <Setter Property="VerticalAlignment"   Value="Stretch"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="h:SmartTooltip.Header"     Value="{Binding Title}"/>
        <Setter Property="h:SmartTooltip.Text"       Value="{Binding Description}"/>
        <Setter Property="h:SmartTooltip.Shortcut"   Value="{Binding ShortcutText}"/>
        <Setter Property="h:SmartTooltip.ContextKey" Value="{Binding HelpKey}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid RenderTransformOrigin="0.5,0.5">
                        <Grid.RenderTransform>
                            <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
                        </Grid.RenderTransform>
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock x:Name="IconText"
                                           Text="{Binding Icon}"
                                           FontSize="20"
                                           Foreground="{StaticResource CalmTextTertiary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock x:Name="TitleText"
                                           Text="{Binding Title}"
                                           FontFamily="{StaticResource FluentFontFamily}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Margin="0,3,0,0"/>
                                <TextBlock x:Name="ShortcutHint"
                                           Text="{Binding ShortcutText}"
                                           FontFamily="{StaticResource FluentFontFamily}"
                                           FontSize="9"
                                           Foreground="{StaticResource CalmTextTertiary}"
                                           HorizontalAlignment="Center"
                                           Margin="0,1,0,0"/>
                            </StackPanel>
                        </Border>
                        <!-- Accent indicator — visible only on hover/press -->
                        <Border x:Name="AccentIndicator"
                                Height="2" VerticalAlignment="Bottom"
                                CornerRadius="1"
                                Background="{StaticResource CalmAccent}"
                                Opacity="0" Margin="8,0,8,2"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding ShortcutText}" Value="">
                            <Setter TargetName="ShortcutHint" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource CalmAccentSubtle}"/>
                            <Setter TargetName="IconText" Property="Foreground"
                                    Value="{StaticResource CalmAccent}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource CalmTextPrimary}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="AccentIndicator"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource CalmStroke}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource CalmTextPrimary}"/>
                            <Setter TargetName="AccentIndicator" Property="Opacity" Value="1"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="RootScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         13. CALM TOOLBAR LINK BUTTON — text-only link with calm colors

         Resting: CalmTextTertiary, transparent.
         Hover: CalmTextPrimary, CalmAccentSubtle background.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmToolbarLinkButtonStyle" TargetType="Button">
        <Setter Property="FontFamily"          Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"            Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground"          Value="{StaticResource CalmTextTertiary}"/>
        <Setter Property="Background"          Value="Transparent"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="Padding"             Value="6,2"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource FluentCornerSmall}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource CalmAccentSubtle}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource CalmTextPrimary}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource CalmStroke}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource CalmAccent}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         14. CALM ENTERPRISE ACTION BUTTON — desaturated primary action

         Background uses CalmAccent (#4D94D0) instead of FluentAccentDefault
         (#005FB8) so it recedes visually. Hover restores full prominence.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="CalmEnterpriseActionButtonStyle" TargetType="Button">
        <Setter Property="FontFamily"          Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"            Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontWeight"          Value="SemiBold"/>
        <Setter Property="Padding"             Value="14,6"/>
        <Setter Property="Background"          Value="{StaticResource CalmAccent}"/>
        <Setter Property="Foreground"          Value="{StaticResource FluentTextOnAccent}"/>
        <Setter Property="BorderThickness"     Value="0"/>
        <Setter Property="Cursor"              Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="BdScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentAccentHover}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleRest}"
                                            Duration="{StaticResource FluentDurationNormal}"
                                            EasingFunction="{StaticResource FluentEasePoint}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Bd" Property="Background"
                                    Value="{StaticResource FluentAccentPressed}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScalePressed}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="{StaticResource MotionButtonScaleHover}"
                                            Duration="{StaticResource FluentDurationFast}"
                                            EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
