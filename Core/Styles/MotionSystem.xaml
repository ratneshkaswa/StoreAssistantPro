<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers">

    <!--
         MotionSystem remains in the shared style chain for compatibility,
         but speed-first mode strips all storyboard resources. Shared motion
         styles now only map to the no-op Motion attached properties.
    -->

    <Style x:Key="MotionFadeInStyle" TargetType="FrameworkElement">
        <Setter Property="h:Motion.FadeIn" Value="True"/>
    </Style>

    <Style x:Key="MotionSlideFadeInStyle" TargetType="FrameworkElement">
        <Setter Property="h:Motion.SlideFadeIn" Value="True"/>
    </Style>

    <Style x:Key="MotionScaleHoverStyle" TargetType="FrameworkElement">
        <Setter Property="h:Motion.ScaleHover" Value="True"/>
    </Style>

    <Style x:Key="MotionCardStyle" TargetType="FrameworkElement">
        <Setter Property="h:Motion.FadeIn" Value="True"/>
        <Setter Property="h:Motion.ScaleHover" Value="True"/>
    </Style>

</ResourceDictionary>
