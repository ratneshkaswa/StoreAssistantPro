<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime">

    <!-- ═══════════════════════════════════════════════════════════════
         DESIGN SYSTEM — Single Source of Truth
         ═══════════════════════════════════════════════════════════════

         This dictionary defines every primitive design token used
         across the application:  colors, typography, spacing, sizing,
         corner radii, shadows, and animation durations.

         Architecture:
           DesignSystem.xaml   ← pure tokens (this file)
             ↑ referenced by
           FluentTheme.xaml    ← control templates consuming tokens
             ↑ referenced by
           GlobalStyles.xaml   ← named app styles + implicit overrides
             ↑ referenced by
           PosStyles.xaml      ← POS-specific control templates

         Rules:
           • All tokens live here — no magic numbers in templates.
           • Token keys use a consistent {Category}{Semantic} pattern.
           • Colors follow Fluent 2 semantic naming.
           • Spacing uses a 4 px base unit grid.
           • Change a token once → every consumer updates.
         ═══════════════════════════════════════════════════════════════ -->


    <!-- ═══════════════════════════════════════════════════════════════
         1. COLOR PALETTE
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Background (outermost window / page — Win11 Mica tones) ────────────────────── -->
    <SolidColorBrush x:Key="FluentBackgroundPrimary"   Color="#F5F5F5"/>
    <SolidColorBrush x:Key="FluentBackgroundSecondary" Color="#FAFAFA"/>

    <!-- ── Surface (cards, panels, popups — layered elevation) ─────────────────────────── -->
    <SolidColorBrush x:Key="FluentSurface"             Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FluentSurfaceElevated"     Color="#FCFCFC"/>
    <SolidColorBrush x:Key="FluentSurfaceStroke"       Color="#E8E8E8"/>

    <!-- ── Stroke (borders, dividers) ──────────────────────────────── -->
    <SolidColorBrush x:Key="FluentStrokeDefault"       Color="#E5E5E5"/>
    <SolidColorBrush x:Key="FluentStrokeFocus"         Color="#005FB8"/>
    <SolidColorBrush x:Key="FluentStrokeError"         Color="#C42B1C"/>

    <!-- ── Text ─────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="FluentTextPrimary"         Color="#1A1A1A"/>
    <SolidColorBrush x:Key="FluentTextSecondary"       Color="#616161"/>
    <SolidColorBrush x:Key="FluentTextTertiary"        Color="#9E9E9E"/>
    <SolidColorBrush x:Key="FluentTextDisabled"        Color="#BDBDBD"/>
    <SolidColorBrush x:Key="FluentTextOnAccent"        Color="#FFFFFF"/>

    <!-- ── Accent (brand) ──────────────────────────────────────────── -->
    <SolidColorBrush x:Key="FluentAccentDefault"       Color="#005FB8"/>
    <SolidColorBrush x:Key="FluentAccentHover"         Color="#0067C0"/>
    <SolidColorBrush x:Key="FluentAccentPressed"       Color="#003D7A"/>
    <SolidColorBrush x:Key="FluentAccentDisabled"      Color="#C4C4C4"/>
    <SolidColorBrush x:Key="FluentAccentLight1"        Color="#60CDFF"/>
    <SolidColorBrush x:Key="FluentAccentLight2"        Color="#98D8FF"/>
    <SolidColorBrush x:Key="FluentAccentLight3"        Color="#B8E6FF"/>
    <SolidColorBrush x:Key="FluentAccentDark1"         Color="#0050A0"/>
    <SolidColorBrush x:Key="FluentAccentDark2"         Color="#003E7E"/>
    <SolidColorBrush x:Key="FluentAccentDark3"         Color="#002D5E"/>

    <!-- Control fills (WinUI 3 token parity) -->
    <SolidColorBrush x:Key="FluentControlFillDefault"  Color="#FFFFFF"/>
    <SolidColorBrush x:Key="FluentControlFillSecondary" Color="#F9F9F9"/>
    <SolidColorBrush x:Key="FluentControlFillTertiary" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="FluentControlFillDisabled" Color="#F9F9F9"/>

    <!-- ── Subtle (transparent interactive fills) ──────────────────── -->
    <SolidColorBrush x:Key="FluentSubtleTransparent"   Color="Transparent"/>
    <SolidColorBrush x:Key="FluentSubtleHover"         Color="#09000000"/>
    <SolidColorBrush x:Key="FluentSubtlePressed"       Color="#06000000"/>

    <!-- ── Semantic ────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="FluentSuccess"             Color="#0F7B0F"/>
    <SolidColorBrush x:Key="FluentSuccessHover"        Color="#118611"/>
    <SolidColorBrush x:Key="FluentSuccessBackground"   Color="#DFF6DD"/>
    <SolidColorBrush x:Key="FluentWarning"             Color="#9D5D00"/>
    <SolidColorBrush x:Key="FluentWarningBackground"   Color="#FFF4CE"/>
    <SolidColorBrush x:Key="FluentError"               Color="#C42B1C"/>
    <SolidColorBrush x:Key="FluentErrorHover"          Color="#D13438"/>
    <SolidColorBrush x:Key="FluentErrorPressed"        Color="#A4262C"/>
    <SolidColorBrush x:Key="FluentErrorBackground"     Color="#FDE7E9"/>
    <SolidColorBrush x:Key="FluentInfo"                Color="#005FB8"/>
    <SolidColorBrush x:Key="FluentInfoBackground"      Color="#D6EBFF"/>

    <!-- Row highlight tints (subtle DataGrid row backgrounds) -->
    <SolidColorBrush x:Key="RowHighlightSuccess"  Color="#0F7B0F" Opacity="0.08"/>
    <SolidColorBrush x:Key="RowHighlightWarning"  Color="#9D5D00" Opacity="0.10"/>
    <SolidColorBrush x:Key="RowHighlightDanger"   Color="#C42B1C" Opacity="0.10"/>
    <SolidColorBrush x:Key="RowHighlightInactive" Color="#8A8886" Opacity="0.12"/>

    <!-- ── Tip Banner (soft, non-distracting guidance) ──────────────── -->
    <SolidColorBrush x:Key="TipBannerBackground"       Color="#F8F9FB"/>
    <SolidColorBrush x:Key="TipBannerBackgroundHover"  Color="#F2F4F8"/>
    <SolidColorBrush x:Key="TipBannerBorder"           Color="#E6E8ED"/>
    <SolidColorBrush x:Key="TipBannerAccent"           Color="#B4D6F5"/>
    <SolidColorBrush x:Key="TipBannerIconForeground"   Color="#0078D4"/>
    <SolidColorBrush x:Key="TipBannerTitleForeground"  Color="#242424"/>
    <SolidColorBrush x:Key="TipBannerBodyForeground"   Color="#707070"/>

    <!-- ── Chrome (menu bar, status bar, toolbar — Win11 seamless) ──────────────────── -->
    <SolidColorBrush x:Key="FluentMenuBarBackground"   Color="#F5F5F5"/>
    <SolidColorBrush x:Key="FluentMenuBarForeground"   Color="#1A1A1A"/>
    <SolidColorBrush x:Key="FluentStatusBarBackground" Color="#F5F5F5"/>
    <SolidColorBrush x:Key="FluentStatusBarForeground" Color="#5C5C5C"/>
    <SolidColorBrush x:Key="FluentToolbarBackground"   Color="#FAFAFA"/>
    <SolidColorBrush x:Key="FluentToolbarBorder"       Color="#EBEBEB"/>

    <!-- ── KPI Stat Card Palette ───────────────────────────────────── -->
    <SolidColorBrush x:Key="FluentKpiGreen"            Color="#0F7B0F"/>
    <SolidColorBrush x:Key="FluentKpiGreenMuted"       Color="#DFF6DD"/>
    <SolidColorBrush x:Key="FluentKpiOrange"           Color="#C17A0E"/>
    <SolidColorBrush x:Key="FluentKpiOrangeMuted"      Color="#FFF4CE"/>
    <SolidColorBrush x:Key="FluentKpiBlue"             Color="#005FB8"/>
    <SolidColorBrush x:Key="FluentKpiBlueMuted"        Color="#D6EBFF"/>
    <SolidColorBrush x:Key="FluentKpiPurple"           Color="#7719AA"/>
    <SolidColorBrush x:Key="FluentKpiPurpleMuted"      Color="#F0E6FA"/>
    <SolidColorBrush x:Key="FluentKpiRed"              Color="#C42B1C"/>
    <SolidColorBrush x:Key="FluentKpiRedMuted"         Color="#FDE7E9"/>
    <SolidColorBrush x:Key="FluentKpiTeal"             Color="#0E7A6B"/>
    <SolidColorBrush x:Key="FluentKpiTealMuted"        Color="#D1F0EB"/>

    <!-- Role Identity Palette (soft pastels) -->
    <SolidColorBrush x:Key="RoleAdminBackground"       Color="#E8EEFA"/>
    <SolidColorBrush x:Key="RoleAdminBorder"           Color="#B4C8ED"/>
    <SolidColorBrush x:Key="RoleAdminAccent"           Color="#3B6FC0"/>
    <SolidColorBrush x:Key="RoleManagerBackground"     Color="#F0E6FA"/>
    <SolidColorBrush x:Key="RoleManagerBorder"         Color="#D4BEF0"/>
    <SolidColorBrush x:Key="RoleManagerAccent"         Color="#7B3FAF"/>
    <SolidColorBrush x:Key="RoleUserBackground"        Color="#E3F4EC"/>
    <SolidColorBrush x:Key="RoleUserBorder"            Color="#B0DCC5"/>
    <SolidColorBrush x:Key="RoleUserAccent"            Color="#1D7B4E"/>
    <SolidColorBrush x:Key="RoleMasterBackground"      Color="#FDF6E3"/>
    <SolidColorBrush x:Key="RoleMasterBorder"          Color="#F0DFA0"/>
    <SolidColorBrush x:Key="RoleMasterAccent"          Color="#9A7B1A"/>


    <!-- ═══════════════════════════════════════════════════════════════
         2. TYPOGRAPHY
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Font family stack (Fluent 2 preferred → fallback) -->
    <FontFamily x:Key="FluentFontFamily">Segoe UI Variable, Segoe UI, Segoe UI Emoji, sans-serif</FontFamily>

    <!-- Win11 optical-size font variants -->
    <FontFamily x:Key="FluentFontDisplay">Segoe UI Variable Display, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="FluentFontText">Segoe UI Variable Text, Segoe UI, sans-serif</FontFamily>
    <FontFamily x:Key="FluentFontSmall">Segoe UI Variable Small, Segoe UI, sans-serif</FontFamily>

    <!-- Type scale — semantic sizes for each content role -->
    <sys:Double x:Key="FontSizePageTitle">24</sys:Double>
    <sys:Double x:Key="FontSizeDialogTitle">20</sys:Double>
    <sys:Double x:Key="FontSizeKpi">28</sys:Double>
    <sys:Double x:Key="FontSizeSectionHeader">16</sys:Double>
    <sys:Double x:Key="FontSizeBody">13</sys:Double>
    <sys:Double x:Key="FontSizeLabel">12</sys:Double>
    <sys:Double x:Key="FontSizeCaption">11</sys:Double>
    <sys:Double x:Key="FontSizeStatusBar">10</sys:Double>
    <sys:Double x:Key="FontSizeIconMedium">18</sys:Double>
    <sys:Double x:Key="FontSizeIconLarge">40</sys:Double>
    <sys:Double x:Key="FontSizeIconHero">48</sys:Double>

    <sys:Double x:Key="FormLabelColumnMinWidth">100</sys:Double>

    <!-- Line height tokens (Win11 spec) -->
    <sys:Double x:Key="LineHeightTitle">36</sys:Double>
    <sys:Double x:Key="LineHeightSubtitle">28</sys:Double>
    <sys:Double x:Key="LineHeightBody">20</sys:Double>
    <sys:Double x:Key="LineHeightCaption">16</sys:Double>


    <!-- ═══════════════════════════════════════════════════════════════
         3. CORNER RADIUS
         ═══════════════════════════════════════════════════════════════ -->
    <CornerRadius x:Key="FluentCornerXSmall">2</CornerRadius>
    <CornerRadius x:Key="FluentCornerSmall">4</CornerRadius>
    <CornerRadius x:Key="FluentCornerMedium">8</CornerRadius>
    <CornerRadius x:Key="FluentCornerLarge">12</CornerRadius>

    <!-- Directional corners (flyout headers/footers, popups) -->
    <CornerRadius x:Key="FluentCornerLargeTop">12,12,0,0</CornerRadius>
    <CornerRadius x:Key="FluentCornerLargeBottom">0,0,12,12</CornerRadius>
    <CornerRadius x:Key="FluentCornerMediumTop">8,8,0,0</CornerRadius>
    <CornerRadius x:Key="FluentCornerMediumBottom">0,0,8,8</CornerRadius>

    <!-- Alias used by card / inline-form styles -->
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>


    <!-- ═══════════════════════════════════════════════════════════════
         4. SPACING SCALE  (4 px base unit)

         xs  =  4    label → control gap, tight insets
         sm  =  8    inline control gap, compact separators
         md  = 12    form-field group bottom, toolbar gap, card gap
         lg  = 16    section separator, title bottom margin
         xl  = 20    page padding (main content area)
         xxl = 24    dialog / sub-window padding
         ═══════════════════════════════════════════════════════════════ -->
    <sys:Double x:Key="SpacingXs">4</sys:Double>
    <sys:Double x:Key="SpacingSm">8</sys:Double>
    <sys:Double x:Key="SpacingMd">12</sys:Double>
    <sys:Double x:Key="SpacingLg">16</sys:Double>
    <sys:Double x:Key="SpacingXl">20</sys:Double>
    <sys:Double x:Key="SpacingXxl">24</sys:Double>

    <!-- ── Container padding ──────────────────────────────────────── -->
    <Thickness x:Key="PagePadding">20</Thickness>
    <Thickness x:Key="DialogPadding">24</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="PanelPadding">12</Thickness>

    <!-- ── Vertical spacing (bottom margin) ───────────────────────── -->
    <Thickness x:Key="SectionSpacing">0,0,0,16</Thickness>
    <Thickness x:Key="FieldGroupSpacing">0,0,0,12</Thickness>
    <Thickness x:Key="ItemSpacing">0,0,0,8</Thickness>
    <Thickness x:Key="CompactItemSpacing">0,0,0,6</Thickness>
    <Thickness x:Key="FieldLabelSpacing">0,0,0,4</Thickness>
    <Thickness x:Key="TitleSpacing">0,0,0,16</Thickness>
    <Thickness x:Key="ToolbarSpacing">0,0,0,12</Thickness>

    <!-- ── Horizontal spacing (right margin) ──────────────────────── -->
    <Thickness x:Key="InlineControlSpacing">0,0,8,0</Thickness>
    <Thickness x:Key="InlineLabelGap">0,0,4,0</Thickness>
    <Thickness x:Key="FormColumnGap">0,0,12,0</Thickness>
    <Thickness x:Key="WrapFieldGap">0,0,12,0</Thickness>
    <Thickness x:Key="StatusBarStatGap">10,0,2,0</Thickness>
    <Thickness x:Key="StatusBarPillGap">6,0,0,0</Thickness>

    <!-- ── Top spacing (top margin) ───────────────────────────────── -->
    <Thickness x:Key="FormActionBarSpacing">0,12,0,0</Thickness>
    <Thickness x:Key="MessageBarSpacing">0,8,0,0</Thickness>
    <Thickness x:Key="KpiValueSpacing">0,4,0,0</Thickness>

    <!-- ── Uniform gap (between panels or grid splitters) ─────────── -->
    <Thickness x:Key="PanelGap">12</Thickness>
    <Thickness x:Key="EmptyStatePadding">0,24</Thickness>
    <Thickness x:Key="StatCardGap">0,0,8,8</Thickness>
    <Thickness x:Key="HintTextSpacing">0,2,0,0</Thickness>
    <Thickness x:Key="SmallCardPadding">8,6</Thickness>
    <Thickness x:Key="SectionCardGap">0,12,0,0</Thickness>
    <Thickness x:Key="DashboardListItemSpacing">0,2,0,2</Thickness>
    <Thickness x:Key="InlineLeftGap">8,0,0,0</Thickness>
    <Thickness x:Key="NotificationDotOffset">0,4,8,0</Thickness>
    <Thickness x:Key="CardContentPadding">12,8</Thickness>
    <Thickness x:Key="ChipPadding">4,2</Thickness>

    <!-- Setup stepper / strength bar -->
    <sys:Double x:Key="StepCircleSize">24</sys:Double>
    <sys:Double x:Key="StepConnectorHeight">2</sys:Double>
    <sys:Double x:Key="StepperWidth">280</sys:Double>
    <sys:Double x:Key="StrengthBarWidth">24</sys:Double>
    <sys:Double x:Key="StrengthBarHeight">4</sys:Double>
    <sys:Double x:Key="PinDotSize">20</sys:Double>
    <Thickness x:Key="StepConnectorMargin">4,0</Thickness>
    <Thickness x:Key="StrengthBarGap">0,2,3,0</Thickness>
    <Thickness x:Key="StrengthLabelGap">6,0,0,0</Thickness>
    <Thickness x:Key="RoleSectionPadding">8,2</Thickness>
    <Thickness x:Key="RoleSectionMargin">0,0,0,2</Thickness>
    <Thickness x:Key="BadgeOffset">0,-2,2,0</Thickness>
    <Thickness x:Key="RoleButtonGap">2,0</Thickness>
    <Thickness x:Key="StepperMargin">0,4,0,4</Thickness>
    <Thickness x:Key="StepLabelSpacing">0,3,0,0</Thickness>
    <Thickness x:Key="StepConnectorTopOffset">0,4,0,0</Thickness>
    <Thickness x:Key="StepContentTopSpacing">0,8,0,0</Thickness>
    <Thickness x:Key="HintTextTopSpacing">0,4,0,0</Thickness>

    <!-- Grid row height for two-column form layouts -->
    <GridLength x:Key="FormRowSpacing">8</GridLength>


    <!-- ═══════════════════════════════════════════════════════════════
         5. STANDARD SIZES

         Enterprise form density — compact controls that keep data-
         heavy POS screens information-dense without feeling cramped.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Control heights ────────────────────────────────────────── -->
    <sys:Double x:Key="ControlHeight">32</sys:Double>
    <sys:Double x:Key="ButtonHeight">34</sys:Double>
    <sys:Double x:Key="ButtonHeightLarge">36</sys:Double>
    <sys:Double x:Key="DataGridRowHeight">32</sys:Double>

    <!-- ── Control-internal padding ───────────────────────────────── -->
    <Thickness x:Key="ControlPadding">6</Thickness>
    <Thickness x:Key="ButtonPadding">12,6</Thickness>
    <Thickness x:Key="ButtonPaddingLarge">16,8</Thickness>
    <Thickness x:Key="KeypadInset">24,8,24,0</Thickness>
    <Thickness x:Key="PagingButtonPadding">8,4</Thickness>
    <Thickness x:Key="SidebarNavItemPadding">20,12</Thickness>
    <Thickness x:Key="QuickStartCardGap">6</Thickness>
    <Thickness x:Key="QuickStartCardPadding">16,20</Thickness>
    <Thickness x:Key="CardTitleSpacing">0,8,0,0</Thickness>
    <Thickness x:Key="CardSubtitleSpacing">0,2,0,0</Thickness>
    <Thickness x:Key="HeroSectionTopSpacing">0,24,0,0</Thickness>
    <Thickness x:Key="HeroHintSpacing">0,20,0,0</Thickness>
    <Thickness x:Key="SubtitleGap">0,6,0,0</Thickness>
    <sys:Double x:Key="OverlayOpacity">0.85</sys:Double>
    <sys:Double x:Key="KeypadRowMinHeight">56</sys:Double>
    <sys:Double x:Key="ErrorAreaMinHeight">18</sys:Double>
    <sys:Double x:Key="MessageAreaMinHeight">24</sys:Double>
    <sys:Double x:Key="StepIndicatorWidth">260</sys:Double>

    <!-- ── Form field standard widths ─────────────────────────────
         Use instead of magic Width="80" etc. in views.
         Compact  =  80   qty, short codes, small numerics
         Standard = 160   names, single-line text
         Wide     = 250   search boxes, file paths, descriptions
         ──────────────────────────────────────────────────────────── -->
    <sys:Double x:Key="FieldWidthCompact">80</sys:Double>
    <sys:Double x:Key="FieldWidthStandard">160</sys:Double>
    <sys:Double x:Key="FieldWidthWide">250</sys:Double>

    <!-- ── Layout panel widths ─────────────────────────────────────── -->
    <sys:Double x:Key="SidebarNavWidth">200</sys:Double>
    <sys:Double x:Key="NotificationPanelWidth">320</sys:Double>

    <!-- ── DataGrid column standard widths ────────────────────────
         Fixed widths keep column virtualisation enabled (star
         widths disable it).  Use on EnterpriseDataGridStyle grids.
         ──────────────────────────────────────────────────────────── -->
    <DataGridLength x:Key="ColumnWidthId">60</DataGridLength>
    <DataGridLength x:Key="ColumnWidthPrice">110</DataGridLength>
    <DataGridLength x:Key="ColumnWidthQty">60</DataGridLength>
    <DataGridLength x:Key="ColumnWidthStatus">100</DataGridLength>
    <DataGridLength x:Key="ColumnWidthDate">120</DataGridLength>


    <!-- ═══════════════════════════════════════════════════════════════
         6. SHADOWS (Fluent 2 depth system)

         Small   = subtle card lift (8 px blur, 0.08 opacity)
         Medium  = popups, dropdowns (16 px blur, 0.12)
         Large   = dialogs, overlays (24 px blur, 0.14)
         ═══════════════════════════════════════════════════════════════ -->
    <DropShadowEffect x:Key="FluentShadowSmall"
                      BlurRadius="8" ShadowDepth="1"
                      Direction="270" Opacity="0.06"
                      Color="#000000"/>

    <DropShadowEffect x:Key="FluentShadowMedium"
                      BlurRadius="16" ShadowDepth="2"
                      Direction="270" Opacity="0.10"
                      Color="#000000"/>

    <DropShadowEffect x:Key="FluentShadowLarge"
                      BlurRadius="32" ShadowDepth="4"
                      Direction="270" Opacity="0.12"
                      Color="#000000"/>


    <!-- ═══════════════════════════════════════════════════════════════
         7. ANIMATION DURATIONS

         All durations set to 0 — animations disabled.
         Original values preserved in comments for re-enabling.
         ═══════════════════════════════════════════════════════════════ -->
    <Duration x:Key="FluentDurationFast">0:0:0.083</Duration>
    <Duration x:Key="FluentDurationNormal">0:0:0.167</Duration>
    <Duration x:Key="FluentDurationPageFade">0:0:0.15</Duration>
    <Duration x:Key="FluentDurationSlow">0:0:0.25</Duration>

    <!-- Easing curve for panel dimming / focus-lock transitions -->
    <CubicEase x:Key="PanelDimEase" EasingMode="EaseOut"/>


    <!-- ═══════════════════════════════════════════════════════════════
         8. MOTION TOKENS

         Easing curves and scale factors consumed by MotionSystem.xaml
         and Core/Helpers/Motion.cs attached behaviors.

         Fluent 2 motion principles:
           • Decelerate (EaseOut) for entrances — content arrives fast,
             settles gently.
           • Accelerate (EaseIn) for exits — content departs subtly.
           • Point curve (EaseInOut) for scale / positional emphasis.
           • Hover scale is barely perceptible (1.5 %) — professional
             "alive" feel without cartoon bounce.
           • Slide offset is small (12–20 px) — just enough to imply
             direction without jarring shift.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Easing curves -->
    <CubicEase    x:Key="FluentEaseDecelerate" EasingMode="EaseOut"/>
    <CubicEase    x:Key="FluentEaseAccelerate" EasingMode="EaseIn"/>
    <QuadraticEase x:Key="FluentEasePoint"     EasingMode="EaseInOut"/>

    <!-- Scale factors — Win11 subtle hover breathing -->
    <sys:Double x:Key="MotionScaleHoverFrom">0.985</sys:Double>
    <sys:Double x:Key="MotionScaleHoverTo">1.0</sys:Double>

    <!-- Button micro-interaction scale factors -->
    <sys:Double x:Key="MotionButtonScaleHover">1.02</sys:Double>
    <sys:Double x:Key="MotionButtonScalePressed">0.98</sys:Double>
    <sys:Double x:Key="MotionButtonScaleRest">1.0</sys:Double>

    <!-- Slide offsets — Win11 directional motion -->
    <sys:Double x:Key="MotionSlideOffsetSmall">12</sys:Double>
    <sys:Double x:Key="MotionSlideOffsetNormal">20</sys:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         9. TOOLTIP TIMING

         Cold delay  = 1500 ms — first hover after idle; prevents
                       accidental tooltip flash on mouse traversal.
         Warm delay  = 1200 ms — subsequent hover within the warm
                       window; slightly faster for quick scanning.
         Warm window = 1500 ms — period after hiding a tooltip during
                       which the system stays "warm".
         Display     = 5000 ms — auto-hide after this interval unless
                       the mouse remains over the element.
         ═══════════════════════════════════════════════════════════════ -->
    <sys:Double x:Key="TooltipDelayColdMs">1500</sys:Double>
    <sys:Double x:Key="TooltipDelayWarmMs">1200</sys:Double>
    <sys:Double x:Key="TooltipWarmWindowMs">1500</sys:Double>
    <sys:Double x:Key="TooltipDisplayMs">5000</sys:Double>

    <!-- ── Tooltip visual tokens ─────────────────────────────────────
         Used by SmartTooltipStyle in GlobalStyles.xaml.

         Background uses a semi-transparent white to give a subtle
         frosted-glass feel when over dark surfaces.  The inner
         highlight border mimics the Fluent 2 "smoke" inset glow.
         Corner radius is 6 px — between Small (4) and Medium (8) —
         matching the Win 11 tooltip spec.
         ──────────────────────────────────────────────────────────── -->
    <SolidColorBrush x:Key="TooltipBackground"     Color="#F7F7F7"/>
    <SolidColorBrush x:Key="TooltipBorder"         Color="#E0E0E0"/>
    <SolidColorBrush x:Key="TooltipInnerHighlight" Color="#26FFFFFF"/>
    <CornerRadius    x:Key="TooltipCornerRadius">8</CornerRadius>
    <Thickness       x:Key="TooltipPadding">12,8,12,9</Thickness>
    <sys:Double      x:Key="TooltipMaxWidth">320</sys:Double>

    <DropShadowEffect x:Key="TooltipShadow"
                      BlurRadius="12" ShadowDepth="3"
                      Direction="270" Opacity="0.10"
                      Color="#000000"/>

</ResourceDictionary>
