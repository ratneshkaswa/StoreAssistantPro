        </Setter>
    </Style>

    <Style x:Key="SplitButtonFlyoutActionStyle" TargetType="Button" BasedOn="{x:Null}">
        <Setter Property="MinHeight" Value="40"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}">
                        <ContentPresenter Margin="{TemplateBinding Padding}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource SubtleFillColorSecondary}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource SubtleFillColorTertiary}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="Root" Property="Background" Value="{StaticResource LayerFillColorDefault}"/>
                            <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource SubtleFillColorTertiary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:SplitButton">
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:SplitButton">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button x:Name="PART_PrimaryButton"
                                Grid.Column="0"
                                Content="{TemplateBinding Content}"
                                Command="{TemplateBinding Command}"
                                CommandParameter="{TemplateBinding CommandParameter}"
                                Style="{StaticResource SplitButtonPrimarySegmentStyle}"/>
                        <Button x:Name="PART_DropDownButton"
                                Grid.Column="1"
                                Style="{StaticResource SplitButtonChevronSegmentStyle}"
                                AutomationProperties.Name="More actions"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ContextMenu" Value="{x:Null}">
                            <Setter TargetName="PART_DropDownButton" Property="Visibility" Value="Collapsed"/>
                            <Setter TargetName="PART_PrimaryButton" Property="Grid.ColumnSpan" Value="2"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="PART_PrimaryButton" Property="IsEnabled" Value="False"/>
                            <Setter TargetName="PART_DropDownButton" Property="IsEnabled" Value="False"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- AppBranding -->
    <Style TargetType="controls:AppBranding">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:AppBranding">
                    <StackPanel HorizontalAlignment="Center"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                        <Image x:Name="PART_Logo" Source="pack://application:,,,/Assets/logo-256.png"
                               Width="{TemplateBinding LogoSize}" Height="{TemplateBinding LogoSize}"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="{StaticResource FieldLabelSpacing}"/>
                        <TextBlock x:Name="PART_Title" HorizontalAlignment="Center" Margin="0"
                                   Style="{StaticResource DialogTitleStyle}">
                            <Run Text="Store Assistant "/><Run Text="Pro" Foreground="{StaticResource FluentAccentDefault}"/>
                        </TextBlock>
                        <TextBlock x:Name="PART_Subtitle" Text="{TemplateBinding Subtitle}"
                                   HorizontalAlignment="Center"
                                   FontSize="{StaticResource FontSizeLabel}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   Margin="{StaticResource FieldLabelSpacing}"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowTitle" Value="False">
                            <Setter TargetName="PART_Title" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger SourceName="PART_Subtitle" Property="Text" Value="">
                            <Setter TargetName="PART_Subtitle" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>



