        <Setter Property="HorizontalAlignment" Value="Right"/>
    </Style>

    <Style x:Key="ReportListMetaTextStyle" TargetType="TextBlock"
           BasedOn="{StaticResource CaptionLabelStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"  Value="{StaticResource LayerFillColorDefault}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerMedium}"/>
        <Setter Property="Padding"     Value="{StaticResource CardPadding}"/>
        <Setter Property="Margin"      Value="{StaticResource CardMargin}"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="{StaticResource FluentBorderThicknessThin}"/>
        <Setter Property="Effect"      Value="{StaticResource ElevationEffectCard}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="h:CardHover.IsEnabled" Value="True"/>
        <Setter Property="h:PressStateTracker.IsEnabled" Value="True"/>
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource LayerFillColorSecondary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource SubtleFillColorTertiary}"/>
            </Trigger>
            <Trigger Property="h:PressStateTracker.IsPressed" Value="True">
                <Setter Property="Background" Value="{StaticResource ControlAltFillColorSecondary}"/>
                <Setter Property="BorderBrush" Value="{StaticResource SubtleFillColorTertiary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- Setup page card -->
    <Style x:Key="SetupFlatCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerMedium}"/>
        <Setter Property="Padding" Value="{StaticResource SetupCardPadding}"/>
        <Setter Property="Margin" Value="{StaticResource SetupSectionSpacing}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="{StaticResource FluentBorderThicknessThin}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect" Value="{StaticResource ElevationEffectCard}"/>
    </Style>

    <!-- Sidebar container for setup (flat, no shadow) -->
    <Style x:Key="SetupSidebarCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerMedium}"/>
        <Setter Property="Padding" Value="{StaticResource SetupSidebarCardPadding}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="{StaticResource FluentBorderThicknessThin}"/>
    </Style>

    <!-- Setup sidebar/navigation -->
    <Style x:Key="SetupSidebarIconBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource SetupSidebarIconSize}"/>
        <Setter Property="Height" Value="{StaticResource SetupSidebarIconSize}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
        <Setter Property="Margin" Value="{StaticResource SetupSidebarIconMargin}"/>
    </Style>

    <Style x:Key="SetupSidebarNavItemStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="{StaticResource SetupSidebarNavBorderThickness}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="{StaticResource SetupSidebarNavPadding}"/>
        <Setter Property="Margin" Value="{StaticResource SetupSidebarNavMargin}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{TemplateBinding Padding}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource FluentAccentDefault}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtlePressed}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SetupSidebarNavTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
    </Style>

    <Style x:Key="SetupSidebarNavSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="Margin" Value="{StaticResource SetupSubtitleMargin}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="SetupSectionSummaryLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <Style x:Key="SetupPinStrengthSegmentStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource StrengthBarWidth}"/>
        <Setter Property="Height" Value="{StaticResource StrengthBarHeight}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerXSmall}"/>
        <Setter Property="Margin" Value="{StaticResource StrengthBarGap}"/>
    </Style>

    <Style x:Key="SetupPinWarningTextStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
        <Setter Property="Margin" Value="{StaticResource StrengthLabelGap}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="MaxWidth" Value="260"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SetupPinInlineHintStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Margin" Value="{StaticResource StrengthLabelGap}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="MaxWidth" Value="260"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="SetupRolePinCardStyle" TargetType="HeaderedContentControl">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="HeaderedContentControl">
                    <Border Style="{StaticResource SetupFlatCardStyle}">
                        <StackPanel>
                            <Border Background="{StaticResource FluentInfoBackground}"
                                    CornerRadius="{StaticResource FluentCornerSmall}"
                                    Padding="{StaticResource RoleSectionPadding}"
                                    Margin="{StaticResource RoleSectionMargin}"
                                    ToolTip="{TemplateBinding ToolTip}">
                                <TextBlock FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentTextPrimary}"
                                           FontSize="{StaticResource FontSizeBody}">
                                    <Run FontFamily="{StaticResource FluentIconFont}" Text="{TemplateBinding Tag}"/>
                                    <Run Text="{TemplateBinding Header}"/>
                                </TextBlock>
                            </Border>
                            <ContentPresenter Content="{TemplateBinding Content}"
                                              Margin="{StaticResource StepContentTopSpacing}"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- SetupFormCard -->
    <Style TargetType="{x:Type controls:SetupFormCard}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:SetupFormCard}">
                    <Border Style="{StaticResource SetupFlatCardStyle}">
                        <ContentPresenter Content="{TemplateBinding FormContent}"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Inline form card border (inherits FluentCard and shadow) -->
    <Style x:Key="FormCardStyle" TargetType="Border"
           BasedOn="{StaticResource FluentCardStyle}">
        <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
        <Setter Property="Margin" Value="{StaticResource FieldGroupSpacing}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="{StaticResource FluentBorderThicknessThin}"/>
        <Setter Property="Effect" Value="{StaticResource ElevationEffectBase}"/>
    </Style>

    <!-- Section panel card (list panels, detail panels) -->
    <Style x:Key="SectionCardStyle" TargetType="Border"
           BasedOn="{StaticResource FluentCardStyle}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="{StaticResource FluentBorderThicknessThin}"/>
        <Setter Property="Effect" Value="{StaticResource ElevationEffectBase}"/>
    </Style>

    <!-- Section card header bar (colored banner at top of card) -->
    <Style x:Key="SectionCardHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerMediumTop}"/>
        <Setter Property="Padding" Value="{StaticResource CardContentPadding}"/>
    </Style>

    <!-- Detail panel (bottom split pane, sale detail, etc.) -->
    <Style x:Key="DetailPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Padding" Value="{StaticResource CardContentPadding}"/>
    </Style>

    <!-- Processing / loading overlay card -->
    <Style x:Key="OverlayCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource LoadingOverlayScrim}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
    </Style>

    <!-- Settings sidebar navigation panel -->
    <Style x:Key="SidebarNavStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
