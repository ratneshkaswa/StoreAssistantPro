<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
                    xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls">

    <!-- All design tokens moved to DesignSystem.xaml -->

    <!-- =================================================================
         VALIDATION ERROR TEMPLATE
         ================================================================= -->
    <!-- ErrorTemplate = adorner layer. Use AdornedElementPlaceholder
         only (no border here) to avoid double-border with the
         controls own BorderBrush set via Validation.HasError trigger. -->
    <ControlTemplate x:Key="InlineValidationErrorTemplate">
        <AdornedElementPlaceholder/>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════
         IMPLICIT CONTROL STYLES

         Each implicit style inherits its Fluent base template from
         FluentTheme.xaml, then adds app-specific setters (MinHeight,
         behaviors, validation).  All controls automatically get
         rounded corners, Fluent colors, and focus indicators.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Button inherits FluentStandardButtonStyle (rounded, animated hover) -->
    <Style TargetType="Button" BasedOn="{StaticResource FluentStandardButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
    </Style>

    <!-- TextBox inherits FluentTextBoxStyle (rounded, accent-focus) -->
    <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="h:SelectOnFocus.IsEnabled" Value="True"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- PasswordBox inherits FluentPasswordBoxStyle (rounded, accent-focus) -->
    <Style TargetType="PasswordBox" BasedOn="{StaticResource FluentPasswordBoxStyle}">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBox inherits FluentComboBoxStyle (rounded, accent-focus, Fluent dropdown) -->
    <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBoxItem inherits FluentComboBoxItemStyle (subtle hover/selection) -->
    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource FluentComboBoxItemStyle}"/>

    <!-- CheckBox inherits FluentCheckBoxStyle (accent fill, rounded box, glyph) -->
    <Style TargetType="CheckBox" BasedOn="{StaticResource FluentCheckBoxStyle}"/>

    <!-- GroupBox inherits FluentGroupBoxStyle (card container, header region) -->
    <Style TargetType="GroupBox" BasedOn="{StaticResource FluentGroupBoxStyle}"/>

    <!-- ToolTip - Win11 rounded frosted card globally -->
    <Style TargetType="ToolTip" BasedOn="{StaticResource FluentToolTipStyle}"/>

    <!-- ContextMenu - Win11 rounded flyout globally -->
    <Style TargetType="ContextMenu" BasedOn="{StaticResource FluentContextMenuStyle}"/>

    <Style TargetType="DatePicker" BasedOn="{StaticResource {x:Type DatePicker}}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="Padding" Value="10,8"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         NAMED STYLES

         Each named button/card style inherits its Fluent base
         template, then adds app-specific sizing overrides.
         All existing Style="{StaticResource XxxStyle}" references
         across 12+ views continue to work unchanged.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Page title (24 px bold — main content pages) ───────────── -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontDisplay}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizePageTitle}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Margin" Value="{StaticResource TitleSpacing}"/>
    </Style>

    <!-- ── Dialog / sub-window title (20 px bold) ─────────────────── -->
    <Style x:Key="DialogTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontDisplay}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeDialogTitle}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Margin" Value="{StaticResource TitleSpacing}"/>
    </Style>

    <!-- ── Section header (14 px semi-bold, inside forms/cards) ───── -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ── Field label (12 px semi-bold, sits above its control) ──── -->
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Margin" Value="{StaticResource FieldLabelSpacing}"/>
    </Style>

    <!-- Inline form-row label (right-aligned, vertically centered) -->
    <Style x:Key="FormRowLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Margin" Value="{StaticResource FormColumnGap}"/>
    </Style>

    <!-- ── Muted / caption label (12 px, secondary foreground) ────── -->
    <Style x:Key="CaptionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <!-- ── Toolbar / compact action button (inherits FluentSubtle) ── -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button"
           BasedOn="{StaticResource FluentSubtleButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeight}"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <!-- ── Primary action button (inherits FluentAccent) ──────────── -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button"
           BasedOn="{StaticResource FluentAccentButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeightLarge}"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPaddingLarge}"/>
    </Style>

    <!-- Secondary action button (inherits FluentStandard) -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button"
           BasedOn="{StaticResource FluentStandardButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeightLarge}"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPaddingLarge}"/>
    </Style>

    <!-- ── Inline form card border (inherits FluentCard + shadow) ─── -->
    <Style x:Key="FormCardStyle" TargetType="Border"
           BasedOn="{StaticResource FluentCardStyle}">
        <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
        <Setter Property="Margin" Value="{StaticResource FieldGroupSpacing}"/>
    </Style>

    <!-- Section panel card (list panels, detail panels) -->
    <Style x:Key="SectionCardStyle" TargetType="Border"
           BasedOn="{StaticResource FluentCardStyle}">
        <Setter Property="Padding" Value="0"/>
    </Style>

    <!-- Section card header bar (colored banner at top of card) -->
    <Style x:Key="SectionCardHeaderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerMediumTop}"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <!-- Detail panel (bottom split pane, sale detail, etc.) -->
    <Style x:Key="DetailPanelStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="BorderThickness" Value="0,1,0,0"/>
        <Setter Property="Padding" Value="12,8"/>
    </Style>

    <!-- Processing / loading overlay card -->
    <Style x:Key="OverlayCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#D0FFFFFF"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
    </Style>

    <!-- Settings sidebar navigation panel -->
    <Style x:Key="SidebarNavStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="BorderThickness" Value="0,0,1,0"/>
    </Style>

    <!-- KPI stat card (dashboard summary tiles) -->
    <Style x:Key="StatCardStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
        <Setter Property="Padding" Value="16,12"/>
        <Setter Property="Effect" Value="{StaticResource FluentShadowSmall}"/>
    </Style>

    <!-- ── Error message bar ──────────────────────────────────────── -->
    <Style x:Key="ErrorMessageStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- ── Success message bar ────────────────────────────────────── -->
    <Style x:Key="SuccessMessageStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Hint / info text (below fields, footnotes) -->
    <Style x:Key="HintTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="Margin" Value="{StaticResource HintTextTopSpacing}"/>
    </Style>

    <!-- Warning caption text -->
    <Style x:Key="WarningTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
    </Style>

    <!-- Card item title (workspace quick-start cards) -->
    <Style x:Key="CardItemTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="{StaticResource CardTitleSpacing}"/>
    </Style>

    <!-- Card item subtitle (workspace quick-start cards) -->
    <Style x:Key="CardItemSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="{StaticResource CardSubtitleSpacing}"/>
    </Style>

    <!-- Footer / version text -->
    <Style x:Key="FooterTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextDisabled}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <!-- Hero / welcome title -->
    <Style x:Key="HeroTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontDisplay}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSectionHeader}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
    </Style>

    <!-- Hero subtitle -->
    <Style x:Key="HeroSubtitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Margin" Value="{StaticResource SubtitleGap}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         DATAGRID VIRTUALISATION &amp; SCROLL PERFORMANCE

         Implicit style:  baseline for every DataGrid in the app.
         EnterpriseDataGridStyle:  full optimisation for grids that
             display large / growing datasets (Products, Sales history,
             future Billing grid).

         Key settings:
           ┌─ Row virtualisation ───── VirtualizingPanel.IsVirtualizing
           │  Rows outside the viewport are never materialised.
           ├─ Container recycling ──── VirtualizingPanel.VirtualizationMode
           │  Reuses row containers instead of GC-ing and re-creating.
           ├─ Column virtualisation ── EnableColumnVirtualization
           │  Only measures / renders visible columns.
           │  NOTE: Star-width (*) columns disable column virtualisation;
           │  enterprise grids use fixed pixel widths instead.
           ├─ Pixel scrolling ──────── VirtualizingPanel.ScrollUnit
           │  Smooth, sub-row scroll offset (default is item-based).
           ├─ Deferred scrolling ───── ScrollViewer.IsDeferredScrollingEnabled
           │  Delays re-query while the thumb is dragged.
           └─ Fixed row height ─────── RowHeight
               Avoids per-row measure pass; critical for 10k+ rows.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Baseline: every DataGrid gets virtualisation + Fluent colors -->
    <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="GridLinesVisibility" Value="Horizontal"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource FluentBackgroundSecondary}"/>
        <Setter Property="CanUserAddRows" Value="False"/>
    </Style>

    <!-- Full enterprise optimisation for primary data grids -->
    <Style x:Key="EnterpriseDataGridStyle" TargetType="DataGrid"
           BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        <Setter Property="VirtualizingPanel.CacheLength" Value="2,2"/>
        <Setter Property="VirtualizingPanel.CacheLengthUnit" Value="Page"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"/>
        <Setter Property="RowHeight" Value="32"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
    </Style>

    <!-- DataGrid column header: Win11 flat, borderless, hover highlight -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Grid>
                        <Border x:Name="HeaderBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{StaticResource FluentSurfaceStroke}"
                                BorderThickness="0,0,0,1"
                                Padding="10,8"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <Thumb x:Name="PART_RightHeaderGripper"
                               HorizontalAlignment="Right" Width="4"
                               Cursor="SizeWE" Margin="0,0,-2,0">
                            <Thumb.Style>
                                <Style TargetType="Thumb">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="Transparent" Width="4"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Thumb.Style>
                        </Thumb>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBd" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid row: Win11 subtle hover + accent-left selection indicator -->
    <Style TargetType="DataGridRow">
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridRow">
                    <Grid x:Name="RowRoot" SnapsToDevicePixels="True">
                        <Border x:Name="RowBg"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"/>
                        <!-- Win11 accent indicator (left edge, appears on selection) -->
                        <Border x:Name="SelectionIndicator"
                                Width="3" HorizontalAlignment="Left"
                                CornerRadius="1.5"
                                Margin="1,4,0,4"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0"/>
                        <SelectiveScrollingGrid>
                            <SelectiveScrollingGrid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </SelectiveScrollingGrid.ColumnDefinitions>
                            <SelectiveScrollingGrid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </SelectiveScrollingGrid.RowDefinitions>
                            <DataGridCellsPresenter Grid.Column="1" Grid.Row="0"
                                ItemsPanel="{TemplateBinding ItemsPanel}"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            <DataGridDetailsPresenter Grid.Column="1" Grid.Row="1"
                                SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                Visibility="{TemplateBinding DetailsVisibility}"/>
                        </SelectiveScrollingGrid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RowBg" Property="Background"
                                    Value="{StaticResource FluentSubtleHover}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RowBg" Property="Background"
                                    Value="{StaticResource FluentSubtlePressed}"/>
                            <Setter TargetName="SelectionIndicator" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid cell: Win11 clean padding, no focus rectangle -->
    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="10,6"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}"
                            SnapsToDevicePixels="True">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         BASE WINDOW + KEYBOARD &amp; FOCUS BEHAVIOR

         Inherits FluentWindowStyle from FluentTheme.xaml which sets:
           Background, Foreground, FontFamily, FontSize, BorderThickness,
           SnapsToDevicePixels, UseLayoutRounding, TextFormattingMode,
           TextRenderingMode.

         This implicit style layers on app-specific behaviors:
           Enter       = DefaultCommand or next input
           Shift+Enter = move backward
           Escape      = EscapeCommand, clear focus, or IsCancel
           Tab         = standard WPF order
           AutoFocus   = first input receives focus on load

         Applied automatically to every Window (MainWindow, login,
         setup, and all BaseDialogWindow subclasses).
         To opt-out: h:KeyboardNav.IsEnabled="False"
                     h:PredictiveFocusBehavior.IsEnabled="False"
         ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="Window" BasedOn="{StaticResource FluentWindowStyle}">
        <Setter Property="h:KeyboardNav.IsEnabled" Value="True"/>
        <Setter Property="h:PredictiveFocusBehavior.IsEnabled" Value="True"/>
        <Setter Property="h:LayoutDiagnostics.IsEnabled" Value="True"/>
        <Setter Property="h:StyleComplianceDiagnostics.IsEnabled" Value="True"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         PAGE VIEW FADE-IN

         Every UserControl (page view) automatically fades in on
         Loaded via the Motion.PageFadeIn attached behavior.
         Duration: FluentDurationPageFade (150 ms), no movement,
         zero layout cost (Opacity is GPU-composited).

         To opt-out on a specific view: h:Motion.PageFadeIn="False"
         ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="UserControl">
        <Setter Property="h:Motion.PageFadeIn" Value="True"/>
    </Style>


    <!-- ═══════════════════════════════════════════════════════════════
         SMART TOOLTIP  (Fluent 2 styled)

         Modern tooltip with:
           • Soft 6 px rounded corners (TooltipCornerRadius token)
           • Light frosted background (TooltipBackground token)
           • 1 px outer stroke + 1 px inner highlight inset for the
             Fluent 2 "smoke glass" layered look
           • Purpose-built lightweight shadow (TooltipShadow — 12 px
             blur, 0.10 opacity — softer than FluentShadowMedium)
           • Compact 10/7/10/8 padding that stays dense on short text
             but breathes on multi-line help
           • Segoe UI Variable at FontSizeLabel (12 px) for body text
           • Animated entrance: 167 ms fade + 4 px slide-up (Decelerate)
           • Animated exit:     120 ms fade-out (Accelerate)
           • Max width 320 px to keep text scannable

         Content is built programmatically by SmartTooltip.cs /
         HelpHint.cs — header (SemiBold, FluentTextPrimary, Body size)
         sits above description (Regular, FluentTextSecondary, Label
         size) inside a StackPanel.

         Usage:
           Automatic — SmartTooltip.cs resolves "SmartTooltipStyle"
           from the element's resource tree at show time.
         ═══════════════════════════════════════════════════════════════ -->
    <Style x:Key="SmartTooltipStyle" TargetType="ToolTip">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background"      Value="{StaticResource TooltipBackground}"/>
        <Setter Property="Foreground"       Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource TooltipBorder}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="{StaticResource TooltipPadding}"/>
        <Setter Property="FontFamily"       Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"         Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="MaxWidth"         Value="{StaticResource TooltipMaxWidth}"/>
        <Setter Property="HasDropShadow"    Value="False"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <!-- Outer chrome: border + shadow -->
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource TooltipCornerRadius}"
                            Effect="{StaticResource TooltipShadow}"
                            SnapsToDevicePixels="True"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0">
                        <Border.RenderTransform>
                            <TranslateTransform Y="4"/>
                        </Border.RenderTransform>

                        <!-- Inner highlight — 1 px white inset (Fluent smoke) -->
                        <Border CornerRadius="{StaticResource TooltipCornerRadius}"
                                BorderBrush="{StaticResource TooltipInnerHighlight}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Entrance: fade-in + slide-up -->
                        <EventTrigger RoutedEvent="Opened">
                            <BeginStoryboard x:Name="OpenStoryboard">
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1"
                                        Duration="{StaticResource FluentDurationNormal}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="RenderTransform.Y"
                                        From="4" To="0"
                                        Duration="{StaticResource FluentDurationNormal}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Exit: quick fade-out -->
                        <EventTrigger RoutedEvent="Closed">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0" Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseIn"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ═════════════════════════════════════════════════════════════════
         INLINE TIP BANNER

         Soft, non-distracting inline guidance banner that blends
         with the page surface.  Follows the Fluent 2 TeachingTip
         visual language:

           • Near-white background (TipBannerBackground) with a
             subtle cool undertone — reads as "neutral surface"
             rather than "alert".
           • Neutral-cool 1 px border (TipBannerBorder) matching
             the card/panel stroke family.
           • 3 px left accent bar (TipBannerAccent) in muted sky
             blue — provides the info semantic signal without
             competing with content.
           • Icon uses accent foreground — the single color pop.
           • Title at FontSizeLabel (12 px) SemiBold in near-black
             (TipBannerTitleForeground); body at FontSizeBody
             (13 px) in medium-grey (TipBannerBodyForeground).
           • 8 px rounded corners (FluentCornerMedium).
           • Compact 36 px min-height, 12,8 inner padding.
           • Slide-fade entrance, fade-out dismiss.
           • Subtle hover tint (TipBannerBackgroundHover) for
             "alive" feel without competing with content.

         Visual weight: below FormCardStyle, above plain text.
         The banner should feel like a helpful whisper, not a shout.

         Usage:
           <controls:InlineTipBanner
               Title="Quick tip"
               TipText="Use Ctrl+N to start a new sale."
               IsDismissed="{Binding IsTipDismissed, Mode=TwoWay}"/>
         ═════════════════════════════════════════════════════════════════ -->
    <Style TargetType="controls:InlineTipBanner">
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="MinHeight" Value="36"/>
        <Setter Property="Margin" Value="{StaticResource FieldGroupSpacing}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:InlineTipBanner">
                    <Border x:Name="PART_Root"
                            Background="{StaticResource TipBannerBackground}"
                            BorderBrush="{StaticResource TipBannerBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="0"
                            SnapsToDevicePixels="True"
                            h:Motion.SlideFadeIn="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <!-- Left accent bar -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Icon -->
                                <ColumnDefinition Width="Auto"/>
                                <!-- Text -->
                                <ColumnDefinition Width="*"/>
                                <!-- Close -->
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Left accent indicator (3 px bar, muted) -->
                            <Border Grid.Column="0"
                                    Width="3" Margin="0,6"
                                    CornerRadius="1.5"
                                    Background="{StaticResource TipBannerAccent}"/>

                            <!-- Bulb icon (accent-colored) -->
                            <TextBlock Grid.Column="1" Text="💡"
                                       FontSize="14"
                                       Foreground="{StaticResource TipBannerIconForeground}"
                                       VerticalAlignment="Center"
                                       Margin="10,0,6,0"/>

                            <!-- Title + tip text -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                        Margin="0,7,0,7">
                                <TextBlock FontFamily="{StaticResource FluentFontFamily}"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TipBannerTitleForeground}"
                                           Text="{TemplateBinding Title}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontFamily="{StaticResource FluentFontFamily}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{StaticResource TipBannerBodyForeground}"
                                           Text="{TemplateBinding TipText}"
                                           TextWrapping="Wrap"
                                           LineHeight="18"
                                           Margin="0,2,0,0"/>
                            </StackPanel>

                            <!-- Close button -->
                            <Button x:Name="PART_CloseButton"
                                    Grid.Column="3"
                                    Content="✕"
                                    FontSize="10"
                                    Padding="5,3"
                                    Margin="6,0,8,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource FluentTextDisabled}"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    Focusable="False"
                                    Opacity="0"
                                    IsHitTestVisible="True">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CloseBd"
                                                Background="Transparent"
                                                CornerRadius="{StaticResource FluentCornerSmall}"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CloseBd" Property="Background"
                                                        Value="{StaticResource FluentSubtleHover}"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource FluentTextSecondary}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="CloseBd" Property="Background"
                                                        Value="{StaticResource FluentSubtlePressed}"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource FluentTextPrimary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Banner-level hover: tint background + reveal close button -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Root" Property="Background"
                                    Value="{StaticResource TipBannerBackgroundHover}"/>
                            <Setter TargetName="PART_CloseButton" Property="Opacity"
                                    Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsDismissed" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
            </Trigger>
        </Style.Triggers>
    </Style>


    <!-- EmptyStateOverlay default style -->
    <Style TargetType="controls:EmptyStateOverlay">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="IsHitTestVisible" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EmptyStateOverlay">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="{StaticResource EmptyStatePadding}">
                        <TextBlock Text="{TemplateBinding Icon}"
                                   FontSize="36" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{TemplateBinding Title}"
                                   FontSize="{StaticResource FontSizeSectionHeader}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{TemplateBinding Description}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   MaxWidth="400" Margin="0,4,0,12"/>
                        <Button Content="{TemplateBinding ActionText}"
                                Command="{TemplateBinding ActionCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- AppBranding -->
    <Style TargetType="controls:AppBranding">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:AppBranding">
                    <StackPanel HorizontalAlignment="Center">
                        <Image x:Name="PART_Logo" Source="/Assets/logo-256.png"
                               Width="{TemplateBinding LogoSize}" Height="{TemplateBinding LogoSize}"
                               HorizontalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"
                               Margin="{StaticResource FieldLabelSpacing}"/>
                        <TextBlock x:Name="PART_Title" HorizontalAlignment="Center" Margin="0"
                                   Style="{StaticResource DialogTitleStyle}">
                            <Run Text="Store Assistant "/><Run Text="Pro" Foreground="{StaticResource FluentAccentDefault}"/>
                        </TextBlock>
                        <TextBlock x:Name="PART_Subtitle" Text="{TemplateBinding Subtitle}"
                                   HorizontalAlignment="Center"
                                   FontSize="{StaticResource FontSizeLabel}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   Margin="{StaticResource FieldLabelSpacing}"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="ShowTitle" Value="False">
                            <Setter TargetName="PART_Title" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger SourceName="PART_Subtitle" Property="Text" Value="">
                            <Setter TargetName="PART_Subtitle" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
