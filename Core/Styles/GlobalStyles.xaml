    <!-- Baseline: every DataGrid gets virtualisation + Fluent colors -->
    <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="RowHeight" Value="{DynamicResource AppDataGridRowHeight}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource FluentSurfaceStroke}"/>
        <Setter Property="VerticalGridLinesBrush" Value="Transparent"/>
        <Setter Property="h:DataGridRightClickSelection.IsEnabled" Value="True"/>
        <Setter Property="h:DataGridEmptyState.IsEnabled" Value="True"/>
        <Setter Property="h:DataGridSortTransition.IsEnabled" Value="True"/>
        <Setter Property="h:DataGridStarColumnSizing.IsEnabled" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        <Setter Property="VirtualizingPanel.CacheLength" Value="1,1"/>
        <Setter Property="VirtualizingPanel.CacheLengthUnit" Value="Page"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="GridLinesVisibility" Value="None"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="RowHeaderWidth" Value="0"/>
        <Setter Property="AlternatingRowBackground" Value="{StaticResource FluentBackgroundSecondary}"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserReorderColumns" Value="True"/>
    </Style>

    <!-- Full enterprise optimisation for primary data grids -->
    <Style x:Key="EnterpriseDataGridStyle" TargetType="DataGrid"
           BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.IsVirtualizingWhenGrouping" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        <Setter Property="VirtualizingPanel.CacheLength" Value="2,2"/>
        <Setter Property="VirtualizingPanel.CacheLengthUnit" Value="Page"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"/>
        <Setter Property="h:DataGridStarColumnSizing.IsEnabled" Value="True"/>
        <Setter Property="AlternationCount" Value="2"/>
        <Setter Property="RowHeight" Value="{DynamicResource AppDataGridRowHeight}"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserReorderColumns" Value="True"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
    </Style>

    <Style x:Key="AnalyticalReportDataGridColumnHeaderStyle" TargetType="DataGridColumnHeader"
           BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <Style x:Key="AnalyticalReportDataGridStyle" TargetType="DataGrid"
           BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="ColumnHeaderStyle" Value="{StaticResource AnalyticalReportDataGridColumnHeaderStyle}"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
        <Setter Property="AlternationCount" Value="2"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="CanUserDeleteRows" Value="False"/>
        <Setter Property="CanUserResizeRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
    </Style>

    <!-- DataGrid column header: Win11 flat, borderless, hover highlight, sort indicators -->
    <Style TargetType="DataGridColumnHeader">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="{DynamicResource AppDataGridHeaderPadding}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridColumnHeader">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="HeaderBd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Grid UseLayoutRounding="True"
                                  SnapsToDevicePixels="True">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ContentPresenter Grid.Column="0"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"/>
                                <!-- Sort direction indicator -->
                                <Path x:Name="SortArrow" Grid.Column="1"
                                      Visibility="Collapsed"
                                      Stretch="Uniform" Width="8" Height="6"
                                      Margin="8,0,0,0"
                                      Fill="{StaticResource FluentAccentDefault}"
                                      VerticalAlignment="Center"
                                      RenderTransformOrigin="0.5,0.5"
                                      Data="M 0,0 L 4,4 L 8,0 Z"/>
                            </Grid>
                        </Border>
                        <Border x:Name="StickyHeaderShadow"
                                Height="4"
                                Margin="0,0,0,-4"
                                VerticalAlignment="Bottom"
                                Background="{StaticResource StickyHeaderShadowBrush}"
                                Opacity="0"
                                IsHitTestVisible="False"/>
                        <Thumb x:Name="PART_RightHeaderGripper"
                               HorizontalAlignment="Right" Width="6"
                               Background="Transparent"
                               Opacity="0"
                               Cursor="SizeWE" Margin="0,0,-2,0">
                            <Thumb.Style>
                                <Style TargetType="Thumb">
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{TemplateBinding Background}"
                                                        Width="2"
                                                        HorizontalAlignment="Center"
                                                        CornerRadius="1"/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Thumb.Style>
                        </Thumb>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <DataTrigger Binding="{Binding VerticalOffset,
                                                       RelativeSource={RelativeSource AncestorType=ScrollViewer},
                                                       Converter={StaticResource DoubleGreaterThanConverter},
                                                       ConverterParameter=0}"
                                     Value="True">
                            <Setter TargetName="StickyHeaderShadow" Property="Opacity" Value="1"/>
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="HeaderBd" Property="Background"
                                    Value="{StaticResource SubtleFillColorSecondary}"/>
                            <Setter TargetName="PART_RightHeaderGripper" Property="Background"
                                    Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="PART_RightHeaderGripper" Property="Opacity"
                                    Value="1"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextPrimary}"/>
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Ascending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="SortArrow" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleY="-1"/>
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="SortDirection" Value="Descending">
                            <Setter TargetName="SortArrow" Property="Visibility" Value="Visible"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DataGridRowSelectionCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="Width" Value="18"/>
        <Setter Property="Height" Value="18"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Focusable" Value="False"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid Width="{TemplateBinding Width}"
                          Height="{TemplateBinding Height}">
                        <Border x:Name="SelectorChrome"
                                Background="{StaticResource LayerFillColorDefault}"
                                BorderBrush="{StaticResource DividerStrokeColorDefault}"
                                BorderThickness="1"
                                CornerRadius="9"/>
                        <Path x:Name="SelectorCheck"
                              Width="8"
                              Height="6"
                              Stroke="{StaticResource FluentTextOnAccent}"
                              StrokeThickness="1.8"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"
                              Data="M 0,3 L 2.75,6 L 8,0"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Opacity="0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="SelectorChrome" Property="BorderBrush" Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="SelectorChrome" Property="Background" Value="{StaticResource FluentAccentLight3}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="SelectorChrome" Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="SelectorChrome" Property="BorderBrush" Value="{StaticResource FluentAccentDefault}"/>
                            <Setter TargetName="SelectorCheck" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="SelectorChrome" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DataGridInlineEditTextBoxStyle" TargetType="TextBox"
           BasedOn="{StaticResource FluentTextBoxStyle}">
        <Setter Property="Padding" Value="0"/>
        <Setter Property="MinHeight" Value="24"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="h:SelectOnFocus.IsEnabled" Value="True"/>
    </Style>

    <Style x:Key="DataGridGroupCountBadgeStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentAccentLight3}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentAccentLight2}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerMedium}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="8,0,0,0"/>
    </Style>

    <Style x:Key="DataGridGroupItemStyle" TargetType="GroupItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="GroupItem">
                    <Expander IsExpanded="True"
                              Margin="0,0,0,8">
                        <Expander.Header>
                            <Border Background="{StaticResource LayerFillColorDefault}"
                                    BorderBrush="{StaticResource DividerStrokeColorDefault}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource FluentCornerMedium}"
                                    Padding="12,8">
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="{Binding Name, TargetNullValue=Ungrouped}"
                                               VerticalAlignment="Center"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource FluentTextSecondary}"/>
                                    <Border DockPanel.Dock="Right"
                                            Style="{StaticResource DataGridGroupCountBadgeStyle}">
                                        <TextBlock Text="{Binding ItemCount}"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FontSizeStatusBar}"
                                                   FontWeight="Normal"
                                                   Foreground="{StaticResource FluentAccentDark2}"/>
                                    </Border>
                                </DockPanel>
                            </Border>
                        </Expander.Header>
                        <Border Margin="0,4,0,0"
                                Background="{StaticResource LayerFillColorSecondary}"
                                CornerRadius="{StaticResource FluentCornerMedium}">
                            <ItemsPresenter/>
                        </Border>
                    </Expander>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid row: Win11 subtle hover + accent-left selection indicator -->
    <Style TargetType="DataGridRow">
        <Setter Property="Background" Value="White"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="h:PressStateTracker.IsEnabled" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridRow">
                    <Grid x:Name="RowRoot"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="RowBg"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Margin="4,0"/>
                        <!-- Win11 accent indicator (left edge, appears on selection) -->
                        <Border x:Name="SelectionIndicator"
                                Width="4" HorizontalAlignment="Left"
                                CornerRadius="2"
                                Margin="4,8,0,8"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0"/>
                        <SelectiveScrollingGrid UseLayoutRounding="True"
                                                SnapsToDevicePixels="True">
                            <SelectiveScrollingGrid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </SelectiveScrollingGrid.ColumnDefinitions>
                            <SelectiveScrollingGrid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </SelectiveScrollingGrid.RowDefinitions>
                            <Grid x:Name="RowGrip"
                                  Grid.Column="0"
                                  Grid.Row="0"
                                  Width="16"
                                  Margin="8,0,4,0"
                                  VerticalAlignment="Center"
                                  HorizontalAlignment="Center"
                                  Opacity="0"
                                  IsHitTestVisible="False">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Ellipse Width="3" Height="3" Fill="{StaticResource FluentTextTertiary}" Margin="0,0,4,4"/>
                                <Ellipse Grid.Column="1" Width="3" Height="3" Fill="{StaticResource FluentTextTertiary}" Margin="0,0,0,4"/>
                                <Ellipse Grid.Row="1" Width="3" Height="3" Fill="{StaticResource FluentTextTertiary}" Margin="0,0,4,4"/>
                                <Ellipse Grid.Column="1" Grid.Row="1" Width="3" Height="3" Fill="{StaticResource FluentTextTertiary}" Margin="0,0,0,4"/>
                                <Ellipse Grid.Row="2" Width="3" Height="3" Fill="{StaticResource FluentTextTertiary}"/>
                                <Ellipse Grid.Column="1" Grid.Row="2" Width="3" Height="3" Fill="{StaticResource FluentTextTertiary}"/>
                            </Grid>
                            <CheckBox x:Name="RowSelector"
                                      Grid.Column="0"
                                      Grid.Row="0"
                                      Width="18"
                                      Height="18"
                                      Margin="8,0,4,0"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"
                                      Opacity="0"
                                      Visibility="Collapsed"
                                      Style="{StaticResource DataGridRowSelectionCheckBoxStyle}"
                                      IsChecked="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsSelected, Mode=TwoWay}"/>
                            <DataGridCellsPresenter Grid.Column="1" Grid.Row="0"
                                ItemsPanel="{TemplateBinding ItemsPanel}"
                                SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"/>
                            <DataGridDetailsPresenter Grid.Column="1" Grid.Row="1"
                                SelectiveScrollingGrid.SelectiveScrollingOrientation="{Binding AreRowDetailsFrozen, ConverterParameter={x:Static SelectiveScrollingOrientation.Vertical}, Converter={x:Static DataGrid.RowDetailsScrollingConverter}, RelativeSource={RelativeSource AncestorType={x:Type DataGrid}}}"
                                Visibility="{TemplateBinding DetailsVisibility}"/>
                        </SelectiveScrollingGrid>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="AlternationIndex" Value="1">
                            <Setter TargetName="RowBg" Property="Background"
                                    Value="{StaticResource FluentSurfaceElevated}"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="RowBg" Property="Background"
                                    Value="{StaticResource SubtleFillColorSecondary}"/>
                            <Setter TargetName="RowGrip" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="h:PressStateTracker.IsPressed" Value="True">
                            <Setter TargetName="RowBg" Property="Background"
                                    Value="{StaticResource SubtleFillColorTertiary}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="RowBg" Property="Background"
                                    Value="{StaticResource SubtleFillColorTertiary}"/>
                            <Setter TargetName="RowGrip" Property="Opacity" Value="0.7"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SelectionIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="SelectionIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=(h:DataGridMultiSelect.IsEnabled)}"
                                     Value="True">
                            <Setter TargetName="RowGrip" Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=(h:DataGridMultiSelect.IsEnabled)}"
                                           Value="True"/>
                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource TemplatedParent}}"
                                           Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="RowSelector" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="RowSelector" Property="Opacity" Value="1"/>
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                                <Condition Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGrid}, Path=(h:DataGridMultiSelect.IsEnabled)}"
                                           Value="True"/>
                                <Condition Binding="{Binding IsSelected, RelativeSource={RelativeSource TemplatedParent}}"
                                           Value="True"/>
                            </MultiDataTrigger.Conditions>
                            <Setter TargetName="RowSelector" Property="Visibility" Value="Visible"/>
                            <Setter TargetName="RowSelector" Property="Opacity" Value="1"/>
                        </MultiDataTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- DataGrid cell: Win11 clean padding, no focus rectangle -->
    <Style TargetType="DataGridCell">
        <Setter Property="Padding" Value="{DynamicResource AppDataGridCellPadding}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DataGridCell">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="FocusGlow"
                                Margin="-5"
                                Background="{StaticResource FluentAccentDefault}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Opacity="0"
                                IsHitTestVisible="False"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <BlurEffect Radius="10"
                                            RenderingBias="Performance"/>
                            </Border.Effect>
                        </Border>
                        <Border x:Name="CellRoot"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                        <Border x:Name="OuterFocusRing"
                                BorderBrush="{StaticResource FocusVisualOuterBrush}"
                                BorderThickness="{StaticResource FocusVisualThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Opacity="0"
                                IsHitTestVisible="False"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True"/>
                        <Border x:Name="InnerFocusRing"
                                Margin="2"
                                BorderBrush="{StaticResource FocusVisualInnerBrush}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Opacity="0"
                                IsHitTestVisible="False"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="CellRoot" Property="Background" Value="{StaticResource LayerFillColorSecondary}"/>
                            <Setter TargetName="CellRoot" Property="BorderBrush" Value="Transparent"/>
                            <Setter TargetName="CellRoot" Property="BorderThickness" Value="0"/>
                            <Setter TargetName="FocusGlow" Property="Opacity" Value="0.18"/>
                            <Setter TargetName="OuterFocusRing" Property="Opacity" Value="1"/>
                            <Setter TargetName="InnerFocusRing" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsSelected" Value="True">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
            </Trigger>
        </Style.Triggers>
    </Style>

