        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- Hint / info text (below fields, footnotes) -->
    <Style x:Key="HintTextStyle" TargetType="TextBlock">
        <Setter Property="Visibility" Value="Collapsed"/>
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="Margin" Value="{StaticResource HintTextTopSpacing}"/>
    </Style>

    <Style x:Key="DirtyStateHintTextStyle" TargetType="TextBlock"
           BasedOn="{StaticResource HintTextStyle}">
        <Setter Property="Visibility" Value="Visible"/>
        <Setter Property="Margin" Value="0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding DataContext.IsDirty, RelativeSource={RelativeSource Self}}"
                         Value="True">
                <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Auto-collapsing hint text (collapses when empty or null) -->
    <Style x:Key="CollapsibleHintTextStyle" TargetType="TextBlock">
        <Setter Property="Visibility" Value="Collapsed"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
            <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                <Setter Property="Visibility" Value="Collapsed"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

    <!-- Warning caption text -->
    <Style x:Key="WarningTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
    </Style>

    <!-- Card item title (workspace quick-start cards) -->
    <Style x:Key="CardItemTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
