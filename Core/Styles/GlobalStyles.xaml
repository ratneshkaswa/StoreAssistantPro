                            </Grid.ColumnDefinitions>

                            <!-- Left accent indicator (3 px bar, muted) -->
                            <Border Grid.Column="0"
                                    Width="4" Margin="0,8"
                                    CornerRadius="1.5"
                                    Background="{StaticResource TipBannerAccent}"/>

                            <!-- Bulb icon (accent-colored) -->
                            <TextBlock Grid.Column="1" Text="&#xEA80;"
                                       FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeBody}"
                                       Foreground="{StaticResource TipBannerIconForeground}"
                                       VerticalAlignment="Center"
                                       Margin="12,0,8,0"/>

                            <!-- Title + tip text -->
                            <StackPanel Grid.Column="2" VerticalAlignment="Center"
                                        Margin="0,8,0,8">
                                <TextBlock FontFamily="{StaticResource FluentFontFamily}"
                                           FontSize="{StaticResource FontSizeLabel}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TipBannerTitleForeground}"
                                           Text="{TemplateBinding Title}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontFamily="{StaticResource FluentFontFamily}"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{StaticResource TipBannerBodyForeground}"
                                           Text="{TemplateBinding TipText}"
                                           TextWrapping="Wrap"
                                           LineHeight="18"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <!-- Close button -->
                            <Button x:Name="PART_CloseButton"
                                    Grid.Column="3"
                                    Content="&#xE10A;"
                                    FontFamily="{StaticResource FluentIconFont}"
                                    FontSize="{StaticResource FontSizeStatusBar}"
                                    Padding="4"
                                    Margin="8,0"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{StaticResource FluentTextDisabled}"
                                    Cursor="Hand"
                                    VerticalAlignment="Center"
                                    Focusable="False"
                                    ToolTip="Dismiss tip"
                                    AutomationProperties.Name="Dismiss tip"
                                    Opacity="0"
                                    IsHitTestVisible="True">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="CloseBd"
                                                Background="Transparent"
                                                CornerRadius="{StaticResource FluentCornerSmall}"
                                                Padding="{TemplateBinding Padding}"
                                                SnapsToDevicePixels="True">
                                            <ContentPresenter HorizontalAlignment="Center"
                                                              VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="CloseBd" Property="Background"
                                                        Value="{StaticResource FluentSubtleHover}"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource FluentTextSecondary}"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter TargetName="CloseBd" Property="Background"
                                                        Value="{StaticResource FluentSubtlePressed}"/>
                                                <Setter Property="Foreground"
                                                        Value="{StaticResource FluentTextPrimary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Banner-level hover: tint background + reveal close button -->
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="PART_Root" Property="Background"
                                    Value="{StaticResource TipBannerBackgroundHover}"/>
                            <Setter TargetName="PART_CloseButton" Property="Opacity"
                                    Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="IsDismissed" Value="True">
                <Setter Property="Visibility" Value="Collapsed"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="ExpandableTextToggleButtonStyle"
           TargetType="Button"
           BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="MinHeight" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,8,0,0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HorizontalAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="Transparent"
                            SnapsToDevicePixels="True"
                            UseLayoutRounding="True">
                        <TextBlock x:Name="ToggleText"
                                   Text="{TemplateBinding Content}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="SemiBold"
                                   Foreground="{TemplateBinding Foreground}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="ToggleText" Property="TextDecorations" Value="Underline"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="ToggleText" Property="Opacity" Value="0.8"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="ToggleText" Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:ExpandableTextBlock">
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ExpandableTextBlock">
                    <StackPanel UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                        <Border x:Name="PART_ContentHost"
                                ClipToBounds="True"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <TextBlock x:Name="PART_TextBlock"
                                       Margin="{TemplateBinding Padding}"
                                       Text="{TemplateBinding Text}"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontFamily="{TemplateBinding FontFamily}"
                                       FontSize="{TemplateBinding FontSize}"
                                       FontStyle="{TemplateBinding FontStyle}"
                                       FontWeight="{TemplateBinding FontWeight}"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"/>
                        </Border>
                        <Button x:Name="PART_ToggleButton"
                                Style="{StaticResource ExpandableTextToggleButtonStyle}"
                                Content="{TemplateBinding ShowMoreText}"
                                ToolTip="Expand full text"
                                AutomationProperties.Name="Show more"
                                Visibility="Collapsed"/>
                    </StackPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- EmptyStateOverlay default style -->
    <Style TargetType="controls:EmptyStateOverlay">
        <Setter Property="HorizontalAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="IsHitTestVisible" Value="True"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:EmptyStateOverlay">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True"
                                Margin="{StaticResource EmptyStatePadding}">
                        <TextBlock x:Name="IconText"
                                   Text="{TemplateBinding Icon}"
                                   FontSize="{StaticResource FontSizeIconLarge}" HorizontalAlignment="Center"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{TemplateBinding Title}"
                                   FontSize="{StaticResource FontSizeSectionHeader}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock x:Name="DescriptionText"
                                   Text="{TemplateBinding Description}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   HorizontalAlignment="Center" TextWrapping="Wrap"
                                   MaxWidth="400" Margin="0,4,0,12"/>
                        <Button x:Name="ActionButton"
                                Content="{TemplateBinding ActionText}"
                                Command="{TemplateBinding ActionCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"
                                HorizontalAlignment="Center"/>
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Icon" Value="">
                            <Setter TargetName="IconText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Description" Value="">
                            <Setter TargetName="DescriptionText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="DescriptionText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ActionText" Value="">
                            <Setter TargetName="ActionButton" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ActionText" Value="{x:Null}">
                            <Setter TargetName="ActionButton" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ActionCommand" Value="{x:Null}">
                            <Setter TargetName="ActionButton" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:ErrorStateOverlay">
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="VerticalAlignment" Value="Stretch"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:ErrorStateOverlay">
                    <Grid x:Name="Root"
                          Visibility="Collapsed"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border Background="{StaticResource LoadingOverlayScrim}"
                                Opacity="0.92"/>

                        <Border HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="480"
                                Margin="24"
                                Padding="32"
                                Background="{StaticResource FluentSurfaceElevated}"
                                BorderBrush="{StaticResource FluentErrorBackground}"
                                BorderThickness="1"
                                CornerRadius="{StaticResource FluentCornerLarge}"
                                Effect="{StaticResource ElevationEffectFlyout}">
                            <StackPanel HorizontalAlignment="Center"
                                        UseLayoutRounding="True"
                                        SnapsToDevicePixels="True">
                                <TextBlock x:Name="IconText"
                                           Text="{TemplateBinding Icon}"
                                           FontSize="{StaticResource FontSizeDisplay}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentError}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="{TemplateBinding Title}"
                                           Margin="0,12,0,0"
                                           FontSize="{StaticResource FontSizeTitle}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentTextPrimary}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"/>
                                <TextBlock x:Name="DescriptionText"
                                           Text="{TemplateBinding Description}"
                                           Margin="0,8,0,0"
                                           MaxWidth="380"
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"
                                           HorizontalAlignment="Center"/>
                                <Button x:Name="ActionButton"
                                        Margin="0,20,0,0"
                                        Padding="16,0"
                                        Content="{TemplateBinding ActionText}"
                                        Command="{TemplateBinding ActionCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        HorizontalAlignment="Center"
                                        AutomationProperties.Name="Retry load"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsOpen" Value="True">
                            <Setter TargetName="Root" Property="Visibility" Value="Visible"/>
                        </Trigger>
                        <Trigger Property="Icon" Value="">
                            <Setter TargetName="IconText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Icon" Value="{x:Null}">
                            <Setter TargetName="IconText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Description" Value="">
                            <Setter TargetName="DescriptionText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Description" Value="{x:Null}">
                            <Setter TargetName="DescriptionText" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ActionText" Value="">
                            <Setter TargetName="ActionButton" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ActionText" Value="{x:Null}">
                            <Setter TargetName="ActionButton" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="ActionCommand" Value="{x:Null}">
                            <Setter TargetName="ActionButton" Property="Visibility" Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="controls:DateRangePicker">
        <Setter Property="Background" Value="{StaticResource FluentControlFillDefault}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="controls:DateRangePicker">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <ToggleButton x:Name="PART_ToggleButton"
                                      IsChecked="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsDropDownOpen, Mode=TwoWay}"
                                      Background="Transparent"
                                      BorderThickness="0"
                                      Cursor="Hand"
                                      Focusable="True"
                                      AutomationProperties.Name="Choose date range">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="SummaryBorder"
                                            Background="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:DateRangePicker}}, Path=Background}"
                                            BorderBrush="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:DateRangePicker}}, Path=BorderBrush}"
                                            BorderThickness="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:DateRangePicker}}, Path=BorderThickness}"
                                            CornerRadius="{StaticResource FluentCornerMedium}"
                                            UseLayoutRounding="True"
                                            SnapsToDevicePixels="True">
                                        <Grid Margin="12,8,12,8"
                                              UseLayoutRounding="True"
                                              SnapsToDevicePixels="True">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel Grid.Column="0"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:DateRangePicker}}, Path=StartHeader}"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{StaticResource FluentTextTertiary}"/>
                                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:DateRangePicker}}, Path=StartDate, StringFormat={}{0:dd MMM yyyy}}"
                                                           Margin="0,4,0,0"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:DateRangePicker}}, Path=Foreground}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1"
                                                        Margin="16,0"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Border Width="14"
                                                        Height="1"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource DividerStrokeColorDefault}"/>
                                                <TextBlock Margin="8,0"
                                                           VerticalAlignment="Center"
                                                           FontFamily="{StaticResource FluentIconFont}"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{StaticResource FluentAccentDefault}"
                                                           Text="&#xE72A;"/>
                                                <Border Width="14"
                                                        Height="1"
                                                        VerticalAlignment="Center"
                                                        Background="{StaticResource DividerStrokeColorDefault}"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:DateRangePicker}}, Path=EndHeader}"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{StaticResource FluentTextTertiary}"/>
                                                <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:DateRangePicker}}, Path=EndDate, StringFormat={}{0:dd MMM yyyy}}"
                                                           Margin="0,4,0,0"
                                                           FontWeight="SemiBold"
                                                           Foreground="{Binding RelativeSource={RelativeSource AncestorType={x:Type controls:DateRangePicker}}, Path=Foreground}"/>
                                            </StackPanel>

                                            <TextBlock x:Name="ChevronGlyph"
                                                       Grid.Column="3"
                                                       Margin="12,0,0,0"
                                                       VerticalAlignment="Center"
                                                       FontFamily="{StaticResource FluentIconFont}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{StaticResource FluentTextTertiary}"
                                                       Text="&#xE70D;"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="SummaryBorder" Property="BorderThickness" Value="1"/>
                                            <Setter TargetName="SummaryBorder" Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="SummaryBorder" Property="BorderThickness" Value="1"/>
                                            <Setter TargetName="SummaryBorder" Property="BorderBrush" Value="{StaticResource FluentStrokeFocus}"/>
                                            <Setter TargetName="ChevronGlyph" Property="Text" Value="&#xE70E;"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Border x:Name="FocusIndicator"
                                Height="2"
                                Margin="2,0,2,0"
                                VerticalAlignment="Bottom"
                                Background="{StaticResource FluentAccentDefault}"
                                CornerRadius="{StaticResource FluentCornerMediumBottom}"
                                Opacity="0"/>

                        <Popup IsOpen="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=IsDropDownOpen, Mode=TwoWay}"
                               Placement="Bottom"
                               PlacementTarget="{Binding ElementName=PART_ToggleButton}"
                               StaysOpen="False"
                               Style="{StaticResource AnchoredFlyoutPopupStyle}">
                            <Border Margin="0,8,0,0"
                                    Padding="16"
                                    Style="{StaticResource FlyoutPopupSurfaceStyle}">
                                <Grid UseLayoutRounding="True"
                                      SnapsToDevicePixels="True">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=StartHeader}"
                                                   Margin="0,0,0,8"
                                                   FontSize="{StaticResource FontSizeLabel}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FluentTextSecondary}"/>
                                        <Calendar SelectedDate="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=StartDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayDateEnd="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=EndDate}"
                                                  Style="{StaticResource FluentCalendarStyle}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1"
                                                Margin="16,0"
                                                VerticalAlignment="Center">
                                        <Border Width="1"
                                                Height="48"
                                                HorizontalAlignment="Center"
                                                Background="{StaticResource DividerStrokeColorDefault}"/>
                                        <Border Width="36"
                                                Margin="0,10,0,10"
                                                Padding="8,4"
                                                HorizontalAlignment="Center"
                                                Background="{StaticResource SubtleFillColorSecondary}"
                                                BorderBrush="{StaticResource DividerStrokeColorDefault}"
                                                BorderThickness="1"
                                                CornerRadius="{StaticResource FluentCornerMedium}">
                                            <TextBlock HorizontalAlignment="Center"
                                                       FontFamily="{StaticResource FluentIconFont}"
                                                       FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{StaticResource FluentAccentDefault}"
                                                       Text="&#xE72A;"/>
                                        </Border>
                                        <Border Width="1"
                                                Height="48"
                                                HorizontalAlignment="Center"
                                                Background="{StaticResource DividerStrokeColorDefault}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=EndHeader}"
                                                   Margin="0,0,0,8"
                                                   FontSize="{StaticResource FontSizeLabel}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource FluentTextSecondary}"/>
                                        <Calendar SelectedDate="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=EndDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  DisplayDateStart="{Binding RelativeSource={RelativeSource TemplatedParent}, Path=StartDate}"
                                                  Style="{StaticResource FluentCalendarStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocusWithin" Value="True">
                            <Setter TargetName="FocusIndicator" Property="Opacity" Value="1"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SplitButtonPrimarySegmentStyle" TargetType="Button" BasedOn="{x:Null}">
