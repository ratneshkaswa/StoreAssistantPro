<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
                    xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls">

    <!-- All design tokens moved to DesignSystem.xaml -->

    <!-- =================================================================
         VALIDATION ERROR TEMPLATE
         ================================================================= -->
    <!-- ErrorTemplate = adorner layer. Use AdornedElementPlaceholder
         only (no border here) to avoid double-border with the
         controls own BorderBrush set via Validation.HasError trigger. -->
    <ControlTemplate x:Key="InlineValidationErrorTemplate">
        <AdornedElementPlaceholder/>
    </ControlTemplate>


    <!-- ================================================================
         IMPLICIT CONTROL STYLES

         Each implicit style inherits its Fluent base template from
         FluentTheme.xaml, then adds app-specific setters such as
         MinHeight, behaviors, and validation.
         ================================================================ -->

    <!-- Button inherits FluentStandardButtonStyle (rounded, animated hover) -->
    <Style TargetType="Button" BasedOn="{StaticResource FluentStandardButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisualStyle}"/>
    </Style>

    <!-- TextBox inherits FluentTextBoxStyle (rounded, accent-focus) -->
    <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="h:SelectOnFocus.IsEnabled" Value="True"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- PasswordBox inherits FluentPasswordBoxStyle (rounded, accent-focus) -->
    <Style TargetType="PasswordBox" BasedOn="{StaticResource FluentPasswordBoxStyle}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBox inherits FluentComboBoxStyle (rounded, accent-focus, Fluent dropdown) -->
    <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBoxItem inherits FluentComboBoxItemStyle (subtle hover/selection) -->
    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource FluentComboBoxItemStyle}"/>

    <!-- CheckBox inherits FluentCheckBoxStyle (accent fill, rounded box, glyph) -->
    <Style TargetType="CheckBox" BasedOn="{StaticResource FluentCheckBoxStyle}"/>

    <!-- GroupBox inherits FluentGroupBoxStyle (card container, header region) -->
    <Style TargetType="GroupBox" BasedOn="{StaticResource FluentGroupBoxStyle}"/>

    <!-- ToolTip - Win11 rounded frosted card globally -->
    <Style TargetType="ToolTip" BasedOn="{StaticResource FluentToolTipStyle}"/>

    <!-- ContextMenu - Win11 rounded flyout globally -->
    <Style TargetType="ContextMenu" BasedOn="{StaticResource FluentContextMenuStyle}"/>

    <!-- RadioButton inherits FluentRadioButtonStyle (accent circle, dot indicator) -->
    <Style TargetType="RadioButton" BasedOn="{StaticResource FluentRadioButtonStyle}"/>

    <!-- ProgressBar inherits FluentProgressBarStyle (thin accent bar) -->
    <Style TargetType="ProgressBar" BasedOn="{StaticResource FluentProgressBarStyle}"/>
    <!-- ScrollViewer inherits FluentScrollViewerStyle (overlay scrollbars with fade) -->
    <Style TargetType="ScrollViewer" BasedOn="{StaticResource FluentScrollViewerStyle}"/>


    <Style TargetType="DatePicker" BasedOn="{StaticResource FluentDatePickerStyle}">
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DatePickerTextBox - remove legacy WPF watermark chrome -->
    <Style TargetType="DatePickerTextBox">
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePickerTextBox">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Hidden"
                                  Focusable="False"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚Â
         NAMED STYLES

         Each named button/card style inherits its Fluent base
         template, then adds app-specific sizing overrides.
         All existing Style="{StaticResource XxxStyle}" references
         across 12+ views continue to work unchanged.
         ÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚ÂÃƒÂ¢Ã¢â‚¬Â¢Ã‚Â -->

    <!-- ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ Page title (24 px bold ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â main content pages) ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontDisplay}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizePageTitle}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Margin" Value="{StaticResource TitleSpacing}"/>
    </Style>

    <!-- ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ Dialog / sub-window title (20 px bold) ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ -->
    <Style x:Key="DialogTitleStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontDisplay}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeDialogTitle}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Margin" Value="{StaticResource TitleSpacing}"/>
    </Style>

    <!-- ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ Section header (14 px semi-bold, inside forms/cards) ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ Field label (12 px semi-bold, sits above its control) ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ -->
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Margin" Value="{StaticResource FieldLabelSpacing}"/>
    </Style>

    <!-- Inline form-row label (right-aligned, vertically centered) -->
    <Style x:Key="FormRowLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Margin" Value="{StaticResource FormColumnGap}"/>
    </Style>

    <!-- Setup-scoped text styles (keep setup density local) -->
    <Style x:Key="SetupSectionHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionHeaderStyle}">
        <Setter Property="Margin" Value="{StaticResource SetupSectionTitleMargin}"/>
    </Style>

    <Style x:Key="SetupSectionHintTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Margin" Value="{StaticResource SetupSectionHintMargin}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
    </Style>

    <Style x:Key="SetupFormRowLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FormRowLabelStyle}">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>

    <!-- ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ Muted / caption label (12 px, secondary foreground) ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ -->
    <Style x:Key="CaptionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <!-- ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ Toolbar / compact action button (inherits FluentSubtle) ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button"
           BasedOn="{StaticResource FluentSubtleButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeight}"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <!-- ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ Primary action button (inherits FluentAccent) ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button"
           BasedOn="{StaticResource FluentAccentButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeightLarge}"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPaddingLarge}"/>
    </Style>

    <!-- Secondary action button (inherits FluentStandard) -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button"
           BasedOn="{StaticResource FluentStandardButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeightLarge}"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPaddingLarge}"/>
    </Style>

    <!-- ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ Elevated card (setup screens, prominent forms) ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ÃƒÂ¢Ã¢â‚¬ÂÃ¢â€šÂ¬ -->
    <Style x:Key="CardStyle" TargetType="Border">
        <Setter Property="Background"  Value="{StaticResource FluentSurface}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerLarge}"/>
        <Setter Property="Padding"     Value="24"/>
        <Setter Property="Margin"      Value="{StaticResource CardMargin}"/>
        <Setter Property="Effect"      Value="{StaticResource FluentShadowCard}"/>
    </Style>

    <!-- Flat card for setup pages (no shadow, CornerRadius 8, light border) -->
    <Style x:Key="SetupFlatCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerMedium}"/>
        <Setter Property="Padding" Value="{StaticResource SetupCardPadding}"/>
        <Setter Property="Margin" Value="{StaticResource SetupSectionSpacing}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="{StaticResource FluentBorderThicknessThin}"/>
    </Style>

    <!-- Sidebar container for setup (flat, no shadow) -->
    <Style x:Key="SetupSidebarCardStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerMedium}"/>
        <Setter Property="Padding" Value="{StaticResource SetupSidebarCardPadding}"/>
        <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
        <Setter Property="BorderThickness" Value="{StaticResource FluentBorderThicknessThin}"/>
    </Style>

    <!-- Setup sidebar/navigation -->
    <Style x:Key="SetupSidebarIconBadgeStyle" TargetType="Border">
        <Setter Property="Width" Value="{StaticResource SetupSidebarIconSize}"/>
        <Setter Property="Height" Value="{StaticResource SetupSidebarIconSize}"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
        <Setter Property="Margin" Value="{StaticResource SetupSidebarIconMargin}"/>
    </Style>

    <Style x:Key="SetupSidebarNavItemStyle" TargetType="RadioButton">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="{StaticResource SetupSidebarNavBorderThickness}"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="HorizontalAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="{StaticResource SetupSidebarNavPadding}"/>
        <Setter Property="Margin" Value="{StaticResource SetupSidebarNavMargin}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RadioButton">
