<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
                    xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls">

    <!-- All design tokens moved to DesignSystem.xaml -->

    <!-- =================================================================
         VALIDATION ERROR TEMPLATE
         ================================================================= -->
    <Thickness x:Key="InlineValidationTextPadding">12,8,32,8</Thickness>
    <Thickness x:Key="InlineValidationTrailingChromePadding">12,8,36,8</Thickness>
    <h:DoubleGreaterThanConverter x:Key="DoubleGreaterThanConverter"/>

    <!-- ErrorTemplate = adorner layer. Keep the border on the control
         itself, then overlay a small inline error badge inside the
         field rather than outside the layout slot. -->
    <ControlTemplate x:Key="InlineValidationErrorTemplate">
        <Grid UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <AdornedElementPlaceholder/>
            <Border Width="16"
                    Height="16"
                    Margin="0,0,8,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="{StaticResource FluentErrorBackground}"
                    BorderBrush="{StaticResource FluentStrokeError}"
                    BorderThickness="1"
                    CornerRadius="8"
                    IsHitTestVisible="False"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True">
                <TextBlock Text="!"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FluentError}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </ControlTemplate>

    <ControlTemplate x:Key="InlineValidationTrailingChromeErrorTemplate">
        <Grid UseLayoutRounding="True"
              SnapsToDevicePixels="True">
            <AdornedElementPlaceholder/>
            <Border Width="16"
                    Height="16"
                    Margin="0,0,40,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Background="{StaticResource FluentErrorBackground}"
                    BorderBrush="{StaticResource FluentStrokeError}"
                    BorderThickness="1"
                    CornerRadius="8"
                    IsHitTestVisible="False"
                    UseLayoutRounding="True"
                    SnapsToDevicePixels="True">
                <TextBlock Text="!"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FluentError}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>
        </Grid>
    </ControlTemplate>


    <!-- ================================================================
         IMPLICIT CONTROL STYLES

         Each implicit style inherits its Fluent base template from
         FluentTheme.xaml, then adds app-specific setters such as
         MinHeight, behaviors, and validation.
         ================================================================ -->

    <!-- Button inherits FluentStandardButtonStyle (rounded, animated hover) -->
    <Style TargetType="Button" BasedOn="{StaticResource FluentStandardButtonStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="FocusVisualStyle" Value="{StaticResource FluentFocusVisualStyle}"/>
        <Setter Property="h:AsyncCommandVisualState.IsEnabled" Value="True"/>
        <Setter Property="h:AccessibilityHelper.AutoLabel" Value="True"/>
    </Style>

    <Style TargetType="TextBlock">
        <Setter Property="h:TrimmedTextToolTip.IsEnabled" Value="True"/>
    </Style>

    <Style x:Key="DialogHeaderBackdropStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource DialogHeaderFrostBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource DividerStrokeColorDefault}"/>
        <Setter Property="BorderThickness" Value="0,0,0,1"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerLargeTop}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Effect">
            <Setter.Value>
                <BlurEffect Radius="8"
                            RenderingBias="Performance"/>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="DialogHeaderContentSurfaceStyle" TargetType="Border">
        <Setter Property="Background" Value="#00FFFFFF"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="CornerRadius" Value="{StaticResource FluentCornerLargeTop}"/>
        <Setter Property="Padding" Value="{StaticResource CardContentPadding}"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
    </Style>

    <!-- TextBox inherits FluentTextBoxStyle (rounded, accent-focus) -->
    <Style TargetType="TextBox" BasedOn="{StaticResource FluentTextBoxStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="h:BringFocusedFieldIntoView.IsEnabled" Value="True"/>
        <Setter Property="h:SelectOnFocus.IsEnabled" Value="True"/>
        <Setter Property="h:Watermark.UseFallbackText" Value="True"/>
        <Setter Property="h:ValidationFeedback.ShakeOnError" Value="True"/>
        <Setter Property="h:AccessibilityHelper.AutoLabel" Value="True"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="Padding" Value="{StaticResource InlineValidationTextPadding}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <Style x:Key="FluentMultilineTextBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="AcceptsReturn" Value="True"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="VerticalContentAlignment" Value="Top"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="MinHeight" Value="44"/>
        <Setter Property="MaxHeight" Value="132"/>
        <Setter Property="Padding" Value="12,8,12,8"/>
        <Setter Property="h:AutoGrowTextBox.IsEnabled" Value="True"/>
    </Style>

    <Style x:Key="FluentSearchTextBoxStyle"
           TargetType="TextBox"
           BasedOn="{StaticResource FluentTextBoxStyle}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="TextAlignment" Value="Left"/>
        <Setter Property="h:DebouncedSearch.IsEnabled" Value="True"/>
        <Setter Property="h:DebouncedSearch.Delay" Value="0:0:0.25"/>
        <Setter Property="h:BringFocusedFieldIntoView.IsEnabled" Value="True"/>
        <Setter Property="h:SelectOnFocus.IsEnabled" Value="True"/>
        <Setter Property="h:Watermark.UseFallbackText" Value="True"/>
        <Setter Property="h:ValidationFeedback.ShakeOnError" Value="True"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationTrailingChromeErrorTemplate}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid UseLayoutRounding="True"
                          SnapsToDevicePixels="True">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="&#xE721;"
                                           FontFamily="{StaticResource FluentIconFont}"
                                           FontSize="{StaticResource FontSizeIconSmall}"
                                           Foreground="{StaticResource FluentTextTertiary}"
                                           Margin="12,0,8,0"
                                           VerticalAlignment="Center"/>

                                <ScrollViewer x:Name="PART_ContentHost"
                                              Grid.Column="1"
                                              Focusable="False"
                                              HorizontalScrollBarVisibility="Hidden"
                                              VerticalScrollBarVisibility="Hidden"
                                              Padding="{TemplateBinding Padding}"/>

                                <Button x:Name="PART_ClearButton"
                                        Grid.Column="2"
                                        Width="28"
                                        Height="28"
                                        Margin="0,0,8,0"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Cursor="Hand"
                                        ToolTip="Clear search"
                                        AutomationProperties.Name="Clear search"
                                        Command="{x:Static h:TextBoxCommands.ClearTextCommand}"
                                        CommandTarget="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                        VerticalAlignment="Center">
                                    <TextBlock Text="&#xE711;"
                                               FontFamily="{StaticResource FluentIconFont}"
                                               FontSize="10"
                                               Foreground="{StaticResource FluentTextTertiary}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </Grid>
                        </Border>
                        <Border x:Name="FocusIndicator"
                                Height="2"
                                VerticalAlignment="Bottom"
                                CornerRadius="{StaticResource FluentCornerMediumBottom}"
                                Background="{StaticResource FluentAccentDefault}"
                                Opacity="0"
                                Margin="2,0,2,0"/>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness"
                                    Value="1"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeDefault}"/>
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="Bd" Property="BorderThickness"
                                    Value="1"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource FluentStrokeFocus}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="1"
                                                         Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FocusIndicator"
                                                         Storyboard.TargetProperty="Opacity"
                                                         To="0"
                                                         Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="PART_ClearButton" Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>
                        <Trigger Property="Validation.HasError" Value="True">
                            <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                            <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                            <Setter Property="Padding" Value="{StaticResource InlineValidationTrailingChromePadding}"/>
                            <Setter Property="ToolTip"
                                    Value="{Binding RelativeSource={RelativeSource Self},
                                                    Path=(Validation.Errors)[0].ErrorContent}"/>
                            <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                            <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background"
                                    Value="{StaticResource FluentControlFillDisabled}"/>
                            <Setter Property="Foreground"
                                    Value="{StaticResource FluentTextDisabled}"/>
                            <Setter TargetName="Bd" Property="BorderThickness"
                                    Value="0,0,0,1"/>
                            <Setter TargetName="Bd" Property="BorderBrush"
                                    Value="{StaticResource DividerStrokeColorDefault}"/>
                            <Setter TargetName="PART_ClearButton" Property="Visibility"
                                    Value="Collapsed"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="TeachingTipTooltipStyle" TargetType="ToolTip"
           BasedOn="{StaticResource SmartTooltipStyle}">
        <Setter Property="Padding" Value="12,8,12,12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Grid x:Name="Root"
                          Margin="0,0,0,4"
                          Opacity="0"
                          UseLayoutRounding="True"
                          SnapsToDevicePixels="True"
                          RenderTransformOrigin="0.5,0"
                          Effect="{StaticResource TooltipShadow}">
                        <Grid.RenderTransform>
                            <TranslateTransform Y="8"/>
                        </Grid.RenderTransform>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0"
                              Width="18"
                              Height="10"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,-1">
                            <Polygon Points="9,0 18,10 0,10"
                                     Fill="{TemplateBinding Background}"
                                     Stroke="{TemplateBinding BorderBrush}"
                                     StrokeThickness="1"
                                     StrokeLineJoin="Round"/>
                        </Grid>
                        <Border Grid.Row="1"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource TooltipCornerRadius}"
                                UseLayoutRounding="True"
                                SnapsToDevicePixels="True">
                            <Border CornerRadius="{StaticResource TooltipCornerRadius}"
                                    BorderBrush="{StaticResource TooltipInnerHighlight}"
                                    BorderThickness="1"
                                    Padding="{TemplateBinding Padding}"
                                    UseLayoutRounding="True"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter
                                    HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                    VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                    RecognizesAccessKey="True"/>
                            </Border>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="Opened">
                            <BeginStoryboard x:Name="OpenStoryboard">
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Root"
                                                     Storyboard.TargetProperty="Opacity"
                                                     From="0"
                                                     To="1"
                                                     Duration="{StaticResource FluentDurationNormal}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation Storyboard.TargetName="Root"
                                                     Storyboard.TargetProperty="RenderTransform.Y"
                                                     From="6"
                                                     To="0"
                                                     Duration="{StaticResource FluentDurationNormal}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="Closed">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="Root"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseIn"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- PasswordBox inherits FluentPasswordBoxStyle (rounded, accent-focus) -->
    <Style TargetType="PasswordBox" BasedOn="{StaticResource FluentPasswordBoxStyle}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="h:BringFocusedFieldIntoView.IsEnabled" Value="True"/>
        <Setter Property="h:Watermark.UseFallbackText" Value="True"/>
        <Setter Property="h:PasswordReveal.IsEnabled" Value="True"/>
        <Setter Property="h:ValidationFeedback.ShakeOnError" Value="True"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="Padding" Value="{StaticResource InlineValidationTextPadding}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBox inherits FluentComboBoxStyle (rounded, accent-focus, Fluent dropdown) -->
    <Style TargetType="ComboBox" BasedOn="{StaticResource FluentComboBoxStyle}">
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="h:BringFocusedFieldIntoView.IsEnabled" Value="True"/>
        <Setter Property="h:Watermark.UseFallbackText" Value="True"/>
        <Setter Property="h:ValidationFeedback.ShakeOnError" Value="True"/>
        <Setter Property="h:AccessibilityHelper.AutoLabel" Value="True"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationTrailingChromeErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="Padding" Value="{StaticResource InlineValidationTrailingChromePadding}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ComboBoxItem inherits FluentComboBoxItemStyle (subtle hover/selection) -->
    <Style TargetType="ComboBoxItem" BasedOn="{StaticResource FluentComboBoxItemStyle}"/>

    <!-- CheckBox inherits FluentCheckBoxStyle (accent fill, rounded box, glyph) -->
    <Style TargetType="CheckBox" BasedOn="{StaticResource FluentCheckBoxStyle}">
        <Setter Property="h:AccessibilityHelper.AutoLabel" Value="True"/>
    </Style>

    <!-- GroupBox inherits FluentGroupBoxStyle (card container, header region) -->
    <Style TargetType="GroupBox" BasedOn="{StaticResource FluentGroupBoxStyle}"/>

    <!-- ToolTip - Win11 rounded frosted card globally -->
    <Style TargetType="ToolTip" BasedOn="{StaticResource FluentToolTipStyle}"/>

    <!-- ContextMenu - Win11 rounded flyout globally -->
    <Style TargetType="ContextMenu" BasedOn="{StaticResource FluentContextMenuStyle}"/>

    <!-- RadioButton inherits FluentRadioButtonStyle (accent circle, dot indicator) -->
    <Style TargetType="RadioButton" BasedOn="{StaticResource FluentRadioButtonStyle}"/>

    <!-- ProgressBar inherits FluentProgressBarStyle (thin accent bar) -->
    <Style TargetType="ProgressBar" BasedOn="{StaticResource FluentProgressBarStyle}"/>
    <!-- ScrollViewer inherits FluentScrollViewerStyle (overlay scrollbars with fade) -->
    <Style TargetType="ScrollViewer" BasedOn="{StaticResource FluentScrollViewerStyle}"/>


    <Style TargetType="DatePicker" BasedOn="{StaticResource FluentDatePickerStyle}">
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="h:BringFocusedFieldIntoView.IsEnabled" Value="True"/>
        <Setter Property="h:Watermark.UseFallbackText" Value="True"/>
        <Setter Property="h:ValidationFeedback.ShakeOnError" Value="True"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationTrailingChromeErrorTemplate}"/>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="BorderBrush" Value="{StaticResource FluentStrokeError}"/>
                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                <Setter Property="Padding" Value="{StaticResource InlineValidationTrailingChromePadding}"/>
                <Setter Property="ToolTip"
                        Value="{Binding RelativeSource={RelativeSource Self},
                                        Path=(Validation.Errors)[0].ErrorContent}"/>
                <Setter Property="ToolTipService.InitialShowDelay" Value="0"/>
                <Setter Property="ToolTipService.ShowDuration" Value="30000"/>
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- DatePickerTextBox - remove legacy WPF watermark chrome -->
    <Style TargetType="DatePickerTextBox">
        <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="DatePickerTextBox">
                    <ScrollViewer x:Name="PART_ContentHost"
                                  HorizontalScrollBarVisibility="Hidden"
                                  VerticalScrollBarVisibility="Hidden"
                                  Focusable="False"/>
                </ControlTemplate>
            </Setter.Value>
