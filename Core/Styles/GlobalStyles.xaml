    <DataTemplate x:Key="CommandButtonContentTemplate">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <Grid Width="16"
                  Height="16"
                  Margin="0,0,8,0"
                  VerticalAlignment="Center">
                <TextBlock x:Name="CommandIcon"
                           Text="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Tag}"
                           FontFamily="{StaticResource FluentIconFont}"
                           FontSize="{StaticResource FontSizeBody}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                <TextBlock x:Name="CommandSpinner"
                           Text="&#xE895;"
                           Visibility="Collapsed"
                           FontFamily="{StaticResource FluentIconFont}"
                           FontSize="{StaticResource FontSizeBody}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                           RenderTransformOrigin="0.5,0.5">
                    <TextBlock.RenderTransform>
                        <RotateTransform x:Name="CommandSpinnerRotate" Angle="0"/>
                    </TextBlock.RenderTransform>
                </TextBlock>
            </Grid>
            <TextBlock x:Name="CommandLabel"
                       Text="{Binding}"
                       VerticalAlignment="Center"
                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
        </StackPanel>
        <DataTemplate.Triggers>
            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=(h:AsyncCommandVisualState.IsRunning)}"
                         Value="True">
                <Setter TargetName="CommandIcon" Property="Visibility" Value="Collapsed"/>
                <Setter TargetName="CommandSpinner" Property="Visibility" Value="Visible"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard x:Name="CommandSpinnerStoryboard">
                        <Storyboard RepeatBehavior="Forever">
                            <DoubleAnimation Storyboard.TargetName="CommandSpinnerRotate"
                                             Storyboard.TargetProperty="Angle"
                                             From="0"
                                             To="360"
                                             Duration="0:0:0.9"/>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <StopStoryboard BeginStoryboardName="CommandSpinnerStoryboard"/>
                </DataTrigger.ExitActions>
            </DataTrigger>
        </DataTemplate.Triggers>
    </DataTemplate>

    <Style x:Key="DataGridRowActionPanelStyle" TargetType="StackPanel">
        <Setter Property="Orientation" Value="Horizontal"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="Opacity" Value="0"/>
        <Setter Property="IsHitTestVisible" Value="False"/>
        <Style.Triggers>
            <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                         Value="True">
                <Setter Property="IsHitTestVisible" Value="True"/>
                <DataTrigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard FillBehavior="HoldEnd">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="1"
                                             Duration="0:0:0.10">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.EnterActions>
                <DataTrigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard FillBehavior="HoldEnd">
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                             To="0"
                                             Duration="0:0:0.10">
                                <DoubleAnimation.EasingFunction>
                                    <QuadraticEase EasingMode="EaseIn"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </DataTrigger.ExitActions>
            </DataTrigger>
            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=DataGridRow}}"
                         Value="True">
                <Setter Property="Opacity" Value="1"/>
                <Setter Property="IsHitTestVisible" Value="True"/>
            </DataTrigger>
        </Style.Triggers>
    </Style>

