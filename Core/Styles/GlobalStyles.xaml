    <!-- ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ Elevated card (setup screens, prominent forms) ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ГғЖ’ГҶвҖҷГғвҖҡГӮВўГғЖ’ГӮВўГғВўГўвӮ¬ЕЎГӮВ¬ГғвҖҡГӮВқГғЖ’ГӮВўГғВўГўвҖҡВ¬Г…ВЎГғвҖҡГӮВ¬ -->
    <Style x:Key="FloatingActionButtonStyle" TargetType="Button"
           BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Width" Value="56"/>
        <Setter Property="Height" Value="56"/>
        <Setter Property="MinWidth" Value="56"/>
        <Setter Property="MinHeight" Value="56"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="FontSize" Value="20"/>
        <Setter Property="Background" Value="{StaticResource FluentAccentGradient}"/>
        <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Effect" Value="{StaticResource ElevationEffectFlyout}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="FabBorder"
                            Width="{TemplateBinding Width}"
                            Height="{TemplateBinding Height}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="28"
                            Padding="{TemplateBinding Padding}"
                            Effect="{TemplateBinding Effect}"
                            UseLayoutRounding="True"
                            SnapsToDevicePixels="True"
                            RenderTransformOrigin="0.5,0.5">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="FabScale"
                                            ScaleX="1"
                                            ScaleY="1"/>
                        </Border.RenderTransform>
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="FabBorder" Property="Background"
                                    Value="{StaticResource FluentAccentGradientHover}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FabScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="{StaticResource MotionButtonScaleHover}"
                                                         Duration="{StaticResource FluentDurationNormal}"/>
                                        <DoubleAnimation Storyboard.TargetName="FabScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="{StaticResource MotionButtonScaleHover}"
                                                         Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FabScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="{StaticResource MotionButtonScaleRest}"
                                                         Duration="{StaticResource FluentDurationNormal}"/>
                                        <DoubleAnimation Storyboard.TargetName="FabScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="{StaticResource MotionButtonScaleRest}"
                                                         Duration="{StaticResource FluentDurationNormal}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="FabBorder" Property="Background"
                                    Value="{StaticResource FluentAccentGradientPressed}"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccentPressed}"/>
                            <Trigger.EnterActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FabScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="{StaticResource MotionButtonScalePressed}"
                                                         Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="FabScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="{StaticResource MotionButtonScalePressed}"
                                                         Duration="{StaticResource FluentDurationFast}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.EnterActions>
                            <Trigger.ExitActions>
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="FabScale"
                                                         Storyboard.TargetProperty="ScaleX"
                                                         To="{StaticResource MotionButtonScaleHover}"
                                                         Duration="{StaticResource FluentDurationFast}"/>
                                        <DoubleAnimation Storyboard.TargetName="FabScale"
                                                         Storyboard.TargetProperty="ScaleY"
                                                         To="{StaticResource MotionButtonScaleHover}"
                                                         Duration="{StaticResource FluentDurationFast}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </Trigger.ExitActions>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter TargetName="FabBorder" Property="Background"
                                    Value="{StaticResource FluentAccentDisabled}"/>
                            <Setter Property="Opacity" Value="0.4"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

