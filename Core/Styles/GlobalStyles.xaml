    <Style x:Key="SmartTooltipStyle" TargetType="ToolTip">
        <Setter Property="OverridesDefaultStyle" Value="True"/>
        <Setter Property="Background"      Value="{StaticResource TooltipBackground}"/>
        <Setter Property="Foreground"       Value="{StaticResource FluentTextPrimary}"/>
        <Setter Property="BorderBrush"      Value="{StaticResource TooltipBorder}"/>
        <Setter Property="BorderThickness"  Value="1"/>
        <Setter Property="Padding"          Value="{StaticResource TooltipPadding}"/>
        <Setter Property="FontFamily"       Value="{StaticResource FluentFontFamily}"/>
        <Setter Property="FontSize"         Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="MaxWidth"         Value="{StaticResource TooltipMaxWidth}"/>
        <Setter Property="HasDropShadow"    Value="False"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <!-- Outer chrome: border + shadow -->
                    <Border x:Name="Root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource TooltipCornerRadius}"
                            Effect="{StaticResource TooltipShadow}"
                            SnapsToDevicePixels="True"
                            Opacity="0"
                            RenderTransformOrigin="0.5,0">
                        <Border.RenderTransform>
                            <TranslateTransform Y="4"/>
                        </Border.RenderTransform>

                        <!-- Inner highlight ÃƒÂ¢Ã¢â€šÂ¬Ã¢â‚¬Â 1 px white inset (Fluent smoke) -->
                        <Border CornerRadius="{StaticResource TooltipCornerRadius}"
                                BorderBrush="{StaticResource TooltipInnerHighlight}"
                                BorderThickness="1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                    </Border>

                    <ControlTemplate.Triggers>
                        <!-- Entrance: fade-in + slide-up -->
                        <EventTrigger RoutedEvent="Opened">
                            <BeginStoryboard x:Name="OpenStoryboard">
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="Opacity"
                                        From="0" To="1"
                                        Duration="{StaticResource FluentDurationNormal}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                    <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="RenderTransform.Y"
                                        From="4" To="0"
                                        Duration="{StaticResource FluentDurationNormal}">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseOut"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>

                        <!-- Exit: quick fade-out -->
                        <EventTrigger RoutedEvent="Closed">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation
                                        Storyboard.TargetName="Root"
                                        Storyboard.TargetProperty="Opacity"
                                        To="0" Duration="0:0:0.12">
                                        <DoubleAnimation.EasingFunction>
                                            <CubicEase EasingMode="EaseIn"/>
                                        </DoubleAnimation.EasingFunction>
                                    </DoubleAnimation>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

