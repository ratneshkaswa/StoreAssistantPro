<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
                    xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers">

    <!-- ═══════════════════════════════════════════════════════════════
         SPACING SCALE  (4 px base unit)

         xs  =  4    label → control gap, tight insets
         sm  =  8    inline control gap, compact separators
         md  = 12    form-field group bottom, toolbar gap, card gap
         lg  = 16    section separator, title bottom margin
         xl  = 20    page padding (main content area)
         xxl = 24    dialog / sub-window padding
         ═══════════════════════════════════════════════════════════════ -->
    <sys:Double x:Key="SpacingXs">4</sys:Double>
    <sys:Double x:Key="SpacingSm">8</sys:Double>
    <sys:Double x:Key="SpacingMd">12</sys:Double>
    <sys:Double x:Key="SpacingLg">16</sys:Double>
    <sys:Double x:Key="SpacingXl">20</sys:Double>
    <sys:Double x:Key="SpacingXxl">24</sys:Double>

    <!-- ── Pre-built Thickness values ─────────────────────────────── -->

    <!-- Outer page / dialog padding -->
    <Thickness x:Key="PagePadding">20</Thickness>
    <Thickness x:Key="DialogPadding">24</Thickness>

    <!-- Vertical separation between major visual sections -->
    <Thickness x:Key="SectionSpacing">0,0,0,16</Thickness>

    <!-- Vertical gap between form-field groups (label + control) -->
    <Thickness x:Key="FieldGroupSpacing">0,0,0,12</Thickness>

    <!-- Gap between a field label and its associated control -->
    <Thickness x:Key="FieldLabelSpacing">0,0,0,4</Thickness>

    <!-- Horizontal gap between label column and input column -->
    <Thickness x:Key="FormColumnGap">0,0,12,0</Thickness>

    <!-- Top margin above action-button bar in forms -->
    <Thickness x:Key="FormActionBarSpacing">0,12,0,0</Thickness>

    <!-- Vertical gap between rows in a two-column form grid -->
    <GridLength x:Key="FormRowSpacing">8</GridLength>

    <!-- Toolbar / action-bar bottom margin -->
    <Thickness x:Key="ToolbarSpacing">0,0,0,12</Thickness>

    <!-- Horizontal gap between inline controls inside a toolbar -->
    <Thickness x:Key="InlineControlSpacing">0,0,8,0</Thickness>

    <!-- Title block bottom margin -->
    <Thickness x:Key="TitleSpacing">0,0,0,16</Thickness>

    <!-- ── Control-internal padding ───────────────────────────────── -->
    <Thickness x:Key="ControlPadding">6</Thickness>
    <Thickness x:Key="ButtonPadding">12,6</Thickness>
    <Thickness x:Key="ButtonPaddingLarge">16,8</Thickness>
    <Thickness x:Key="CardPadding">16</Thickness>

    <!-- Card / inline-form border radius -->
    <CornerRadius x:Key="CardCornerRadius">6</CornerRadius>

    <!-- Enterprise form density: standard control heights -->
    <sys:Double x:Key="ControlHeight">32</sys:Double>
    <sys:Double x:Key="ButtonHeight">34</sys:Double>
    <sys:Double x:Key="ButtonHeightLarge">36</sys:Double>

    <!-- Smooth ease-out for focus-lock panel dimming transitions -->
    <CubicEase x:Key="PanelDimEase" EasingMode="EaseOut"/>

    <!-- ═══════════════════════════════════════════════════════════════
         TYPOGRAPHY SCALE
         ═══════════════════════════════════════════════════════════════ -->
    <sys:Double x:Key="FontSizePageTitle">24</sys:Double>
    <sys:Double x:Key="FontSizeDialogTitle">20</sys:Double>
    <sys:Double x:Key="FontSizeSectionHeader">16</sys:Double>
    <sys:Double x:Key="FontSizeBody">13</sys:Double>
    <sys:Double x:Key="FontSizeLabel">12</sys:Double>
    <sys:Double x:Key="FontSizeCaption">11</sys:Double>

    <!-- ═══════════════════════════════════════════════════════════════
         VALIDATION ERROR TEMPLATE

         Replaces WPF's default red-border-only ErrorTemplate with an
         inline error message below the control.  Activates automatically
         when a binding's INotifyDataErrorInfo reports errors.

         Structure:
           ┌ red border (1.5 px) ─────────┐
           │  [control]                    │
           └───────────────────────────────┘
           ⚠ Error message text               ← inline, below control
         ═══════════════════════════════════════════════════════════════ -->
    <ControlTemplate x:Key="InlineValidationErrorTemplate">
        <StackPanel>
            <Border BorderBrush="#D32F2F" BorderThickness="1.5" CornerRadius="3">
                <AdornedElementPlaceholder/>
            </Border>
            <ItemsControl ItemsSource="{Binding}" Margin="2,3,0,0">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding ErrorContent}"
                                   Foreground="#D32F2F" FontSize="11"
                                   TextWrapping="Wrap"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ControlTemplate>

    <!-- ═══════════════════════════════════════════════════════════════
         IMPLICIT CONTROL STYLES

         Set baseline padding / alignment so every new control looks
         correct without per-instance Padding="…" attributes.
         Existing explicit values on controls still win (local > style).

         Validation.ErrorTemplate provides inline error display with
         a red border and error text below the control — activates
         automatically when INotifyDataErrorInfo reports errors.
         ═══════════════════════════════════════════════════════════════ -->

    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="Padding" Value="{StaticResource ControlPadding}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="h:SelectOnFocus.IsEnabled" Value="True"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
    </Style>

    <Style TargetType="PasswordBox" BasedOn="{StaticResource {x:Type PasswordBox}}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="Padding" Value="{StaticResource ControlPadding}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
    </Style>

    <Style TargetType="ComboBox" BasedOn="{StaticResource {x:Type ComboBox}}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="Padding" Value="{StaticResource ControlPadding}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
    </Style>

    <Style TargetType="DatePicker" BasedOn="{StaticResource {x:Type DatePicker}}">
        <Setter Property="MinHeight" Value="{StaticResource ControlHeight}"/>
        <Setter Property="Padding" Value="4"/>
        <Setter Property="Validation.ErrorTemplate" Value="{StaticResource InlineValidationErrorTemplate}"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         NAMED STYLES

         Use via Style="{StaticResource XxxStyle}" on individual
         controls.  Provides semantic roles that map to the spacing
         and typography scale above.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- ── Page title (24 px bold — main content pages) ───────────── -->
    <Style x:Key="PageTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizePageTitle}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="{StaticResource TitleSpacing}"/>
    </Style>

    <!-- ── Dialog / sub-window title (20 px bold) ─────────────────── -->
    <Style x:Key="DialogTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeDialogTitle}"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="Margin" Value="{StaticResource TitleSpacing}"/>
    </Style>

    <!-- ── Section header (14 px semi-bold, inside forms/cards) ───── -->
    <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="14"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="0,0,0,8"/>
    </Style>

    <!-- ── Field label (12 px semi-bold, sits above its control) ──── -->
    <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Margin" Value="{StaticResource FieldLabelSpacing}"/>
    </Style>

    <!-- Inline form-row label (right-aligned, vertically centered) -->
    <Style x:Key="FormRowLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#444"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Margin" Value="{StaticResource FormColumnGap}"/>
    </Style>

    <!-- ── Muted / caption label (12 px, secondary foreground) ────── -->
    <Style x:Key="CaptionLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="#888"/>
        <Setter Property="Margin" Value="0,0,0,2"/>
    </Style>

    <!-- ── Toolbar / compact action button ────────────────────────── -->
    <Style x:Key="ToolbarButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeight}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPadding}"/>
        <Setter Property="Margin" Value="0,0,6,0"/>
    </Style>

    <!-- ── Primary action button (Save, Submit, Complete) ─────────── -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeightLarge}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPaddingLarge}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
    </Style>

    <!-- Secondary action button (Close, Cancel) -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="MinHeight" Value="{StaticResource ButtonHeightLarge}"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Padding" Value="{StaticResource ButtonPaddingLarge}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
    </Style>

    <!-- ── Inline form card border ────────────────────────────────── -->
    <Style x:Key="FormCardStyle" TargetType="Border">
        <Setter Property="Background" Value="#F5F5F5"/>
        <Setter Property="CornerRadius" Value="{StaticResource CardCornerRadius}"/>
        <Setter Property="Padding" Value="{StaticResource CardPadding}"/>
        <Setter Property="Margin" Value="{StaticResource FieldGroupSpacing}"/>
    </Style>

    <!-- ── Error message bar ──────────────────────────────────────── -->
    <Style x:Key="ErrorMessageStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="Red"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>

    <!-- ── Success message bar ────────────────────────────────────── -->
    <Style x:Key="SuccessMessageStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="#4CAF50"/>
        <Setter Property="TextWrapping" Value="Wrap"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         DATAGRID VIRTUALISATION & SCROLL PERFORMANCE

         Implicit style:  baseline for every DataGrid in the app.
         EnterpriseDataGridStyle:  full optimisation for grids that
             display large / growing datasets (Products, Sales history,
             future Billing grid).

         Key settings:
           ┌─ Row virtualisation ───── VirtualizingPanel.IsVirtualizing
           │  Rows outside the viewport are never materialised.
           ├─ Container recycling ──── VirtualizingPanel.VirtualizationMode
           │  Reuses row containers instead of GC-ing and re-creating.
           ├─ Column virtualisation ── EnableColumnVirtualization
           │  Only measures / renders visible columns.
           │  NOTE: Star-width (*) columns disable column virtualisation;
           │  enterprise grids use fixed pixel widths instead.
           ├─ Pixel scrolling ──────── VirtualizingPanel.ScrollUnit
           │  Smooth, sub-row scroll offset (default is item-based).
           ├─ Deferred scrolling ───── ScrollViewer.IsDeferredScrollingEnabled
           │  Delays re-query while the thumb is dragged.
           └─ Fixed row height ─────── RowHeight
               Avoids per-row measure pass; critical for 10k+ rows.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Baseline: every DataGrid gets virtualisation + recycling -->
    <Style TargetType="DataGrid" BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="CanUserAddRows" Value="False"/>
    </Style>

    <!-- Full enterprise optimisation for primary data grids -->
    <Style x:Key="EnterpriseDataGridStyle" TargetType="DataGrid"
           BasedOn="{StaticResource {x:Type DataGrid}}">
        <Setter Property="VirtualizingPanel.IsVirtualizing" Value="True"/>
        <Setter Property="VirtualizingPanel.VirtualizationMode" Value="Recycling"/>
        <Setter Property="VirtualizingPanel.ScrollUnit" Value="Pixel"/>
        <Setter Property="VirtualizingPanel.CacheLength" Value="2,2"/>
        <Setter Property="VirtualizingPanel.CacheLengthUnit" Value="Page"/>
        <Setter Property="EnableRowVirtualization" Value="True"/>
        <Setter Property="EnableColumnVirtualization" Value="True"/>
        <Setter Property="ScrollViewer.IsDeferredScrollingEnabled" Value="True"/>
        <Setter Property="RowHeight" Value="32"/>
        <Setter Property="CanUserAddRows" Value="False"/>
        <Setter Property="SelectionMode" Value="Single"/>
        <Setter Property="IsReadOnly" Value="True"/>
        <Setter Property="AutoGenerateColumns" Value="False"/>
    </Style>

    <!-- ═══════════════════════════════════════════════════════════════
         KEYBOARD & FOCUS BEHAVIOR

         Enter       = DefaultCommand or next input
         Shift+Enter = move backward
         Escape      = EscapeCommand, clear focus, or IsCancel
         Tab         = standard WPF order
         AutoFocus   = first input receives focus on load

         Applied globally to every Window via the implicit style below.
         To opt-out: h:KeyboardNav.IsEnabled="False"
                     h:AutoFocus.IsEnabled="False"
         ═══════════════════════════════════════════════════════════════ -->
    <Style TargetType="Window">
        <Setter Property="h:KeyboardNav.IsEnabled" Value="True"/>
        <Setter Property="h:AutoFocus.IsEnabled" Value="True"/>
        <Setter Property="h:LayoutDiagnostics.IsEnabled" Value="True"/>
    </Style>

</ResourceDictionary>