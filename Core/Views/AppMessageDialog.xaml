<core:BaseDialogWindow
    x:Class="StoreAssistantPro.Core.Views.AppMessageDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:StoreAssistantPro.Core"
    Title="">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Border Style="{StaticResource DialogHeaderBackdropStyle}"/>
            <Border Style="{StaticResource DialogHeaderContentSurfaceStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="12"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border x:Name="IconBadge"
                            Width="40"
                            Height="40"
                            VerticalAlignment="Top"
                            HorizontalAlignment="Left"
                            Background="{StaticResource FluentInfoBackground}"
                            CornerRadius="20">
                        <Viewbox Width="16"
                                 Height="16"
                                 Stretch="Uniform">
                            <TextBlock x:Name="IconGlyph"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontFamily="{StaticResource FluentFontFamily}"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FluentInfo}"
                                       Text="?"/>
                        </Viewbox>
                    </Border>

                    <StackPanel Grid.Column="2"
                                VerticalAlignment="Center">
                        <TextBlock x:Name="DialogTitleText"
                                   FontFamily="{StaticResource FluentFontDisplay}"
                                   FontSize="{StaticResource FontSizeHeadline}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextPrimary}"
                                   Margin="0"
                                   TextWrapping="WrapWithOverflow"/>
                        <TextBlock x:Name="MessageText"
                                   Margin="0,6,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   LineHeight="18"
                                   TextWrapping="WrapWithOverflow"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="1"
                Style="{StaticResource DialogFooterBarStyle}">
            <StackPanel Style="{StaticResource DialogFooterActionRowStyle}">
                <Button x:Name="SecondaryButton"
                        Style="{StaticResource DialogFooterSecondaryButtonStyle}"
                        Margin="0,0,8,0"
                        IsCancel="True"
                        Click="OnSecondaryClick"/>
                <Button x:Name="PrimaryButton"
                        Style="{StaticResource DialogFooterPrimaryButtonStyle}"
                        IsDefault="True"
                        Click="OnPrimaryClick"/>
            </StackPanel>
        </Border>
    </Grid>
</core:BaseDialogWindow>
