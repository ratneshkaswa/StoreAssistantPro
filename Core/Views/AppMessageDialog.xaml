<core:BaseDialogWindow
    x:Class="StoreAssistantPro.Core.Views.AppMessageDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:StoreAssistantPro.Core"
    Title="Message">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource FormCardStyle}"
                Margin="0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="IconBadge"
                        Width="40"
                        Height="40"
                        VerticalAlignment="Top"
                        HorizontalAlignment="Left"
                        Background="{StaticResource FluentInfoBackground}"
                        CornerRadius="20">
                    <Viewbox Width="16"
                             Height="16"
                             Stretch="Uniform">
                        <TextBlock x:Name="IconGlyph"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontFamily="{StaticResource FluentFontFamily}"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentInfo}"
                                   Text="?"/>
                    </Viewbox>
                </Border>

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="DialogTitleText"
                               FontFamily="{StaticResource FluentFontDisplay}"
                               FontSize="{StaticResource FontSizeHeadline}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FluentTextPrimary}"
                               Margin="0"
                               TextWrapping="Wrap"/>
                    <TextBlock x:Name="MessageText"
                               Margin="0,6,0,0"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource FluentTextSecondary}"
                               FontSize="{StaticResource FontSizeBody}"
                               LineHeight="18"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Padding="0,12,0,0"
                BorderBrush="{StaticResource FluentSurfaceStroke}"
                BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="SecondaryButton"
                        MinWidth="96"
                        MinHeight="36"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0"
                        Click="OnSecondaryClick"/>
                <Button x:Name="PrimaryButton"
                        MinWidth="96"
                        MinHeight="36"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="OnPrimaryClick"/>
            </StackPanel>
        </Border>
    </Grid>
</core:BaseDialogWindow>
