<core:BaseDialogWindow
    x:Class="StoreAssistantPro.Core.Views.MasterPinDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:StoreAssistantPro.Core"
    Title="">

    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title -->
        <Grid Grid.Row="0"
              Margin="{StaticResource FieldGroupSpacing}">
            <Border Style="{StaticResource DialogHeaderBackdropStyle}"/>
            <Border Style="{StaticResource DialogHeaderContentSurfaceStyle}"
                    Padding="14,12">
                <TextBlock x:Name="PromptText"
                           Style="{StaticResource FieldLabelStyle}"
                           TextWrapping="WrapWithOverflow"
                           Margin="0"/>
            </Border>
        </Grid>

        <!-- Row 1: PIN entry -->
        <PasswordBox Grid.Row="1"
                     x:Name="PinBox"
                     AutomationProperties.Name="Master PIN"
                     MaxLength="6"
                     VerticalAlignment="Top"
                     Margin="{StaticResource FieldGroupSpacing}"/>

        <!-- Row 2: Buttons -->
        <Border Grid.Row="2"
                Style="{StaticResource DialogFooterBarStyle}">
            <StackPanel Style="{StaticResource DialogFooterActionRowStyle}">
                <Button Content="Confirm"
                        Style="{StaticResource DialogFooterPrimaryButtonStyle}"
                        Click="OnOkClick"
                        IsDefault="True"
                        Margin="{StaticResource InlineControlSpacing}"/>
                <Button Content="Cancel"
                        Style="{StaticResource DialogFooterSecondaryButtonStyle}"
                        IsCancel="True"/>
            </StackPanel>
        </Border>
    </Grid>
</core:BaseDialogWindow>
