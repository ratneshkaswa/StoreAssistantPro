<core:BaseDialogWindow
    x:Class="StoreAssistantPro.Core.Views.MasterPinDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:core="clr-namespace:StoreAssistantPro.Core"
    Title="Authentication Required">

    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title -->
        <TextBlock Grid.Row="0"
                   x:Name="PromptText"
                   Style="{StaticResource FieldLabelStyle}"
                   TextWrapping="Wrap"
                   Margin="{StaticResource FieldGroupSpacing}"/>

        <!-- Row 1: PIN entry -->
        <PasswordBox Grid.Row="1"
                     x:Name="PinBox"
                     AutomationProperties.Name="Master PIN"
                     MaxLength="6"
                     VerticalAlignment="Top"
                     Margin="{StaticResource FieldGroupSpacing}"/>

        <!-- Row 2: Buttons -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Content="OK"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Click="OnOkClick"
                    IsDefault="True"
                    Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Cancel"
                    Style="{StaticResource SecondaryButtonStyle}"
                    IsCancel="True"/>
        </StackPanel>
    </Grid>
</core:BaseDialogWindow>
