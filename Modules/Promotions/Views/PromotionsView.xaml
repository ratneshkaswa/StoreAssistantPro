<UserControl x:Class="StoreAssistantPro.Modules.Promotions.Views.PromotionsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             Loaded="OnLoaded">
    <controls:EnterprisePageLayout>

        <controls:EnterprisePageLayout.TipBannerContent>
            <controls:InlineTipBanner
                h:TipBannerAutoState.TipKey="PromotionsView.QuickTip"
                h:TipBannerAutoState.ContextKey="Promotions"
                Title="Quick tip"
                TipText="Create coupons for discount codes and vouchers for gift cards. Apply them at billing time."/>
        </controls:EnterprisePageLayout.TipBannerContent>

        <controls:EnterprisePageLayout.ToolbarContent>
            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="{StaticResource FieldGroupSpacing}">
                <Border Style="{StaticResource SectionCardHeaderStyle}">
                    <WrapPanel>
                        <Button Content="➕ Add Coupon" Command="{Binding ShowAddCouponCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" FontWeight="SemiBold"/>
                        <Button Content="🗑 Delete Coupon" Command="{Binding DeleteCouponCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Separator Style="{StaticResource FluentSeparatorStyle}"/>
                        <Button Content="➕ Add Voucher" Command="{Binding ShowAddVoucherCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" FontWeight="SemiBold"/>
                        <Button Content="🗑 Delete Voucher" Command="{Binding DeleteVoucherCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Separator Style="{StaticResource FluentSeparatorStyle}"/>
                        <TextBlock Text="{Binding CountDisplay}" VerticalAlignment="Center"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   Margin="{StaticResource InlineControlSpacing}"/>
                    </WrapPanel>
                </Border>
            </Border>
        </controls:EnterprisePageLayout.ToolbarContent>

        <Border Style="{StaticResource SectionCardStyle}" ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Coupons -->
                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🎫 Coupons" Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource CompactItemSpacing}"/>
                    <DataGrid Grid.Row="1" Style="{StaticResource EnterpriseDataGridStyle}"
                              ItemsSource="{Binding Coupons}"
                              SelectedItem="{Binding SelectedCoupon}"
                              MinHeight="80">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="*"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding DiscountType}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Value" Binding="{Binding DiscountValue}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTextColumn Header="Min Bill" Binding="{Binding MinBillAmount, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTextColumn Header="Used" Binding="{Binding CurrentUsageCount}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Max Uses" Binding="{Binding MaxUsageCount}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Active"
                                                Binding="{Binding IsActive, Converter={StaticResource BoolToActiveText}}"
                                                Width="{StaticResource ColumnWidthQty}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>

                <!-- Vouchers -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="🎁 Vouchers" Style="{StaticResource SectionHeaderStyle}"
                               Margin="{StaticResource CompactItemSpacing}"/>
                    <DataGrid Grid.Row="1" Style="{StaticResource EnterpriseDataGridStyle}"
                              ItemsSource="{Binding Vouchers}"
                              SelectedItem="{Binding SelectedVoucher}"
                              MinHeight="80">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="*"/>
                            <DataGridTextColumn Header="Face Value" Binding="{Binding FaceValue, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTextColumn Header="Active"
                                                Binding="{Binding IsActive, Converter={StaticResource BoolToActiveText}}"
                                                Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Expiry" Binding="{Binding ExpiryDate, StringFormat=d}" Width="{StaticResource ColumnWidthStatus}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Grid>
        </Border>

        <controls:EnterprisePageLayout.BottomFormContent>
            <StackPanel>
                <!-- Add Coupon Form -->
                <Border Style="{StaticResource FormCardStyle}"
                        Visibility="{Binding IsAddCouponVisible, Converter={StaticResource BoolToVisibility}}"
                        h:KeyboardNav.DefaultCommand="{Binding SaveCouponCommand}"
                        h:KeyboardNav.EscapeCommand="{Binding CancelAddCouponCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                                   Text="New Coupon" Style="{StaticResource SectionHeaderStyle}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Code *" Style="{StaticResource FormRowLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewCouponCode, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Discount %" Style="{StaticResource FormRowLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding NewCouponDiscountValue, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Grid.Row="3" Grid.ColumnSpan="4" Orientation="Horizontal"
                                    HorizontalAlignment="Right" Margin="{StaticResource FormActionBarSpacing}">
                            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"
                                       VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
                            <Button Content="Cancel" Command="{Binding CancelAddCouponCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                            <Button Content="💾 Save" Command="{Binding SaveCouponCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Add Voucher Form -->
                <Border Style="{StaticResource FormCardStyle}"
                        Visibility="{Binding IsAddVoucherVisible, Converter={StaticResource BoolToVisibility}}"
                        h:KeyboardNav.DefaultCommand="{Binding SaveVoucherCommand}"
                        h:KeyboardNav.EscapeCommand="{Binding CancelAddVoucherCommand}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                                   Text="New Voucher" Style="{StaticResource SectionHeaderStyle}"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Code *" Style="{StaticResource FormRowLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewVoucherCode, UpdateSourceTrigger=PropertyChanged}"/>
                        <TextBlock Grid.Row="2" Grid.Column="2" Text="Face Value ₹" Style="{StaticResource FormRowLabelStyle}"/>
                        <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding NewVoucherFaceValue, UpdateSourceTrigger=PropertyChanged}"/>

                        <StackPanel Grid.Row="3" Grid.ColumnSpan="4" Orientation="Horizontal"
                                    HorizontalAlignment="Right" Margin="{StaticResource FormActionBarSpacing}">
                            <Button Content="Cancel" Command="{Binding CancelAddVoucherCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                            <Button Content="💾 Save" Command="{Binding SaveVoucherCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </controls:EnterprisePageLayout.BottomFormContent>

    </controls:EnterprisePageLayout>
</UserControl>
