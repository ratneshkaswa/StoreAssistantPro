<UserControl x:Class="StoreAssistantPro.Modules.Quotations.Views.QuotationManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8A5;"/><Run Text=" Quotation Management"/></TextBlock>
            <TextBlock Text="Build customer quotations, manage line items, and move approved quotations into the next sales step."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FluentSearchTextBoxStyle}"
                     AutomationProperties.Name="Search quotations"
                     h:Watermark.Text="Search quotations by number or customer"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding FilterStatus}"
                      Style="{StaticResource FluentComboBoxStyle}"
                      Width="{StaticResource FieldWidthStandard}"
                      Margin="{StaticResource InlineControlSpacing}"
                      AutomationProperties.Name="Filter by status">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource NullToAllConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2"
                    Content="Search"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource SearchButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource MasterDetailListPaneWidth}"/>
                <ColumnDefinition Width="{StaticResource MasterDetailPaneGapWidth}"/>
                <ColumnDefinition Width="{StaticResource MasterDetailEditorPaneWidth}"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid AutomationProperties.Name="Quotations list"
                          ItemsSource="{Binding Quotations}"
                          SelectedItem="{Binding SelectedQuotation}"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          h:DataGridLayoutPersistence.Key="QuotationsGrid"
                          h:DataGridEmptyState.Icon="&#x1F4CB;"
                          h:DataGridEmptyState.Title="No quotations found"
                          h:DataGridEmptyState.Description="Create a quotation to estimate pricing for customers."
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Quote #" Binding="{Binding QuoteNumber}" Width="{StaticResource ColumnWidthId}"/>
                        <DataGridTextColumn Header="Customer" Binding="{Binding Customer.Name}" Width="*"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding QuoteDate, StringFormat=dd-MMM-yyyy}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Valid Until" Binding="{Binding ValidUntil, StringFormat=dd-MMM-yyyy}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1"
                            Style="{StaticResource PaginatorBarStyle}"
                            Visibility="{Binding TotalCount, Converter={StaticResource PositiveToVisibility}}">
                    <Button Content="Prev"
                            Command="{Binding PreviousPageCommand}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding PagingInfo}"
                               VerticalAlignment="Center"
                               Style="{StaticResource PaginatorInfoTextStyle}"/>
                    <Button Content="Next"
                            Command="{Binding NextPageCommand}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False"
                          Margin="{StaticResource ItemSpacing}">
                <StackPanel>
                    <Border Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="New Quotation"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Select the customer, choose the validity date, and add notes before pricing the quotation."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                            <TextBlock Text="Customer (optional)" Style="{StaticResource FormRowLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Customers}"
                                      SelectedItem="{Binding SelectedCustomer}"
                                      DisplayMemberPath="Name"
                                      Style="{StaticResource FluentAutoSuggestComboBoxStyle}"
                                      AutomationProperties.Name="Customer"
                                      Margin="0,0,0,8"/>

                            <TextBlock Text="Valid Until" Style="{StaticResource FormRowLabelStyle}"/>
                            <DatePicker SelectedDate="{Binding ValidUntilDate}"
                                        Style="{StaticResource FluentDatePickerStyle}"
                                        AutomationProperties.Name="Valid until date"
                                        Margin="0,0,0,8"/>

                            <TextBlock Text="Notes" Style="{StaticResource FormRowLabelStyle}"/>
                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FluentMultilineTextBoxStyle}"
                                     MaxLength="500"
                                     AutomationProperties.Name="Notes"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Line Items"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Add products, quantities, and unit prices before creating the quotation."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                            <ItemsControl ItemsSource="{Binding LineItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <ComboBox ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                      SelectedValue="{Binding ProductId}"
                                                      SelectedValuePath="Id"
                                                      DisplayMemberPath="Name"
                                                      Style="{StaticResource FluentAutoSuggestComboBoxStyle}"
                                                      AutomationProperties.Name="Product"/>
                                            <TextBox Grid.Column="1"
                                                     Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FluentTextBoxStyle}"
                                                     Margin="4,0,0,0"
                                                     AutomationProperties.Name="Quantity"/>
                                            <TextBox Grid.Column="2"
                                                     Text="{Binding UnitPrice, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource FluentTextBoxStyle}"
                                                     Margin="4,0,0,0"
                                                     AutomationProperties.Name="Unit price"/>
                                            <Button Grid.Column="3"
                                                    Content="Remove"
                                                    Command="{Binding DataContext.RemoveLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Style="{StaticResource InlineCollectionRemoveButtonStyle}"
                                                    ToolTip="Remove quotation line"
                                                    AutomationProperties.Name="Remove quotation line"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <WrapPanel Style="{StaticResource LineItemActionRowStyle}">
                                <Button Content="Add Line"
                                        Command="{Binding AddLineCommand}"
                                        Style="{StaticResource InlineCollectionAddButtonStyle}"/>
                                <Button Content="Create Quotation"
                                        Command="{Binding CreateQuotationCommand}"
                                        Style="{StaticResource SaveButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="State Actions"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Progress the selected quotation only when its current status allows the next state."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                            <WrapPanel Style="{StaticResource StateTransitionActionBarStyle}">
                                <Button Content="Mark Sent"
                                        Command="{Binding MarkSentCommand}"
                                        IsEnabled="{Binding CanMarkSent}"
                                        Style="{StaticResource StateTransitionSecondaryButtonStyle}"/>
                                <Button Content="Accept"
                                        Command="{Binding AcceptQuotationCommand}"
                                        IsEnabled="{Binding CanAccept}"
                                        Style="{StaticResource StateTransitionPrimaryButtonStyle}"/>
                                <Button Content="Reject"
                                        Command="{Binding RejectQuotationCommand}"
                                        IsEnabled="{Binding CanReject}"
                                        Style="{StaticResource StateTransitionDestructiveButtonStyle}"/>
                                <Button Content="Convert to Sale"
                                        Command="{Binding ConvertToSaleCommand}"
                                        IsEnabled="{Binding CanConvert}"
                                        Style="{StaticResource StateTransitionPrimaryButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <controls:ErrorStateOverlay Grid.Row="2"
                                    IsOpen="{Binding HasLoadError}"
                                    Icon=":("
                                    Title="Couldn't load quotation data"
                                    Description="{Binding LoadErrorMessage}"
                                    ActionText="Retry"
                                    ActionCommand="{Binding LoadCommand}"/>

        <Grid Grid.Row="3"
              MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>
    </Grid>
</UserControl>
