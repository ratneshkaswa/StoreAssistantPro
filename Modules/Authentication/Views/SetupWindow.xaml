<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Store Assistant Pro"
        Icon="pack://application:,,,/Assets/app.ico"
        FontFamily="{StaticResource FluentFontFamily}"
        Closing="OnWindowClosing"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource AppBackgroundBrush}"
        MinWidth="{StaticResource SetupMinWidth}"
        MinHeight="{StaticResource SetupMinHeight}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <Style x:Key="SidebarIconBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="{StaticResource SetupSidebarIconSize}"/>
            <Setter Property="Height" Value="{StaticResource SetupSidebarIconSize}"/>
            <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
            <Setter Property="Margin" Value="{StaticResource SetupSidebarIconMargin}"/>
        </Style>

        <Style x:Key="SidebarNavItemStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="{StaticResource SetupSidebarNavBorderThickness}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="{StaticResource SetupSidebarNavPadding}"/>
            <Setter Property="Margin" Value="{StaticResource SetupSidebarNavMargin}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource FluentAccentDefault}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtlePressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        </Style>

        <Style x:Key="SidebarNavSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
            <Setter Property="Margin" Value="{StaticResource SetupSubtitleMargin}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="SectionSummaryLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </Window.Resources>

    <Grid Margin="{StaticResource SetupRootPadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue"
          h:KeyboardNav.EscapeCommand="{Binding CancelSetupCommand}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{StaticResource SetupRowSpacingMedium}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{StaticResource SetupRowSpacingSmall}"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{StaticResource SetupRowSpacingSmall}"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0"
                Background="{StaticResource FluentSurface}"
                BorderBrush="{StaticResource FluentStrokeDefault}"
                BorderThickness="{StaticResource FluentBorderThicknessThin}"
                CornerRadius="{StaticResource FluentCornerLarge}"
                Padding="{StaticResource SetupHeaderCardPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="{StaticResource SetupHeaderGap}"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Image Grid.Column="0"
                       Source="/Assets/logo-256.png"
                       Width="{StaticResource SetupLogoSize}"
                       Height="{StaticResource SetupLogoSize}"
                       VerticalAlignment="Center"
                       Margin="{StaticResource SetupLogoMargin}"/>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource FluentFontDisplay}"
                               FontSize="{StaticResource FontSizeSectionHeader}"
                               FontWeight="Bold"
                               Foreground="{StaticResource FluentTextPrimary}">
                        <Run Text="Store Assistant "/>
                        <Run Text="Pro" Foreground="{StaticResource FluentAccentDefault}"/>
                    </TextBlock>
                    <TextBlock Text="Set up your store details, billing defaults, security and backups before you begin."
                               FontFamily="{StaticResource FluentFontText}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentTextSecondary}"
                               Margin="{StaticResource SetupSubtitleMargin}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="3"
                        Background="{StaticResource FluentInfoBackground}"
                        CornerRadius="{StaticResource FluentCornerMedium}"
                        Padding="{StaticResource SetupProgressBadgePadding}"
                        VerticalAlignment="Center">
                    <StackPanel>
                        <TextBlock Text="Setup progress"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentTextSecondary}"/>
                        <TextBlock Text="{Binding RequiredFieldsProgress}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextPrimary}"
                                   AutomationProperties.LiveSetting="Polite"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main area -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource SetupSidebarColumnWidth}"/>
                <ColumnDefinition Width="{StaticResource SetupRowSpacingMedium}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0"
                    Background="{StaticResource FluentSurface}"
                    BorderBrush="{StaticResource FluentStrokeDefault}"
                    BorderThickness="{StaticResource FluentBorderThicknessThin}"
                    CornerRadius="{StaticResource FluentCornerLarge}"
                    Padding="{StaticResource SetupSidebarCardPadding}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>

                <DockPanel LastChildFill="True">
                    <StackPanel DockPanel.Dock="Top" Margin="{StaticResource SetupSidebarHeaderMargin}">
                        <TextBlock Text="Setup sections"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextPrimary}"/>
                        <TextBlock Text="Complete the essentials now. Advanced preferences can be adjusted later."
                                   Style="{StaticResource SectionSummaryLabelStyle}"
                                   Margin="{StaticResource SetupSubtitleMargin}"/>
                    </StackPanel>

                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False">
                        <StackPanel>
                            <RadioButton x:Name="NavFirm"
                                         Tag="Firm"
                                         IsChecked="True"
                                         GroupName="SetupNav"
                                         Style="{StaticResource SidebarNavItemStyle}"
                                         Click="OnSidebarSectionClick"
                                         AutomationProperties.Name="Firm Profile">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="&#xE73E;"
                                               FontFamily="{StaticResource FluentIconFont}"
                                               Foreground="{StaticResource FluentSuccess}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               VerticalAlignment="Center"
                                               Margin="{StaticResource SetupSidebarIconMargin}"
                                               Visibility="{Binding IsFirmSectionComplete, Converter={StaticResource BoolToVisibility}}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource FluentInfoBackground}"
                                                Style="{StaticResource SidebarIconBadgeStyle}">
                                            <TextBlock Text="&#xE913;"
                                                       FontFamily="{StaticResource FluentIconFont}"
                                                       Foreground="{StaticResource FluentAccentDefault}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="{StaticResource FontSizeBody}"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Firm Profile" Style="{StaticResource SidebarNavTitleStyle}"/>
                                            <TextBlock Text="Business name, address and contact details"
                                                       Style="{StaticResource SidebarNavSubtitleStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavTax"
                                         Tag="Tax"
                                         GroupName="SetupNav"
                                         Style="{StaticResource SidebarNavItemStyle}"
                                         Click="OnSidebarSectionClick"
                                         AutomationProperties.Name="Tax and Legal">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource FluentKpiGrayMuted}"
                                            Style="{StaticResource SidebarIconBadgeStyle}">
                                        <TextBlock Text="&#xE8A5;"
                                                   FontFamily="{StaticResource FluentIconFont}"
                                                   Foreground="{StaticResource FluentTextSecondary}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Tax &amp; Legal" Style="{StaticResource SidebarNavTitleStyle}"/>
                                        <TextBlock Text="GST registration, GSTIN, PAN and tax defaults"
                                                   Style="{StaticResource SidebarNavSubtitleStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavRegional"
                                         Tag="Regional"
                                         GroupName="SetupNav"
                                         Style="{StaticResource SidebarNavItemStyle}"
                                         Click="OnSidebarSectionClick"
                                         AutomationProperties.Name="Regional Settings">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource FluentKpiGrayMuted}"
                                            Style="{StaticResource SidebarIconBadgeStyle}">
                                        <TextBlock Text="&#xE774;"
                                                   FontFamily="{StaticResource FluentIconFont}"
                                                   Foreground="{StaticResource FluentTextSecondary}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Regional Settings" Style="{StaticResource SidebarNavTitleStyle}"/>
                                        <TextBlock Text="Date format and financial year preferences"
                                                   Style="{StaticResource SidebarNavSubtitleStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavSecurity"
                                         Tag="Security"
                                         GroupName="SetupNav"
                                         Style="{StaticResource SidebarNavItemStyle}"
                                         Click="OnSidebarSectionClick"
                                         AutomationProperties.Name="Security Settings">
                                <DockPanel>
                                    <TextBlock DockPanel.Dock="Right"
                                               Text="&#xE73E;"
                                               FontFamily="{StaticResource FluentIconFont}"
                                               Foreground="{StaticResource FluentSuccess}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               VerticalAlignment="Center"
                                               Margin="{StaticResource SetupSidebarIconMargin}"
                                               Visibility="{Binding IsSecuritySectionComplete, Converter={StaticResource BoolToVisibility}}"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource FluentInfoBackground}"
                                                Style="{StaticResource SidebarIconBadgeStyle}">
                                            <TextBlock Text="&#xE72E;"
                                                       FontFamily="{StaticResource FluentIconFont}"
                                                       Foreground="{StaticResource FluentAccentDefault}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="{StaticResource FontSizeBody}"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Security Settings" Style="{StaticResource SidebarNavTitleStyle}"/>
                                            <TextBlock Text="Role PINs and master authorization PIN"
                                                       Style="{StaticResource SidebarNavSubtitleStyle}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavBackup"
                                         Tag="Backup"
                                         GroupName="SetupNav"
                                         Style="{StaticResource SidebarNavItemStyle}"
                                         Click="OnSidebarSectionClick"
                                         AutomationProperties.Name="Backup and Data">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource FluentKpiGrayMuted}"
                                            Style="{StaticResource SidebarIconBadgeStyle}">
                                        <TextBlock Text="&#xE74E;"
                                                   FontFamily="{StaticResource FluentIconFont}"
                                                   Foreground="{StaticResource FluentTextSecondary}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Backup &amp; Data" Style="{StaticResource SidebarNavTitleStyle}"/>
                                        <TextBlock Text="Automatic backup schedule and storage"
                                                   Style="{StaticResource SidebarNavSubtitleStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>

                            <RadioButton x:Name="NavSystem"
                                         Tag="System"
                                         GroupName="SetupNav"
                                         Style="{StaticResource SidebarNavItemStyle}"
                                         Click="OnSidebarSectionClick"
                                         AutomationProperties.Name="System Settings">
                                <StackPanel Orientation="Horizontal">
                                    <Border Background="{StaticResource FluentKpiGrayMuted}"
                                            Style="{StaticResource SidebarIconBadgeStyle}">
                                        <TextBlock Text="&#xE713;"
                                                   FontFamily="{StaticResource FluentIconFont}"
                                                   Foreground="{StaticResource FluentTextSecondary}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   FontSize="{StaticResource FontSizeBody}"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="System Settings" Style="{StaticResource SidebarNavTitleStyle}"/>
                                        <TextBlock Text="Billing behavior, rounding and inventory rules"
                                                   Style="{StaticResource SidebarNavSubtitleStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </RadioButton>
                        </StackPanel>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <!-- Content shell -->
            <Border Grid.Column="2"
                    Background="{StaticResource FluentSurface}"
                    BorderBrush="{StaticResource FluentStrokeDefault}"
                    BorderThickness="{StaticResource FluentBorderThicknessThin}"
                    CornerRadius="{StaticResource FluentCornerLarge}">
                <Grid>
                    <Frame x:Name="ContentFrame"
                           NavigationUIVisibility="Hidden"
                           JournalOwnership="OwnsJournal"
                           Focusable="False">
                        <Frame.Style>
                            <Style TargetType="Frame">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Frame.Style>
                    </Frame>

                    <!-- Setup complete overlay -->
                    <Grid Visibility="{Binding IsSetupComplete, Converter={StaticResource BoolToVisibility}}"
                          h:Motion.FadeIn="True">
                        <Border Margin="{StaticResource SetupCompleteOverlayMargin}"
                                Background="{StaticResource FluentSurface}"
                                BorderBrush="{StaticResource FluentStrokeDefault}"
                                BorderThickness="{StaticResource FluentBorderThicknessThin}"
                                CornerRadius="{StaticResource FluentCornerLarge}"
                                Padding="{StaticResource SetupCompleteCardPadding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="{StaticResource SetupCompleteMaxWidth}">
                            <StackPanel>
                                <TextBlock Text="&#xE73E;"
                                           FontFamily="{StaticResource FluentIconFont}"
                                           FontSize="{StaticResource FontSizeIconLarge}"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource FluentSuccess}"
                                           Margin="{StaticResource SetupCompleteIconMargin}"
                                           AutomationProperties.Name="Setup complete checkmark"/>
                                <TextBlock Text="Setup complete"
                                           FontSize="{StaticResource FontSizeSectionHeader}"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource FluentTextPrimary}"
                                           AutomationProperties.LiveSetting="Polite"/>
                                <TextBlock Text="Your store settings have been saved successfully."
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="{StaticResource SetupCompleteSubtitleMargin}"/>
                                <TextBlock Text="{Binding RedirectCountdown}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           AutomationProperties.LiveSetting="Polite"
                                           HorizontalAlignment="Center"
                                           Margin="{StaticResource SetupCompleteCountdownMargin}"/>
                                <Button Content="Go to Login"
                                        Command="{Binding GoToLoginCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        MinWidth="{StaticResource SetupPrimaryButtonWidth}"
                                        MinHeight="{StaticResource SetupButtonHeight}"
                                        HorizontalAlignment="Center"
                                        Margin="{StaticResource SetupCompleteButtonMargin}"
                                        AutomationProperties.Name="Go to login"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- Message area -->
        <Border Grid.Row="4"
                Background="{StaticResource FluentSurface}"
                BorderBrush="{StaticResource FluentStrokeDefault}"
                BorderThickness="{StaticResource FluentBorderThicknessThin}"
                CornerRadius="{StaticResource FluentCornerMedium}"
                Padding="{StaticResource SetupMessageCardPadding}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding SuccessMessage}"
                           Style="{StaticResource SuccessMessageStyle}"
                           AutomationProperties.LiveSetting="Polite"/>

                <TextBlock Grid.Row="1"
                           Text="{Binding ErrorMessage}"
                           AutomationProperties.LiveSetting="Assertive">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock" BasedOn="{StaticResource ErrorMessageStyle}">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Border>

        <!-- Footer actions -->
        <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0"
                       Text="You can change most preferences later from Settings."
                       VerticalAlignment="Center"
                       Foreground="{StaticResource FluentTextSecondary}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Cancel"
                        Command="{Binding CancelSetupCommand}"
                        MinWidth="{StaticResource SetupPrimaryButtonWidth}"
                        MinHeight="{StaticResource SetupButtonHeight}"
                        Margin="{StaticResource SetupCancelButtonMargin}"
                        AutomationProperties.Name="Cancel setup and close">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Save and Finish Setup"
                        Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        MinWidth="{StaticResource SetupPrimaryButtonWidth}"
                        MinHeight="{StaticResource SetupButtonHeight}"
                        ToolTip="{Binding RequiredFieldsProgress}"
                        AutomationProperties.Name="Save setup and continue">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Loading overlay -->
        <Grid Grid.Row="0"
              Grid.RowSpan="7"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
              IsHitTestVisible="True"
              Focusable="True"
              FocusManager.IsFocusScope="True"
              KeyboardNavigation.TabNavigation="Cycle"
              KeyboardNavigation.DirectionalNavigation="Cycle">
            <Border Background="{StaticResource LoadingOverlayScrim}"
                    Opacity="{StaticResource OverlayOpacity}"/>

            <Border Background="{StaticResource FluentSurface}"
                    CornerRadius="{StaticResource FluentCornerLarge}"
                    BorderBrush="{StaticResource FluentStrokeDefault}"
                    BorderThickness="{StaticResource FluentBorderThicknessThin}"
                    Padding="{StaticResource SetupLoadingCardPadding}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    MinWidth="{StaticResource SetupLoadingMinWidth}">
                <StackPanel>
                    <TextBlock Text="&#xE895;"
                               FontFamily="{StaticResource FluentIconFont}"
                               FontSize="{StaticResource FontSizeIconLarge}"
                               Foreground="{StaticResource FluentAccentDefault}"
                               HorizontalAlignment="Center"
                               Margin="{StaticResource SetupLoadingIconMargin}"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0"
                                                                     To="360"
                                                                     Duration="{StaticResource SpinnerDuration}"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Text="Saving your setup..."
                               FontFamily="{StaticResource FluentFontText}"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FluentTextPrimary}"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Please wait while your store configuration is being saved."
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentTextSecondary}"
                               TextAlignment="Center"
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"
                               Margin="{StaticResource SetupLoadingDescMargin}"
                               MaxWidth="{StaticResource SetupLoadingDescMaxWidth}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>