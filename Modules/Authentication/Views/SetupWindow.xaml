<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="One Time Setup"
        Icon="pack://application:,,,/Assets/app.ico"
        Closing="OnWindowClosing">

    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:AppBranding Grid.Row="0" LogoSize="48"/>

        <Grid Grid.Row="1">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsSetupComplete, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="&#x2705;" FontSize="{StaticResource FontSizeIconLarge}" HorizontalAlignment="Center"
                               Margin="{StaticResource ItemSpacing}"/>
                    <TextBlock Text="Setup Complete!"
                               FontSize="{StaticResource FontSizeSectionHeader}" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource FluentSuccess}"
                               Margin="{StaticResource FieldLabelSpacing}"/>
                    <TextBlock Text="{Binding RedirectCountdown}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{StaticResource FluentTextSecondary}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <StackPanel>
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <Border Style="{StaticResource FormCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Firm Details" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Style="{StaticResource FormRowLabelStyle}"
                                           AutomationProperties.Name="Firm Name required">
                                    <Run Text="Firm Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                                </TextBlock>
                                <TextBox Grid.Column="1" x:Name="FirmNameBox"
                                         Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="200" h:Watermark.Text="e.g. Sharma Textiles"
                                         AutomationProperties.Name="Firm Name"/>
                            </Grid>
                            <TextBlock Text="You can add address, phone, GSTIN later from Firm Management."
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Foreground="{StaticResource FluentTextTertiary}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource FormCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Security PINs" Style="{StaticResource SectionHeaderStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource RoleAdminBackground}"
                                        CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                                    <TextBlock Text="&#x1F6E1;&#xFE0F; Admin" FontWeight="SemiBold"
                                               Foreground="{StaticResource RoleAdminAccent}" FontSize="{StaticResource FontSizeBody}"/>
                                </Border>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="PIN (4 digits)" Style="{StaticResource FormRowLabelStyle}"/>
                                <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="AdminPinBox" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Admin PIN"/>
                                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                    <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                    <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                                    <TextBlock Text="{Binding AdminPinWarning}" Margin="{StaticResource StrengthLabelGap}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentWarning}"/>
                                </StackPanel>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Confirm" Style="{StaticResource FormRowLabelStyle}"/>
                                <PasswordBox Grid.Row="3" Grid.Column="1" x:Name="AdminPinConfirmBox" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm Admin PIN"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="&#x2713; Match" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentSuccess}">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding AdminConfirmHint}" Value="&#x2713; Match"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>

                                <Border Grid.Row="6" Grid.ColumnSpan="2" Background="{StaticResource RoleManagerBackground}"
                                        CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                                    <TextBlock Text="&#x1F4CB; Manager" FontWeight="SemiBold"
                                               Foreground="{StaticResource RoleManagerAccent}" FontSize="{StaticResource FontSizeBody}"/>
                                </Border>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="PIN (4 digits)" Style="{StaticResource FormRowLabelStyle}"/>
                                <PasswordBox Grid.Row="7" Grid.Column="1" x:Name="ManagerPinBox" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Manager PIN"/>
                                <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                    <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                    <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                                    <TextBlock Text="{Binding ManagerPinWarning}" Margin="{StaticResource StrengthLabelGap}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentWarning}"/>
                                </StackPanel>
                                <TextBlock Grid.Row="9" Grid.Column="0" Text="Confirm" Style="{StaticResource FormRowLabelStyle}"/>
                                <PasswordBox Grid.Row="9" Grid.Column="1" x:Name="ManagerPinConfirmBox" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm Manager PIN"/>
                                <TextBlock Grid.Row="10" Grid.Column="1" Text="&#x2713; Match" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentSuccess}">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding ManagerConfirmHint}" Value="&#x2713; Match"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>

                                <Border Grid.Row="12" Grid.ColumnSpan="2" Background="{StaticResource RoleUserBackground}"
                                        CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                                    <TextBlock Text="&#x1F464; User" FontWeight="SemiBold"
                                               Foreground="{StaticResource RoleUserAccent}" FontSize="{StaticResource FontSizeBody}"/>
                                </Border>
                                <TextBlock Grid.Row="13" Grid.Column="0" Text="PIN (4 digits)" Style="{StaticResource FormRowLabelStyle}"/>
                                <PasswordBox Grid.Row="13" Grid.Column="1" x:Name="UserPinBox" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="User PIN"/>
                                <StackPanel Grid.Row="14" Grid.Column="1" Orientation="Horizontal">
                                    <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                    <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                    <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                                    <TextBlock Text="{Binding UserPinWarning}" Margin="{StaticResource StrengthLabelGap}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentWarning}"/>
                                </StackPanel>
                                <TextBlock Grid.Row="15" Grid.Column="0" Text="Confirm" Style="{StaticResource FormRowLabelStyle}"/>
                                <PasswordBox Grid.Row="15" Grid.Column="1" x:Name="UserPinConfirmBox" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm User PIN"/>
                                <TextBlock Grid.Row="16" Grid.Column="1" Text="&#x2713; Match" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentSuccess}">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding UserConfirmHint}" Value="&#x2713; Match"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>

                                <Border Grid.Row="18" Grid.ColumnSpan="2" Background="{StaticResource FluentSurfaceElevated}"
                                        CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                                    <TextBlock Text="&#x1F510; Master Password" FontWeight="SemiBold"
                                               Foreground="{StaticResource FluentTextPrimary}" FontSize="{StaticResource FontSizeBody}"
                                               ToolTip="Used to recover or change PINs if forgotten."/>
                                </Border>
                                <TextBlock Grid.Row="19" Grid.Column="0" Text="Password (6 digits)" Style="{StaticResource FormRowLabelStyle}"/>
                                <PasswordBox Grid.Row="19" Grid.Column="1" x:Name="MasterPinBox" MaxLength="6" PasswordChanged="OnPinChanged" AutomationProperties.Name="Master Password"/>
                                <TextBlock Grid.Row="21" Grid.Column="0" Text="Confirm" Style="{StaticResource FormRowLabelStyle}"/>
                                <PasswordBox Grid.Row="21" Grid.Column="1" x:Name="MasterPinConfirmBox" MaxLength="6" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm Master Password"/>
                                <TextBlock Grid.Row="22" Grid.Column="1" Text="&#x2713; Match" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentSuccess}">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Setter Property="Visibility" Value="Collapsed"/><Style.Triggers><DataTrigger Binding="{Binding MasterConfirmHint}" Value="&#x2713; Match"><Setter Property="Visibility" Value="Visible"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>

                                <TextBlock Grid.Row="23" Grid.Column="1" Text="{Binding PinConflictWarning}" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentError}" Margin="{StaticResource FieldLabelSpacing}">
                                    <TextBlock.Style><Style TargetType="TextBlock"><Style.Triggers><DataTrigger Binding="{Binding PinConflictWarning}" Value=""><Setter Property="Visibility" Value="Collapsed"/></DataTrigger></Style.Triggers></Style></TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <StackPanel HorizontalAlignment="Center" Margin="{StaticResource FieldLabelSpacing}">
                        <TextBlock Text="&#x1F4A1; Remember your PINs &#x2014; you will need them to log in."
                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentWarning}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="&#x1F510; Master Password is used to authorize critical actions such as deleting major records."
                                   FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentTextTertiary}"
                                   HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
                </StackPanel>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}" Margin="{StaticResource FieldLabelSpacing}"/>

        <Button Grid.Row="3" Content="Complete Setup" Command="{Binding SaveCommand}"
                HorizontalAlignment="Right"
                Margin="{StaticResource FormActionBarSpacing}" AutomationProperties.Name="Complete first time setup">
            <Button.Style>
                <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Button.Style>
        </Button>

        <TextBlock Grid.Row="4" HorizontalAlignment="Center" FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentTextTertiary}" Margin="{StaticResource MessageBarSpacing}">
            <Run Text="&#x00A9; 2025 "/><Run Text="Ratnesh Kaswa" FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}"/>
        </TextBlock>
    </Grid>
</Window>