<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="One Time Setup"
        Icon="pack://application:,,,/Assets/app.ico"
        Closing="OnWindowClosing">
    <Window.InputBindings>
        <KeyBinding Key="Back" Command="{Binding PreviousStepCommand}"/>
    </Window.InputBindings>

    <Grid Margin="{StaticResource DialogPadding}"
          Background="{StaticResource FluentBackgroundSecondary}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Title -->
            <RowDefinition Height="Auto"/>  <!-- 1: Progress bar -->
            <RowDefinition Height="*"/>     <!-- 2: Step content -->
            <RowDefinition Height="Auto"/>  <!-- 3: Error -->
            <RowDefinition Height="Auto"/>  <!-- 4: Nav buttons -->
            <RowDefinition Height="Auto"/>  <!-- 5: Developer credit -->
        </Grid.RowDefinitions>

        <!-- ── Row 0: Logo + title (matches Login window) ───── -->
        <controls:AppBranding Grid.Row="0" LogoSize="48"/>

        <!-- ── Row 1: Numbered step circles + labels ──────────── -->
        <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                    Margin="0,4,0,4">
            <Grid Width="{StaticResource StepperWidth}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Step 1 circle -->
                <Border Grid.Column="0" Width="{StaticResource StepCircleSize}" Height="{StaticResource StepCircleSize}" CornerRadius="12"
                        HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource FluentSuccess}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="1" Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeCaption}" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <!-- Connector 1-2 -->
                <Border Grid.Column="1" Height="{StaticResource StepConnectorHeight}" VerticalAlignment="Center"
                        Margin="{StaticResource StepConnectorMargin}" CornerRadius="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource FluentStrokeDefault}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep1}" Value="False">
                                    <Setter Property="Background" Value="{StaticResource FluentSuccess}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <!-- Step 2 circle -->
                <Border Grid.Column="2" Width="{StaticResource StepCircleSize}" Height="{StaticResource StepCircleSize}" CornerRadius="12"
                        HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource FluentStrokeDefault}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentSuccess}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="2" FontSize="{StaticResource FontSizeCaption}" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
                <!-- Connector 2-3 -->
                <Border Grid.Column="3" Height="{StaticResource StepConnectorHeight}" VerticalAlignment="Center"
                        Margin="{StaticResource StepConnectorMargin}" CornerRadius="1">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource FluentStrokeDefault}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentSuccess}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>
                <!-- Step 3 circle -->
                <Border Grid.Column="4" Width="{StaticResource StepCircleSize}" Height="{StaticResource StepCircleSize}" CornerRadius="12"
                        HorizontalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource FluentStrokeDefault}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="3" FontSize="{StaticResource FontSizeCaption}" FontWeight="Bold"
                               HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>
            </Grid>
            <!-- Step labels — active step is bold + accented -->
            <Grid Width="{StaticResource StepperWidth}" Margin="{StaticResource FieldLabelSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="Firm Details" HorizontalAlignment="Left"
                           FontSize="{StaticResource FontSizeCaption}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="1" Text="Set PINs" HorizontalAlignment="Center"
                           FontSize="{StaticResource FontSizeCaption}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Grid.Column="2" Text="Confirm" HorizontalAlignment="Right"
                           FontSize="{StaticResource FontSizeCaption}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </StackPanel>

        <!-- ═════════════════════════════════════════════════════
             STEP 1: Firm Details
             ═════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden"
                    HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStep1}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <Grid VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="100"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!--  0: Firm Name -->
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>  <!--  2: Address -->
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>  <!--  4: Phone -->
                    <RowDefinition Height="Auto"/>  <!--  5: Phone hint -->
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>  <!--  7: Email -->
                    <RowDefinition Height="Auto"/>  <!--  8: Email hint -->
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>  <!-- 10: GSTIN -->
                    <RowDefinition Height="Auto"/>  <!-- 11: GSTIN hint -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0"
                           Style="{StaticResource FormRowLabelStyle}"
                           AutomationProperties.Name="Firm Name required">
                    <Run Text="Firm Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="FirmNameBox"
                         Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="200" h:Watermark.Text="e.g. Sharma Textiles"
                         AutomationProperties.Name="Firm Name"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Address"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="500" h:Watermark.Text="e.g. 12 MG Road, Indore, MP"
                         AutomationProperties.Name="Address"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="20" h:Watermark.Text="e.g. 9876543210"
                         PreviewTextInput="OnPreviewPhoneOnly"
                         AutomationProperties.Name="Phone number"/>
                <TextBlock Grid.Row="5" Grid.Column="1"
                           Text="{Binding PhoneValidationHint}"
                           FontSize="{StaticResource FontSizeCaption}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding PhoneValidationHint}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding PhoneValidationHint}" Value="Digits, +, - and spaces only">
                                    <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Row="7" Grid.Column="0" Text="Email"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="7" Grid.Column="1"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="200" h:Watermark.Text="e.g. store@example.com"
                         AutomationProperties.Name="Email address"/>
                <TextBlock Grid.Row="8" Grid.Column="1"
                           Text="{Binding EmailValidationHint}"
                           FontSize="{StaticResource FontSizeCaption}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding EmailValidationHint}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding EmailValidationHint}" Value="Enter a valid email address">
                                    <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Row="10" Grid.Column="0" Text="GSTIN"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="10" Grid.Column="1"
                         Text="{Binding GSTIN, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="15" h:Watermark.Text="e.g. 22AAAAA0000A1Z5"
                         CharacterCasing="Upper"
                         AutomationProperties.Name="GST Identification Number"/>
                <TextBlock Grid.Row="11" Grid.Column="1"
                           Text="{Binding GstinValidationHint}"
                           FontSize="{StaticResource FontSizeCaption}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding GstinValidationHint}" Value="">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding GstinValidationHint}" Value="Format: 22AAAAA0000A1Z5">
                                    <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </ScrollViewer>

        <!-- ═════════════════════════════════════════════════════
             STEP 2: Set PINs
             ═════════════════════════════════════════════════════ -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Hidden"
                    HorizontalScrollBarVisibility="Disabled">
            <ScrollViewer.Style>
                <Style TargetType="ScrollViewer">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStep2}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </ScrollViewer.Style>
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!--  0: Admin header -->
                        <RowDefinition Height="Auto"/>  <!--  1: Admin PIN -->
                        <RowDefinition Height="Auto"/>  <!--  2: Admin strength -->
                        <RowDefinition Height="Auto"/>  <!--  3: Admin confirm -->
                        <RowDefinition Height="Auto"/>  <!--  4: Admin confirm hint -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>  <!--  6: Manager header -->
                        <RowDefinition Height="Auto"/>  <!--  7: Manager PIN -->
                        <RowDefinition Height="Auto"/>  <!--  8: Manager strength -->
                        <RowDefinition Height="Auto"/>  <!--  9: Manager confirm -->
                        <RowDefinition Height="Auto"/>  <!-- 10: Manager confirm hint -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>  <!-- 12: User header -->
                        <RowDefinition Height="Auto"/>  <!-- 13: User PIN -->
                        <RowDefinition Height="Auto"/>  <!-- 14: User strength -->
                        <RowDefinition Height="Auto"/>  <!-- 15: User confirm -->
                        <RowDefinition Height="Auto"/>  <!-- 16: User confirm hint -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>  <!-- 18: Master header -->
                        <RowDefinition Height="Auto"/>  <!-- 19: Master PIN -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>  <!-- 21: Master confirm -->
                        <RowDefinition Height="Auto"/>  <!-- 22: Master confirm hint -->
                        <RowDefinition Height="Auto"/>  <!-- 23: Conflict warning -->
                    </Grid.RowDefinitions>

                    <!-- ── Admin (blue pastel section) ── -->
                    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource RoleAdminBackground}"
                            CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                        <TextBlock Text="🛡️ Admin" FontWeight="SemiBold"
                                   Foreground="{StaticResource RoleAdminAccent}"
                                   FontSize="{StaticResource FontSizeBody}"/>
                    </Border>
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="PIN (4 digits)"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <PasswordBox Grid.Row="1" Grid.Column="1"
                                 x:Name="AdminPinBox" MaxLength="4"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.Name="Admin PIN"/>
                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                        <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}"
                                Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                        <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}"
                                Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                        <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}"
                                Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                        <TextBlock Text="{Binding AdminPinWarning}" Margin="{StaticResource StrengthLabelGap}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentWarning}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Confirm"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <PasswordBox Grid.Row="3" Grid.Column="1"
                                 x:Name="AdminPinConfirmBox" MaxLength="4"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.Name="Confirm Admin PIN"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="✓ Match"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentSuccess}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding AdminConfirmHint}" Value="✓ Match">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ── Manager (purple pastel section) ── -->
                    <Border Grid.Row="6" Grid.ColumnSpan="2" Background="{StaticResource RoleManagerBackground}"
                            CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                        <TextBlock Text="📋 Manager" FontWeight="SemiBold"
                                   Foreground="{StaticResource RoleManagerAccent}"
                                   FontSize="{StaticResource FontSizeBody}"/>
                    </Border>
                    <TextBlock Grid.Row="7" Grid.Column="0" Text="PIN (4 digits)"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <PasswordBox Grid.Row="7" Grid.Column="1"
                                 x:Name="ManagerPinBox" MaxLength="4"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.Name="Manager PIN"/>
                    <StackPanel Grid.Row="8" Grid.Column="1" Orientation="Horizontal">
                        <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}"
                                Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                        <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}"
                                Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                        <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}"
                                Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                        <TextBlock Text="{Binding ManagerPinWarning}" Margin="{StaticResource StrengthLabelGap}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentWarning}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Confirm"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <PasswordBox Grid.Row="9" Grid.Column="1"
                                 x:Name="ManagerPinConfirmBox" MaxLength="4"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.Name="Confirm Manager PIN"/>
                    <TextBlock Grid.Row="10" Grid.Column="1" Text="✓ Match"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentSuccess}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ManagerConfirmHint}" Value="✓ Match">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ── User (green pastel section) ── -->
                    <Border Grid.Row="12" Grid.ColumnSpan="2" Background="{StaticResource RoleUserBackground}"
                            CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                        <TextBlock Text="👤 User" FontWeight="SemiBold"
                                   Foreground="{StaticResource RoleUserAccent}"
                                   FontSize="{StaticResource FontSizeBody}"/>
                    </Border>
                    <TextBlock Grid.Row="13" Grid.Column="0" Text="PIN (4 digits)"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <PasswordBox Grid.Row="13" Grid.Column="1"
                                 x:Name="UserPinBox" MaxLength="4"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.Name="User PIN"/>
                    <StackPanel Grid.Row="14" Grid.Column="1" Orientation="Horizontal">
                        <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}"
                                Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                        <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}"
                                Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                        <Border Width="{StaticResource StrengthBarWidth}" Height="{StaticResource StrengthBarHeight}" CornerRadius="2" Margin="{StaticResource StrengthBarGap}"
                                Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                        <TextBlock Text="{Binding UserPinWarning}" Margin="{StaticResource StrengthLabelGap}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentWarning}"/>
                    </StackPanel>
                    <TextBlock Grid.Row="15" Grid.Column="0" Text="Confirm"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <PasswordBox Grid.Row="15" Grid.Column="1"
                                 x:Name="UserPinConfirmBox" MaxLength="4"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.Name="Confirm User PIN"/>
                    <TextBlock Grid.Row="16" Grid.Column="1" Text="✓ Match"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentSuccess}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UserConfirmHint}" Value="✓ Match">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- ── Master Password ── -->
                    <Border Grid.Row="18" Grid.ColumnSpan="2" Background="{StaticResource FluentSurfaceElevated}"
                            CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                        <TextBlock Text="🔐 Master Password" FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextPrimary}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   ToolTip="Used to recover or change PINs if forgotten."/>
                    </Border>
                    <TextBlock Grid.Row="19" Grid.Column="0" Text="Password (6 digits)"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <PasswordBox Grid.Row="19" Grid.Column="1"
                                 x:Name="MasterPinBox" MaxLength="6"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.Name="Master Password"/>
                    <TextBlock Grid.Row="21" Grid.Column="0" Text="Confirm"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <PasswordBox Grid.Row="21" Grid.Column="1"
                                 x:Name="MasterPinConfirmBox" MaxLength="6"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.Name="Confirm Master Password"/>
                    <TextBlock Grid.Row="22" Grid.Column="1" Text="✓ Match"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentSuccess}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding MasterConfirmHint}" Value="✓ Match">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <TextBlock Grid.Row="23" Grid.Column="1"
                               Text="{Binding PinConflictWarning}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentError}"
                               Margin="{StaticResource FieldLabelSpacing}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding PinConflictWarning}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- ═════════════════════════════════════════════════════
             STEP 3: Confirmation
             ═════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsStep3}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>

            <!-- Success overlay -->
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsSetupComplete, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="✅" FontSize="{StaticResource FontSizeIconLarge}" HorizontalAlignment="Center"
                           Margin="{StaticResource ItemSpacing}"/>
                <TextBlock Text="Setup Complete!"
                           FontSize="{StaticResource FontSizeSectionHeader}" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource FluentSuccess}"
                           Margin="{StaticResource FieldLabelSpacing}"/>
                <TextBlock Text="{Binding RedirectCountdown}"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource FluentTextSecondary}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Review panel -->
            <ScrollViewer VerticalScrollBarVisibility="Hidden"
                         HorizontalScrollBarVisibility="Disabled">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>
                <StackPanel>
                    <TextBlock Text="Please review your settings before completing setup."
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{StaticResource FluentTextSecondary}"
                               Margin="{StaticResource ItemSpacing}"/>

                    <!-- Firm details card -->
                    <Border Background="{StaticResource FluentSurfaceElevated}"
                            BorderBrush="{StaticResource FluentStrokeDefault}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{StaticResource CardPadding}"
                            Margin="{StaticResource CompactItemSpacing}"
                            Effect="{StaticResource FluentShadowSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                       Text="Firm Details" FontWeight="Bold"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="{StaticResource CompactItemSpacing}"/>

                            <TextBlock Grid.Row="1" Margin="{StaticResource CompactItemSpacing}">
                                <Run Text="Firm Name: " FontWeight="SemiBold"/>
                                <Run Text="{Binding FirmName, Mode=OneWay}"/>
                            </TextBlock>
                            <Button Grid.Row="1" Grid.Column="1" Content="Edit"
                                    Command="{Binding GoToStepCommand}" CommandParameter="1"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    FontSize="{StaticResource FontSizeCaption}"
                                    Padding="{StaticResource ChipPadding}"
                                    VerticalAlignment="Center"/>

                            <TextBlock Grid.Row="2" Margin="{StaticResource CompactItemSpacing}">
                                <Run Text="Address: " FontWeight="SemiBold"/>
                                <Run Text="{Binding AddressDisplay, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Grid.Row="3" Margin="{StaticResource CompactItemSpacing}">
                                <Run Text="Phone: " FontWeight="SemiBold"/>
                                <Run Text="{Binding PhoneDisplay, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Grid.Row="4" Margin="{StaticResource CompactItemSpacing}">
                                <Run Text="Email: " FontWeight="SemiBold"/>
                                <Run Text="{Binding EmailDisplay, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Grid.Row="5" Margin="{StaticResource CompactItemSpacing}">
                                <Run Text="GSTIN: " FontWeight="SemiBold"/>
                                <Run Text="{Binding GstinDisplay, Mode=OneWay}"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <!-- PINs card -->
                    <Border Background="{StaticResource FluentSurfaceElevated}"
                            BorderBrush="{StaticResource FluentStrokeDefault}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource FluentCornerMedium}"
                            Padding="{StaticResource CardPadding}"
                            Margin="{StaticResource CompactItemSpacing}"
                            Effect="{StaticResource FluentShadowSmall}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.ColumnSpan="2"
                                       Text="Security" FontWeight="Bold"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="{StaticResource CompactItemSpacing}"/>

                            <TextBlock Grid.Row="1" Margin="{StaticResource CompactItemSpacing}">
                                <Run Text="Admin PIN: " FontWeight="SemiBold"
                                     Foreground="{StaticResource RoleAdminAccent}"/>
                                <Run Text="••••"/>
                            </TextBlock>
                            <Button Grid.Row="1" Grid.Column="1" Content="Edit"
                                    Command="{Binding GoToStepCommand}" CommandParameter="2"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    FontSize="{StaticResource FontSizeCaption}"
                                    Padding="{StaticResource ChipPadding}"
                                    VerticalAlignment="Center"/>
                            <TextBlock Grid.Row="2" Margin="{StaticResource CompactItemSpacing}">
                                <Run Text="Manager PIN: " FontWeight="SemiBold"
                                     Foreground="{StaticResource RoleManagerAccent}"/>
                                <Run Text="••••"/>
                            </TextBlock>
                            <TextBlock Grid.Row="3" Margin="{StaticResource CompactItemSpacing}">
                                <Run Text="User PIN: " FontWeight="SemiBold"
                                     Foreground="{StaticResource RoleUserAccent}"/>
                                <Run Text="••••"/>
                            </TextBlock>
                            <TextBlock Grid.Row="4">
                                <Run Text="Master Password: " FontWeight="SemiBold"/>
                                <Run Text="••••••"/>
                            </TextBlock>
                        </Grid>
                    </Border>

                    <TextBlock Text="💡 Remember your PINs — you will need them to log in."
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentWarning}"
                               Margin="{StaticResource FieldLabelSpacing}"/>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- ── Row 3: Error ───────────────────────────────────── -->
        <TextBlock Grid.Row="3" Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorMessageStyle}"
                   Margin="{StaticResource FieldLabelSpacing}"/>

        <!-- ── Row 4: Navigation ──────────────────────────────── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="← Back" Command="{Binding PreviousStepCommand}"
                    Margin="{StaticResource InlineControlSpacing}"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    AutomationProperties.Name="Go to previous step"/>
            <Button Content="Next →" Command="{Binding NextStepCommand}"
                    AutomationProperties.Name="Go to next step">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
            <Button Content="Complete Setup" Command="{Binding SaveCommand}"
                    AutomationProperties.Name="Complete first time setup">
                <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>

        <!-- ── Row 5: Developer credit ────────────────────────────── -->
        <TextBlock Grid.Row="5" HorizontalAlignment="Center"
                   FontSize="{StaticResource FontSizeCaption}"
                   Foreground="{StaticResource FluentTextTertiary}"
                   Margin="{StaticResource MessageBarSpacing}">
            <Run Text="© 2025 "/><Run Text="Ratnesh Kaswa" FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}"/>
        </TextBlock>
    </Grid>
</Window>
