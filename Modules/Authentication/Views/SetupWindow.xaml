<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Store Assistant Pro"
        Icon="pack://application:,,,/Assets/app.ico"
        FontFamily="{StaticResource FluentFontFamily}"
        Closing="OnWindowClosing"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource AppBackgroundBrush}">

    <Window.Resources>
        <!-- Sidebar icon badge (colored rounded square background) -->
        <Style x:Key="SidebarIconBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="{StaticResource SetupSidebarIconSize}"/>
            <Setter Property="Height" Value="{StaticResource SetupSidebarIconSize}"/>
            <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
            <Setter Property="Margin" Value="{StaticResource SetupSidebarIconMargin}"/>
        </Style>

        <!-- Sidebar nav item button -->
        <Style x:Key="SidebarNavItemStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="{StaticResource SetupSidebarNavBorderThickness}"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="{StaticResource SetupSidebarNavPadding}"/>
            <Setter Property="Margin" Value="{StaticResource SetupSidebarNavMargin}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource FluentStrokeDefault}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource FluentAccentDefault}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtlePressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        </Style>

        <Style x:Key="SidebarNavSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
            <Setter Property="Margin" Value="{StaticResource SetupSubtitleMargin}"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        </Window.Resources>

    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue"
          h:KeyboardNav.EscapeCommand="{Binding CancelSetupCommand}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="{StaticResource SetupHeaderMargin}">
            <Image Source="/Assets/logo-256.png" Width="{StaticResource SetupLogoSize}" Height="{StaticResource SetupLogoSize}" VerticalAlignment="Center" Margin="{StaticResource SetupLogoMargin}"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock FontFamily="{StaticResource FluentFontDisplay}"
                           FontSize="{StaticResource FontSizeSectionHeader}"
                           FontWeight="Bold"
                           Foreground="{StaticResource FluentTextPrimary}">
                    <Run Text="Store Assistant "/><Run Text="Pro" Foreground="{StaticResource FluentAccentDefault}"/>
                </TextBlock>
                <TextBlock Text="Configure your store before starting operations."
                           FontFamily="{StaticResource FluentFontText}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource FluentTextSecondary}"
                           Margin="{StaticResource SetupSubtitleMargin}"/>
            </StackPanel>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource SetupSidebarWidth}"/>
                <ColumnDefinition Width="{StaticResource FormRowSpacing}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT PANEL: Sidebar Navigation -->
            <Border Grid.Column="0" VerticalAlignment="Stretch">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource SetupSidebarCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <RadioButton x:Name="NavFirm" Tag="Firm" IsChecked="True" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick"
                                 AutomationProperties.Name="Firm Profile">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Text="&#xE73E;" FontFamily="{StaticResource FluentIconFont}"
                                       Foreground="{StaticResource FluentSuccess}" FontSize="{StaticResource FontSizeCaption}"
                                       VerticalAlignment="Center" Margin="{StaticResource SetupSidebarIconMargin}"
                                       Visibility="{Binding IsFirmSectionComplete, Converter={StaticResource BoolToVisibility}}"/>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource FluentInfoBackground}" Style="{StaticResource SidebarIconBadgeStyle}">
                                    <TextBlock Text="&#xE913;" FontFamily="{StaticResource FluentIconFont}"
                                               Foreground="{StaticResource FluentAccentDefault}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="{StaticResource FontSizeBody}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Firm Profile" Style="{StaticResource SidebarNavTitleStyle}"/>
                                    <TextBlock Text="Name, address and contact" Style="{StaticResource SidebarNavSubtitleStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavTax" Tag="Tax" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick"
                                 AutomationProperties.Name="Tax and Legal">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentKpiGrayMuted}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Tax and Legal" Style="{StaticResource SidebarNavTitleStyle}"/>
                                <TextBlock Text="GSTIN, PAN and GST type" Style="{StaticResource SidebarNavSubtitleStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavRegional" Tag="Regional" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick"
                                 AutomationProperties.Name="Regional Settings">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentKpiGrayMuted}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE774;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Regional Settings" Style="{StaticResource SidebarNavTitleStyle}"/>
                                <TextBlock Text="Date format and financial year" Style="{StaticResource SidebarNavSubtitleStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavSecurity" Tag="Security" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick"
                                 AutomationProperties.Name="Security Settings">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Right" Text="&#xE73E;" FontFamily="{StaticResource FluentIconFont}"
                                       Foreground="{StaticResource FluentSuccess}" FontSize="{StaticResource FontSizeCaption}"
                                       VerticalAlignment="Center" Margin="{StaticResource SetupSidebarIconMargin}"
                                       Visibility="{Binding IsSecuritySectionComplete, Converter={StaticResource BoolToVisibility}}"/>
                            <StackPanel Orientation="Horizontal">
                                <Border Background="{StaticResource FluentInfoBackground}" Style="{StaticResource SidebarIconBadgeStyle}">
                                    <TextBlock Text="&#xE72E;" FontFamily="{StaticResource FluentIconFont}"
                                               Foreground="{StaticResource FluentAccentDefault}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               FontSize="{StaticResource FontSizeBody}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Security Settings" Style="{StaticResource SidebarNavTitleStyle}"/>
                                    <TextBlock Text="Role PINs and master key" Style="{StaticResource SidebarNavSubtitleStyle}"/>
                                </StackPanel>
                            </StackPanel>
                        </DockPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavBackup" Tag="Backup" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick"
                                 AutomationProperties.Name="Backup and Data">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentKpiGrayMuted}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE74E;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Backup &amp; Data" Style="{StaticResource SidebarNavTitleStyle}"/>
                                <TextBlock Text="Auto backup schedule" Style="{StaticResource SidebarNavSubtitleStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavSystem" Tag="System" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick"
                                 AutomationProperties.Name="System Settings">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentKpiGrayMuted}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE713;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="System Settings" Style="{StaticResource SidebarNavTitleStyle}"/>
                                <TextBlock Text="Tax mode, rounding and stock" Style="{StaticResource SidebarNavSubtitleStyle}"/>
                            </StackPanel>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- RIGHT PANEL: Frame navigation (one page at a time) -->
            <Frame x:Name="ContentFrame" Grid.Column="2"
                   NavigationUIVisibility="Hidden"
                   JournalOwnership="OwnsJournal"
                   Focusable="False">
                <Frame.Style>
                    <Style TargetType="Frame">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Frame.Style>
            </Frame>

            <!-- Setup Complete overlay (spans all columns, after sidebar/frame for correct Z-order) -->
            <StackPanel Grid.ColumnSpan="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsSetupComplete, Converter={StaticResource BoolToVisibility}}"
                        h:Motion.FadeIn="True">
                <TextBlock Text="&#xE73E;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconLarge}" HorizontalAlignment="Center"
                           Foreground="{StaticResource FluentSuccess}"
                           Margin="{StaticResource ItemSpacing}"
                           AutomationProperties.Name="Setup complete checkmark"/>
                <TextBlock Text="Setup Complete!"
                           FontSize="{StaticResource FontSizeSectionHeader}" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource FluentSuccess}"
                           AutomationProperties.LiveSetting="Polite"
                           Margin="{StaticResource FieldLabelSpacing}"/>
                <TextBlock Text="{Binding RedirectCountdown}"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource FluentTextSecondary}"
                           AutomationProperties.LiveSetting="Polite"
                           HorizontalAlignment="Center"
                           Margin="{StaticResource FieldLabelSpacing}"/>
                <Button Content="Go to Login" Command="{Binding GoToLoginCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        MinWidth="{StaticResource SetupPrimaryButtonWidth}"
                        MinHeight="{StaticResource SetupButtonHeight}"
                        HorizontalAlignment="Center"
                        AutomationProperties.Name="Skip countdown and go to login now"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}" Margin="{StaticResource FieldLabelSpacing}">
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                       AutomationProperties.LiveSetting="Polite"/>
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"
                       AutomationProperties.LiveSetting="Assertive"/>
        </StackPanel>

        <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding RequiredFieldsProgress}"
                       VerticalAlignment="Center"
                       Foreground="{Binding RequiredFieldsProgress, Converter={StaticResource HintForegroundConverter}}"
                       AutomationProperties.LiveSetting="Polite">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Cancel" Command="{Binding CancelSetupCommand}"
                        MinWidth="{StaticResource SetupPrimaryButtonWidth}"
                        MinHeight="{StaticResource SetupButtonHeight}"
                        Margin="{StaticResource SetupCancelButtonMargin}"
                        AutomationProperties.Name="Cancel setup and close">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <Button Content="Complete Setup" Command="{Binding SaveCommand}"
                        IsEnabled="{Binding IsBusy, Converter={StaticResource InverseBoolConverter}}"
                        MinWidth="{StaticResource SetupPrimaryButtonWidth}"
                        MinHeight="{StaticResource SetupButtonHeight}"
                        ToolTip="{Binding RequiredFieldsProgress}"
                        AutomationProperties.Name="Complete first time setup">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Loading overlay -->
        <Grid Grid.Row="0" Grid.RowSpan="4"
              Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
              IsHitTestVisible="True"
              Focusable="True"
              FocusManager.IsFocusScope="True"
              KeyboardNavigation.TabNavigation="Cycle"
              KeyboardNavigation.DirectionalNavigation="Cycle">
            <Border Background="{StaticResource LoadingOverlayScrim}"
                    Opacity="{StaticResource OverlayOpacity}"/>
            <Border Background="{StaticResource FluentSurface}"
                    CornerRadius="{StaticResource FluentCornerMedium}"
                    BorderBrush="{StaticResource FluentStrokeDefault}"
                    BorderThickness="{StaticResource FluentBorderThicknessThin}"
                    Padding="{StaticResource CardPadding}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="&#xE895;" FontFamily="{StaticResource FluentIconFont}"
                               FontSize="{StaticResource FontSizeIconLarge}"
                               Foreground="{StaticResource FluentAccentDefault}"
                               HorizontalAlignment="Center" Margin="{StaticResource ItemSpacing}"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                        <DataTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard RepeatBehavior="Forever">
                                                    <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(RotateTransform.Angle)"
                                                                     From="0" To="360" Duration="{StaticResource SpinnerDuration}"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </DataTrigger.EnterActions>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="Processing&#x2026;"
                               FontFamily="{StaticResource FluentFontText}"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FluentAccentDefault}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>

