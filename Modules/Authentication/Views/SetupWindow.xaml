<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Store Assistant Pro - Setup"
        Icon="pack://application:,,,/Assets/app.ico"
        FontFamily="{StaticResource FluentFontFamily}"
        Closing="OnWindowClosing"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource AppBackgroundBrush}"
        MinWidth="{StaticResource SetupMinWidth}"
        MinHeight="{StaticResource SetupMinHeight}">

    <Grid Margin="{StaticResource SetupRootPadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue"
          h:KeyboardNav.DefaultCommand="{Binding SaveCommand}"
          h:KeyboardNav.EscapeCommand="{Binding CancelSetupCommand}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{StaticResource SetupRowSpacingMedium}"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="{StaticResource SetupRowSpacingSmall}"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="{StaticResource SetupRowSpacingSmall}"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource FluentSurface}"
                BorderBrush="{StaticResource FluentStrokeDefault}"
                BorderThickness="{StaticResource FluentBorderThicknessThin}"
                CornerRadius="{StaticResource FluentCornerLarge}"
                Padding="{StaticResource SetupShellPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <DockPanel LastChildFill="False">
                        <Image Source="pack://application:,,,/Assets/logo-256.png"
                               Width="{StaticResource SetupLogoSize}"
                               Height="{StaticResource SetupLogoSize}"
                               Stretch="Uniform"
                               Margin="{StaticResource SetupLogoMargin}"
                               VerticalAlignment="Center"
                               AutomationProperties.Name="Store Assistant Pro logo"
                               DockPanel.Dock="Left"/>
                    </DockPanel>

                    <TextBlock FontFamily="{StaticResource FluentFontDisplay}"
                               FontSize="{StaticResource FontSizeSectionHeader}"
                               FontWeight="Bold"
                               Foreground="{StaticResource FluentTextPrimary}">
                        <Run Text="Set up "/>
                        <Run Text="Store Assistant Pro" Foreground="{StaticResource FluentAccentDefault}"/>
                    </TextBlock>

                    <TextBlock Text="Business and security details only. Advanced settings stay out of the way until later."
                               FontFamily="{StaticResource FluentFontText}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{StaticResource FluentTextSecondary}"
                               Margin="{StaticResource SetupIntroTextMargin}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1"
                        Background="{StaticResource FluentBackgroundSecondary}"
                        BorderBrush="{StaticResource FluentStrokeDefault}"
                        BorderThickness="{StaticResource FluentBorderThicknessThin}"
                        CornerRadius="{StaticResource FluentCornerLarge}"
                        Padding="{StaticResource SetupProgressBadgePadding}"
                        VerticalAlignment="Top"
                        Margin="{StaticResource SetupProgressCardMargin}">
                    <StackPanel MinWidth="180" MaxWidth="260">
                        <TextBlock Text="{Binding RequiredFieldsProgress}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextPrimary}"
                                   Margin="{StaticResource SetupProgressTextMargin}"
                                   AutomationProperties.LiveSetting="Polite"/>
                        <TextBlock Text="{Binding SaveReadinessMessage}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   Margin="{StaticResource SetupProgressHintMargin}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Background="{StaticResource FluentBackgroundSecondary}"
                BorderBrush="{StaticResource FluentStrokeDefault}"
                BorderThickness="{StaticResource FluentBorderThicknessThin}"
                CornerRadius="{StaticResource FluentCornerLarge}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0"
                        Padding="{StaticResource SetupStepperPadding}"
                        Background="Transparent"
                        CornerRadius="{StaticResource FluentCornerLarge}">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="{StaticResource SetupRowSpacingMedium}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <RadioButton x:Name="NavFirm"
                                     Grid.Column="0"
                                     Tag="Firm"
                                     GroupName="SetupNav"
                                     IsChecked="True"
                                     Style="{StaticResource SetupSidebarNavItemStyle}"
                                     Checked="OnSidebarSectionChecked"
                                     AutomationProperties.Name="Firm Profile">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="{StaticResource SetupStepIconSize}"
                                        Height="{StaticResource SetupStepIconSize}"
                                        CornerRadius="{StaticResource FluentCornerSmall}"
                                        Background="{StaticResource FluentInfoBackground}"
                                        Margin="{StaticResource SetupStepIconMargin}">
                                    <TextBlock Text="&#xE913;"
                                               FontFamily="{StaticResource FluentIconFont}"
                                               Foreground="{StaticResource FluentAccentDefault}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="{StaticResource FontSizeBody}"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Firm profile" Style="{StaticResource SetupSidebarNavTitleStyle}"/>
                                    <TextBlock Text="Business identity and contact details"
                                               Style="{StaticResource SetupSidebarNavSubtitleStyle}"/>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource SetupSectionSummaryLabelStyle}">
                                                <Setter Property="Text" Value="{Binding FirmSectionStatusText}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsFirmSectionComplete}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="&#xE73E;"
                                           FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentSuccess}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsFirmSectionComplete, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </RadioButton>

                        <RadioButton x:Name="NavSecurity"
                                     Grid.Column="2"
                                     Tag="Security"
                                     GroupName="SetupNav"
                                     Style="{StaticResource SetupSidebarNavItemStyle}"
                                     Checked="OnSidebarSectionChecked"
                                     AutomationProperties.Name="Security Settings">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0"
                                        Width="{StaticResource SetupStepIconSize}"
                                        Height="{StaticResource SetupStepIconSize}"
                                        CornerRadius="{StaticResource FluentCornerSmall}"
                                        Background="{StaticResource FluentInfoBackground}"
                                        Margin="{StaticResource SetupStepIconMargin}">
                                    <TextBlock Text="&#xE72E;"
                                               FontFamily="{StaticResource FluentIconFont}"
                                               Foreground="{StaticResource FluentAccentDefault}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="{StaticResource FontSizeBody}"/>
                                </Border>

                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Security settings" Style="{StaticResource SetupSidebarNavTitleStyle}"/>
                                    <TextBlock Text="Role PINs and recovery protection"
                                               Style="{StaticResource SetupSidebarNavSubtitleStyle}"/>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource SetupSectionSummaryLabelStyle}">
                                                <Setter Property="Text" Value="{Binding SecuritySectionStatusText}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSecuritySectionComplete}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="&#xE73E;"
                                           FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentSuccess}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           VerticalAlignment="Center"
                                           Visibility="{Binding IsSecuritySectionComplete, Converter={StaticResource BoolToVisibility}}"/>
                            </Grid>
                        </RadioButton>
                    </Grid>
                </Border>

                <Border Grid.Row="1"
                        Height="{StaticResource SetupDividerThickness}"
                        Background="{StaticResource FluentStrokeDefault}"
                        Margin="{StaticResource SetupDividerMargin}"/>

                <Grid Grid.Row="2">
                    <Frame x:Name="ContentFrame"
                           Margin="{StaticResource SetupCardPadding}"
                           NavigationUIVisibility="Hidden"
                           JournalOwnership="OwnsJournal"
                           Focusable="False">
                        <Frame.Style>
                            <Style TargetType="Frame">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Frame.Style>
                    </Frame>

                    <Grid Visibility="{Binding IsSetupComplete, Converter={StaticResource BoolToVisibility}}"
                          h:Motion.FadeIn="True">
                        <Border Margin="{StaticResource SetupCompleteOverlayMargin}"
                                Background="{StaticResource FluentBackgroundSecondary}"
                                BorderBrush="{StaticResource FluentStrokeDefault}"
                                BorderThickness="{StaticResource FluentBorderThicknessThin}"
                                CornerRadius="{StaticResource FluentCornerLarge}"
                                Padding="{StaticResource SetupCompleteCardPadding}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                MaxWidth="{StaticResource SetupCompleteMaxWidth}">
                            <StackPanel>
                                <Border Width="{StaticResource SetupCompleteBadgeSize}"
                                        Height="{StaticResource SetupCompleteBadgeSize}"
                                        Background="{StaticResource FluentInfoBackground}"
                                        CornerRadius="{StaticResource SetupCompleteBadgeCorner}"
                                        HorizontalAlignment="Center"
                                        Margin="{StaticResource SetupCompleteBadgeMargin}">
                                    <TextBlock Text="&#xE73E;"
                                               FontFamily="{StaticResource FluentIconFont}"
                                               FontSize="{StaticResource FontSizeIconLarge}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{StaticResource FluentSuccess}"
                                               AutomationProperties.Name="Setup complete checkmark"/>
                                </Border>
                                <TextBlock Text="Setup complete"
                                           FontSize="{StaticResource FontSizeSectionHeader}"
                                           FontWeight="Bold"
                                           HorizontalAlignment="Center"
                                           Foreground="{StaticResource FluentTextPrimary}"
                                           AutomationProperties.LiveSetting="Polite"/>
                                <TextBlock Text="Your essential store setup is saved. You can review advanced preferences after sign-in."
                                           FontSize="{StaticResource FontSizeBody}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="{StaticResource SetupCompleteSubtitleMargin}"/>
                                <TextBlock Text="{Binding RedirectCountdown}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           AutomationProperties.LiveSetting="Polite"
                                           HorizontalAlignment="Center"
                                           Margin="{StaticResource SetupCompleteCountdownMargin}"/>
                                <Button Content="Go to Login"
                                        Command="{Binding GoToLoginCommand}"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        MinWidth="{StaticResource SetupPrimaryButtonWidth}"
                                        MinHeight="{StaticResource SetupButtonHeight}"
                                        HorizontalAlignment="Center"
                                        Margin="{StaticResource SetupCompleteButtonMargin}"
                                        AutomationProperties.Name="Go to login"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Grid Grid.Row="4">
            <controls:InfoBar Severity="Success"
                              Title="Setup saved"
                              Message="{Binding SuccessMessage}"
                              Visibility="{Binding HasSuccess, Converter={StaticResource BoolToVisibility}}"
                              AutomationProperties.LiveSetting="Polite"/>

            <controls:InfoBar Severity="Error"
                              Title="Setup issue"
                              Message="{Binding ErrorMessage}"
                              Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                              AutomationProperties.LiveSetting="Assertive"/>
        </Grid>

        <Grid Grid.Row="6">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Visible"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding IsBusy}" Value="True">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        VerticalAlignment="Center">
                <TextBlock FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource FluentTextSecondary}"
                           TextWrapping="Wrap">
                    <Run Text="Required: business name and all security PINs. "/>
                    <Run Text="Optional details can be added now or later."
                         Foreground="{StaticResource FluentTextTertiary}"/>
                </TextBlock>
            </StackPanel>

            <WrapPanel Grid.Column="1"
                       Orientation="Horizontal"
                       HorizontalAlignment="Right">
                <Button Content="Cancel"
                        Command="{Binding CancelSetupCommand}"
                        MinWidth="{StaticResource SetupPrimaryButtonWidth}"
                        MinHeight="{StaticResource SetupButtonHeight}"
                        Margin="{StaticResource SetupCancelButtonMargin}"
                        AutomationProperties.Name="Cancel setup and close">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsBusy}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>

                <Button Content="Save and finish setup"
                        Command="{Binding SaveCommand}"
                        MinWidth="168"
                        MinHeight="{StaticResource SetupButtonHeight}"
                        ToolTip="{Binding SaveReadinessMessage}"
                        AutomationProperties.Name="Save setup and continue">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Setter Property="IsEnabled" Value="{Binding IsReadyForSave}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </WrapPanel>
        </Grid>

        <controls:LoadingOverlay Grid.Row="0"
                                 Grid.RowSpan="7"
                                 IsActive="{Binding IsBusy}"
                                 Message="Saving your setup..."/>
    </Grid>
</Window>
