<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="One Time Setup"
        Icon="pack://application:,,,/Assets/app.ico"
        FontFamily="{StaticResource FluentFontFamily}"
        Closing="OnWindowClosing"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource AppBackgroundBrush}">

    <Window.Resources>
        <!-- Sidebar icon badge (colored rounded square background) -->
        <Style x:Key="SidebarIconBadgeStyle" TargetType="Border">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="CornerRadius" Value="{StaticResource FluentCornerSmall}"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
        </Style>

        <!-- Sidebar nav item button -->
        <Style x:Key="SidebarNavItemStyle" TargetType="RadioButton">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="3,0,0,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="{StaticResource FluentAccentDefault}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtlePressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SidebarNavTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
        </Style>

        <Style x:Key="SidebarNavSubtitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
            <Setter Property="Margin" Value="0,2,0,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue"
          h:KeyboardNav.DefaultCommand="{Binding SaveCommand}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="{StaticResource SetupHeaderMargin}">
            <TextBlock Text="StoreAssistantPro Setup"
                       FontFamily="{StaticResource FluentFontDisplay}"
                       FontSize="{StaticResource FontSizePageTitle}"
                       FontWeight="Bold"
                       Foreground="{StaticResource FluentTextPrimary}"/>
            <TextBlock Text="Configure your store before starting operations."
                       FontFamily="{StaticResource FluentFontText}"
                       FontSize="{StaticResource FontSizeBody}"
                       Foreground="{StaticResource FluentTextSecondary}"
                       Margin="{StaticResource ValidationHintMargin}"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="{StaticResource FormRowSpacing}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Setup Complete overlay (spans all columns) -->
            <StackPanel Grid.ColumnSpan="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                        Visibility="{Binding IsSetupComplete, Converter={StaticResource BoolToVisibility}}">
                <TextBlock Text="&#xE73E;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconLarge}" HorizontalAlignment="Center"
                           Margin="{StaticResource ItemSpacing}"/>
                <TextBlock Text="Setup Complete!"
                           FontSize="{StaticResource FontSizeSectionHeader}" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{StaticResource FluentSuccess}"
                           AutomationProperties.LiveSetting="Polite"
                           AutomationProperties.HelpText="Setup complete"
                           Margin="{StaticResource FieldLabelSpacing}"/>
                <TextBlock Text="{Binding RedirectCountdown}"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource FluentTextSecondary}"
                           AutomationProperties.LiveSetting="Polite"
                           AutomationProperties.HelpText="{Binding RedirectCountdown}"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- LEFT PANEL: Sidebar Navigation -->
            <Border Grid.Column="0" VerticalAlignment="Stretch">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource SetupSidebarCardStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel>
                    <RadioButton x:Name="NavFirm" Tag="Firm" IsChecked="True" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentInfoBackground}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE913;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentAccentDefault}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <TextBlock Text="Firm Profile" Style="{StaticResource SidebarNavTitleStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavTax" Tag="Tax" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentSuccessBackground}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentSuccess}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <TextBlock Text="Tax and Legal" Style="{StaticResource SidebarNavTitleStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavRegional" Tag="Regional" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentKpiTealMuted}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE774;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentKpiTeal}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <TextBlock Text="Regional Settings" Style="{StaticResource SidebarNavTitleStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavSecurity" Tag="Security" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentKpiPurpleMuted}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE72E;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentKpiPurple}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <TextBlock Text="Security Settings" Style="{StaticResource SidebarNavTitleStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavBackup" Tag="Backup" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentKpiOrangeMuted}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE74E;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentKpiOrange}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <TextBlock Text="Backup &amp; Data" Style="{StaticResource SidebarNavTitleStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton x:Name="NavSystem" Tag="System" GroupName="SetupNav"
                                 Style="{StaticResource SidebarNavItemStyle}" Click="OnSidebarSectionClick">
                        <StackPanel Orientation="Horizontal">
                            <Border Background="{StaticResource FluentKpiGrayMuted}" Style="{StaticResource SidebarIconBadgeStyle}">
                                <TextBlock Text="&#xE713;" FontFamily="{StaticResource FluentIconFont}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           FontSize="{StaticResource FontSizeBody}"/>
                            </Border>
                            <TextBlock Text="System Settings" Style="{StaticResource SidebarNavTitleStyle}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>
            </Border>

            <!-- RIGHT PANEL: Frame navigation (one page at a time) -->
            <Frame x:Name="ContentFrame" Grid.Column="2"
                   NavigationUIVisibility="Hidden"
                   JournalOwnership="OwnsJournal"
                   Focusable="False">
                <Frame.Style>
                    <Style TargetType="Frame">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Frame.Style>
            </Frame>
        </Grid>

        <StackPanel Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}" Margin="{StaticResource FieldLabelSpacing}">
            <Border Background="{StaticResource FluentErrorBackground}"
                    BorderBrush="{StaticResource FluentStrokeError}"
                    BorderThickness="{StaticResource FluentBorderThicknessThin}"
                    CornerRadius="{StaticResource FluentCornerSmall}"
                    Padding="{StaticResource SmallCardPadding}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Please review highlighted fields and try again."
                           Style="{StaticResource HintTextStyle}"
                           Foreground="{StaticResource FluentError}"/>
            </Border>
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"
                       AutomationProperties.LiveSetting="Assertive"
                       AutomationProperties.HelpText="{Binding ErrorMessage}"/>
        </StackPanel>

        <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding RequiredFieldsProgress}"
                       VerticalAlignment="Center"
                       Foreground="{Binding RequiredFieldsProgress, Converter={StaticResource HintForegroundConverter}}"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.HelpText="{Binding RequiredFieldsProgress}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Complete Setup" Command="{Binding SaveCommand}"
                        MinWidth="{StaticResource SetupPrimaryButtonWidth}"
                        MinHeight="{StaticResource SetupButtonHeight}"
                        AutomationProperties.Name="Complete first time setup">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="4" Style="{StaticResource FooterTextStyle}" Margin="{StaticResource MessageBarSpacing}">
            <Run Text="Developed By "/><Run Text="Ratnesh Kaswa" FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}"/>
        </TextBlock>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{StaticResource LoadingOverlayScrim}"
                Opacity="{StaticResource OverlayOpacity}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                IsHitTestVisible="True">
            <Border Background="{StaticResource FluentSurface}"
                    CornerRadius="{StaticResource FluentCornerMedium}"
                    BorderBrush="{StaticResource FluentStrokeDefault}"
                    BorderThickness="{StaticResource FluentBorderThicknessThin}"
                    Padding="{StaticResource CardPadding}"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="&#xE895;" FontFamily="{StaticResource FluentIconFont}"
                               FontSize="{StaticResource FontSizeIconLarge}"
                               Foreground="{StaticResource FluentAccentDefault}"
                               HorizontalAlignment="Center" Margin="{StaticResource ItemSpacing}"/>
                    <TextBlock Text="Processing&#x2026;"
                               FontFamily="{StaticResource FluentFontText}"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FluentAccentDefault}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>

