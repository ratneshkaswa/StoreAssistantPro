<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="One Time Setup"
        Icon="pack://application:,,,/Assets/app.ico"
        Closing="OnWindowClosing"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Background="{StaticResource AppBackgroundBrush}">

    <Window.Resources>
        <Style x:Key="PinStrengthSegmentStyle" TargetType="Border">
            <Setter Property="Width" Value="{StaticResource StrengthBarWidth}"/>
            <Setter Property="Height" Value="{StaticResource StrengthBarHeight}"/>
            <Setter Property="CornerRadius" Value="{StaticResource FluentCornerXSmall}"/>
            <Setter Property="Margin" Value="{StaticResource StrengthBarGap}"/>
        </Style>

        <Style x:Key="PinWarningTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
            <Setter Property="Margin" Value="{StaticResource StrengthLabelGap}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="AutomationProperties.LiveSetting" Value="Polite"/>
            <Setter Property="AutomationProperties.HelpText" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PinInlineHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Margin" Value="{StaticResource StrengthLabelGap}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Setter Property="AutomationProperties.LiveSetting" Value="Polite"/>
            <Setter Property="AutomationProperties.HelpText" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CollapsibleHintTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Margin" Value="{StaticResource ValidationHintMargin}"/>
            <Setter Property="AutomationProperties.LiveSetting" Value="Polite"/>
            <Setter Property="AutomationProperties.HelpText" Value="{Binding Text, RelativeSource={RelativeSource Self}}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SetupSidebarButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="{StaticResource ValidationHintMargin}"/>
            <Setter Property="Padding" Value="{StaticResource SmallCardPadding}"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SetupSidebarIconStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeDialogTitle}"/>
            <Setter Property="Margin" Value="{StaticResource StrengthLabelGap}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style x:Key="SetupSidebarSubtitleStyle" TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
            <Setter Property="Margin" Value="0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="{StaticResource PagePadding}" h:Motion.WindowFadeIn="True"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue"
          h:KeyboardNav.DefaultCommand="{Binding SaveCommand}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <controls:AppBranding LogoSize="48"/>
        </StackPanel>

        <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FieldWidthWide}"/>
                    <ColumnDefinition Width="{StaticResource FormRowSpacing}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" VerticalAlignment="Top">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource CardStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <TextBlock Style="{StaticResource SectionHeaderStyle}" Margin="{StaticResource FieldLabelSpacing}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE80F;"/><Run Text=" Setup Home"/></TextBlock>
                        <StackPanel Margin="{StaticResource StepContentTopSpacing}">
                            <Button x:Name="SidebarFirmButton" Tag="FirmProfileSection" Style="{StaticResource SetupSidebarButtonStyle}" Click="OnSidebarSectionClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE80F;" FontFamily="{StaticResource FluentIconFont}" Foreground="{StaticResource FluentAccentDefault}" Style="{StaticResource SetupSidebarIconStyle}"/>
                                    <StackPanel VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}">
                                        <TextBlock Text="Firm Profile" Style="{StaticResource FormRowLabelStyle}"/>
                                        <TextBlock Text="Business identity and contact" Style="{StaticResource SetupSidebarSubtitleStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SidebarTaxButton" Tag="TaxLegalSection" Style="{StaticResource SetupSidebarButtonStyle}" Click="OnSidebarSectionClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8A5;" FontFamily="{StaticResource FluentIconFont}" Foreground="{StaticResource FluentWarning}" Style="{StaticResource SetupSidebarIconStyle}"/>
                                    <StackPanel VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}">
                                        <TextBlock Text="Tax and Legal" Style="{StaticResource FormRowLabelStyle}"/>
                                        <TextBlock Text="GSTIN, PAN and compliance" Style="{StaticResource SetupSidebarSubtitleStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SidebarRegionalButton" Tag="RegionalSection" Style="{StaticResource SetupSidebarButtonStyle}" Click="OnSidebarSectionClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE774;" FontFamily="{StaticResource FluentIconFont}" Foreground="{StaticResource FluentInfo}" Style="{StaticResource SetupSidebarIconStyle}"/>
                                    <StackPanel VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}">
                                        <TextBlock Text="Regional Settings" Style="{StaticResource FormRowLabelStyle}"/>
                                        <TextBlock Text="Tax mode, rounding and preferences" Style="{StaticResource SetupSidebarSubtitleStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SidebarSecurityButton" Tag="SecuritySection" Style="{StaticResource SetupSidebarButtonStyle}" Click="OnSidebarSectionClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE72E;" FontFamily="{StaticResource FluentIconFont}" Foreground="{StaticResource FluentSuccess}" Style="{StaticResource SetupSidebarIconStyle}"/>
                                    <StackPanel VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}">
                                        <TextBlock Text="Security Settings" Style="{StaticResource FormRowLabelStyle}"/>
                                        <TextBlock Text="Role PIN and master security" Style="{StaticResource SetupSidebarSubtitleStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                            <Button x:Name="SidebarBackupButton" Tag="BackupSection" Style="{StaticResource SetupSidebarButtonStyle}" Click="OnSidebarSectionClick">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74E;" FontFamily="{StaticResource FluentIconFont}" Foreground="{StaticResource FluentTextSecondary}" Style="{StaticResource SetupSidebarIconStyle}"/>
                                    <StackPanel VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}">
                                        <TextBlock Text="Backup &amp; Data" Style="{StaticResource FormRowLabelStyle}"/>
                                        <TextBlock Text="Auto backup schedule" Style="{StaticResource SetupSidebarSubtitleStyle}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <StackPanel Grid.ColumnSpan="3" HorizontalAlignment="Center" VerticalAlignment="Center"
                            Visibility="{Binding IsSetupComplete, Converter={StaticResource BoolToVisibility}}"
                            h:Motion.FadeIn="True">
                    <TextBlock Text="&#xE73E;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconLarge}" HorizontalAlignment="Center"
                               Margin="{StaticResource ItemSpacing}"/>
                    <TextBlock Text="Setup Complete!"
                               FontSize="{StaticResource FontSizeSectionHeader}" FontWeight="Bold"
                               HorizontalAlignment="Center"
                               Foreground="{StaticResource FluentSuccess}"
                               AutomationProperties.LiveSetting="Polite"
                               AutomationProperties.HelpText="Setup complete"
                               Margin="{StaticResource FieldLabelSpacing}"/>
                    <TextBlock Text="{Binding RedirectCountdown}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{StaticResource FluentTextSecondary}"
                               AutomationProperties.LiveSetting="Polite"
                               AutomationProperties.HelpText="{Binding RedirectCountdown}"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Responsive layout (3/2/1 columns): Firm Profile | Tax+Master | Security PINs -->
                <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="False"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly"
                              AutomationProperties.Name="Setup form content"
                              AutomationProperties.HelpText="Scroll to review all setup sections"
                              h:SmoothScroll.IsEnabled="False">
                    <ScrollViewer.Style>
                        <Style TargetType="ScrollViewer">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </ScrollViewer.Style>
                <Grid Margin="{StaticResource InlineControlSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="{StaticResource FormRowSpacing}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left column: Firm Profile + Tax & Legal -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top">
                        <Border x:Name="FirmProfileSection" Style="{StaticResource CardStyle}" VerticalAlignment="Top" h:Motion.SlideFadeIn="True" h:Motion.StaggerIndex="0">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeaderStyle}" AutomationProperties.Name="Firm Profile section"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8D2;"/><Run Text=" Firm Profile"/></TextBlock>
                                <Grid Margin="{StaticResource StepContentTopSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- 0: Firm Name -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>  <!-- 2: Address -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>  <!-- 4: State -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>  <!-- 6: Pincode -->
                                    <RowDefinition Height="Auto"/>  <!-- 7: Pincode hint -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>  <!-- 9: Phone -->
                                    <RowDefinition Height="Auto"/>  <!-- 10: Phone hint -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>  <!-- 12: Email -->
                                    <RowDefinition Height="Auto"/>  <!-- 13: Email hint -->
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="FirmNameLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                                    <Run Text="Firm Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                                </TextBlock>
                                <TextBox Grid.Row="0" Grid.Column="1" x:Name="FirmNameBox" TabIndex="0"
                                         Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="100"
                                         AutomationProperties.LabeledBy="{Binding ElementName=FirmNameLabel}"
                                         AutomationProperties.Name="Firm Name"/>

                                <TextBlock x:Name="AddressLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="Address"/><Run Text=" (optional)" Foreground="{StaticResource FluentTextTertiary}"/></TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="1" TabIndex="1"
                                         Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="200"
                                         AutomationProperties.LabeledBy="{Binding ElementName=AddressLabel}"
                                         AutomationProperties.Name="Address"/>

                                <TextBlock x:Name="StateLabel" Grid.Row="4" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="State"/><Run Text=" (optional)" Foreground="{StaticResource FluentTextTertiary}"/></TextBlock>
                                <ComboBox Grid.Row="4" Grid.Column="1" TabIndex="2" AutomationProperties.Name="State"
                                          ItemsSource="{Binding IndianStates}" IsEditable="True" IsTextSearchEnabled="True"
                                          Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                                          AutomationProperties.LabeledBy="{Binding ElementName=StateLabel}"
                                          MaxDropDownHeight="300"/>

                                <TextBlock x:Name="PincodeLabel" Grid.Row="6" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="Pincode"/><Run Text=" (optional)" Foreground="{StaticResource FluentTextTertiary}"/></TextBlock>
                                <TextBox Grid.Row="6" Grid.Column="1" x:Name="PincodeBox" TabIndex="3" AutomationProperties.Name="Pincode"
                                         Text="{Binding Pincode, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                         AutomationProperties.LabeledBy="{Binding ElementName=PincodeLabel}"
                                         MaxLength="6"
                                         h:NumericInput.IsIntegerOnly="True"/>
                                <TextBlock Grid.Row="7" Grid.Column="1"
                                           Text="{Binding PincodeValidationHint}"
                                           Foreground="{Binding PincodeValidationHint, Converter={StaticResource HintForegroundConverter}}"
                                           Style="{StaticResource CollapsibleHintTextStyle}"/>

                                <TextBlock x:Name="PhoneLabel" Grid.Row="9" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="Phone"/><Run Text=" (optional)" Foreground="{StaticResource FluentTextTertiary}"/></TextBlock>
                                <TextBox Grid.Row="9" Grid.Column="1" x:Name="PhoneBox" TabIndex="4"
                                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                                         MaxLength="15"
                                         AutomationProperties.LabeledBy="{Binding ElementName=PhoneLabel}"
                                         AutomationProperties.Name="Phone"/>
                                <TextBlock Grid.Row="10" Grid.Column="1"
                                           Text="{Binding PhoneValidationHint}"
                                           Foreground="{Binding PhoneValidationHint, Converter={StaticResource HintForegroundConverter}}"
                                           Style="{StaticResource CollapsibleHintTextStyle}"/>

                                <TextBlock x:Name="EmailLabel" Grid.Row="12" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="Email"/><Run Text=" (optional)" Foreground="{StaticResource FluentTextTertiary}"/></TextBlock>
                                <TextBox Grid.Row="12" Grid.Column="1" x:Name="EmailBox" TabIndex="5"
                                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="100"
                                         AutomationProperties.LabeledBy="{Binding ElementName=EmailLabel}"
                                         AutomationProperties.Name="Email"/>
                                <TextBlock Grid.Row="13" Grid.Column="1"
                                           Text="{Binding EmailValidationHint}"
                                           Foreground="{Binding EmailValidationHint, Converter={StaticResource HintForegroundConverter}}"
                                           Style="{StaticResource CollapsibleHintTextStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    <Border x:Name="TaxLegalSection" Style="{StaticResource CardStyle}" h:Motion.SlideFadeIn="True" h:Motion.StaggerIndex="1">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderStyle}" AutomationProperties.Name="Tax and Legal section"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8A5;"/><Run Text=" Tax &amp; Legal"/></TextBlock>
                            <Grid Margin="{StaticResource StepContentTopSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- 0: GST Registration Type -->
                                    <RowDefinition Height="Auto"/>  <!-- 1: Composition Rate (conditional) -->
                                    <RowDefinition Height="Auto"/>  <!-- 2: Composition hint (conditional) -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>  <!-- 4: GSTIN -->
                                    <RowDefinition Height="Auto"/>  <!-- 5: GSTIN hint -->
                                    <RowDefinition Height="Auto"/>  <!-- 6: State Code display -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>  <!-- 8: PAN -->
                                    <RowDefinition Height="Auto"/>  <!-- 9: PAN hint -->
                                    <RowDefinition Height="Auto"/>  <!-- 10: Cross hint -->
                                </Grid.RowDefinitions>

                                <TextBlock x:Name="GstRegTypeLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="GST Type "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                                <ComboBox Grid.Row="0" Grid.Column="1" TabIndex="9" AutomationProperties.Name="GST Registration Type"
                                          ItemsSource="{Binding GstRegistrationTypes}" SelectedItem="{Binding SelectedGstRegistrationType}"
                                          AutomationProperties.LabeledBy="{Binding ElementName=GstRegTypeLabel}"
                                          Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                                <TextBlock x:Name="CompRateLabel" Grid.Row="1" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"
                                           Visibility="{Binding IsCompositionScheme, Converter={StaticResource BoolToVisibility}}"><Run Text="Rate (%)"/></TextBlock>
                                <TextBox Grid.Row="1" Grid.Column="1" TabIndex="10"
                                         Text="{Binding CompositionRate, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                         MaxLength="4" AutomationProperties.Name="Composition Rate"
                                         AutomationProperties.LabeledBy="{Binding ElementName=CompRateLabel}"
                                         Visibility="{Binding IsCompositionScheme, Converter={StaticResource BoolToVisibility}}"
                                         h:NumericInput.IsIntegerOnly="True"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding CompositionRateHint}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           Style="{StaticResource CollapsibleHintTextStyle}"/>

                                <TextBlock x:Name="GstinLabel" Grid.Row="4" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="GSTIN"/><Run Text=" (optional)" Foreground="{StaticResource FluentTextTertiary}"/></TextBlock>
                                <TextBox Grid.Row="4" Grid.Column="1" x:Name="GstinBox" TabIndex="11" AutomationProperties.Name="GSTIN"
                                         Text="{Binding GSTIN, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"
                                         AutomationProperties.LabeledBy="{Binding ElementName=GstinLabel}"
                                         MaxLength="15" CharacterCasing="Upper"/>
                                <TextBlock Grid.Row="5" Grid.Column="1"
                                           Text="{Binding GstinValidationHint}"
                                           Foreground="{Binding GstinValidationHint, Converter={StaticResource HintForegroundConverter}}"
                                           Style="{StaticResource CollapsibleHintTextStyle}"/>
                                <TextBlock Grid.Row="6" Grid.Column="1"
                                           Text="{Binding DerivedStateCodeDisplay}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           Style="{StaticResource CollapsibleHintTextStyle}"/>

                                <TextBlock x:Name="PanLabel" Grid.Row="8" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="PAN"/><Run Text=" (optional)" Foreground="{StaticResource FluentTextTertiary}"/></TextBlock>
                                <TextBox Grid.Row="8" Grid.Column="1" x:Name="PanBox" TabIndex="12" AutomationProperties.Name="PAN"
                                         Text="{Binding PAN, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left" MaxLength="10"
                                         AutomationProperties.LabeledBy="{Binding ElementName=PanLabel}"
                                         CharacterCasing="Upper"/>
                                <TextBlock Grid.Row="9" Grid.Column="1"
                                           Text="{Binding PanValidationHint}"
                                           Foreground="{Binding PanValidationHint, Converter={StaticResource HintForegroundConverter}}"
                                           Style="{StaticResource CollapsibleHintTextStyle}"/>
                                <TextBlock Grid.Row="10" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding GstinPanCrossHint}"
                                           Foreground="{Binding GstinPanCrossHint, Converter={StaticResource HintForegroundConverter}}"
                                           Margin="{StaticResource CrossHintMargin}"
                                           Style="{StaticResource CollapsibleHintTextStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    </StackPanel>

                    <!-- Right column: Regional Settings + Master PIN + Security PINs -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">
                        <Border x:Name="RegionalSection" Style="{StaticResource CardStyle}" h:Motion.SlideFadeIn="True" h:Motion.StaggerIndex="2">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeaderStyle}" AutomationProperties.Name="Regional Settings section"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE774;"/><Run Text=" Regional Settings"/></TextBlock>
                                <Grid Margin="{StaticResource StepContentTopSpacing}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>  <!-- 8 -->
                                        <RowDefinition Height="Auto"/>  <!-- 9: Tax Mode -->
                                        <RowDefinition Height="Auto"/>  <!-- 10: Tax Mode hint -->
                                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                        <RowDefinition Height="Auto"/>  <!-- 12: Rounding -->
                                        <RowDefinition Height="Auto"/>  <!-- 13: Rounding hint -->
                                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                        <RowDefinition Height="Auto"/>  <!-- 15: Number-to-Words -->
                                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                        <RowDefinition Height="Auto"/>  <!-- 17: Negative Stock -->
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Currency"
                                               x:Name="CurrencyLabel"
                                               Style="{StaticResource FormRowLabelStyle}"/>
                                    <ComboBox Grid.Row="0" Grid.Column="1" TabIndex="13" AutomationProperties.Name="Currency Symbol"
                                              ItemsSource="{Binding CurrencySymbols}" SelectedItem="{Binding SelectedCurrencySymbol}"
                                              AutomationProperties.LabeledBy="{Binding ElementName=CurrencyLabel}"
                                              Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1"
                                               Text="{Binding CurrencyPreview}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>

                                    <TextBlock Grid.Row="3" Grid.Column="0" Text="FY Start"
                                               x:Name="FyStartLabel"
                                               Style="{StaticResource FormRowLabelStyle}"/>
                                    <ComboBox Grid.Row="3" Grid.Column="1" TabIndex="14" AutomationProperties.Name="Financial Year Start Month"
                                              ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedFYStartMonth}"
                                              AutomationProperties.LabeledBy="{Binding ElementName=FyStartLabel}"
                                              Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Row="4" Grid.Column="1"
                                               Text="{Binding FinancialYearDisplay}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>

                                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Date Format"
                                               x:Name="DateFormatLabel"
                                               Style="{StaticResource FormRowLabelStyle}"/>
                                    <ComboBox Grid.Row="6" Grid.Column="1" TabIndex="15" AutomationProperties.Name="Date Format"
                                              ItemsSource="{Binding DateFormats}" SelectedItem="{Binding SelectedDateFormat}"
                                              AutomationProperties.LabeledBy="{Binding ElementName=DateFormatLabel}"
                                              Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Row="7" Grid.Column="1"
                                               Text="{Binding DateFormatPreview}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>

                                    <TextBlock Grid.Row="9" Grid.Column="0" Text="Tax Mode"
                                               x:Name="TaxModeLabel"
                                               Style="{StaticResource FormRowLabelStyle}"/>
                                    <ComboBox Grid.Row="9" Grid.Column="1" TabIndex="16" AutomationProperties.Name="Tax Mode"
                                              ItemsSource="{Binding TaxModes}" SelectedItem="{Binding SelectedTaxMode}"
                                              AutomationProperties.LabeledBy="{Binding ElementName=TaxModeLabel}"
                                              Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Row="10" Grid.Column="1"
                                               Text="{Binding TaxModeHint}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>

                                    <TextBlock Grid.Row="12" Grid.Column="0" Text="Rounding"
                                               x:Name="RoundingLabel"
                                               Style="{StaticResource FormRowLabelStyle}"/>
                                    <ComboBox Grid.Row="12" Grid.Column="1" TabIndex="17" AutomationProperties.Name="Bill Rounding Method"
                                              ItemsSource="{Binding RoundingMethods}" SelectedItem="{Binding SelectedRoundingMethod}"
                                              AutomationProperties.LabeledBy="{Binding ElementName=RoundingLabel}"
                                              Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"/>
                                    <TextBlock Grid.Row="13" Grid.Column="1"
                                               Text="{Binding RoundingPreview}"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>

                                    <TextBlock Grid.Row="15" Grid.Column="0" Text="Words Lang"
                                               x:Name="WordsLangLabel"
                                               Style="{StaticResource FormRowLabelStyle}"/>
                                    <ComboBox Grid.Row="15" Grid.Column="1" TabIndex="18" AutomationProperties.Name="Number-to-Words Language"
                                              ItemsSource="{Binding NumberToWordsLanguages}" SelectedItem="{Binding SelectedNumberToWordsLanguage}"
                                              AutomationProperties.LabeledBy="{Binding ElementName=WordsLangLabel}"
                                              Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                                    <TextBlock Grid.Row="17" Grid.Column="0" Text="Neg. Stock"
                                               Style="{StaticResource FormRowLabelStyle}"/>
                                    <DockPanel Grid.Row="17" Grid.Column="1">
                                        <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                                  IsChecked="{Binding NegativeStockAllowed}"
                                                  AutomationProperties.Name="Allow Negative Stock"
                                                  DockPanel.Dock="Left"/>
                                        <TextBlock Text="Allow billing with zero stock"
                                                   FontSize="{StaticResource FontSizeCaption}"
                                                   Foreground="{StaticResource FluentTextSecondary}"
                                                   VerticalAlignment="Center" Margin="{StaticResource StrengthLabelGap}"/>
                                    </DockPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border x:Name="SecuritySection" Style="{StaticResource CardStyle}" h:Motion.SlideFadeIn="True" h:Motion.StaggerIndex="3">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionHeaderStyle}" AutomationProperties.Name="Master PIN section"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE72E;"/><Run Text=" Master PIN"/></TextBlock>
                                <Grid Margin="{StaticResource StepContentTopSpacing}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="0"/>
                                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource RoleMasterBackground}"
                                            CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                                        <TextBlock FontWeight="SemiBold"
                                                   Foreground="{StaticResource RoleMasterAccent}" FontSize="{StaticResource FontSizeBody}"
                                                   ToolTip="Used to recover or change PINs if forgotten."><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE72E;"/><Run Text=" Master (6 digits)"/></TextBlock>
                                    </Border>
                                    <TextBlock x:Name="MasterPinLabel" Grid.Row="1" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                                    <DockPanel Grid.Row="1" Grid.Column="1">
                                        <PasswordBox x:Name="MasterPinBox" TabIndex="20" MaxLength="6" PasswordChanged="OnPinChanged" AutomationProperties.Name="Master PIN"
                                                     AutomationProperties.LabeledBy="{Binding ElementName=MasterPinLabel}"
                                                     Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                                        <TextBlock Style="{StaticResource PinWarningTextStyle}"
                                                   Text="{Binding MasterPinWarning}"
                                                   ToolTip="{Binding MasterPinWarningDetail}"/>
                                    </DockPanel>
                                    <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource ValidationHintMargin}">
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding MasterPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding MasterPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding MasterPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                                    </StackPanel>

                                    <TextBlock x:Name="MasterConfirmLabel" Grid.Row="4" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="Confirm "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                                    <DockPanel Grid.Row="4" Grid.Column="1">
                                        <PasswordBox x:Name="MasterPinConfirmBox" TabIndex="21" MaxLength="6" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm Master PIN"
                                                     AutomationProperties.LabeledBy="{Binding ElementName=MasterConfirmLabel}"
                                                     Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                                        <TextBlock Style="{StaticResource PinInlineHintStyle}"
                                                   Text="{Binding MasterConfirmHint}"
                                                   Foreground="{Binding MasterConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                                    </DockPanel>

                                    <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                               Text="Master PIN authorizes critical actions such as deleting major records."
                                               Style="{StaticResource HintTextStyle}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    <!-- Security PINs (Admin / Manager / User) -->
                    <Border Style="{StaticResource CardStyle}" VerticalAlignment="Top" Margin="{StaticResource InlineControlSpacing}" h:Motion.SlideFadeIn="True" h:Motion.StaggerIndex="4">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderStyle}" AutomationProperties.Name="Security PINs section"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE9D9;"/><Run Text=" Security PINs"/></TextBlock>
                            <Grid Margin="{StaticResource StepContentTopSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!--  0: Admin role banner -->
                                    <RowDefinition Height="Auto"/>  <!--  1: Admin PIN -->
                                    <RowDefinition Height="Auto"/>  <!--  2: Admin strength -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>  <!-- 3: gap -->
                                    <RowDefinition Height="Auto"/>  <!--  4: Admin Confirm -->
                                    <RowDefinition Height="0"/>  <!--  5: Admin confirm hint -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>  <!-- 6: section gap -->
                                    <RowDefinition Height="Auto"/>  <!--  7: Manager role banner -->
                                    <RowDefinition Height="Auto"/>  <!--  8: Manager PIN -->
                                    <RowDefinition Height="Auto"/>  <!--  9: Manager strength -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>  <!-- 10: gap -->
                                    <RowDefinition Height="Auto"/>  <!-- 11: Manager Confirm -->
                                    <RowDefinition Height="0"/>  <!-- 12: Manager confirm hint -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>  <!-- 13: section gap -->
                                    <RowDefinition Height="Auto"/>  <!-- 14: User role banner -->
                                    <RowDefinition Height="Auto"/>  <!-- 15: User PIN -->
                                    <RowDefinition Height="Auto"/>  <!-- 16: User strength -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>  <!-- 17: gap -->
                                    <RowDefinition Height="Auto"/>  <!-- 18: User Confirm -->
                                    <RowDefinition Height="0"/>  <!-- 19: User confirm hint -->
                                    <RowDefinition Height="Auto"/>  <!-- 20: Pin conflict warning -->
                                </Grid.RowDefinitions>

                                <!-- Admin -->
                                <Border Grid.Row="0" Grid.ColumnSpan="2" Background="{StaticResource RoleAdminBackground}"
                                        CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{StaticResource RoleAdminAccent}" FontSize="{StaticResource FontSizeBody}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE83D;"/><Run Text=" Admin (4 digits)"/></TextBlock>
                                </Border>
                                <TextBlock x:Name="AdminPinLabel" Grid.Row="1" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                                <DockPanel Grid.Row="1" Grid.Column="1">
                                    <PasswordBox x:Name="AdminPinBox" TabIndex="30" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Admin PIN"
                                                 AutomationProperties.LabeledBy="{Binding ElementName=AdminPinLabel}"
                                                 Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                                    <TextBlock Style="{StaticResource PinWarningTextStyle}"
                                               Text="{Binding AdminPinWarning}"
                                               ToolTip="{Binding AdminPinWarningDetail}"/>
                                </DockPanel>
                                <DockPanel Grid.Row="2" Grid.Column="1" Margin="{StaticResource ValidationHintMargin}">
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock x:Name="AdminConfirmLabel" Grid.Row="4" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="Confirm "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                                <DockPanel Grid.Row="4" Grid.Column="1">
                                    <PasswordBox x:Name="AdminPinConfirmBox" TabIndex="31" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm Admin PIN"
                                                 AutomationProperties.LabeledBy="{Binding ElementName=AdminConfirmLabel}"
                                                 Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                                    <TextBlock Style="{StaticResource PinInlineHintStyle}"
                                               Text="{Binding AdminConfirmHint}"
                                               Foreground="{Binding AdminConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                                </DockPanel>

                                <!-- Manager -->
                                <Border Grid.Row="7" Grid.ColumnSpan="2" Background="{StaticResource RoleManagerBackground}"
                                        CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{StaticResource RoleManagerAccent}" FontSize="{StaticResource FontSizeBody}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE77B;"/><Run Text=" Manager (4 digits)"/></TextBlock>
                                </Border>
                                <TextBlock x:Name="ManagerPinLabel" Grid.Row="8" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                                <DockPanel Grid.Row="8" Grid.Column="1">
                                    <PasswordBox x:Name="ManagerPinBox" TabIndex="32" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Manager PIN"
                                                 AutomationProperties.LabeledBy="{Binding ElementName=ManagerPinLabel}"
                                                 Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                                    <TextBlock Style="{StaticResource PinWarningTextStyle}"
                                               Text="{Binding ManagerPinWarning}"
                                               ToolTip="{Binding ManagerPinWarningDetail}"/>
                                </DockPanel>
                                <DockPanel Grid.Row="9" Grid.Column="1" Margin="{StaticResource ValidationHintMargin}">
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock x:Name="ManagerConfirmLabel" Grid.Row="11" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="Confirm "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                                <DockPanel Grid.Row="11" Grid.Column="1">
                                    <PasswordBox x:Name="ManagerPinConfirmBox" TabIndex="33" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm Manager PIN"
                                                 AutomationProperties.LabeledBy="{Binding ElementName=ManagerConfirmLabel}"
                                                 Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                                    <TextBlock Style="{StaticResource PinInlineHintStyle}"
                                               Text="{Binding ManagerConfirmHint}"
                                               Foreground="{Binding ManagerConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                                </DockPanel>

                                <!-- User -->
                                <Border Grid.Row="14" Grid.ColumnSpan="2" Background="{StaticResource RoleUserBackground}"
                                        CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                                    <TextBlock FontWeight="SemiBold"
                                               Foreground="{StaticResource RoleUserAccent}" FontSize="{StaticResource FontSizeBody}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7EE;"/><Run Text=" User (4 digits)"/></TextBlock>
                                </Border>
                                <TextBlock x:Name="UserPinLabel" Grid.Row="15" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                                <DockPanel Grid.Row="15" Grid.Column="1">
                                    <PasswordBox x:Name="UserPinBox" TabIndex="34" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="User PIN"
                                                 AutomationProperties.LabeledBy="{Binding ElementName=UserPinLabel}"
                                                 Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                                    <TextBlock Style="{StaticResource PinWarningTextStyle}"
                                               Text="{Binding UserPinWarning}"
                                               ToolTip="{Binding UserPinWarningDetail}"/>
                                </DockPanel>
                                <DockPanel Grid.Row="16" Grid.Column="1" Margin="{StaticResource ValidationHintMargin}">
                                    <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                        <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                                    </StackPanel>
                                </DockPanel>
                                <TextBlock x:Name="UserConfirmLabel" Grid.Row="18" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="Confirm "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                                <DockPanel Grid.Row="18" Grid.Column="1">
                                    <PasswordBox x:Name="UserPinConfirmBox" TabIndex="35" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm User PIN"
                                                 AutomationProperties.LabeledBy="{Binding ElementName=UserConfirmLabel}"
                                                 Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                                    <TextBlock Style="{StaticResource PinInlineHintStyle}"
                                               Text="{Binding UserConfirmHint}"
                                               Foreground="{Binding UserConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                                </DockPanel>

                                <TextBlock Grid.Row="20" Grid.Column="0" Grid.ColumnSpan="2"
                                           Text="{Binding PinConflictWarning}"
                                           Foreground="{StaticResource FluentError}"
                                           Margin="{StaticResource FieldLabelSpacing}"
                                           Style="{StaticResource CollapsibleHintTextStyle}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Backup & Data -->
                    <Border x:Name="BackupSection" Style="{StaticResource CardStyle}" VerticalAlignment="Top" Margin="{StaticResource InlineControlSpacing}" h:Motion.SlideFadeIn="True" h:Motion.StaggerIndex="5">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionHeaderStyle}" AutomationProperties.Name="Backup and Data section"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE74E;"/><Run Text=" Backup &amp; Data"/></TextBlock>
                            <Grid Margin="{StaticResource StepContentTopSpacing}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- 0: Auto Backup toggle -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>  <!-- 2: Backup Time -->
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>  <!-- 4: Backup Location -->
                                    <RowDefinition Height="Auto"/>  <!-- 5: Location hint -->
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Auto Backup"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <DockPanel Grid.Row="0" Grid.Column="1">
                                    <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                              IsChecked="{Binding AutoBackupEnabled}"
                                              AutomationProperties.Name="Enable Auto Backup"
                                              DockPanel.Dock="Left"/>
                                    <TextBlock Text="Daily scheduled backup"
                                               FontSize="{StaticResource FontSizeCaption}"
                                               Foreground="{StaticResource FluentTextSecondary}"
                                               VerticalAlignment="Center" Margin="{StaticResource StrengthLabelGap}"/>
                                </DockPanel>

                                <TextBlock x:Name="BackupTimeLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"
                                           Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}"><Run Text="Time (HH:mm)"/></TextBlock>
                                <TextBox Grid.Row="2" Grid.Column="1" TabIndex="40"
                                         Text="{Binding BackupTime, UpdateSourceTrigger=PropertyChanged}"
                                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                         MaxLength="5" AutomationProperties.Name="Backup Time"
                                         AutomationProperties.LabeledBy="{Binding ElementName=BackupTimeLabel}"
                                         Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}"/>

                                <TextBlock x:Name="BackupPathLabel" Grid.Row="4" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"
                                           Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}"><Run Text="Location"/></TextBlock>
                                <TextBox Grid.Row="4" Grid.Column="1" TabIndex="41"
                                         Text="{Binding BackupLocation, UpdateSourceTrigger=PropertyChanged}"
                                         HorizontalAlignment="Stretch"
                                         AutomationProperties.Name="Backup Location"
                                         AutomationProperties.LabeledBy="{Binding ElementName=BackupPathLabel}"
                                         Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Grid.Row="5" Grid.Column="1"
                                           Text="Folder must exist. Default: Documents\StoreAssistantPro\Backups"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource FluentTextTertiary}"
                                           Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}"
                                           Margin="{StaticResource ValidationHintMargin}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                    </StackPanel>
                </Grid>
                </ScrollViewer>
        </Grid>

        <StackPanel Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}" Margin="{StaticResource FieldLabelSpacing}">
            <Border Background="{StaticResource FluentErrorBackground}"
                    BorderBrush="{StaticResource FluentStrokeError}"
                    BorderThickness="{StaticResource FluentBorderThicknessThin}"
                    CornerRadius="{StaticResource FluentCornerSmall}"
                    Padding="{StaticResource SmallCardPadding}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock Text="Please review highlighted fields and try again."
                           Style="{StaticResource HintTextStyle}"
                           Foreground="{StaticResource FluentError}"/>
            </Border>
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"
                       AutomationProperties.LiveSetting="Assertive"
                       AutomationProperties.HelpText="{Binding ErrorMessage}"/>
        </StackPanel>

        <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{Binding RequiredFieldsProgress}"
                       VerticalAlignment="Center"
                       Foreground="{Binding RequiredFieldsProgress, Converter={StaticResource HintForegroundConverter}}"
                       AutomationProperties.LiveSetting="Polite"
                       AutomationProperties.HelpText="{Binding RequiredFieldsProgress}">
                <TextBlock.Style>
                    <Style TargetType="TextBlock" BasedOn="{StaticResource HintTextStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button Content="Complete Setup" Command="{Binding SaveCommand}"
                        AutomationProperties.Name="Complete first time setup">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSetupComplete}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>

        <TextBlock Grid.Row="4" Style="{StaticResource FooterTextStyle}" Margin="{StaticResource MessageBarSpacing}">
            <Run Text="Developed By "/><Run Text="Ratnesh Kaswa" FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}"/>
        </TextBlock>

        <!-- Loading overlay -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{StaticResource LoadingOverlayScrim}"
                Opacity="{StaticResource OverlayOpacity}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                IsHitTestVisible="True">
            <Border Style="{StaticResource CardStyle}" Padding="{StaticResource CardPadding}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="&#xE895;" FontFamily="{StaticResource FluentIconFont}"
                               FontSize="{StaticResource FontSizeIconLarge}"
                               Foreground="{StaticResource FluentAccentDefault}"
                               HorizontalAlignment="Center" Margin="{StaticResource ItemSpacing}"
                               RenderTransformOrigin="0.5,0.5">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="SpinnerRotation"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation Storyboard.TargetName="SpinnerRotation"
                                                         Storyboard.TargetProperty="Angle"
                                                         From="0" To="360" Duration="{StaticResource SpinnerDuration}"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>
                    <TextBlock Text="Processing&#x2026;"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FluentAccentDefault}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>

