<Page x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupPages.RegionalSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
      Background="Transparent"
      FontFamily="{StaticResource FluentFontFamily}"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <ScrollViewer
                  Focusable="False" CanContentScroll="False" PanningMode="VerticalOnly">
        <StackPanel>
            <!-- Page Header -->
            <TextBlock FontFamily="{StaticResource FluentFontDisplay}"
                       FontSize="{StaticResource FontSizePageTitle}" FontWeight="Bold"
                       Foreground="{StaticResource FluentTextPrimary}"
                       Text="Regional Settings"/>
            <TextBlock Text="Currency, date formats and business preferences."
                       FontFamily="{StaticResource FluentFontText}"
                       FontSize="{StaticResource FontSizeBody}"
                       Foreground="{StaticResource FluentTextSecondary}"
                       Margin="{StaticResource SetupHeaderMargin}"/>

            <!-- Card: Locale -->
            <Border Style="{StaticResource SetupFlatCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Currency" x:Name="CurrencyLabel" Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" TabIndex="13" AutomationProperties.Name="Currency Symbol"
                              ItemsSource="{Binding CurrencySymbols}" SelectedItem="{Binding SelectedCurrencySymbol}"
                              AutomationProperties.LabeledBy="{Binding ElementName=CurrencyLabel}"
                              Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding CurrencyPreview}"
                               FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="FY Start" x:Name="FyStartLabel" Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" TabIndex="14" AutomationProperties.Name="Financial Year Start Month"
                              ItemsSource="{Binding Months}" SelectedItem="{Binding SelectedFYStartMonth}"
                              AutomationProperties.LabeledBy="{Binding ElementName=FyStartLabel}"
                              Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding FinancialYearDisplay}"
                               FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Date Format" x:Name="DateFormatLabel" Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox Grid.Row="6" Grid.Column="1" TabIndex="15" AutomationProperties.Name="Date Format"
                              ItemsSource="{Binding DateFormats}" SelectedItem="{Binding SelectedDateFormat}"
                              AutomationProperties.LabeledBy="{Binding ElementName=DateFormatLabel}"
                              Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding DateFormatPreview}"
                               FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>
                </Grid>
            </Border>

            <!-- Card: Tax & Billing -->
            <Border Style="{StaticResource SetupFlatCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Tax Mode" x:Name="TaxModeLabel" Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox Grid.Row="0" Grid.Column="1" TabIndex="16" AutomationProperties.Name="Tax Mode"
                              ItemsSource="{Binding TaxModes}" SelectedItem="{Binding SelectedTaxMode}"
                              AutomationProperties.LabeledBy="{Binding ElementName=TaxModeLabel}"
                              Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding TaxModeHint}"
                               FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Rounding" x:Name="RoundingLabel" Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox Grid.Row="3" Grid.Column="1" TabIndex="17" AutomationProperties.Name="Bill Rounding Method"
                              ItemsSource="{Binding RoundingMethods}" SelectedItem="{Binding SelectedRoundingMethod}"
                              AutomationProperties.LabeledBy="{Binding ElementName=RoundingLabel}"
                              Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding RoundingPreview}"
                               FontSize="{StaticResource FontSizeCaption}" Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource ValidationHintMargin}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Words Lang" x:Name="WordsLangLabel" Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox Grid.Row="6" Grid.Column="1" TabIndex="18" AutomationProperties.Name="Number-to-Words Language"
                              ItemsSource="{Binding NumberToWordsLanguages}" SelectedItem="{Binding SelectedNumberToWordsLanguage}"
                              AutomationProperties.LabeledBy="{Binding ElementName=WordsLangLabel}"
                              Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Neg. Stock" Style="{StaticResource FormRowLabelStyle}"/>
                    <DockPanel Grid.Row="8" Grid.Column="1">
                        <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                  IsChecked="{Binding NegativeStockAllowed}"
                                  AutomationProperties.Name="Allow Negative Stock"
                                  DockPanel.Dock="Left"/>
                        <TextBlock Text="Allow billing with zero stock"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   VerticalAlignment="Center" Margin="{StaticResource StrengthLabelGap}"/>
                    </DockPanel>
                </Grid>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
