<Page x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupPages.BackupDataPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
      Background="Transparent"
      FontFamily="{StaticResource FluentFontFamily}"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Page.Resources>
        <Style x:Key="BackupConfigHintTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CollapsibleHintTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsBackupConfigVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Focusable="False" CanContentScroll="False" PanningMode="VerticalOnly">
        <StackPanel>
            <controls:SetupPageHeader Title="Backup &amp; Data"
                                       Description="Configure automatic backup schedule and storage location."/>

            <controls:SetupFormCard>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="AutoBackupLabel" Grid.Row="0" Grid.Column="0" Text="Auto Backup" Style="{StaticResource FormRowLabelStyle}"/>
                    <DockPanel Grid.Row="0" Grid.Column="1">
                        <CheckBox x:Name="AutoBackupToggle" Style="{StaticResource FluentToggleSwitchStyle}"
                                  IsChecked="{Binding AutoBackupEnabled}"
                                  AutomationProperties.Name="Enable Auto Backup"
                                  AutomationProperties.LabeledBy="{Binding ElementName=AutoBackupLabel}"
                                  DockPanel.Dock="Left"/>
                        <TextBlock FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   VerticalAlignment="Center" Margin="{StaticResource StrengthLabelGap}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Off — use manual backup only"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AutoBackupEnabled}" Value="True">
                                            <Setter Property="Text" Value="Daily scheduled backup"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>

                    <TextBlock x:Name="BackupTimeLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"
                               Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}"><Run Text="Time (HH:mm)"/></TextBlock>
                    <TextBox Grid.Row="2" Grid.Column="1" x:Name="BackupTimeBox" TabIndex="40"
                             Text="{Binding BackupTime, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                             MaxLength="5" AutomationProperties.Name="Backup Time"
                             AutomationProperties.LabeledBy="{Binding ElementName=BackupTimeLabel}"
                             Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1"
                               Text="{Binding BackupTimeValidationHint}"
                               Foreground="{Binding BackupTimeValidationHint, Converter={StaticResource HintForegroundConverter}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="{StaticResource ValidationHintMargin}"
                               Style="{StaticResource BackupConfigHintTextStyle}"/>

                    <TextBlock x:Name="BackupPathLabel" Grid.Row="5" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"
                               Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}"><Run Text="Location"/></TextBlock>
                    <DockPanel Grid.Row="5" Grid.Column="1"
                               Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}">
                        <Button DockPanel.Dock="Right" Content="Browse&#x2026;"
                                Click="OnBrowseBackupFolder"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="{StaticResource SetupBrowseButtonMargin}"
                                MinHeight="{StaticResource SetupBrowseButtonMinHeight}"
                                AutomationProperties.Name="Browse for backup folder"/>
                        <TextBox x:Name="BackupPathBox" TabIndex="41"
                                 Text="{Binding BackupLocation, UpdateSourceTrigger=PropertyChanged}"
                                 HorizontalAlignment="Stretch"
                                 MaxLength="260"
                                 AutomationProperties.Name="Backup Location"
                                 AutomationProperties.LabeledBy="{Binding ElementName=BackupPathLabel}"/>
                    </DockPanel>
                    <TextBlock Grid.Row="6" Grid.Column="1"
                               Text="Folder must exist. Default: Documents\StoreAssistantPro\Backups"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentTextTertiary}"
                               Visibility="{Binding IsBackupConfigVisible, Converter={StaticResource BoolToVisibility}}"
                               Margin="{StaticResource ValidationHintMargin}"/>
                </Grid>
            </controls:SetupFormCard>
        </StackPanel>
    </ScrollViewer>
</Page>
