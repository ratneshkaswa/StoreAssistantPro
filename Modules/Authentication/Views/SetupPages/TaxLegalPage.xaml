<Page x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupPages.TaxLegalPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
      xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
      Background="Transparent"
      FontFamily="{StaticResource FluentFontFamily}"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Focusable="False" CanContentScroll="False" PanningMode="VerticalOnly">
        <StackPanel>
            <controls:SetupPageHeader Title="Tax &amp; Legal"
                                       Description="Manage GSTIN, PAN and GST compliance settings."/>

            <!-- Card: GST Registration -->
            <controls:SetupFormCard>
                <StackPanel>
                    <TextBlock Text="GST Registration" Style="{StaticResource SectionHeaderStyle}" Margin="{StaticResource SetupSectionTitleMargin}"/>
                    <TextBlock Text="Select your registration mode and composition rate if applicable."
                               Style="{StaticResource HintTextStyle}" Margin="{StaticResource SetupSectionHintMargin}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="GstRegTypeLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"><Run Text="GST Type "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                        <ComboBox Grid.Row="0" Grid.Column="1" x:Name="GstRegTypeCombo" TabIndex="9" AutomationProperties.Name="GST Registration Type"
                                  ItemsSource="{Binding GstRegistrationTypes}" SelectedItem="{Binding SelectedGstRegistrationType}"
                                  AutomationProperties.LabeledBy="{Binding ElementName=GstRegTypeLabel}"
                                  Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                        <TextBlock x:Name="CompRateLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"
                                   Visibility="{Binding IsCompositionScheme, Converter={StaticResource BoolToVisibility}}"><Run Text="Rate (%)"/></TextBlock>
                        <TextBox Grid.Row="2" Grid.Column="1" x:Name="CompRateBox" TabIndex="10"
                                 Text="{Binding CompositionRate, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                 MaxLength="4" AutomationProperties.Name="Composition Rate"
                                 h:Watermark.Text="e.g. 1"
                                 AutomationProperties.LabeledBy="{Binding ElementName=CompRateLabel}"
                                 Visibility="{Binding IsCompositionScheme, Converter={StaticResource BoolToVisibility}}"/>
                        <StackPanel Grid.Row="3" Grid.Column="1">
                            <TextBlock Text="{Binding CompositionRateValidationHint}"
                                       Foreground="{Binding CompositionRateValidationHint, Converter={StaticResource HintForegroundConverter}}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="{StaticResource ValidationHintMargin}"
                                       Style="{StaticResource CollapsibleHintTextStyle}"/>
                            <TextBlock Text="{Binding CompositionRateHint}"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="{StaticResource ValidationHintMargin}"
                                       Style="{StaticResource CollapsibleHintTextStyle}"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </controls:SetupFormCard>

            <!-- Card: Tax Identifiers -->
            <controls:SetupFormCard>
                <StackPanel>
                    <TextBlock Text="Tax Identifiers" Style="{StaticResource SectionHeaderStyle}" Margin="{StaticResource SetupSectionTitleMargin}"/>
                    <TextBlock Text="Keep these fields blank if your business is currently unregistered."
                               Style="{StaticResource HintTextStyle}" Margin="{StaticResource SetupSectionHintMargin}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="GstinLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}" Text="GSTIN"/>
                        <TextBox Grid.Row="0" Grid.Column="1" x:Name="GstinBox" TabIndex="11" AutomationProperties.Name="GSTIN"
                                 Text="{Binding GSTIN, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"
                                 h:Watermark.Text="e.g. 22AAAAA0000A1Z5"
                                 AutomationProperties.LabeledBy="{Binding ElementName=GstinLabel}"
                                 MaxLength="15" CharacterCasing="Upper"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                   Text="{Binding GstinValidationHint}"
                                   Foreground="{Binding GstinValidationHint, Converter={StaticResource HintForegroundConverter}}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Margin="{StaticResource ValidationHintMargin}"
                                   Style="{StaticResource CollapsibleHintTextStyle}"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                   Text="{Binding DerivedStateCodeDisplay}"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Margin="{StaticResource ValidationHintMargin}"
                                   Style="{StaticResource CollapsibleHintTextStyle}"/>

                        <TextBlock x:Name="PanLabel" Grid.Row="4" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}" Text="PAN"/>
                        <TextBox Grid.Row="4" Grid.Column="1" x:Name="PanBox" TabIndex="12" AutomationProperties.Name="PAN"
                                 Text="{Binding PAN, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left" MaxLength="10"
                                 h:Watermark.Text="e.g. ABCDE1234F"
                                 AutomationProperties.LabeledBy="{Binding ElementName=PanLabel}"
                                 CharacterCasing="Upper"/>
                        <TextBlock Grid.Row="5" Grid.Column="1"
                                   Text="{Binding PanValidationHint}"
                                   Foreground="{Binding PanValidationHint, Converter={StaticResource HintForegroundConverter}}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Margin="{StaticResource ValidationHintMargin}"
                                   Style="{StaticResource CollapsibleHintTextStyle}"/>
                        <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="{Binding GstinPanCrossHint}"
                                   Foreground="{Binding GstinPanCrossHint, Converter={StaticResource HintForegroundConverter}}"
                                   Margin="{StaticResource CrossHintMargin}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Style="{StaticResource CollapsibleHintTextStyle}"/>
                    </Grid>
                </StackPanel>
            </controls:SetupFormCard>
        </StackPanel>
    </ScrollViewer>
</Page>
