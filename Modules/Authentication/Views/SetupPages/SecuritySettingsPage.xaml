<Page x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupPages.SecuritySettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
      Background="Transparent"
      FontFamily="{StaticResource FluentFontFamily}"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Focusable="False" CanContentScroll="False" PanningMode="VerticalOnly">
        <StackPanel>
            <controls:InfoBar Severity="Info"
                              Title="Security setup"
                              Message="Set one PIN for each role. Role PINs must stay unique, and the master PIN should only be used for recovery or high-risk actions."
                              Margin="{StaticResource SecurityInfoBarMargin}"/>

            <Border Style="{StaticResource SetupFlatCardStyle}" Margin="0">
                <StackPanel>
                    <TextBlock Text="Access PINs"
                               Style="{StaticResource SetupSectionHeaderStyle}"/>
                    <TextBlock Text="These are the day-to-day role PINs used across the app."
                               Style="{StaticResource SetupSectionHintTextStyle}"/>

                    <Grid Margin="{StaticResource SecuritySectionTopMargin}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource SecurityRoleLabelWidth}"/>
                            <ColumnDefinition Width="{StaticResource SecurityRolePinColumnWidth}"/>
                            <ColumnDefinition Width="{StaticResource SecurityRolePinColumnWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource SetupFormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource SetupFormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="AdminPinLabel" Grid.Row="0" Grid.Column="0"
                                   Style="{StaticResource SetupFormRowLabelStyle}"
                                   VerticalAlignment="Center">
                            <Run Text="Admin PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                        </TextBlock>
                        <PasswordBox x:Name="AdminPinBox"
                                     Grid.Row="0" Grid.Column="1"
                                     TabIndex="8"
                                     MaxLength="4"
                                     Width="{StaticResource SecurityRolePinBoxWidth}"
                                     HorizontalAlignment="Left"
                                     PasswordChanged="OnPinChanged"
                                     AutomationProperties.Name="Admin PIN"
                                     AutomationProperties.LabeledBy="{Binding ElementName=AdminPinLabel}"
                                     AutomationProperties.IsRequiredForForm="True"/>
                        <PasswordBox x:Name="AdminPinConfirmBox"
                                     Grid.Row="0" Grid.Column="2"
                                     TabIndex="9"
                                     MaxLength="4"
                                     Width="{StaticResource SecurityRolePinBoxWidth}"
                                     HorizontalAlignment="Left"
                                     PasswordChanged="OnPinChanged"
                                     AutomationProperties.Name="Confirm Admin PIN"/>
                        <StackPanel Grid.Row="0" Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SetupPinWarningTextStyle}" Text="{Binding AdminPinWarning}" ToolTip="{Binding AdminPinWarningDetail}"/>
                            <TextBlock Style="{StaticResource SetupPinInlineHintStyle}" Text="{Binding AdminConfirmHint}" Foreground="{Binding AdminConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                        </StackPanel>

                        <TextBlock x:Name="ManagerPinLabel" Grid.Row="2" Grid.Column="0"
                                   Style="{StaticResource SetupFormRowLabelStyle}"
                                   VerticalAlignment="Center">
                            <Run Text="Manager PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                        </TextBlock>
                        <PasswordBox x:Name="ManagerPinBox"
                                     Grid.Row="2" Grid.Column="1"
                                     TabIndex="10"
                                     MaxLength="4"
                                     Width="{StaticResource SecurityRolePinBoxWidth}"
                                     HorizontalAlignment="Left"
                                     PasswordChanged="OnPinChanged"
                                     AutomationProperties.Name="Manager PIN"
                                     AutomationProperties.LabeledBy="{Binding ElementName=ManagerPinLabel}"
                                     AutomationProperties.IsRequiredForForm="True"/>
                        <PasswordBox x:Name="ManagerPinConfirmBox"
                                     Grid.Row="2" Grid.Column="2"
                                     TabIndex="11"
                                     MaxLength="4"
                                     Width="{StaticResource SecurityRolePinBoxWidth}"
                                     HorizontalAlignment="Left"
                                     PasswordChanged="OnPinChanged"
                                     AutomationProperties.Name="Confirm Manager PIN"/>
                        <StackPanel Grid.Row="2" Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SetupPinWarningTextStyle}" Text="{Binding ManagerPinWarning}" ToolTip="{Binding ManagerPinWarningDetail}"/>
                            <TextBlock Style="{StaticResource SetupPinInlineHintStyle}" Text="{Binding ManagerConfirmHint}" Foreground="{Binding ManagerConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                        </StackPanel>

                        <TextBlock x:Name="UserPinLabel" Grid.Row="4" Grid.Column="0"
                                   Style="{StaticResource SetupFormRowLabelStyle}"
                                   VerticalAlignment="Center">
                            <Run Text="User PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                        </TextBlock>
                        <PasswordBox x:Name="UserPinBox"
                                     Grid.Row="4" Grid.Column="1"
                                     TabIndex="12"
                                     MaxLength="4"
                                     Width="{StaticResource SecurityRolePinBoxWidth}"
                                     HorizontalAlignment="Left"
                                     PasswordChanged="OnPinChanged"
                                     AutomationProperties.Name="User PIN"
                                     AutomationProperties.LabeledBy="{Binding ElementName=UserPinLabel}"
                                     AutomationProperties.IsRequiredForForm="True"/>
                        <TextBlock x:Name="UserConfirmLabel"
                                   Grid.Row="4" Grid.Column="2"
                                   Visibility="Collapsed"
                                   Text="Confirm User PIN"/>
                        <PasswordBox x:Name="UserPinConfirmBox"
                                     Grid.Row="4" Grid.Column="2"
                                     TabIndex="13"
                                     MaxLength="4"
                                     Width="{StaticResource SecurityRolePinBoxWidth}"
                                     HorizontalAlignment="Left"
                                     PasswordChanged="OnPinChanged"
                                     AutomationProperties.Name="Confirm User PIN"
                                     AutomationProperties.LabeledBy="{Binding ElementName=UserConfirmLabel}"
                                     AutomationProperties.IsRequiredForForm="True"/>
                        <StackPanel Grid.Row="4" Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                            </StackPanel>
                            <TextBlock Style="{StaticResource SetupPinWarningTextStyle}" Text="{Binding UserPinWarning}" ToolTip="{Binding UserPinWarningDetail}"/>
                            <TextBlock Style="{StaticResource SetupPinInlineHintStyle}" Text="{Binding UserConfirmHint}" Foreground="{Binding UserConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                        </StackPanel>
                    </Grid>

                    <controls:InfoBar Severity="Warning"
                                      Title="PIN conflict"
                                      Message="{Binding PinConflictWarning}"
                                      Visibility="{Binding PinConflictWarning, Converter={StaticResource NonEmptyStringToVisibility}}"
                                      Margin="{StaticResource SecurityConflictMargin}"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource SetupFlatCardStyle}">
                <StackPanel>
                    <TextBlock Text="Recovery PIN"
                               Style="{StaticResource SetupSectionHeaderStyle}"/>
                    <TextBlock Text="Use this only for recovery and restricted actions. It must stay different from all role PINs."
                               Style="{StaticResource SetupSectionHintTextStyle}"/>

                    <Grid Margin="{StaticResource SecuritySectionTopMargin}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                            <ColumnDefinition Width="{StaticResource SecurityRecoveryPinColumnWidth}"/>
                            <ColumnDefinition Width="{StaticResource SecurityRecoveryPinColumnWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource SetupFormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource SetupFormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="MasterPinLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}">
                            <Run Text="Master PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                        </TextBlock>
                        <PasswordBox x:Name="MasterPinBox"
                                     Grid.Row="0" Grid.Column="1"
                                     TabIndex="6"
                                     MaxLength="6"
                                     Width="{StaticResource SecurityMasterPinBoxWidth}"
                                     HorizontalAlignment="Left"
                                     PasswordChanged="OnPinChanged"
                                     AutomationProperties.Name="Master PIN"
                                     AutomationProperties.LabeledBy="{Binding ElementName=MasterPinLabel}"
                                     AutomationProperties.IsRequiredForForm="True"/>
                        <PasswordBox x:Name="MasterPinConfirmBox"
                                     Grid.Row="0" Grid.Column="2"
                                     TabIndex="7"
                                     MaxLength="6"
                                     Width="{StaticResource SecurityMasterPinBoxWidth}"
                                     HorizontalAlignment="Left"
                                     PasswordChanged="OnPinChanged"
                                     AutomationProperties.Name="Confirm Master PIN"
                                     AutomationProperties.LabeledBy="{Binding ElementName=MasterConfirmLabel}"
                                     AutomationProperties.IsRequiredForForm="True"/>
                        <StackPanel Grid.Row="0" Grid.Column="3"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Style="{StaticResource SetupPinWarningTextStyle}" Text="{Binding MasterPinWarning}" ToolTip="{Binding MasterPinWarningDetail}"/>
                            <TextBlock Style="{StaticResource SetupPinInlineHintStyle}" Text="{Binding MasterConfirmHint}" Foreground="{Binding MasterConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Orientation="Horizontal"
                                    Margin="{StaticResource ValidationHintMargin}">
                            <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding MasterPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                            <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding MasterPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                            <Border Style="{StaticResource SetupPinStrengthSegmentStyle}" Background="{Binding MasterPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                        </StackPanel>

                        <TextBlock x:Name="MasterConfirmLabel" Grid.Row="3" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}">
                            <Run Text="Purpose"/>
                        </TextBlock>
                        <TextBlock Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3"
                                   Text="PIN recovery, protected settings, and high-risk actions."
                                   Style="{StaticResource SetupSectionHintTextStyle}"
                                   Margin="0"/>

                        <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="4"
                                   Text="Keep the master PIN private and separate from day-to-day staff access."
                                   Style="{StaticResource SetupSectionHintTextStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
