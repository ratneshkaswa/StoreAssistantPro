<Page x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupPages.SecuritySettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent"
      FontFamily="{StaticResource FluentFontFamily}"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <Page.Resources>
        <Style x:Key="PinStrengthSegmentStyle" TargetType="Border">
            <Setter Property="Width" Value="{StaticResource StrengthBarWidth}"/>
            <Setter Property="Height" Value="{StaticResource StrengthBarHeight}"/>
            <Setter Property="CornerRadius" Value="{StaticResource FluentCornerXSmall}"/>
            <Setter Property="Margin" Value="{StaticResource StrengthBarGap}"/>
        </Style>

        <Style x:Key="PinWarningTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
            <Setter Property="Margin" Value="{StaticResource StrengthLabelGap}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PinInlineHintStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="Margin" Value="{StaticResource StrengthLabelGap}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Text, RelativeSource={RelativeSource Self}}" Value="">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Focusable="False" CanContentScroll="False" PanningMode="VerticalOnly">
        <StackPanel>
            <!-- Card: Master PIN -->
            <Border Style="{StaticResource SetupFlatCardStyle}">
                <StackPanel>
                    <Border Background="{StaticResource RoleMasterBackground}"
                            CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource RoleMasterAccent}" FontSize="{StaticResource FontSizeBody}"
                                   ToolTip="Used to recover or change role PINs if forgotten."><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE72E;"/><Run Text=" Master PIN (6 digits)"/></TextBlock>
                    </Border>
                    <Grid Margin="{StaticResource StepContentTopSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource SetupFormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource SetupFormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="MasterPinLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}"><Run Text="PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                        <DockPanel Grid.Row="0" Grid.Column="1">
                            <PasswordBox x:Name="MasterPinBox" TabIndex="20" MaxLength="6" PasswordChanged="OnPinChanged" AutomationProperties.Name="Master PIN"
                                             AutomationProperties.LabeledBy="{Binding ElementName=MasterPinLabel}"
                                             AutomationProperties.IsRequiredForForm="True"
                                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource PinWarningTextStyle}" Text="{Binding MasterPinWarning}" ToolTip="{Binding MasterPinWarningDetail}"/>
                        </DockPanel>
                        <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="{StaticResource ValidationHintMargin}">
                            <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding MasterPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                            <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding MasterPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                            <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding MasterPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                        </StackPanel>

                        <TextBlock x:Name="MasterConfirmLabel" Grid.Row="3" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}"><Run Text="Confirm PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                        <DockPanel Grid.Row="3" Grid.Column="1">
                            <PasswordBox x:Name="MasterPinConfirmBox" TabIndex="21" MaxLength="6" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm Master PIN"
                                             AutomationProperties.LabeledBy="{Binding ElementName=MasterConfirmLabel}"
                                             AutomationProperties.IsRequiredForForm="True"
                                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource PinInlineHintStyle}" Text="{Binding MasterConfirmHint}" Foreground="{Binding MasterConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                        </DockPanel>

                        <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                                   Text="Master PIN is used for high-risk actions and PIN recovery."
                                   Style="{StaticResource SetupSectionHintTextStyle}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Card: Admin PIN -->
            <Border Style="{StaticResource SetupFlatCardStyle}">
                <StackPanel>
                    <Border Background="{StaticResource RoleAdminBackground}"
                            CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource RoleAdminAccent}" FontSize="{StaticResource FontSizeBody}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE83D;"/><Run Text=" Admin PIN (4 digits)"/></TextBlock>
                    </Border>
                    <Grid Margin="{StaticResource StepContentTopSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource SetupFormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="AdminPinLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}"><Run Text="PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                        <DockPanel Grid.Row="0" Grid.Column="1">
                            <PasswordBox x:Name="AdminPinBox" TabIndex="30" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Admin PIN"
                                             AutomationProperties.LabeledBy="{Binding ElementName=AdminPinLabel}"
                                             AutomationProperties.IsRequiredForForm="True"
                                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource PinWarningTextStyle}" Text="{Binding AdminPinWarning}" ToolTip="{Binding AdminPinWarningDetail}"/>
                        </DockPanel>
                        <DockPanel Grid.Row="1" Grid.Column="1" Margin="{StaticResource ValidationHintMargin}">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding AdminPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                            </StackPanel>
                        </DockPanel>
                        <TextBlock x:Name="AdminConfirmLabel" Grid.Row="3" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}"><Run Text="Confirm PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                        <DockPanel Grid.Row="3" Grid.Column="1">
                            <PasswordBox x:Name="AdminPinConfirmBox" TabIndex="31" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm Admin PIN"
                                             AutomationProperties.LabeledBy="{Binding ElementName=AdminConfirmLabel}"
                                             AutomationProperties.IsRequiredForForm="True"
                                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource PinInlineHintStyle}" Text="{Binding AdminConfirmHint}" Foreground="{Binding AdminConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                        </DockPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Card: Manager PIN -->
            <Border Style="{StaticResource SetupFlatCardStyle}">
                <StackPanel>
                    <Border Background="{StaticResource RoleManagerBackground}"
                            CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource RoleManagerAccent}" FontSize="{StaticResource FontSizeBody}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE77B;"/><Run Text=" Manager PIN (4 digits)"/></TextBlock>
                    </Border>
                    <Grid Margin="{StaticResource StepContentTopSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource SetupFormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="ManagerPinLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}"><Run Text="PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                        <DockPanel Grid.Row="0" Grid.Column="1">
                            <PasswordBox x:Name="ManagerPinBox" TabIndex="32" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Manager PIN"
                                             AutomationProperties.LabeledBy="{Binding ElementName=ManagerPinLabel}"
                                             AutomationProperties.IsRequiredForForm="True"
                                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource PinWarningTextStyle}" Text="{Binding ManagerPinWarning}" ToolTip="{Binding ManagerPinWarningDetail}"/>
                        </DockPanel>
                        <DockPanel Grid.Row="1" Grid.Column="1" Margin="{StaticResource ValidationHintMargin}">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding ManagerPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                            </StackPanel>
                        </DockPanel>
                        <TextBlock x:Name="ManagerConfirmLabel" Grid.Row="3" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}"><Run Text="Confirm PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                        <DockPanel Grid.Row="3" Grid.Column="1">
                            <PasswordBox x:Name="ManagerPinConfirmBox" TabIndex="33" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm Manager PIN"
                                             AutomationProperties.LabeledBy="{Binding ElementName=ManagerConfirmLabel}"
                                             AutomationProperties.IsRequiredForForm="True"
                                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource PinInlineHintStyle}" Text="{Binding ManagerConfirmHint}" Foreground="{Binding ManagerConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                        </DockPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Card: User PIN -->
            <Border Style="{StaticResource SetupFlatCardStyle}">
                <StackPanel>
                    <Border Background="{StaticResource RoleUserBackground}"
                            CornerRadius="{StaticResource FluentCornerSmall}" Padding="{StaticResource RoleSectionPadding}" Margin="{StaticResource RoleSectionMargin}">
                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource RoleUserAccent}" FontSize="{StaticResource FontSizeBody}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7EE;"/><Run Text=" User PIN (4 digits)"/></TextBlock>
                    </Border>
                    <Grid Margin="{StaticResource StepContentTopSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource SetupFormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock x:Name="UserPinLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}"><Run Text="PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                        <DockPanel Grid.Row="0" Grid.Column="1">
                            <PasswordBox x:Name="UserPinBox" TabIndex="34" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="User PIN"
                                             AutomationProperties.LabeledBy="{Binding ElementName=UserPinLabel}"
                                             AutomationProperties.IsRequiredForForm="True"
                                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource PinWarningTextStyle}" Text="{Binding UserPinWarning}" ToolTip="{Binding UserPinWarningDetail}"/>
                        </DockPanel>
                        <DockPanel Grid.Row="1" Grid.Column="1" Margin="{StaticResource ValidationHintMargin}">
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                                <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=0}"/>
                                <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=1}"/>
                                <Border Style="{StaticResource PinStrengthSegmentStyle}" Background="{Binding UserPinStrength, Converter={StaticResource PinStrengthConverter}, ConverterParameter=2}"/>
                            </StackPanel>
                        </DockPanel>
                        <TextBlock x:Name="UserConfirmLabel" Grid.Row="3" Grid.Column="0" Style="{StaticResource SetupFormRowLabelStyle}"><Run Text="Confirm PIN "/><Run Text="*" Foreground="{StaticResource FluentError}"/></TextBlock>
                        <DockPanel Grid.Row="3" Grid.Column="1">
                            <PasswordBox x:Name="UserPinConfirmBox" TabIndex="35" MaxLength="4" PasswordChanged="OnPinChanged" AutomationProperties.Name="Confirm User PIN"
                                             AutomationProperties.LabeledBy="{Binding ElementName=UserConfirmLabel}"
                                             AutomationProperties.IsRequiredForForm="True"
                                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                            <TextBlock Style="{StaticResource PinInlineHintStyle}" Text="{Binding UserConfirmHint}" Foreground="{Binding UserConfirmHint, Converter={StaticResource HintForegroundConverter}}"/>
                        </DockPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Pin conflict warning -->
            <TextBlock Text="{Binding PinConflictWarning}"
                       Foreground="{StaticResource FluentWarning}"
                       Margin="{StaticResource FieldLabelSpacing}"
                       FontSize="{StaticResource FontSizeCaption}"
                       Style="{StaticResource CollapsibleHintTextStyle}"/>
        </StackPanel>
    </ScrollViewer>
</Page>
