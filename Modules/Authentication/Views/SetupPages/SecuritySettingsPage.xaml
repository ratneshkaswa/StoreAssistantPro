<UserControl x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupPages.SecuritySettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             Background="Transparent"
             FontFamily="{StaticResource FluentFontFamily}"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="RolePinPasswordBoxStyle"
               TargetType="PasswordBox"
               BasedOn="{StaticResource {x:Type PasswordBox}}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowRolePins}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RolePinTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowRolePins}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MasterPinPasswordBoxStyle"
               TargetType="PasswordBox"
               BasedOn="{StaticResource {x:Type PasswordBox}}">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowMasterPins}" Value="True">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="MasterPinTextBoxStyle"
               TargetType="TextBox"
               BasedOn="{StaticResource {x:Type TextBox}}">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowMasterPins}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SetupPinFieldLabelStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SetupFormRowLabelStyle}">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="{StaticResource CompactItemSpacing}"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>

        <Style x:Key="SetupPinFeedbackTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SetupPinInlineHintStyle}">
            <Setter Property="Margin" Value="{StaticResource ValidationHintMargin}"/>
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
        </Style>

        <Style x:Key="SetupPinConflictTextStyle"
               TargetType="TextBlock"
               BasedOn="{StaticResource SetupPinInlineHintStyle}">
            <Setter Property="MinHeight" Value="18"/>
            <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
            <Setter Property="TextAlignment" Value="Left"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="{StaticResource SetupPageTopInset}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="1"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0"
                  HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="22"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="AdminPinLabel"
                           Grid.Row="0"
                           Grid.Column="0"
                           Text="Admin PIN *"
                           Style="{StaticResource SetupPinFieldLabelStyle}"/>
                <TextBlock x:Name="AdminConfirmLabel"
                           Grid.Row="0"
                           Grid.Column="2"
                           Text="Confirm"
                           Style="{StaticResource SetupPinFieldLabelStyle}"/>

                <Grid Grid.Row="2" Grid.Column="0">
                    <PasswordBox x:Name="AdminPinBox"
                                 AutomationProperties.Name="Admin PIN"
                                 TabIndex="6"
                                 MaxLength="4"
                                 Width="{StaticResource SecurityRolePinBoxWidth}"
                                 MinHeight="{StaticResource ControlHeight}"
                                 h:Watermark.Text="e.g. 2480"
                                 HorizontalContentAlignment="Center"
                                 Style="{StaticResource RolePinPasswordBoxStyle}"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.HelpText="4 digits"
                                 AutomationProperties.LabeledBy="{Binding ElementName=AdminPinLabel}"
                                 AutomationProperties.IsRequiredForForm="True"/>
                    <TextBox x:Name="AdminPinTextBox"
                             AutomationProperties.Name="Admin PIN (visible)"
                             TabIndex="6"
                             MaxLength="4"
                             Width="{StaticResource SecurityRolePinBoxWidth}"
                             MinHeight="{StaticResource ControlHeight}"
                             h:Watermark.Text="e.g. 2480"
                             HorizontalContentAlignment="Center"
                             Style="{StaticResource RolePinTextBoxStyle}"
                             Text="{Binding AdminPin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="OnPinTextChanged"
                             AutomationProperties.HelpText="4 digits"
                             AutomationProperties.LabeledBy="{Binding ElementName=AdminPinLabel}"
                             AutomationProperties.IsRequiredForForm="True"/>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="2">
                    <PasswordBox x:Name="AdminPinConfirmBox"
                                 AutomationProperties.Name="Confirm Admin PIN"
                                 TabIndex="7"
                                 MaxLength="4"
                                 Width="{StaticResource SecurityRolePinBoxWidth}"
                                 MinHeight="{StaticResource ControlHeight}"
                                 h:Watermark.Text="e.g. 2480"
                                 HorizontalContentAlignment="Center"
                                 Style="{StaticResource RolePinPasswordBoxStyle}"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.HelpText="4 digits"
                                 AutomationProperties.LabeledBy="{Binding ElementName=AdminConfirmLabel}"
                                 AutomationProperties.IsRequiredForForm="True"/>
                    <TextBox x:Name="AdminPinConfirmTextBox"
                             AutomationProperties.Name="Confirm Admin PIN (visible)"
                             TabIndex="7"
                             MaxLength="4"
                             Width="{StaticResource SecurityRolePinBoxWidth}"
                             MinHeight="{StaticResource ControlHeight}"
                             h:Watermark.Text="e.g. 2480"
                             HorizontalContentAlignment="Center"
                             Style="{StaticResource RolePinTextBoxStyle}"
                             Text="{Binding AdminPinConfirm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="OnPinTextChanged"
                             AutomationProperties.HelpText="4 digits"
                             AutomationProperties.LabeledBy="{Binding ElementName=AdminConfirmLabel}"
                             AutomationProperties.IsRequiredForForm="True"/>
                </Grid>

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Text="{Binding AdminConfirmHint}"
                           Style="{StaticResource SetupPinFeedbackTextStyle}"/>
            </Grid>

            <Grid Grid.Column="2"
                  HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="22"/>
                </Grid.RowDefinitions>

                <TextBlock x:Name="UserPinLabel"
                           Grid.Row="0"
                           Grid.Column="0"
                           Text="User PIN *"
                           Style="{StaticResource SetupPinFieldLabelStyle}"/>
                <TextBlock x:Name="UserConfirmLabel"
                           Grid.Row="0"
                           Grid.Column="2"
                           Text="Confirm"
                           Style="{StaticResource SetupPinFieldLabelStyle}"/>

                <Grid Grid.Row="2" Grid.Column="0">
                    <PasswordBox x:Name="UserPinBox"
                                 AutomationProperties.Name="User PIN"
                                 TabIndex="8"
                                 MaxLength="4"
                                 Width="{StaticResource SecurityRolePinBoxWidth}"
                                 MinHeight="{StaticResource ControlHeight}"
                                 h:Watermark.Text="e.g. 1357"
                                 HorizontalContentAlignment="Center"
                                 Style="{StaticResource RolePinPasswordBoxStyle}"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.HelpText="4 digits"
                                 AutomationProperties.LabeledBy="{Binding ElementName=UserPinLabel}"
                                 AutomationProperties.IsRequiredForForm="True"/>
                    <TextBox x:Name="UserPinTextBox"
                             AutomationProperties.Name="User PIN (visible)"
                             TabIndex="8"
                             MaxLength="4"
                             Width="{StaticResource SecurityRolePinBoxWidth}"
                             MinHeight="{StaticResource ControlHeight}"
                             h:Watermark.Text="e.g. 1357"
                             HorizontalContentAlignment="Center"
                             Style="{StaticResource RolePinTextBoxStyle}"
                             Text="{Binding UserPin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="OnPinTextChanged"
                             AutomationProperties.HelpText="4 digits"
                             AutomationProperties.LabeledBy="{Binding ElementName=UserPinLabel}"
                             AutomationProperties.IsRequiredForForm="True"/>
                </Grid>

                <Grid Grid.Row="2" Grid.Column="2">
                    <PasswordBox x:Name="UserPinConfirmBox"
                                 AutomationProperties.Name="Confirm User PIN"
                                 TabIndex="9"
                                 MaxLength="4"
                                 Width="{StaticResource SecurityRolePinBoxWidth}"
                                 MinHeight="{StaticResource ControlHeight}"
                                 h:Watermark.Text="e.g. 1357"
                                 HorizontalContentAlignment="Center"
                                 Style="{StaticResource RolePinPasswordBoxStyle}"
                                 PasswordChanged="OnPinChanged"
                                 AutomationProperties.HelpText="4 digits"
                                 AutomationProperties.LabeledBy="{Binding ElementName=UserConfirmLabel}"
                                 AutomationProperties.IsRequiredForForm="True"/>
                    <TextBox x:Name="UserPinConfirmTextBox"
                             AutomationProperties.Name="Confirm User PIN (visible)"
                             TabIndex="9"
                             MaxLength="4"
                             Width="{StaticResource SecurityRolePinBoxWidth}"
                             MinHeight="{StaticResource ControlHeight}"
                             h:Watermark.Text="e.g. 1357"
                             HorizontalContentAlignment="Center"
                             Style="{StaticResource RolePinTextBoxStyle}"
                             Text="{Binding UserPinConfirm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             TextChanged="OnPinTextChanged"
                             AutomationProperties.HelpText="4 digits"
                             AutomationProperties.LabeledBy="{Binding ElementName=UserConfirmLabel}"
                             AutomationProperties.IsRequiredForForm="True"/>
                </Grid>

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Grid.ColumnSpan="3"
                           Text="{Binding UserConfirmHint}"
                           Style="{StaticResource SetupPinFeedbackTextStyle}"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="2"
              HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="32"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                <CheckBox IsChecked="{Binding ShowRolePins}"
                          Style="{StaticResource FluentToggleSwitchStyle}"
                          AutomationProperties.Name="Show role PINs toggle"/>
                <TextBlock Text="Show role PINs"
                           Margin="{StaticResource InlineLeftGap}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource FluentTextPrimary}"
                           FontSize="{StaticResource FontSizeBody}"/>
            </StackPanel>

            <TextBlock Grid.Column="2"
                       Text="{Binding PinConflictWarning}"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Left"
                       Style="{StaticResource SetupPinConflictTextStyle}"/>
        </Grid>

        <Border Grid.Row="4"
                Height="{StaticResource SetupDividerThickness}"
                Background="{StaticResource FluentStrokeDefault}"/>

        <Grid Grid.Row="6"
              HorizontalAlignment="Left">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="8"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="22"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="MasterPinLabel"
                       Grid.Row="0"
                       Grid.Column="0"
                       Text="Master PIN *"
                       Style="{StaticResource SetupPinFieldLabelStyle}"/>
            <TextBlock x:Name="MasterConfirmLabel"
                       Grid.Row="0"
                       Grid.Column="2"
                       Text="Confirm"
                       Style="{StaticResource SetupPinFieldLabelStyle}"/>

            <Grid Grid.Row="2" Grid.Column="0">
                <PasswordBox x:Name="MasterPinBox"
                             AutomationProperties.Name="Master PIN"
                             TabIndex="10"
                             MaxLength="6"
                             Width="{StaticResource SecurityMasterPinBoxWidth}"
                             MinHeight="{StaticResource ControlHeight}"
                             h:Watermark.Text="e.g. 482913"
                             HorizontalContentAlignment="Center"
                             Style="{StaticResource MasterPinPasswordBoxStyle}"
                             PasswordChanged="OnPinChanged"
                             AutomationProperties.HelpText="6 digits"
                             AutomationProperties.LabeledBy="{Binding ElementName=MasterPinLabel}"
                             AutomationProperties.IsRequiredForForm="True"/>
                <TextBox x:Name="MasterPinTextBox"
                         AutomationProperties.Name="Master PIN (visible)"
                         TabIndex="10"
                         MaxLength="6"
                         Width="{StaticResource SecurityMasterPinBoxWidth}"
                         MinHeight="{StaticResource ControlHeight}"
                         h:Watermark.Text="e.g. 482913"
                         HorizontalContentAlignment="Center"
                         Style="{StaticResource MasterPinTextBoxStyle}"
                         Text="{Binding MasterPin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="OnPinTextChanged"
                         AutomationProperties.HelpText="6 digits"
                         AutomationProperties.LabeledBy="{Binding ElementName=MasterPinLabel}"
                         AutomationProperties.IsRequiredForForm="True"/>
            </Grid>

            <Grid Grid.Row="2" Grid.Column="2">
                <PasswordBox x:Name="MasterPinConfirmBox"
                             AutomationProperties.Name="Confirm Master PIN"
                             TabIndex="11"
                             MaxLength="6"
                             Width="{StaticResource SecurityMasterPinBoxWidth}"
                             MinHeight="{StaticResource ControlHeight}"
                             h:Watermark.Text="e.g. 482913"
                             HorizontalContentAlignment="Center"
                             Style="{StaticResource MasterPinPasswordBoxStyle}"
                             PasswordChanged="OnPinChanged"
                             AutomationProperties.HelpText="6 digits"
                             AutomationProperties.LabeledBy="{Binding ElementName=MasterConfirmLabel}"
                             AutomationProperties.IsRequiredForForm="True"/>
                <TextBox x:Name="MasterPinConfirmTextBox"
                         AutomationProperties.Name="Confirm Master PIN (visible)"
                         TabIndex="11"
                         MaxLength="6"
                         Width="{StaticResource SecurityMasterPinBoxWidth}"
                         MinHeight="{StaticResource ControlHeight}"
                         h:Watermark.Text="e.g. 482913"
                         HorizontalContentAlignment="Center"
                         Style="{StaticResource MasterPinTextBoxStyle}"
                         Text="{Binding MasterPinConfirm, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         TextChanged="OnPinTextChanged"
                         AutomationProperties.HelpText="6 digits"
                         AutomationProperties.LabeledBy="{Binding ElementName=MasterConfirmLabel}"
                         AutomationProperties.IsRequiredForForm="True"/>
            </Grid>

            <TextBlock Grid.Row="3"
                       Grid.Column="0"
                       Grid.ColumnSpan="3"
                       Text="{Binding MasterConfirmHint}"
                       Style="{StaticResource SetupPinFeedbackTextStyle}"/>
        </Grid>

        <Grid Grid.Row="8"
              HorizontalAlignment="Stretch">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                <CheckBox IsChecked="{Binding ShowMasterPins}"
                          Style="{StaticResource FluentToggleSwitchStyle}"
                          AutomationProperties.Name="Show master PIN toggle"/>
                <TextBlock Text="Show master PIN"
                           Margin="{StaticResource InlineLeftGap}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource FluentTextPrimary}"
                           FontSize="{StaticResource FontSizeBody}"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
