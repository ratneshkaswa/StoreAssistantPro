<UserControl x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupPages.FirmProfilePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             Background="Transparent"
             FontFamily="{StaticResource FluentFontFamily}"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="OptionalFirmFieldsStyle" TargetType="Grid">
            <Setter Property="Visibility" Value="Collapsed"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding ShowOptionalFirmFields}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SetupDisclosureButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontFamily" Value="{StaticResource FluentFontFamily}"/>
            <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerMedium}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                                <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="{StaticResource FluentSubtlePressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="{StaticResource SetupPageTopInset}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" HorizontalAlignment="Stretch">
            <TextBlock x:Name="FirmNameLabel"
                       Text="Firm name *"
                       FontSize="{StaticResource FontSizeBody}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource FluentTextPrimary}"
                       HorizontalAlignment="Left"
                       Margin="{StaticResource CompactItemSpacing}"/>
            <TextBox x:Name="FirmNameBox"
                     AutomationProperties.Name="Firm Name"
                     TabIndex="0"
                     Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}"
                     h:Watermark.Text="e.g. Sonali Collection"
                     MaxLength="100"
                     MinHeight="{StaticResource ControlHeight}"
                     AutomationProperties.LabeledBy="{Binding ElementName=FirmNameLabel}"
                     AutomationProperties.IsRequiredForForm="True"/>
        </StackPanel>

        <Button Grid.Row="2"
                Content="{Binding OptionalFirmToggleText}"
                Click="OnToggleOptionalFieldsClick"
                Style="{StaticResource SetupDisclosureButtonStyle}"
                AutomationProperties.Name="Toggle additional business details"/>

        <Grid Grid.Row="4"
              Style="{StaticResource OptionalFirmFieldsStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" HorizontalAlignment="Stretch">
                <TextBlock x:Name="AddressLabel"
                           Text="Address"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FluentTextPrimary}"
                           HorizontalAlignment="Left"
                           Margin="{StaticResource CompactItemSpacing}"/>
                <TextBox x:Name="AddressBox"
                         AutomationProperties.Name="Address"
                         TabIndex="1"
                         Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="e.g. 12 Bapu Bazaar, Jaipur"
                         MaxLength="60"
                         MinHeight="{StaticResource ControlHeight}"
                         TextWrapping="NoWrap"
                         AcceptsReturn="False"
                         VerticalContentAlignment="Center"
                         AutomationProperties.LabeledBy="{Binding ElementName=AddressLabel}"
                         />
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="2" HorizontalAlignment="Stretch">
                <TextBlock x:Name="EmailLabel"
                           Text="Email"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FluentTextPrimary}"
                           HorizontalAlignment="Left"
                           Margin="{StaticResource CompactItemSpacing}"/>
                <TextBox x:Name="EmailBox"
                         AutomationProperties.Name="Email"
                         TabIndex="3"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="e.g. hello@yourstore.in"
                         MaxLength="100"
                         MinHeight="{StaticResource ControlHeight}"
                         AutomationProperties.LabeledBy="{Binding ElementName=EmailLabel}"/>
            </StackPanel>

            <StackPanel Grid.Row="2" Grid.Column="0" HorizontalAlignment="Stretch">
                <TextBlock x:Name="StateLabel"
                           Text="State/UT"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FluentTextPrimary}"
                           HorizontalAlignment="Left"
                           Margin="{StaticResource CompactItemSpacing}"/>
                <ComboBox x:Name="StateCombo"
                          AutomationProperties.Name="State"
                          TabIndex="2"
                          MinHeight="{StaticResource ControlHeight}"
                          ItemsSource="{Binding IndianStates}"
                          IsEditable="False"
                          IsTextSearchEnabled="True"
                          Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                          h:Watermark.Text="e.g. Rajasthan"
                          AutomationProperties.LabeledBy="{Binding ElementName=StateLabel}"
                          MaxDropDownHeight="300"/>
            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="0" HorizontalAlignment="Stretch">
                <TextBlock x:Name="PhoneLabel"
                           Text="Phone"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FluentTextPrimary}"
                           HorizontalAlignment="Left"
                           Margin="{StaticResource CompactItemSpacing}"/>
                <TextBox x:Name="PhoneBox"
                         AutomationProperties.Name="Phone"
                         TabIndex="4"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="e.g. 9876543210"
                         MinHeight="{StaticResource ControlHeight}"
                         HorizontalAlignment="Stretch"
                         VerticalContentAlignment="Center"
                         MaxLength="10"
                         h:NumericInput.IsIntegerOnly="True"
                         AutomationProperties.LabeledBy="{Binding ElementName=PhoneLabel}"
                         AutomationProperties.HelpText="10 digits"
                         />            </StackPanel>

            <StackPanel Grid.Row="4" Grid.Column="2" HorizontalAlignment="Stretch">
                <TextBlock x:Name="PincodeLabel"
                           Text="Postal PIN"
                           FontSize="{StaticResource FontSizeBody}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FluentTextPrimary}"
                           HorizontalAlignment="Left"
                           Margin="{StaticResource CompactItemSpacing}"/>
                <TextBox x:Name="PincodeBox"
                         AutomationProperties.Name="Postal PIN"
                         TabIndex="5"
                         Text="{Binding Pincode, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="e.g. 302001"
                         MinHeight="{StaticResource ControlHeight}"
                         HorizontalAlignment="Stretch"
                         VerticalContentAlignment="Center"
                         AutomationProperties.LabeledBy="{Binding ElementName=PincodeLabel}"
                         AutomationProperties.HelpText="6 digits"
                         MaxLength="6"
                         h:NumericInput.IsIntegerOnly="True"/>
            </StackPanel>
        </Grid>

    </Grid>
</UserControl>
