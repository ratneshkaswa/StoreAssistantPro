<Page x:Class="StoreAssistantPro.Modules.Authentication.Views.SetupPages.FirmProfilePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
      xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
      Background="Transparent"
      FontFamily="{StaticResource FluentFontFamily}"
      UseLayoutRounding="True"
      SnapsToDevicePixels="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                  Focusable="False" CanContentScroll="False" PanningMode="VerticalOnly">
        <StackPanel>
            <controls:SetupPageHeader Title="Firm Profile"
                                       Description="Configure your business identity and store details."/>

            <!-- Card: Business Details -->
            <controls:SetupFormCard>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="FirmNameLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Firm Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="FirmNameBox" TabIndex="0"
                             Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="100"
                             AutomationProperties.LabeledBy="{Binding ElementName=FirmNameLabel}"
                             AutomationProperties.Name="Firm Name"
                             AutomationProperties.IsRequiredForForm="True"/>

                    <TextBlock x:Name="AddressLabel" Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}" Text="Address"/>
                    <TextBox Grid.Row="2" Grid.Column="1" TabIndex="1"
                             Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="200"
                             AutomationProperties.LabeledBy="{Binding ElementName=AddressLabel}"
                             AutomationProperties.Name="Address"/>

                    <TextBlock x:Name="StateLabel" Grid.Row="4" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}" Text="State"/>
                    <ComboBox x:Name="StateCombo" Grid.Row="4" Grid.Column="1" TabIndex="2" AutomationProperties.Name="State"
                              ItemsSource="{Binding IndianStates}" IsEditable="True" IsTextSearchEnabled="True"
                              Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                              AutomationProperties.LabeledBy="{Binding ElementName=StateLabel}"
                              MaxDropDownHeight="300"/>
                </Grid>
            </controls:SetupFormCard>

            <!-- Card: Contact Details -->
            <controls:SetupFormCard>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="{StaticResource SetupLabelColumnWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock x:Name="PincodeLabel" Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}" Text="Pincode"/>
                    <TextBox Grid.Row="0" Grid.Column="1" x:Name="PincodeBox" TabIndex="3" AutomationProperties.Name="Pincode"
                             Text="{Binding Pincode, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                             AutomationProperties.LabeledBy="{Binding ElementName=PincodeLabel}"
                             MaxLength="6"
                             h:NumericInput.IsIntegerOnly="True"/>
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding PincodeValidationHint}"
                               Foreground="{Binding PincodeValidationHint, Converter={StaticResource HintForegroundConverter}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="{StaticResource ValidationHintMargin}"
                               Style="{StaticResource CollapsibleHintTextStyle}"/>

                    <TextBlock x:Name="PhoneLabel" Grid.Row="3" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}" Text="Phone"/>
                    <TextBox Grid.Row="3" Grid.Column="1" x:Name="PhoneBox" TabIndex="4"
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                             MaxLength="15"
                             AutomationProperties.LabeledBy="{Binding ElementName=PhoneLabel}"
                             AutomationProperties.Name="Phone"/>
                    <TextBlock Grid.Row="4" Grid.Column="1"
                               Text="{Binding PhoneValidationHint}"
                               Foreground="{Binding PhoneValidationHint, Converter={StaticResource HintForegroundConverter}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="{StaticResource ValidationHintMargin}"
                               Style="{StaticResource CollapsibleHintTextStyle}"/>

                    <TextBlock x:Name="EmailLabel" Grid.Row="6" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}" Text="Email"/>
                    <TextBox Grid.Row="6" Grid.Column="1" x:Name="EmailBox" TabIndex="5"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="100"
                             AutomationProperties.LabeledBy="{Binding ElementName=EmailLabel}"
                             AutomationProperties.Name="Email"/>
                    <TextBlock Grid.Row="7" Grid.Column="1"
                               Text="{Binding EmailValidationHint}"
                               Foreground="{Binding EmailValidationHint, Converter={StaticResource HintForegroundConverter}}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Margin="{StaticResource ValidationHintMargin}"
                               Style="{StaticResource CollapsibleHintTextStyle}"/>
                </Grid>
            </controls:SetupFormCard>
        </StackPanel>
    </ScrollViewer>
</Page>
