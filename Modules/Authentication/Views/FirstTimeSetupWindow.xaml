<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.FirstTimeSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Store Assistant Pro — First Time Setup">
    <Grid Margin="{StaticResource DialogPadding}"
          h:KeyboardNav.DefaultCommand="{Binding SaveCommand}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="First Time Setup" Style="{StaticResource DialogTitleStyle}"/>

        <!-- Two-column form grid -->
        <Grid Grid.Row="1" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Firm Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Firm Name"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="200"/>

            <!-- Row 2: Admin PIN -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Admin PIN (4 digits)"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="2" Grid.Column="1"
                         x:Name="AdminPinBox" MaxLength="4"
                         PasswordChanged="OnPinChanged"/>

            <!-- Row 4: Manager PIN -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Manager PIN (4 digits)"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="4" Grid.Column="1"
                         x:Name="ManagerPinBox" MaxLength="4"
                         PasswordChanged="OnPinChanged"/>

            <!-- Row 6: User PIN -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="User PIN (4 digits)"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="6" Grid.Column="1"
                         x:Name="UserPinBox" MaxLength="4"
                         PasswordChanged="OnPinChanged"/>

            <!-- Row 8: Master Password -->
            <TextBlock Grid.Row="8" Grid.Column="0" Text="Master Password (6 digits)"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="8" Grid.Column="1"
                         x:Name="MasterPinBox" MaxLength="6"
                         PasswordChanged="OnPinChanged"/>
        </Grid>

        <!-- Messages -->
        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorMessageStyle}" Margin="0,4,0,0"/>

        <!-- Action button — pinned to bottom -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="Complete Setup" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</Window>
