<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.PinLoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="{Binding Title}">
    <Grid Margin="30" h:KeyboardNav.DefaultCommand="{Binding LoginCommand}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Enter PIN" FontSize="12" Margin="0,0,0,3"/>
            <PasswordBox x:Name="PinBox" MaxLength="4" Padding="6" FontSize="18"
                         HorizontalContentAlignment="Center"
                         PasswordChanged="OnPinChanged"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="{Binding ErrorMessage}" Foreground="Red"
                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <Button Grid.Row="3" Content="Login" Command="{Binding LoginCommand}"
                Padding="12,8" FontSize="14" FontWeight="SemiBold"
                HorizontalAlignment="Stretch"/>
    </Grid>
</Window>
