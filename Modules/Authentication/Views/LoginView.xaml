<UserControl x:Class="StoreAssistantPro.Modules.Authentication.Views.LoginView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:models="clr-namespace:StoreAssistantPro.Models"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <UserControl.Resources>
        <Style x:Key="LoginRoleButtonStyle" TargetType="Button"
               BasedOn="{StaticResource SelectableUserButtonStyle}">
            <Setter Property="MinHeight" Value="{StaticResource LoginRoleButtonMinHeight}"/>
            <Setter Property="Padding" Value="{StaticResource ButtonPaddingLarge}"/>
        </Style>

        <Style x:Key="LoginKeypadButtonStyle" TargetType="Button"
               BasedOn="{StaticResource PosKeypadButtonStyle}">
            <Setter Property="MinWidth" Value="{StaticResource LoginKeypadButtonMinSize}"/>
            <Setter Property="MinHeight" Value="{StaticResource LoginKeypadButtonMinSize}"/>
        </Style>

        <Style x:Key="LoginInteractiveRegionStyle" TargetType="FrameworkElement">
            <Setter Property="Opacity" Value="1"/>
            <Setter Property="IsHitTestVisible" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPinRequired}" Value="False">
                    <Setter Property="Opacity" Value="0.58"/>
                    <Setter Property="IsHitTestVisible" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Admin button — blue pastel, deepens on selection -->
        <Style x:Key="AdminButtonStyle" TargetType="Button"
               BasedOn="{StaticResource LoginRoleButtonStyle}">
            <Setter Property="Background" Value="{StaticResource RoleAdminBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RoleAdminBorder}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                            <Binding Path="SelectedUserType"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{StaticResource RoleAdminAccent}"/>
                    <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RoleAdminAccent}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- User button — green pastel -->
        <Style x:Key="UserButtonStyle" TargetType="Button"
               BasedOn="{StaticResource LoginRoleButtonStyle}">
            <Setter Property="Background" Value="{StaticResource RoleUserBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RoleUserBorder}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                            <Binding Path="SelectedUserType"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{StaticResource RoleUserAccent}"/>
                    <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RoleUserAccent}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

    </UserControl.Resources>

    <Grid Background="{StaticResource AppBackgroundBrush}">
        <Border MaxWidth="{StaticResource LoginCardMaxWidth}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="{StaticResource CardMargin}"
                Background="{StaticResource FluentSurface}"
                BorderBrush="{StaticResource FluentSurfaceStroke}"
                BorderThickness="{StaticResource FluentBorderThicknessThin}"
                CornerRadius="{StaticResource FluentCornerXLarge}"
                Padding="{StaticResource CardPadding}"
                Effect="{StaticResource FluentShadowMedium}">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Focusable="False"
                          CanContentScroll="False"
                          PanningMode="Both">
                <Grid MinWidth="{Binding ViewportWidth, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                      MinHeight="{Binding ViewportHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}">
                    <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: Branding -->
                    <RowDefinition Height="Auto"/>  <!-- 1: Default PIN banner -->
                    <RowDefinition Height="Auto"/>  <!-- 2: Role buttons -->
                    <RowDefinition Height="Auto"/>  <!-- 3: PIN card -->
                    <RowDefinition Height="Auto"/>  <!-- 4: Footer -->
                </Grid.RowDefinitions>

            <!-- Row 0: Logo + title -->
                <controls:AppBranding Grid.Row="0" LogoSize="52" Subtitle="{Binding FirmName}"
                                      Margin="{StaticResource FieldLabelSpacing}"/>

            <!-- Row 1: Default admin PIN warning banner -->
                <controls:InfoBar Grid.Row="1"
                                  Severity="Warning"
                                  Title="Default admin PIN"
                                  Message="Admin PIN is 1234. Please change it in User Management."
                                  Visibility="{Binding IsDefaultAdminPin, Converter={StaticResource BoolToVisibility}}"
                                  Margin="{StaticResource ItemSpacing}"/>

            <!-- Row 2: Role buttons -->
                <StackPanel Grid.Row="2" Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="{StaticResource FieldLabelSpacing}">
                    <Button Margin="{StaticResource RoleButtonGap}"
                            Style="{StaticResource AdminButtonStyle}"
                            Tag="{x:Static models:UserType.Admin}"
                            Command="{Binding SelectUserCommand}"
                            CommandParameter="{x:Static models:UserType.Admin}"
                            AutomationProperties.Name="Admin login"
                            MinWidth="{StaticResource LoginRoleButtonMinHeight}">
                        <StackPanel>
                            <TextBlock Text="&#xE83D;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconMedium}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Admin" HorizontalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource HintTextSpacing}"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="{StaticResource RoleButtonGap}"
                            Style="{StaticResource UserButtonStyle}"
                            Tag="{x:Static models:UserType.User}"
                            Command="{Binding SelectUserCommand}"
                            CommandParameter="{x:Static models:UserType.User}"
                            AutomationProperties.Name="User login"
                            MinWidth="{StaticResource LoginRoleButtonMinHeight}"
                            Visibility="{Binding IsUserRoleVisible, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="&#xE7EE;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconMedium}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="User" HorizontalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource HintTextSpacing}"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            <!-- Row 3: PIN card (only for Admin) -->
                <Border Grid.Row="3"
                        Background="{StaticResource FluentBackgroundSecondary}"
                        BorderBrush="{StaticResource FluentStrokeDefault}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource FluentCornerMedium}"
                        Padding="{StaticResource CardPadding}"
                        Margin="{StaticResource ItemSpacing}"
                        Visibility="{Binding IsPinRequired, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <!-- Normal PIN entry mode (Hidden, not Collapsed, to preserve card height) -->
                    <StackPanel Visibility="{Binding IsNormalMode, Converter={StaticResource BoolToHiddenVisibility}}"
                                IsHitTestVisible="{Binding IsNormalMode}">
                        <controls:InfoBar Severity="Success"
                                          Title="PIN reset complete"
                                          Message="{Binding ResetSuccessMessage}"
                                          Visibility="{Binding ResetSuccessMessage, Converter={StaticResource NonEmptyStringToVisibility}}"
                                          Margin="{StaticResource ItemSpacing}"/>

                        <StackPanel Style="{StaticResource LoginInteractiveRegionStyle}">
                            <!-- PIN dots -->
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        Margin="{StaticResource FieldLabelSpacing}"
                                        AutomationProperties.Name="PIN entry progress">
                                <Ellipse Style="{StaticResource PinDotStyle}"
                                         Fill="{Binding PinPad.PinLength, Converter={StaticResource PinDotConverter}, ConverterParameter=0}"/>
                                <Ellipse Style="{StaticResource PinDotStyle}"
                                         Fill="{Binding PinPad.PinLength, Converter={StaticResource PinDotConverter}, ConverterParameter=1}"/>
                                <Ellipse Style="{StaticResource PinDotStyle}"
                                         Fill="{Binding PinPad.PinLength, Converter={StaticResource PinDotConverter}, ConverterParameter=2}"/>
                                <Ellipse Style="{StaticResource PinDotStyle}"
                                         Fill="{Binding PinPad.PinLength, Converter={StaticResource PinDotConverter}, ConverterParameter=3}"/>
                            </StackPanel>

                            <controls:InfoBar Severity="Error"
                                              Title="Login issue"
                                              Message="{Binding ErrorMessage}"
                                              Visibility="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringToVisibility}}"
                                              Margin="{StaticResource ItemSpacing}"/>

                            <!-- Fixed square keypad -->
                            <UniformGrid Columns="3"
                                         Rows="4"
                                         Width="{StaticResource LoginKeypadWidth}"
                                         Height="{StaticResource LoginKeypadHeight}"
                                         HorizontalAlignment="Center"
                                         Margin="{StaticResource KeypadInset}">
                                <Button Content="1" x:Name="Digit1Button" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="1" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="2" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="2" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="3" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="3" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="4" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="4" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="5" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="5" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="6" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="6" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="7" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="7" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="8" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="8" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="9" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="9" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="Clear" Command="{Binding PinPad.ClearCommand}" Style="{StaticResource LoginKeypadButtonStyle}" FontSize="{StaticResource FontSizeBody}"/>
                                <Button Content="0" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="0" Style="{StaticResource LoginKeypadButtonStyle}"/>
                                <Button Content="Back" Command="{Binding PinPad.BackspaceCommand}" Style="{StaticResource LoginKeypadButtonStyle}"
                                        AutomationProperties.Name="Backspace"/>
                            </UniformGrid>

                            <!-- Forgot PIN link -->
                            <TextBlock HorizontalAlignment="Center"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       Margin="{StaticResource CompactItemSpacing}">
                                <Hyperlink Command="{Binding ForgotPinCommand}"
                                           Foreground="{StaticResource FluentAccentDefault}"
                                           TextDecorations="None">
                                    Forgot PIN?
                                </Hyperlink>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- Forgot PIN recovery form -->
                    <StackPanel Visibility="{Binding IsForgotPinMode, Converter={StaticResource BoolToVisibility}}"
                                VerticalAlignment="Top">
                        <TextBlock Text="Reset PIN" HorizontalAlignment="Center"
                                   FontSize="{StaticResource FontSizeSectionHeader}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource FluentAccentDefault}"
                                   Margin="{StaticResource ItemSpacing}"/>
                        <Grid Margin="{StaticResource ItemSpacing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Master"
                                       Style="{StaticResource FormRowLabelStyle}"/>
                            <PasswordBox Grid.Row="0" Grid.Column="1"
                                         x:Name="ResetMasterBox" MaxLength="6"
                                         PasswordChanged="OnResetPinChanged"
                                         AutomationProperties.Name="Master PIN"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="New PIN"
                                       Style="{StaticResource FormRowLabelStyle}"/>
                            <PasswordBox Grid.Row="2" Grid.Column="1"
                                         x:Name="ResetNewPinBox" MaxLength="4"
                                         PasswordChanged="OnResetPinChanged"
                                         AutomationProperties.Name="New PIN"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Confirm"
                                       Style="{StaticResource FormRowLabelStyle}"/>
                            <PasswordBox Grid.Row="4" Grid.Column="1"
                                         x:Name="ResetConfirmPinBox" MaxLength="4"
                                         PasswordChanged="OnResetPinChanged"
                                         AutomationProperties.Name="Confirm New PIN"/>
                        </Grid>

                        <!-- CapsLock warning -->
                        <TextBlock x:Name="CapsLockWarning"
                                   Text="Caps Lock is on"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentWarning}"
                                   HorizontalAlignment="Center"
                                   Visibility="Collapsed"
                                   Margin="{StaticResource ItemSpacing}"/>

                        <controls:InfoBar Severity="Error"
                                          Title="Reset issue"
                                          Message="{Binding ErrorMessage}"
                                          Visibility="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringToVisibility}}"
                                          Margin="{StaticResource ItemSpacing}"/>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="{StaticResource FormActionBarSpacing}">
                            <Button Content="Cancel"
                                    Command="{Binding CancelForgotPinCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="{StaticResource InlineControlSpacing}"
                                    AutomationProperties.Name="Cancel PIN reset"/>
                            <Button Content="Reset PIN"
                                    Command="{Binding ResetPinCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    AutomationProperties.Name="Confirm PIN reset"/>
                        </StackPanel>
                    </StackPanel>

                    <controls:LoadingOverlay IsActive="{Binding IsVerifying}"
                                             Message="Verifying login..."/>
                </Grid>
                </Border>

            <!-- Row 4: Footer -->
                <StackPanel Grid.Row="4" Margin="{StaticResource CompactItemSpacing}">
                <Border Height="{StaticResource SeparatorHeight}" Background="{StaticResource FluentStrokeDefault}"
                        Margin="{StaticResource CompactItemSpacing}"/>
                <WrapPanel HorizontalAlignment="Center"
                           Margin="{StaticResource CompactItemSpacing}">
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="{StaticResource FontSizeLabel}"
                               Foreground="{StaticResource FluentTextSecondary}"
                               FontWeight="SemiBold"
                               Text="{Binding CurrentTime}"
                               Margin="{StaticResource RoleButtonGap}"/>
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="{StaticResource FontSizeLabel}"
                               Margin="{StaticResource InlineLeftGap}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="{Binding ConnectionStatus, Mode=OneWay}"/>
                    </TextBlock>
                </WrapPanel>
                <TextBlock Style="{StaticResource FooterTextStyle}"
                           Margin="{StaticResource FieldLabelSpacing}">
                    <Run Text="v"/><Run Text="{Binding AppVersion, Mode=OneWay}"/><Run Text=" &#x00B7; Developed By "/><Run Text="Ratnesh Kaswa" FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}"/>
                </TextBlock>
                </StackPanel>
                    </Grid>

            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
