<Window x:Class="StoreAssistantPro.Modules.Authentication.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:models="clr-namespace:StoreAssistantPro.Models"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="Login"
        Icon="pack://application:,,,/Assets/app.ico"
        Closing="OnWindowClosing"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Window.Resources>
        <!-- Admin button — blue pastel, deepens on selection -->
        <Style x:Key="AdminButtonStyle" TargetType="Button"
               BasedOn="{StaticResource SelectableUserButtonStyle}">
            <Setter Property="Background" Value="{StaticResource RoleAdminBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RoleAdminBorder}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                            <Binding Path="SelectedUserType"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{StaticResource RoleAdminAccent}"/>
                    <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RoleAdminAccent}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- Manager button — purple pastel -->
        <Style x:Key="ManagerButtonStyle" TargetType="Button"
               BasedOn="{StaticResource SelectableUserButtonStyle}">
            <Setter Property="Background" Value="{StaticResource RoleManagerBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RoleManagerBorder}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                            <Binding Path="SelectedUserType"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{StaticResource RoleManagerAccent}"/>
                    <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RoleManagerAccent}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
        <!-- User button — green pastel -->
        <Style x:Key="UserButtonStyle" TargetType="Button"
               BasedOn="{StaticResource SelectableUserButtonStyle}">
            <Setter Property="Background" Value="{StaticResource RoleUserBackground}"/>
            <Setter Property="BorderBrush" Value="{StaticResource RoleUserBorder}"/>
            <Style.Triggers>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding RelativeSource="{RelativeSource Self}" Path="Tag"/>
                            <Binding Path="SelectedUserType"/>
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{StaticResource RoleUserAccent}"/>
                    <Setter Property="Foreground" Value="{StaticResource FluentTextOnAccent}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource RoleUserAccent}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Border MaxWidth="{StaticResource LoginCardMaxWidth}"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Margin="{StaticResource DialogPadding}"
                Background="{StaticResource FluentSurface}"
                BorderBrush="{StaticResource FluentStrokeDefault}"
                BorderThickness="1"
                CornerRadius="{StaticResource FluentCornerLarge}"
                Padding="{StaticResource CardPadding}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: Branding -->
                    <RowDefinition Height="Auto"/>  <!-- 1: Role buttons -->
                    <RowDefinition Height="Auto"/>  <!-- 2: PIN card -->
                    <RowDefinition Height="Auto"/>  <!-- 3: Footer -->
                </Grid.RowDefinitions>

            <!-- ── Row 0: Logo + title ──────────────────────── -->
                <controls:AppBranding Grid.Row="0" LogoSize="56" Subtitle="{Binding FirmName}"
                                      Margin="{StaticResource ItemSpacing}"/>

            <!-- ── Row 1: Role buttons ────────────────────────── -->
                <UniformGrid Grid.Row="1" Columns="3"
                             Margin="{StaticResource ItemSpacing}">
                    <Button Margin="{StaticResource RoleButtonGap}"
                            Style="{StaticResource AdminButtonStyle}"
                            Tag="{x:Static models:UserType.Admin}"
                            Command="{Binding SelectUserCommand}"
                            CommandParameter="{x:Static models:UserType.Admin}"
                            AutomationProperties.Name="Admin login"
                            ToolTip="F1 — Admin">
                        <StackPanel>
                            <TextBlock Text="&#xE83D;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconMedium}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Admin" HorizontalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource HintTextSpacing}"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="{StaticResource RoleButtonGap}"
                            Style="{StaticResource ManagerButtonStyle}"
                            Tag="{x:Static models:UserType.Manager}"
                            Command="{Binding SelectUserCommand}"
                            CommandParameter="{x:Static models:UserType.Manager}"
                            AutomationProperties.Name="Manager login"
                            ToolTip="F2 — Manager">
                        <StackPanel>
                            <TextBlock Text="&#xE77B;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconMedium}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Manager" HorizontalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource HintTextSpacing}"/>
                        </StackPanel>
                    </Button>
                    <Button Margin="{StaticResource RoleButtonGap}"
                            Style="{StaticResource UserButtonStyle}"
                            Tag="{x:Static models:UserType.User}"
                            Command="{Binding SelectUserCommand}"
                            CommandParameter="{x:Static models:UserType.User}"
                            AutomationProperties.Name="User login"
                            ToolTip="F3 — User">
                        <StackPanel>
                            <TextBlock Text="&#xE7EE;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconMedium}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="User" HorizontalAlignment="Center"
                                       FontSize="{StaticResource FontSizeBody}" Margin="{StaticResource HintTextSpacing}"/>
                        </StackPanel>
                    </Button>
                </UniformGrid>

            <!-- ── Row 2: PIN card (disabled until role selected) ── -->
                <Border Grid.Row="2"
                        Background="{StaticResource FluentBackgroundSecondary}"
                        BorderBrush="{StaticResource FluentStrokeDefault}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource FluentCornerMedium}"
                        Padding="{StaticResource CardPadding}"
                        Margin="{StaticResource ItemSpacing}"
                        IsEnabled="{Binding IsUserSelected}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="1"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsUserSelected}" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Grid>
                    <!-- Normal PIN entry mode (Hidden, not Collapsed, to preserve card height) -->
                    <StackPanel Visibility="{Binding IsNormalMode, Converter={StaticResource BoolToHiddenVisibility}}"
                                IsHitTestVisible="{Binding IsNormalMode}">
                        <!-- Role hint / instruction (always visible, layout-stable) -->
                        <controls:InfoBar Severity="Success"
                                          Title="PIN reset complete"
                                          Message="{Binding ResetSuccessMessage}"
                                          Visibility="{Binding ResetSuccessMessage, Converter={StaticResource NonEmptyStringToVisibility}}"
                                          Margin="{StaticResource ItemSpacing}"/>

                        <TextBlock Text="{Binding RoleHintText}"
                                   HorizontalAlignment="Center"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   FontWeight="SemiBold"
                                   Margin="{StaticResource ItemSpacing}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsUserSelected}" Value="False">
                                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                    <!-- PIN dots -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                Margin="{StaticResource ItemSpacing}"
                                AutomationProperties.Name="PIN entry progress">
                        <Ellipse Style="{StaticResource PinDotStyle}"
                                 Fill="{Binding PinPad.PinLength, Converter={StaticResource PinDotConverter}, ConverterParameter=0}"/>
                        <Ellipse Style="{StaticResource PinDotStyle}"
                                 Fill="{Binding PinPad.PinLength, Converter={StaticResource PinDotConverter}, ConverterParameter=1}"/>
                        <Ellipse Style="{StaticResource PinDotStyle}"
                                 Fill="{Binding PinPad.PinLength, Converter={StaticResource PinDotConverter}, ConverterParameter=2}"/>
                        <Ellipse Style="{StaticResource PinDotStyle}"
                                 Fill="{Binding PinPad.PinLength, Converter={StaticResource PinDotConverter}, ConverterParameter=3}"/>
                    </StackPanel>

                        <controls:InfoBar Severity="Error"
                                          Title="Login issue"
                                          Message="{Binding ErrorMessage}"
                                          Visibility="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringToVisibility}}"
                                          Margin="{StaticResource ItemSpacing}"/>

                    <!-- Keypad -->
                    <Grid Margin="{StaticResource KeypadInset}">
                        <Grid.RowDefinitions>
                            <RowDefinition MinHeight="{StaticResource KeypadRowMinHeight}"/>
                            <RowDefinition MinHeight="{StaticResource KeypadRowMinHeight}"/>
                            <RowDefinition MinHeight="{StaticResource KeypadRowMinHeight}"/>
                            <RowDefinition MinHeight="{StaticResource KeypadRowMinHeight}"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Row="0" Grid.Column="0" Content="1" x:Name="Digit1Button" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="1" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="0" Grid.Column="1" Content="2" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="2" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="0" Grid.Column="2" Content="3" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="3" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="1" Grid.Column="0" Content="4" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="4" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="1" Grid.Column="1" Content="5" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="5" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="1" Grid.Column="2" Content="6" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="6" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="2" Grid.Column="0" Content="7" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="7" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="2" Grid.Column="1" Content="8" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="8" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="2" Grid.Column="2" Content="9" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="9" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="3" Grid.Column="0" Content="Clear" Command="{Binding PinPad.ClearCommand}" Style="{StaticResource PosKeypadButtonStyle}" FontSize="{StaticResource FontSizeBody}"/>
                        <Button Grid.Row="3" Grid.Column="1" Content="0" Command="{Binding PinPad.AddDigitCommand}" CommandParameter="0" Style="{StaticResource PosKeypadButtonStyle}"/>
                        <Button Grid.Row="3" Grid.Column="2" Content="⌫" Command="{Binding PinPad.BackspaceCommand}" Style="{StaticResource PosKeypadButtonStyle}"
                                AutomationProperties.Name="Backspace"/>
                    </Grid>

                    <!-- Keyboard hint -->
                        <TextBlock Text="Or use keyboard 0–9"
                                   Style="{StaticResource HintTextStyle}"
                                   HorizontalAlignment="Center"
                                   Margin="{StaticResource ItemSpacing}"/>

                    <!-- Forgot PIN link -->
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Margin="{StaticResource ItemSpacing}">
                            <Hyperlink Command="{Binding ForgotPinCommand}"
                                       Foreground="{StaticResource FluentAccentDefault}"
                                       TextDecorations="None">
                                Forgot PIN?
                            </Hyperlink>
                        </TextBlock>
                    </StackPanel>

                    <!-- Forgot PIN recovery form (anchored top within reserved card space) -->
                    <StackPanel Visibility="{Binding IsForgotPinMode, Converter={StaticResource BoolToVisibility}}"
                                VerticalAlignment="Top">
                        <TextBlock Text="Reset PIN" HorizontalAlignment="Center"
                                   FontSize="{StaticResource FontSizeSectionHeader}"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource FluentAccentDefault}"
                                   Margin="{StaticResource ItemSpacing}"/>
                        <TextBlock HorizontalAlignment="Center"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   Margin="{StaticResource ItemSpacing}">
                            <Run Text="Enter Master PIN to reset"/>
                            <Run Text="{Binding SelectedUserType, Mode=OneWay}"/>
                            <Run Text="PIN"/>
                        </TextBlock>

                        <Grid Margin="{StaticResource ItemSpacing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Master"
                                       Style="{StaticResource FormRowLabelStyle}"/>
                            <PasswordBox Grid.Row="0" Grid.Column="1"
                                         x:Name="ResetMasterBox" MaxLength="6"
                                         PasswordChanged="OnResetPinChanged"
                                         AutomationProperties.Name="Master PIN"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="New PIN"
                                       Style="{StaticResource FormRowLabelStyle}"/>
                            <PasswordBox Grid.Row="2" Grid.Column="1"
                                         x:Name="ResetNewPinBox" MaxLength="4"
                                         PasswordChanged="OnResetPinChanged"
                                         AutomationProperties.Name="New PIN"/>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Confirm"
                                       Style="{StaticResource FormRowLabelStyle}"/>
                            <PasswordBox Grid.Row="4" Grid.Column="1"
                                         x:Name="ResetConfirmPinBox" MaxLength="4"
                                         PasswordChanged="OnResetPinChanged"
                                         AutomationProperties.Name="Confirm New PIN"/>
                        </Grid>

                        <!-- CapsLock warning -->
                        <TextBlock x:Name="CapsLockWarning"
                                   Text="⚠ Caps Lock is on"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentWarning}"
                                   HorizontalAlignment="Center"
                                   Visibility="Collapsed"
                                   Margin="{StaticResource ItemSpacing}"/>

                        <controls:InfoBar Severity="Error"
                                          Title="Reset issue"
                                          Message="{Binding ErrorMessage}"
                                          Visibility="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringToVisibility}}"
                                          Margin="{StaticResource ItemSpacing}"/>

                        <!-- Action buttons -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                    Margin="{StaticResource FormActionBarSpacing}">
                            <Button Content="Cancel"
                                    Command="{Binding CancelForgotPinCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="{StaticResource InlineControlSpacing}"
                                    AutomationProperties.Name="Cancel PIN reset"/>
                            <Button Content="Reset PIN"
                                    Command="{Binding ResetPinCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    AutomationProperties.Name="Confirm PIN reset"/>
                        </StackPanel>
                    </StackPanel>

                    <controls:LoadingOverlay IsActive="{Binding IsVerifying}"
                                             Message="Verifying login..."/>
                </Grid>
                </Border>

            <!-- ── Row 3: Footer ──────────────────────────────── -->
                <StackPanel Grid.Row="3" Margin="{StaticResource ItemSpacing}">
                <!-- Separator -->
                <Border Height="{StaticResource SeparatorHeight}" Background="{StaticResource FluentStrokeDefault}"
                        Margin="{StaticResource ItemSpacing}"/>
                <TextBlock HorizontalAlignment="Center"
                           FontSize="{StaticResource FontSizeLabel}"
                           Foreground="{StaticResource FluentTextSecondary}"
                           FontWeight="SemiBold"
                           Text="{Binding CurrentTime}"
                           Margin="{StaticResource ItemSpacing}"/>
                <!-- Connection status -->
                <TextBlock HorizontalAlignment="Center"
                           FontSize="{StaticResource FontSizeStatusBar}"
                           Margin="{StaticResource ItemSpacing}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsOffline}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                    <Run Text="{Binding ConnectionStatus, Mode=OneWay}"/>
                </TextBlock>
                <TextBlock Style="{StaticResource FooterTextStyle}">
                    <Run Text="v"/><Run Text="{Binding AppVersion, Mode=OneWay}"/><Run Text=" &#x00B7; Developed By "/><Run Text="Ratnesh Kaswa" FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}"/>
                </TextBlock>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
