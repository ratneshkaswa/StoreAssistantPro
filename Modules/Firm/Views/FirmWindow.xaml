<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Firm.Views.FirmWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Firm Management"
        ConfirmCommand="{Binding ConfirmStepCommand}"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 0: Title + step indicator -->
            <RowDefinition Height="*"/>     <!-- 1: Step content -->
            <RowDefinition Height="Auto"/>  <!-- 2: Messages -->
            <RowDefinition Height="Auto"/>  <!-- 3: Buttons -->
        </Grid.RowDefinitions>

        <!-- Row 0: Title + step indicator -->
        <StackPanel>
            <TextBlock Style="{StaticResource DialogTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE731;"/><Run Text=" Firm Management"/></TextBlock>

            <!-- Visual step progress: ●──────○──────○ -->
            <Grid HorizontalAlignment="Center" Margin="{StaticResource ItemSpacing}" Width="{StaticResource StepIndicatorWidth}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Step 1 dot + label -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Ellipse Width="{StaticResource StepDotSize}" Height="{StaticResource StepDotSize}" HorizontalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource FluentAccentDefault}"/>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Profile" HorizontalAlignment="Center"
                               FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource StepLabelSpacing}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Line 1→2 -->
                <Border Grid.Column="1" Height="{StaticResource StepConnectorHeight}" VerticalAlignment="Top" Margin="{StaticResource StepConnectorTopOffset}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource FluentStrokeDefault}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep1}" Value="False">
                                    <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Step 2 dot + label -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <Ellipse Width="{StaticResource StepDotSize}" Height="{StaticResource StepDotSize}" HorizontalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource FluentStrokeDefault}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep1}" Value="False">
                                        <Setter Property="Fill" Value="{StaticResource FluentAccentDefault}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Tax" HorizontalAlignment="Center"
                               FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource StepLabelSpacing}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <!-- Line 2→3 -->
                <Border Grid.Column="3" Height="{StaticResource StepConnectorHeight}" VerticalAlignment="Top" Margin="{StaticResource StepConnectorTopOffset}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource FluentStrokeDefault}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Step 3 dot + label -->
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <Ellipse Width="{StaticResource StepDotSize}" Height="{StaticResource StepDotSize}" HorizontalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource FluentStrokeDefault}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource FluentAccentDefault}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Regional" HorizontalAlignment="Center"
                               FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource StepLabelSpacing}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Row 1: Step content -->
        <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">

            <!-- ───── Step 1: Firm Profile ───── -->
            <Grid Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Firm Name: full width (up to 200 chars) -->
                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Firm Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                         MaxLength="100" h:Watermark.Text="e.g. Sharma Textiles"/>

                <!-- Address: full width, taller for multi-line -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="Address"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="200" h:Watermark.Text="e.g. 123, Gandhi Nagar, Jaipur"/>

                <!-- State: full width -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="State"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="50" h:Watermark.Text="e.g. Rajasthan"/>

                <!-- Pincode: compact (6 digits) -->
                <TextBlock Grid.Row="6" Grid.Column="0" Text="Pincode"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="6" Grid.Column="1"
                         Text="{Binding Pincode, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                         MaxLength="6" h:NumericInput.IsIntegerOnly="True"
                         h:Watermark.Text="e.g. 302001" Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>

                <!-- Phone: standard (10–15 digits) -->
                <TextBlock Grid.Row="8" Grid.Column="0" Text="Phone"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="8" Grid.Column="1"
                         Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                         h:NumericInput.IsIntegerOnly="True"
                         MaxLength="15" h:Watermark.Text="e.g. 9876543210"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                <!-- Email: full width (long addresses) -->
                <TextBlock Grid.Row="10" Grid.Column="0" Text="Email"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="10" Grid.Column="1"
                         Text="{Binding Email, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                         MaxLength="100" h:Watermark.Text="e.g. info@sharmatextiles.com"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="Phone number will also be used as WhatsApp number."
                           Style="{StaticResource HintTextStyle}"/>
            </Grid>

            <!-- ───── Step 2: Tax &amp; Legal ───── -->
            <Grid Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- 0: GST Registration Type -->
                    <RowDefinition Height="Auto"/>  <!-- 1: Composition Rate (conditional) -->
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>  <!-- 3: GSTIN -->
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>  <!-- 5: PAN -->
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>  <!-- 7: hint -->
                </Grid.RowDefinitions>

                <!-- GST Registration Type -->
                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="GST Type"/>
                </TextBlock>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding GstRegistrationTypes}"
                          SelectedItem="{Binding SelectedGstRegistrationType}"
                          Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                <!-- Composition Rate (conditional) -->
                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}"
                           Visibility="{Binding IsCompositionScheme, Converter={StaticResource BoolToVisibility}}">
                    <Run Text="Rate (%)"/>
                </TextBlock>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding CompositionRate, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                         MaxLength="4" h:NumericInput.IsIntegerOnly="True"
                         Visibility="{Binding IsCompositionScheme, Converter={StaticResource BoolToVisibility}}"/>

                <!-- GSTIN: wide (15 alphanumeric chars) -->
                <TextBlock Grid.Row="3" Grid.Column="0" Text="GSTIN"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="3" Grid.Column="1"
                         Text="{Binding GSTNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                         MaxLength="15" CharacterCasing="Upper"
                         h:Watermark.Text="e.g. 08ABCDE1234F1Z5"
                         Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"/>

                <!-- PAN: standard (10 alphanumeric chars) -->
                <TextBlock Grid.Row="5" Grid.Column="0" Text="PAN"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="5" Grid.Column="1"
                         Text="{Binding PANNumber, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                         MaxLength="10" CharacterCasing="Upper"
                         h:Watermark.Text="e.g. ABCDE1234F"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="2"
                           Text="Business vertical: Clothing Retail"
                           Style="{StaticResource HintTextStyle}"/>
            </Grid>

            <!-- ───── Step 3: Regional Settings ───── -->
            <Grid Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Currency Symbol -->
                <TextBlock Grid.Row="0" Grid.Column="0" Text="Currency"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          ItemsSource="{Binding CurrencySymbols}"
                          SelectedItem="{Binding SelectedCurrencySymbol}"
                          Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>

                <!-- Financial Year Start -->
                <TextBlock Grid.Row="2" Grid.Column="0" Text="FY Starts"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <ComboBox ItemsSource="{Binding Months}"
                              SelectedItem="{Binding SelectedFYStartMonth}"
                              Width="{StaticResource FieldWidthStandard}"/>
                    <TextBlock Text="{Binding FinancialYearDisplay}" VerticalAlignment="Center"
                               Margin="{StaticResource FormColumnGap}"
                               FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentTextSecondary}"/>
                </StackPanel>

                <!-- Date Format -->
                <TextBlock Grid.Row="4" Grid.Column="0" Text="Date Format"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <ComboBox Grid.Row="4" Grid.Column="1"
                          ItemsSource="{Binding DateFormats}"
                          SelectedItem="{Binding SelectedDateFormat}"
                          Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2"
                           Style="{StaticResource HintTextStyle}"
                           Text="Number format: Indian (1,00,000)"/>
            </Grid>
        </Grid>

        <!-- Row 2: Messages (reserved space prevents layout shift) -->
        <StackPanel Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}"
                    Margin="{StaticResource FieldLabelSpacing}">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                       h:AutoDismiss.IsEnabled="True" h:AutoDismiss.Seconds="4"/>
        </StackPanel>

        <!-- Row 3: Navigation buttons -->
        <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&#x2190; Back" Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibility}}"/>

            <StackPanel Grid.Column="2" Orientation="Horizontal">
                <Button Content="Next &#x2192;" Command="{Binding NextCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="{StaticResource InlineControlSpacing}"
                        Visibility="{Binding CanGoNext, Converter={StaticResource BoolToVisibility}}"/>
                <Button Content="Save" Command="{Binding SaveFirmCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="{StaticResource InlineControlSpacing}"
                        Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVisibility}}"/>
                <Button Content="Close" IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </StackPanel>
        </Grid>
    </Grid>
</core:BaseDialogWindow>
