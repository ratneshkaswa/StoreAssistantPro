<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Firm.Views.FirmManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Firm Management"
        ConfirmCommand="{Binding SaveFirmCommand}"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="🏢 Firm Management" Style="{StaticResource DialogTitleStyle}"/>

        <!-- Two-column form grid -->
        <Grid Grid.Row="1" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="80"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Firm Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Firm Name *"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                     MaxLength="200"/>

            <!-- Row 2: Address -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Address"
                       Style="{StaticResource FormRowLabelStyle}"
                       VerticalAlignment="Top" Margin="0,6,12,0"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="500" TextWrapping="Wrap"
                     AcceptsReturn="True" MinHeight="50"
                     VerticalScrollBarVisibility="Auto"/>

            <!-- Row 4: Phone -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBox Grid.Row="4" Grid.Column="1"
                     Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                     h:NumericInput.IsIntegerOnly="True"
                     MaxLength="20"/>
        </Grid>

        <!-- Messages -->
        <StackPanel Grid.Row="2" Margin="{StaticResource FieldLabelSpacing}">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                       h:AutoDismiss.IsEnabled="True" h:AutoDismiss.Seconds="4"/>
        </StackPanel>

        <!-- Action buttons — pinned to bottom -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="💾 Save" Command="{Binding SaveFirmCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</core:BaseDialogWindow>
