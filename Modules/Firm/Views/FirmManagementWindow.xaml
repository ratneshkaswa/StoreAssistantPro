<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Firm.Views.FirmManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        Title="Firm Management"
        ConfirmCommand="{Binding SaveFirmCommand}"
        Loaded="OnLoaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🏢 Firm Management" Style="{StaticResource DialogTitleStyle}" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="{StaticResource FieldGroupSpacing}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Firm Name *" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox Grid.Row="1" Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                     MaxLength="200" HorizontalAlignment="Stretch"/>
        </Grid>

        <Grid Grid.Row="2" Margin="{StaticResource FieldGroupSpacing}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Address" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox Grid.Row="1" Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="500" TextWrapping="Wrap"
                     AcceptsReturn="True" Height="50" VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch"/>
        </Grid>

        <Grid Grid.Row="3" Margin="{StaticResource FieldGroupSpacing}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="Phone" Style="{StaticResource FieldLabelStyle}"/>
            <TextBox Grid.Row="1" Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="20" HorizontalAlignment="Stretch"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,0,0,5">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Grid.Row="0" Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Grid.Row="1" Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"/>
        </Grid>

        <Grid Grid.Row="5" HorizontalAlignment="Right">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="0" Content="💾 Save" Command="{Binding SaveFirmCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="Close" IsCancel="True"
                    Padding="{StaticResource ButtonPaddingLarge}" FontSize="{StaticResource FontSizeBody}"/>
        </Grid>
    </Grid>
    </ScrollViewer>
</core:BaseDialogWindow>
