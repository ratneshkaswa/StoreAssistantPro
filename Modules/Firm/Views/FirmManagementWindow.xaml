<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Firm.Views.FirmManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        Title="Firm Management"
        ConfirmCommand="{Binding SaveFirmCommand}"
        Loaded="OnLoaded">
    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="🏢 Firm Management" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Firm Name *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged, ValidatesOnNotifyDataErrors=True}"
                     Padding="6" MaxLength="200"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Address" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" MaxLength="500" TextWrapping="Wrap"
                     AcceptsReturn="True" Height="50" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,12">
            <TextBlock Text="Phone" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,3"/>
            <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" MaxLength="20"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,5">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#4CAF50" TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="💾 Save" Command="{Binding SaveFirmCommand}"
                    Padding="16,8" FontSize="13" FontWeight="SemiBold" Margin="0,0,8,0"/>
            <Button Content="Close" IsCancel="True"
                    Padding="16,8" FontSize="13"/>
        </StackPanel>
    </Grid>
    </ScrollViewer>
</core:BaseDialogWindow>
