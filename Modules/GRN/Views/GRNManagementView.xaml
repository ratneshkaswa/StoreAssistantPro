<UserControl x:Class="StoreAssistantPro.Modules.GRN.Views.GRNManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7B8;"/><Run Text=" Goods Received Notes"/></TextBlock>
            <TextBlock Text="Receive purchase orders into stock, review received quantities, and complete or cancel GRN processing."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FluentSearchTextBoxStyle}"
                     AutomationProperties.Name="Search GRNs"
                     h:Watermark.Text="Search GRNs by number, PO, or supplier"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StatusOptions}"
                      SelectedItem="{Binding FilterStatus}"
                      Style="{StaticResource FluentComboBoxStyle}"
                      Width="{StaticResource FieldWidthStandard}"
                      Margin="{StaticResource InlineControlSpacing}"
                      AutomationProperties.Name="Filter by status">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource NullToAllConverter}}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Grid.Column="2"
                    Content="Search"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource SearchButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource MasterDetailListPaneWidth}"/>
                <ColumnDefinition Width="{StaticResource MasterDetailPaneGapWidth}"/>
                <ColumnDefinition Width="{StaticResource MasterDetailEditorPaneWidth}"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid AutomationProperties.Name="GRN list"
                          ItemsSource="{Binding GRNs}"
                          SelectedItem="{Binding SelectedGRN}"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          h:DataGridLayoutPersistence.Key="GRNGrid"
                          h:DataGridEmptyState.Icon="&#x1F4E6;"
                          h:DataGridEmptyState.Title="No goods received notes"
                          h:DataGridEmptyState.Description="Create a GRN from a purchase order to track goods received."
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="GRN #" Binding="{Binding GRNNumber}" Width="{StaticResource ColumnWidthId}"/>
                        <DataGridTextColumn Header="PO #" Binding="{Binding PurchaseOrder.OrderNumber}" Width="{StaticResource ColumnWidthId}"/>
                        <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.Name}" Width="*"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding ReceivedDate, StringFormat=dd-MMM-yyyy}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1"
                            Style="{StaticResource PaginatorBarStyle}"
                            Visibility="{Binding TotalCount, Converter={StaticResource PositiveToVisibility}}">
                    <Button Content="Prev"
                            Command="{Binding PreviousPageCommand}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding PagingInfo}"
                               VerticalAlignment="Center"
                               Style="{StaticResource PaginatorInfoTextStyle}"/>
                    <Button Content="Next"
                            Command="{Binding NextPageCommand}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False"
                          Margin="{StaticResource ItemSpacing}">
                <StackPanel>
                    <Border Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Create GRN from Purchase Order"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Choose a pending purchase order and add notes before receiving the related goods."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                            <TextBlock Text="Purchase Order" Style="{StaticResource FormRowLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding PendingPOs}"
                                      SelectedItem="{Binding SelectedPO}"
                                      DisplayMemberPath="OrderNumber"
                                      Style="{StaticResource FluentAutoSuggestComboBoxStyle}"
                                      AutomationProperties.Name="Purchase order"
                                      Margin="0,0,0,8"/>

                            <TextBlock Text="Notes" Style="{StaticResource FormRowLabelStyle}"/>
                            <TextBox Text="{Binding GRNNotes, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource FluentMultilineTextBoxStyle}"
                                     MaxLength="500"
                                     AutomationProperties.Name="GRN notes"/>

                            <WrapPanel Style="{StaticResource LineItemActionRowStyle}">
                                <Button Content="Create GRN"
                                        Command="{Binding CreateFromPOCommand}"
                                        Style="{StaticResource SaveButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Selected GRN"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Review expected, received, and rejected quantities for the currently selected GRN."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                            <DataGrid ItemsSource="{Binding SelectedGRN.Items}"
                                      Style="{StaticResource EnterpriseDataGridStyle}"
                                      AutomationProperties.Name="GRN items"
                                      MaxHeight="{StaticResource EditableGridMaxHeight}"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      Visibility="{Binding HasSelectedGRN, Converter={StaticResource BoolToVisibility}}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="*"/>
                                    <DataGridTextColumn Header="Expected" Binding="{Binding QtyExpected}" Width="{StaticResource ColumnWidthQty}"/>
                                    <DataGridTextColumn Header="Received" Binding="{Binding QtyReceived}" Width="{StaticResource ColumnWidthQty}"/>
                                    <DataGridTextColumn Header="Rejected" Binding="{Binding QtyRejected}" Width="{StaticResource ColumnWidthQty}"/>
                                    <DataGridTextColumn Header="Unit Cost" Binding="{Binding UnitCost, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <WrapPanel Style="{StaticResource StateTransitionActionBarStyle}">
                                <Button Content="Confirm GRN"
                                        Command="{Binding ConfirmGRNCommand}"
                                        IsEnabled="{Binding CanConfirm}"
                                        Style="{StaticResource StateTransitionPrimaryButtonStyle}"/>
                                <Button Content="Cancel GRN"
                                        Command="{Binding CancelGRNCommand}"
                                        IsEnabled="{Binding CanCancel}"
                                        Style="{StaticResource StateTransitionDestructiveButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <controls:ErrorStateOverlay Grid.Row="2"
                                    IsOpen="{Binding HasLoadError}"
                                    Icon=":("
                                    Title="Couldn't load goods received notes"
                                    Description="{Binding LoadErrorMessage}"
                                    ActionText="Retry"
                                    ActionCommand="{Binding LoadCommand}"/>

        <Grid Grid.Row="3"
              MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>
    </Grid>
</UserControl>
