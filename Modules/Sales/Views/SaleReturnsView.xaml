<UserControl x:Class="StoreAssistantPro.Modules.Sales.Views.SaleReturnsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             Loaded="OnLoaded">
    <controls:EnterprisePageLayout>

        <controls:EnterprisePageLayout.TipBannerContent>
            <controls:InlineTipBanner
                h:TipBannerAutoState.TipKey="SaleReturnsView.QuickTip"
                h:TipBannerAutoState.ContextKey="SaleReturns"
                Title="Quick tip"
                TipText="View all processed sale returns. Returns are created from the Sales page."/>
        </controls:EnterprisePageLayout.TipBannerContent>

        <controls:EnterprisePageLayout.ToolbarContent>
            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="{StaticResource FieldGroupSpacing}">
                <Border Style="{StaticResource SectionCardHeaderStyle}">
                    <WrapPanel>
                        <Button Content="🔄 Refresh" Command="{Binding LoadReturnsCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Separator Style="{StaticResource FluentSeparatorStyle}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthWide}"
                                 h:Watermark.Text="🔍 Search returns..."
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="{Binding CountDisplay}" VerticalAlignment="Center"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   Margin="{StaticResource InlineControlSpacing}"/>
                    </WrapPanel>
                </Border>
            </Border>
        </controls:EnterprisePageLayout.ToolbarContent>

        <Border Style="{StaticResource SectionCardStyle}" ClipToBounds="True">
            <Grid>
                <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding Returns}"
                          SelectedItem="{Binding SelectedReturn}"
                          MinHeight="100">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Return #" Binding="{Binding ReturnNumber}" Width="*"/>
                        <DataGridTextColumn Header="Sale ID" Binding="{Binding SaleId}" Width="{StaticResource ColumnWidthId}"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Refund" Binding="{Binding RefundAmount, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="{StaticResource ColumnWidthStatus}"/>
                        <DataGridTextColumn Header="Stock Restored"
                                            Binding="{Binding StockRestored, Converter={StaticResource BoolToActiveText}}"
                                            Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding ReturnDate, StringFormat=g}" Width="{StaticResource ColumnWidthStatus}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <controls:EmptyStateOverlay
                    Icon="↩️"
                    Title="No returns found"
                    Description="Sale returns will appear here after processing."
                    ItemCount="{Binding Returns.Count}"/>
            </Grid>
        </Border>

    </controls:EnterprisePageLayout>
</UserControl>
