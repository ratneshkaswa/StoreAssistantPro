<UserControl x:Class="StoreAssistantPro.Modules.Sales.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="800"
             Loaded="OnLoaded">
    <UserControl.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding ShowNewSaleCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding ExportSalesCommand}"/>
    </UserControl.InputBindings>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Title          -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: Tip banner     -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: Toolbar        -->
            <RowDefinition Height="Auto"/>  <!-- Row 3: New sale form  -->
            <RowDefinition Height="Auto"/>  <!-- Row 4: Messages       -->
            <RowDefinition Height="*"/>     <!-- Row 5: Sales history  -->
        </Grid.RowDefinitions>

        <TextBlock Text="Sales" Style="{StaticResource PageTitleStyle}"/>

        <!-- Tip banner — standard slot: top of content, below title -->
        <controls:InlineTipBanner Grid.Row="1"
            h:TipBannerAutoState.TipKey="SalesView.QuickTip"
            h:TipBannerAutoState.ContextKey="NewSale"
            Title="Quick tip"
            TipText="Start a new sale transaction."/>

        <WrapPanel Grid.Row="2" Margin="{StaticResource ToolbarSpacing}">
            <Button Content="🖨 Reprint Last" Command="{Binding ReprintLastInvoiceCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
            <Button Content="📄 Export All Items" Command="{Binding ExportAllSaleItemsCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="{StaticResource FieldWidthWide}"
                     h:Watermark.Text="🔍 Search sales..."
                     VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
            <Button Content="🛒 New Sale" Command="{Binding ShowNewSaleCommand}"
                    Style="{StaticResource ToolbarButtonStyle}" FontWeight="SemiBold"
                    VerticalAlignment="Center"
                    h:HelpHint.ShortcutText="Ctrl+N"
                    h:HelpHint.HelpText="Start a new sale transaction"
                    h:HelpHint.Category="Sales"
                    h:SmartTooltip.ContextKey="NewSale"
                    Visibility="{Binding CanCreateSales, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="From:" VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
            <DatePicker SelectedDate="{Binding FilterFrom}" Width="{StaticResource FieldWidthStandard}"
                        VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
            <TextBlock Text="To:" VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
            <DatePicker SelectedDate="{Binding FilterTo}" Width="{StaticResource FieldWidthStandard}"
                        VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Filter" Command="{Binding FilterByDateCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.HelpText="Filter sales by date range"
                    h:HelpHint.Category="Sales"
                    h:SmartTooltip.ContextKey="FilterSales"
                    VerticalAlignment="Center"/>
            <Button Content="Load All" Command="{Binding LoadSalesCommand}"
                    Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                    h:HelpHint.HelpText="Clear date filter and show all sales"
                    h:HelpHint.Category="Sales"
                    h:SmartTooltip.ContextKey="LoadAllSales"
                    VerticalAlignment="Center"/>
            <Button Content="📤 Export" Command="{Binding ExportSalesCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.ShortcutText="Ctrl+Shift+E"
                    h:HelpHint.HelpText="Export all sales to CSV"
                    h:HelpHint.Category="Sales"
                    VerticalAlignment="Center"/>
            <Button Content="📤 Export Filtered" Command="{Binding ExportFilteredSalesCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.HelpText="Export only the currently visible/filtered sales to CSV"
                    h:HelpHint.Category="Sales"
                    VerticalAlignment="Center"/>
            <ComboBox SelectedItem="{Binding SelectedPaymentMethod, Mode=TwoWay}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"
                      VerticalAlignment="Center"
                      ToolTip="Filter by payment method"
                      ItemsSource="{Binding PaymentMethodFilterOptions}"/>
            <ComboBox SelectedItem="{Binding SelectedCashierFilter, Mode=TwoWay}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"
                      VerticalAlignment="Center"
                      ToolTip="Filter by cashier role"
                      ItemsSource="{Binding CashierFilterOptions}"/>
            <ComboBox ItemsSource="{Binding PageSizeOptions}"
                      SelectedItem="{Binding PageSize, Mode=TwoWay}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"
                      VerticalAlignment="Center"
                      ToolTip="Page size"/>
        </WrapPanel>

        <!-- New Sale Form -->
        <Border Grid.Row="3" Style="{StaticResource FormCardStyle}"
                Visibility="{Binding IsNewSaleVisible, Converter={StaticResource BoolToVisibility}}"
                h:KeyboardNav.DefaultCommand="{Binding AddToCartCommand}"
                h:KeyboardNav.EscapeCommand="{Binding CancelNewSaleCommand}"
                h:Motion.SlideFadeReveal="True">
            <Grid>
                <!-- Main form content -->
                <Grid IsEnabled="{Binding IsCartLocked, Converter={StaticResource InverseBoolConverter}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="New Sale" Style="{StaticResource SectionHeaderStyle}"
                               Grid.ColumnSpan="2"/>

                    <!-- Product picker -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="{StaticResource ItemSpacing}" Grid.ColumnSpan="2">
                        <ComboBox ItemsSource="{Binding AvailableProducts}"
                                  SelectedItem="{Binding SelectedProduct}"
                                  DisplayMemberPath="Name" Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource InlineControlSpacing}"/>
                        <TextBlock Text="Qty:" VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
                        <TextBox Text="{Binding CartQuantity, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsIntegerOnly="True"
                                 Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource InlineControlSpacing}" VerticalContentAlignment="Center"/>
                        <Button Content="Add to Cart" Command="{Binding AddToCartCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                                h:SmartTooltip.ContextKey="Cart"/>
                    </StackPanel>

                    <!-- Cart -->
                    <ScrollViewer Grid.Row="2" Grid.ColumnSpan="2" Margin="{StaticResource ItemSpacing}" VerticalScrollBarVisibility="Auto">
                        <DataGrid ItemsSource="{Binding CartItems}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  SelectionMode="Single"
                                  CanUserAddRows="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="*"/>
                                <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                                <DataGridTemplateColumn Header="" Width="Auto">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="✕"
                                                    Style="{StaticResource CartRemoveButtonStyle}"
                                                    Command="{Binding DataContext.RemoveFromCartCommand,
                                                        RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>

                    <!-- Footer: Discount + Totals + Actions -->
                    <Grid Grid.Row="3" Grid.ColumnSpan="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Discount row (compact inline, expands when type selected) -->
                        <StackPanel Orientation="Horizontal" Margin="{StaticResource ItemSpacing}">
                            <TextBlock Text="Discount:" VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
                            <ComboBox ItemsSource="{Binding DiscountTypes}"
                                      SelectedItem="{Binding SelectedDiscountType}"
                                      Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource InlineControlSpacing}"/>
                            <TextBox Text="{Binding DiscountInput, UpdateSourceTrigger=PropertyChanged}"
                                     h:NumericInput.IsDecimalOnly="True"
                                     h:Watermark.Text="Value"
                                     Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource InlineControlSpacing}" VerticalContentAlignment="Center"/>
                            <TextBox Text="{Binding DiscountReason, UpdateSourceTrigger=PropertyChanged}"
                                     h:Watermark.Text="Reason (optional)"
                                     Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource InlineControlSpacing}" VerticalContentAlignment="Center"/>
                            <TextBlock VerticalAlignment="Center" Foreground="{StaticResource FluentWarning}"
                                       Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVisibility}}">
                                <Run Text="−"/>
                                <Run Text="{Binding BillDiscountAmount, StringFormat=C, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>

                        <!-- Totals + action buttons -->
                        <StackPanel Grid.Row="1" Orientation="Horizontal">
                            <TextBlock Text="Payment:" VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
                            <ComboBox ItemsSource="{Binding PaymentMethods}"
                                     SelectedItem="{Binding PaymentMethod}" Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource WrapFieldGap}"/>
                            <TextBlock VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"
                                       Foreground="{StaticResource FluentTextTertiary}"
                                       Visibility="{Binding HasDiscount, Converter={StaticResource BoolToVisibility}}">
                                <Run Text="Subtotal: "/>
                                <Run Text="{Binding CartTotal, StringFormat=C, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock VerticalAlignment="Center" Margin="{StaticResource WrapFieldGap}"
                                       FontSize="{StaticResource FontSizeSectionHeader}" FontWeight="Bold">
                                <Run Text="Total: "/>
                                <Run Text="{Binding BillFinalAmount, StringFormat=C, Mode=OneWay}"/>
                            </TextBlock>
                            <Button Command="{Binding CompleteSaleCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}" FontWeight="SemiBold"
                                    h:SmartTooltip.ContextKey="CompleteSale">
                                <Button.Content>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⏳ " Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibility}}"/>
                                        <TextBlock>
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="✅ Complete Sale"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSaving}" Value="True">
                                                            <Setter Property="Text" Value="Saving…"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </Button.Content>
                            </Button>
                            <Button Content="Cancel" Command="{Binding CancelNewSaleCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                        </StackPanel>
                    </Grid>
                </Grid>

                <!-- Processing overlay — shown during save -->
                <Border Style="{StaticResource OverlayCardStyle}"
                        Visibility="{Binding IsSaving, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="⏳" FontSize="{StaticResource FontSizePageTitle}" HorizontalAlignment="Center" Margin="{StaticResource CompactItemSpacing}"/>
                        <TextBlock Text="{Binding SavingStatusText}"
                                   FontSize="{StaticResource FontSizeSectionHeader}" FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentAccentDefault}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <TextBlock Grid.Row="4" Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorMessageStyle}"/>

        <!-- Sales history: star-sized area -->
        <Grid Grid.Row="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Loading Indicator -->
            <TextBlock Grid.Row="0" Text="⏳ Loading..." FontSize="{StaticResource FontSizeSectionHeader}"
                       Foreground="{StaticResource FluentTextTertiary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <DataGrid Grid.Row="0"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      ItemsSource="{Binding Sales}"
                      SelectedItem="{Binding SelectedSale}"
                      Sorting="OnSorting">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" SortMemberPath="Id" Width="{StaticResource ColumnWidthId}"/>
                    <DataGridTextColumn Header="Invoice #" Binding="{Binding InvoiceNumber}" SortMemberPath="InvoiceNumber" Width="{StaticResource ColumnWidthStatus}"/>
                    <DataGridTemplateColumn Header="Date" SortMemberPath="SaleDate" Width="{StaticResource ColumnWidthDate}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding SaleDate, StringFormat=g}" VerticalAlignment="Center"
                                           ToolTip="{Binding SaleDate, StringFormat='dddd, dd MMM yyyy hh:mm:ss tt'}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=C}" SortMemberPath="TotalAmount" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTemplateColumn Header="Discount" SortMemberPath="DiscountAmount" Width="{StaticResource ColumnWidthPrice}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DiscountAmount, StringFormat=C}" VerticalAlignment="Center"
                                           ToolTip="{Binding DiscountSummary}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Payment" Binding="{Binding PaymentMethod}" SortMemberPath="PaymentMethod" Width="{StaticResource ColumnWidthStatus}"/>
                    <DataGridTextColumn Header="Cashier" Binding="{Binding CashierRole}" SortMemberPath="CashierRole" Width="{StaticResource ColumnWidthStatus}"/>
                    <DataGridTemplateColumn Header="Ref #" SortMemberPath="PaymentReference" Width="{StaticResource ColumnWidthStatus}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding PaymentReference}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding PaymentReference}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Items" SortMemberPath="ItemCount" Width="{StaticResource ColumnWidthQty}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Items.Count}" VerticalAlignment="Center"
                                           ToolTip="{Binding ItemsSummary}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <controls:EmptyStateOverlay
                Icon="💰"
                Title="No sales found"
                Description="Complete your first sale to see transaction history here."
                ItemCount="{Binding Sales.Count}"/>

            <!-- Paging Controls -->
            <StackPanel Grid.Row="1" Orientation="Horizontal"
                        HorizontalAlignment="Center" Margin="{StaticResource ItemSpacing}">
                <Button Content="◀ Previous" Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Padding="{StaticResource PagingButtonPadding}"/>
                <TextBlock Text="{Binding PageDisplay}" VerticalAlignment="Center"
                           FontSize="{StaticResource FontSizeLabel}"
                           Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Content="Next ▶" Command="{Binding NextPageCommand}"
                        Style="{StaticResource ToolbarButtonStyle}"
                        Padding="{StaticResource PagingButtonPadding}" Margin="0"/>
            </StackPanel>

            <!-- Sale Detail Panel -->
            <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                          Visibility="{Binding HasSelectedSale, Converter={StaticResource BoolToVisibility}}"
                          h:Motion.SlideFadeReveal="True">
                <Border Style="{StaticResource DetailPanelStyle}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Orientation="Vertical" Margin="{StaticResource CompactItemSpacing}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📋 Invoice #" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"/>
                                <TextBlock>
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding SelectedSale.InvoiceNumber}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding SelectedSale.InvoiceNumber}" Value="">
                                                    <Setter Property="Text" Value="{Binding SelectedSale.Id}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBlock Text=" — " Foreground="{StaticResource FluentTextTertiary}"/>
                                <TextBlock Text="{Binding SelectedSale.SaleDate, StringFormat=g}"
                                           Foreground="{StaticResource FluentTextSecondary}"/>
                                <TextBlock Text=" — " Foreground="{StaticResource FluentTextTertiary}"/>
                                <TextBlock Text="{Binding SelectedSale.PaymentMethod}"
                                           Foreground="{StaticResource FluentTextSecondary}"/>
                                <TextBlock Text=" — Total: "
                                           Foreground="{StaticResource FluentTextTertiary}"
                                           Margin="{StaticResource StatusBarStatGap}"/>
                                <TextBlock Text="{Binding SelectedSale.TotalAmount, StringFormat=C}"
                                           FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="Reference: " FontWeight="SemiBold" FontSize="{StaticResource FontSizeLabel}" Visibility="{Binding SelectedSale.PaymentReference, Converter={StaticResource BoolToVisibility}}"/>
                                <TextBlock Text="{Binding SelectedSale.PaymentReference}" FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextSecondary}" Visibility="{Binding SelectedSale.PaymentReference, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0"
                                        Visibility="{Binding SelectedSale.DiscountAmount, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="Discount: " FontWeight="SemiBold" FontSize="{StaticResource FontSizeLabel}"/>
                                <TextBlock Text="{Binding SelectedSale.DiscountSummary}" FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentWarning}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="🖨 Print" Command="{Binding PrintInvoiceCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
                                <Button Content="↩ Refund" Command="{Binding RefundSaleCommand}" Style="{StaticResource ToolbarButtonStyle}" Margin="0,0,8,0"/>
                                <Button Content="📄 Export Items" Command="{Binding ExportSaleItemsCommand}" Style="{StaticResource ToolbarButtonStyle}"/>
                            </StackPanel>
                        </StackPanel>
                        <DataGrid ItemsSource="{Binding SelectedSale.Items}"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                                  BorderThickness="0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="*"/>
                                <DataGridTextColumn Header="Unit Price" Binding="{Binding UnitPrice, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                                <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
