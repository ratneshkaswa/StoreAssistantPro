<UserControl x:Class="StoreAssistantPro.Modules.Debtors.Views.DebtorManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="700" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE779;"/>
                <Run Text=" Debtors"/>
            </TextBlock>
            <TextBlock Text="Track outstanding debtor balances, follow-up status, and settlement progress."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Stat Cards -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="OUTSTANDING" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalOutstanding, StringFormat='₹{0:N0}'}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentError}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="PENDING" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding PendingDebtors}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentWarning}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalDebtors}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentAccentDark1}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Style="{StaticResource FormCardStyle}" Margin="{StaticResource ItemSpacing}">
            <StackPanel>
                <TextBlock Text="Add debtor" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding DebtorName, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Debtor name" MaxLength="200"
                                 AutomationProperties.Name="Debtor name"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Phone" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.Scope="TelephoneNumber"
                                 h:Watermark.Text="Phone" MaxLength="15"
                                 AutomationProperties.Name="Phone"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Total ₹" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding TotalAmountText, UpdateSourceTrigger=PropertyChanged}"
                                 h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                 h:NumericInput.Scope="Number"
                                 h:Watermark.Text="Total" MaxLength="10"
                                 AutomationProperties.Name="Total amount"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Paid ₹" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding PaidAmountText, UpdateSourceTrigger=PropertyChanged}"
                                 h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                 h:NumericInput.Scope="Number"
                                 h:Watermark.Text="Paid" MaxLength="10"
                                 AutomationProperties.Name="Paid amount"/>
                    </StackPanel>
                    <StackPanel Grid.Column="8">
                        <TextBlock Text="Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding DebtDate}"
                                    AutomationProperties.Name="Debt date"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Note" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FluentMultilineTextBoxStyle}"
                                 h:Watermark.Text="Note (optional)" MaxLength="500"
                                 AutomationProperties.Name="Note"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Style="{StaticResource FormActionRowStyle}" VerticalAlignment="Bottom" Margin="8,0,0,0">
                        <Button Content="Clear" Command="{Binding ClearFormCommand}"
                                Style="{StaticResource UtilityButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                                Style="{StaticResource SaveButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FluentSearchTextBoxStyle}"
                     h:Watermark.Text="Search debtors by name or phone"
                     AutomationProperties.Name="Search debtors"/>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}"
                    Style="{StaticResource SearchButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- Filter Chips -->
        <StackPanel Grid.Row="4" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SegmentedFilterHostStyle}">
                <StackPanel Orientation="Horizontal">
                    <Button Content="All" Command="{Binding SetStatusFilterCommand}" CommandParameter="All"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter all">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveStatusFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Pending" Command="{Binding SetStatusFilterCommand}" CommandParameter="Pending"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter pending">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveStatusFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Cleared" Command="{Binding SetStatusFilterCommand}" CommandParameter="Cleared"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            AutomationProperties.Name="Filter cleared">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveStatusFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </StackPanel>
            </Border>

            <WrapPanel Margin="0,8,0,0">
                    <Button Content="{Binding ActiveStatusFilter, StringFormat=Status: {0}}"
                            Command="{Binding SetStatusFilterCommand}"
                            CommandParameter="All">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActiveFilterChipButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveStatusFilter}" Value="All">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
            </WrapPanel>

            <TextBlock Text="{Binding FilterCountText}"
                       FontSize="11"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource FluentTextTertiary}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="5" AutomationProperties.Name="Debtor list"
                  ItemsSource="{Binding Debtors}" SelectedItem="{Binding SelectedDebtor}"
                  Style="{StaticResource EnterpriseDataGridStyle}" HeadersVisibility="Column"
                  h:DataGridLayoutPersistence.Key="DebtorsGrid"
                  h:DataGridEmptyState.Icon="💳"
                  h:DataGridEmptyState.Title="No debtor balances found"
                  h:DataGridEmptyState.Description="Adjust the current filters or wait for unpaid invoices to surface here.">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedDebtor}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedDebtor}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="NAME" Binding="{Binding Name}"
                                    SortMemberPath="Name" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="PHONE" Binding="{Binding Phone}"
                                    SortMemberPath="Phone" Width="120"/>
                <DataGridTextColumn Header="TOTAL" Binding="{Binding TotalAmount, StringFormat='₹{0:N0}'}"
                                    SortMemberPath="TotalAmount" Width="100"/>
                <DataGridTextColumn Header="PAID" Binding="{Binding PaidAmount, StringFormat='₹{0:N0}'}"
                                    SortMemberPath="PaidAmount" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="BALANCE" Binding="{Binding Balance, StringFormat='₹{0:N0}'}"
                                    SortMemberPath="Balance" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="SINCE" Binding="{Binding DaysAgo}"
                                    SortMemberPath="Date" Width="80">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Style="{StaticResource DataGridRowActionPanelStyle}">
                                <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Edit"
                                        AutomationProperties.Name="Edit" Margin="0,0,2,0" Padding="4">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Delete"
                                        AutomationProperties.Name="Delete" Padding="4">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Messages -->
        <Grid Grid.Row="6" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing debtor..."/>
    </Grid>
</UserControl>
