<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Tax.Views.TaxWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Tax Management"
        ConfirmCommand="{Binding SaveCommand}"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="💰 Tax Management" Style="{StaticResource DialogTitleStyle}"/>

        <!-- Tax profile list -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding TaxProfiles}"
                  SelectedItem="{Binding SelectedProfile}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  Margin="{StaticResource ItemSpacing}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Profile Name"
                                    Binding="{Binding ProfileName}" Width="*"/>
                <DataGridCheckBoxColumn Header="Default"
                                        Binding="{Binding IsDefault, Mode=OneWay}"
                                        IsReadOnly="True"
                                        Width="{StaticResource ColumnWidthQty}"/>
                <DataGridTextColumn Header="Status"
                                    Binding="{Binding IsActive, Converter={StaticResource BoolToActiveText}}"
                                    Width="{StaticResource ColumnWidthStatus}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Add / Edit form — two-column grid -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="100"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Section header -->
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="{Binding FormTitle}" Style="{StaticResource SectionHeaderStyle}"
                       Margin="0"/>

            <!-- Profile Name -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Profile Name *"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="100"/>

            <!-- Tax Rate -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Tax Rate (%)"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <StackPanel Grid.Row="4" Grid.Column="1">
                <TextBox Text="{Binding TaxRate, UpdateSourceTrigger=PropertyChanged}"
                         h:NumericInput.IsDecimalOnly="True"
                         MaxLength="6"/>
                <TextBlock Text="{Binding TaxComponentBreakdown}"
                           FontSize="{StaticResource FontSizeCaption}"
                           Foreground="{StaticResource FluentTextTertiary}"
                           Margin="0,2,0,0"/>
            </StackPanel>

            <!-- Active checkbox -->
            <CheckBox Grid.Row="6" Grid.Column="1"
                      Content="Active"
                      IsChecked="{Binding IsProfileActive}"
                      VerticalContentAlignment="Center"/>
        </Grid>

        <!-- Messages -->
        <StackPanel Grid.Row="3" Margin="{StaticResource FieldLabelSpacing}">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                       h:AutoDismiss.IsEnabled="True" h:AutoDismiss.Seconds="4"/>
        </StackPanel>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="➕ New" Command="{Binding NewProfileCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="⭐ Set Default" Command="{Binding SetDefaultCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="🚫 Toggle Active" Command="{Binding ToggleActiveCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="💾 Save" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</core:BaseDialogWindow>
