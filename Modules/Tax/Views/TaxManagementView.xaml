<UserControl x:Class="StoreAssistantPro.Modules.Tax.Views.TaxManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8C7;"/><Run Text=" Tax Management"/></TextBlock>

        <!-- Tab selector buttons -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Button Content="Tax Rates" Tag="0" Command="{Binding SwitchTabCommand}" CommandParameter="0"
                    Style="{StaticResource SegmentedButtonStyle}"/>
            <Button Content="Tax Groups" Tag="1" Command="{Binding SwitchTabCommand}" CommandParameter="1"
                    Style="{StaticResource SegmentedButtonStyle}"/>
            <Button Content="HSN Codes" Tag="2" Command="{Binding SwitchTabCommand}" CommandParameter="2"
                    Style="{StaticResource SegmentedButtonStyle}"/>
        </WrapPanel>

        <!-- Tab 0: Tax Rates -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabRates, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid AutomationProperties.Name="Tax rates" ItemsSource="{Binding Taxes}"
                      SelectedItem="{Binding SelectedTax}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Tax Name" Binding="{Binding TaxName}" Width="*"/>
                    <DataGridTextColumn Header="Slab %" Binding="{Binding SlabPercent, StringFormat={}{0:G}}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTemplateColumn Header="Active" CellTemplate="{StaticResource ActiveToggleReadOnlyTemplate}" Width="{StaticResource ColumnWidthQty}"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Tax Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1"
                         AutomationProperties.Name="Tax name"
                         Text="{Binding TaxName, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                         MaxLength="100" h:Watermark.Text="e.g. GST 5%"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Slab % "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Row="2" Grid.Column="1"
                         AutomationProperties.Name="Tax slab percentage"
                         Text="{Binding SlabPercent, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                         MaxLength="6" h:Watermark.Text="e.g. 5"/>
            </Grid>

            <Grid Grid.Row="2" Margin="{StaticResource FormActionBarSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Clear" Command="{Binding ClearFormCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Grid.Column="2" Content="Delete" Command="{Binding DeleteRateCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Grid.Column="3" Content="Save" Command="{Binding SaveRateCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </Grid>
        </Grid>

        <!-- Tab 1: Tax Groups & Slabs -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabGroups, Converter={StaticResource BoolToVisibility}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid AutomationProperties.Name="Tax groups" ItemsSource="{Binding TaxGroups}"
                          SelectedItem="{Binding SelectedGroup}"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          HeadersVisibility="Column">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Group Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTemplateColumn Header="Active" Width="{StaticResource ColumnWidthQty}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                              IsChecked="{Binding IsActive, Mode=OneWay}"
                                              CommandParameter="{Binding}"
                                              Command="{Binding DataContext.ToggleGroupActiveCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             AutomationProperties.Name="Tax group name"
                             Text="{Binding GroupName, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="100" h:Watermark.Text="e.g. GST Garments"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Description"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             AutomationProperties.Name="Tax group description"
                             Text="{Binding GroupDescription, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="300" h:Watermark.Text="e.g. Garments up to Rs. 1000"/>
                </Grid>

                <Grid Grid.Row="2" Margin="{StaticResource FormActionBarSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1" Content="Clear" Command="{Binding ClearGroupFormCommand}"
                             Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Grid.Column="2" Content="Save Group" Command="{Binding SaveGroupCommand}"
                             Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                </Grid>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Price-Based Slabs" Style="{StaticResource SectionHeaderStyle}"/>

                <DataGrid AutomationProperties.Name="Tax slabs" Grid.Row="1"
                          ItemsSource="{Binding GroupSlabs}"
                          SelectedItem="{Binding SelectedSlab}"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          HeadersVisibility="Column"
                          Margin="{StaticResource ItemSpacing}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="GST %" Binding="{Binding GSTPercent, StringFormat={}{0:G}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="From ₹" Binding="{Binding PriceFrom, Converter={StaticResource PriceToDisplayConverter}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="To ₹" Binding="{Binding PriceTo, Converter={StaticResource PriceToDisplayConverter}}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>

                <Grid Grid.Row="2" Margin="{StaticResource StepContentTopSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="GST % "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             AutomationProperties.Name="Slab GST percentage"
                             Text="{Binding SlabGST, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                             MaxLength="6" h:Watermark.Text="e.g. 5"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Price From ₹"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             AutomationProperties.Name="Slab price from"
                             Text="{Binding SlabPriceFrom, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                             MaxLength="12" h:Watermark.Text="e.g. 0"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Price To ₹"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1"
                             AutomationProperties.Name="Slab price to"
                             Text="{Binding SlabPriceTo, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                             MaxLength="12" h:Watermark.Text="e.g. 1000 or blank"/>
                </Grid>

                <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="1" Content="Clear" Command="{Binding ClearSlabFormCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Grid.Column="2" Content="Delete Slab" Command="{Binding DeleteSlabCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Grid.Column="3" Content="{Binding SlabActionText}" Command="{Binding AddSlabCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Tab 2: HSN Codes -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabHSN, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid AutomationProperties.Name="HSN codes" ItemsSource="{Binding HSNCodes}"
                      SelectedItem="{Binding SelectedHSN}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="HSN Code" Binding="{Binding Code}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTemplateColumn Header="Active" Width="{StaticResource ColumnWidthQty}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                          IsChecked="{Binding IsActive, Mode=OneWay}"
                                          CommandParameter="{Binding}"
                                          Command="{Binding DataContext.ToggleHSNActiveCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="HSN Code "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1"
                         AutomationProperties.Name="HSN code"
                         Text="{Binding HSNCodeValue, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                         MaxLength="8" h:Watermark.Text="e.g. 6109"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Description "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Row="2" Grid.Column="1"
                         AutomationProperties.Name="HSN description"
                         Text="{Binding HSNDescription, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="300" h:Watermark.Text="e.g. T-shirts, singlets and other vests"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Category"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <ComboBox Grid.Row="4" Grid.Column="1"
                          AutomationProperties.Name="HSN category"
                          ItemsSource="{Binding HSNCategories}"
                          SelectedItem="{Binding HSNCategory}"
                          Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>
            </Grid>

            <Grid Grid.Row="2" Margin="{StaticResource FormActionBarSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Clear" Command="{Binding ClearHSNFormCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Grid.Column="2" Content="Save HSN" Command="{Binding SaveHSNCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </Grid>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasErrorMessage}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccessMessage}"/>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving tax settings..."/>
    </Grid>
</UserControl>
