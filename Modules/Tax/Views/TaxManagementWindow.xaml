<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Tax.Views.TaxManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Tax Management"
        ConfirmCommand="{Binding SaveCommand}"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="&#x1F4B0; Tax Management" Style="{StaticResource DialogTitleStyle}"/>

        <!-- Tax slab grid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding TaxSlabs}"
                  SelectedItem="{Binding SelectedTaxSlab}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  Margin="{StaticResource ItemSpacing}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Tax Name" Binding="{Binding TaxName}" Width="*"/>
                <DataGridTextColumn Header="GST %" Binding="{Binding TaxRate, StringFormat={}{0:G}}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridTextColumn Header="HSN" Binding="{Binding HSNCode}" Width="{StaticResource ColumnWidthId}"/>
                <DataGridTextColumn Header="Category" Binding="{Binding ApplicableCategory}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=OneWay}" Width="{StaticResource ColumnWidthQty}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Form fields -->
        <Grid Grid.Row="2" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                <Run Text="Tax Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
            </TextBlock>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding TaxName, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="100" h:Watermark.Text="e.g. CGST 9%"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                <Run Text="GST % "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
            </TextBlock>
            <TextBox Grid.Row="2" Grid.Column="1"
                     Text="{Binding TaxRate, UpdateSourceTrigger=PropertyChanged}"
                     Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                     MaxLength="6" h:Watermark.Text="e.g. 9"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="HSN Code"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBox Grid.Row="4" Grid.Column="1"
                     Text="{Binding HSNCode, UpdateSourceTrigger=PropertyChanged}"
                     Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                     MaxLength="8" h:Watermark.Text="4–8 digits"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Applicable To"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="6" Grid.Column="1"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>
        </Grid>

        <!-- Messages -->
        <StackPanel Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
                    Margin="{StaticResource FieldLabelSpacing}">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                       h:AutoDismiss.IsEnabled="True" h:AutoDismiss.Seconds="4"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="&#x2795; New" Command="{Binding NewTaxSlabCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Toggle Active" Command="{Binding ToggleActiveCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="&#x1F4BE; Save" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</core:BaseDialogWindow>
