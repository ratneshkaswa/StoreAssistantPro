<UserControl x:Class="StoreAssistantPro.Modules.Billing.Views.CashRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}">
            <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7A1;"/>
            <Run Text=" Cash Register"/>
        </TextBlock>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: Register actions -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- OPEN REGISTER (shown when closed) -->
                    <Border Visibility="{Binding IsRegisterClosed, Converter={StaticResource BoolToVisibility}}"
                            BorderBrush="{StaticResource FluentStrokeDefault}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMedium}"
                            Padding="{StaticResource DialogPadding}"
                            Margin="{StaticResource ItemSpacing}">
                        <StackPanel>
                            <TextBlock Text="Open Register" FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       Margin="{StaticResource ItemSpacing}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Opening Balance"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding OpeningBalanceInput, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Opening balance"
                                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                         MaxLength="10"
                                         h:Watermark.Text="e.g. 5000"/>
                            </Grid>
                            <Button Content="Open Register" Command="{Binding OpenRegisterCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- REGISTER STATUS (shown when open) -->
                    <Border Visibility="{Binding IsRegisterOpen, Converter={StaticResource BoolToVisibility}}"
                            BorderBrush="{StaticResource FluentAccentDefault}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMedium}"
                            Padding="{StaticResource DialogPadding}"
                            Margin="{StaticResource ItemSpacing}">
                        <StackPanel>
                            <TextBlock Text="Register Open" FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       Foreground="{StaticResource FluentSuccess}"
                                       Margin="{StaticResource ItemSpacing}"/>
                            <TextBlock Margin="0,4,0,0">
                                <Run Text="Opening: " FontWeight="SemiBold"/>
                                <Run Text="{Binding OpenRegister.OpeningBalance, StringFormat={}{0:C}, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0">
                                <Run Text="Expected Cash: " FontWeight="SemiBold"/>
                                <Run Text="{Binding ExpectedBalance, StringFormat={}{0:C}, Mode=OneWay}"/>
                            </TextBlock>
                            <TextBlock Margin="0,4,0,0" Foreground="{StaticResource FluentTextSecondary}"
                                       FontSize="{StaticResource FontSizeCaption}">
                                <Run Text="Opened: "/>
                                <Run Text="{Binding OpenRegister.OpenedAt, StringFormat={}{0:dd MMM yyyy hh:mm tt}, Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- CASH MOVEMENT (shown when open) -->
                    <Border Visibility="{Binding IsRegisterOpen, Converter={StaticResource BoolToVisibility}}"
                            BorderBrush="{StaticResource FluentStrokeDefault}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMedium}"
                            Padding="{StaticResource DialogPadding}"
                            Margin="{StaticResource ItemSpacing}">
                        <StackPanel>
                            <TextBlock Text="Cash In / Out" FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       Margin="{StaticResource ItemSpacing}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Direction"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Directions}"
                                          SelectedItem="{Binding MovementDirection}"
                                          AutomationProperties.Name="Cash direction"
                                          Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Text="Amount"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding MovementAmount, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Movement amount"
                                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                         MaxLength="10"
                                         h:Watermark.Text="e.g. 500"/>

                                <TextBlock Grid.Row="4" Text="Reason"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Row="4" Grid.Column="1"
                                         Text="{Binding MovementReason, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Movement reason"
                                         MaxLength="200"
                                         h:Watermark.Text="e.g. Petty cash withdrawal"/>
                            </Grid>
                            <Button Content="Record Movement" Command="{Binding RecordMovementCommand}"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- CLOSE REGISTER (shown when open) -->
                    <Border Visibility="{Binding IsRegisterOpen, Converter={StaticResource BoolToVisibility}}"
                            BorderBrush="{StaticResource FluentStrokeDefault}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMedium}"
                            Padding="{StaticResource DialogPadding}"
                            Margin="{StaticResource ItemSpacing}">
                        <StackPanel>
                            <TextBlock Text="Close Register / Day End" FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       Margin="{StaticResource ItemSpacing}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Actual Cash"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding ClosingBalanceInput, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Closing balance"
                                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                         MaxLength="10"
                                         h:Watermark.Text="Count your cash"/>

                                <TextBlock Grid.Row="2" Text="Notes"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding CloseNotes, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FluentMultilineTextBoxStyle}"
                                         AutomationProperties.Name="Close notes"
                                         MaxLength="500"
                                         h:Watermark.Text="e.g. ₹50 note damaged"/>
                            </Grid>
                            <Button Content="Close Register" Command="{Binding CloseRegisterCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- MOVEMENTS TABLE (shown when open) -->
                    <Border Visibility="{Binding IsRegisterOpen, Converter={StaticResource BoolToVisibility}}"
                            BorderBrush="{StaticResource FluentStrokeDefault}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMedium}"
                            Padding="{StaticResource DialogPadding}"
                            Margin="{StaticResource ItemSpacing}">
                        <StackPanel>
                            <TextBlock Text="Today's Movements" FontWeight="SemiBold"
                                       FontSize="{StaticResource FontSizeSubtitle}"
                                       Margin="{StaticResource ItemSpacing}"/>
                            <DataGrid ItemsSource="{Binding Movements}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column" CanUserAddRows="False"
                                      MaxHeight="200">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:hh:mm tt}}" Width="Auto"/>
                                    <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="Auto"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right panel: Day-end summary + History -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- DAY-END SUMMARY (shown after close or when viewing history) -->
                    <Border Visibility="{Binding HasDayEndSummary, Converter={StaticResource BoolToVisibility}}"
                            Background="{StaticResource FluentSurface}"
                            BorderBrush="{StaticResource FluentStrokeDefault}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource CornerRadiusMedium}"
                            Padding="{StaticResource DialogPadding}"
                            Margin="{StaticResource ItemSpacing}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Day-End Summary" FontWeight="SemiBold"
                                           FontSize="{StaticResource FontSizeSubtitle}"/>
                                <Button Grid.Column="1" Content="✕" ToolTip="Dismiss"
                                        Command="{Binding DismissSummaryCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}" Padding="6,2"/>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Opening Balance" Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding DayEndSummary.OpeningBalance, StringFormat={}{0:C}}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="1" Text="Cash Sales" Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DayEndSummary.TotalCashSales, StringFormat={}{0:C}}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="2" Text="Card Sales" Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DayEndSummary.TotalCardSales, StringFormat={}{0:C}}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="3" Text="UPI Sales" Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DayEndSummary.TotalUpiSales, StringFormat={}{0:C}}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="4" Text="Credit Sales" Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DayEndSummary.TotalCreditSales, StringFormat={}{0:C}}" HorizontalAlignment="Right"/>

                                <TextBlock Grid.Row="5" Text="Cash Returns" Style="{StaticResource FormRowLabelStyle}" Foreground="{StaticResource FluentError}"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DayEndSummary.TotalCashReturns, StringFormat=-{0:C}}" HorizontalAlignment="Right" Foreground="{StaticResource FluentError}"/>

                                <TextBlock Grid.Row="6" Text="Cash In / Out" Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" HorizontalAlignment="Right">
                                    <Run Text="+"/><Run Text="{Binding DayEndSummary.TotalCashIn, StringFormat={}{0:C}, Mode=OneWay}"/>
                                    <Run Text=" / -"/><Run Text="{Binding DayEndSummary.TotalCashOut, StringFormat={}{0:C}, Mode=OneWay}"/>
                                </TextBlock>

                                <Separator Grid.Row="7" Grid.ColumnSpan="2" Margin="0,8"/>

                                <TextBlock Grid.Row="8" Text="Expected Cash" FontWeight="Bold" Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding DayEndSummary.ExpectedCash, StringFormat={}{0:C}}" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>

                            <StackPanel Margin="0,12,0,0">
                                <TextBlock>
                                    <Run Text="Actual Cash: " FontWeight="SemiBold"/>
                                    <Run Text="{Binding DayEndSummary.ActualCash, StringFormat={}{0:C}, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock FontWeight="Bold"
                                           Foreground="{StaticResource FluentAccentDefault}">
                                    <Run Text="Discrepancy: "/>
                                    <Run Text="{Binding DayEndSummary.Discrepancy, StringFormat={}{0:C}, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Foreground="{StaticResource FluentTextSecondary}"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Margin="0,4,0,0">
                                    <Run Text="Sales: "/><Run Text="{Binding DayEndSummary.SaleCount, Mode=OneWay}"/>
                                    <Run Text=" · Returns: "/><Run Text="{Binding DayEndSummary.ReturnCount, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Cash variance alert (#252) -->
                                <Border Visibility="{Binding HasCashVarianceAlert, Converter={StaticResource BoolToVisibility}}"
                                        Background="{StaticResource FluentErrorBackground}"
                                        BorderBrush="{StaticResource FluentStrokeError}"
                                        BorderThickness="1"
                                        CornerRadius="{StaticResource ControlCornerRadius}"
                                        Padding="12,8"
                                        Margin="0,8,0,0">
                                    <TextBlock Text="{Binding CashVarianceAlertMessage}"
                                               Foreground="{StaticResource FluentError}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- REGISTER HISTORY -->
                    <TextBlock Text="Register History" FontWeight="SemiBold"
                               FontSize="{StaticResource FontSizeSubtitle}"
                               Margin="{StaticResource ItemSpacing}"/>
                    <DataGrid ItemsSource="{Binding RegisterHistory}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding OpenedAt, StringFormat={}{0:dd MMM yyyy}}" Width="Auto"/>
                            <DataGridTextColumn Header="Opening" Binding="{Binding OpeningBalance, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTextColumn Header="Closing" Binding="{Binding ClosingBalance, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTextColumn Header="Discrepancy" Binding="{Binding Discrepancy, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTemplateColumn Header="" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Summary"
                                                Command="{Binding DataContext.ViewDayEndSummaryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SecondaryButtonStyle}" Padding="8,2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Severity="Error"
                              Title="Cash Register"
                              Message="{Binding ErrorMessage}"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringToVisibility}}"/>
            <controls:InfoBar Severity="Success"
                              Title="Cash Register"
                              Message="{Binding SuccessMessage}"
                              Visibility="{Binding SuccessMessage, Converter={StaticResource NonEmptyStringToVisibility}}"/>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Loading register..."/>
    </Grid>
</UserControl>
