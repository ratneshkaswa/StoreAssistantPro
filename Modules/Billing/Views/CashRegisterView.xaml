<UserControl x:Class="StoreAssistantPro.Modules.Billing.Views.CashRegisterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7A1;"/>
                <Run Text=" Cash Register"/>
            </TextBlock>
            <TextBlock Text="Open the till, record cash movement, and review day-end cash totals in one place."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Main content -->
        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left panel: Register actions -->
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- OPEN REGISTER (shown when closed) -->
                    <Border Visibility="{Binding IsRegisterClosed, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Open Register"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Start the till with the opening cash so expected-balance tracking begins for the day."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Opening Balance"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding OpeningBalanceInput, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Opening balance"
                                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                         MaxLength="10"
                                         h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                         h:NumericInput.Scope="Number"
                                         h:NumericInput.IsDecimalOnly="True"
                                         h:Watermark.Text="Opening amount"/>
                            </Grid>
                            <Button Content="Open Register" Command="{Binding OpenRegisterCommand}"
                                    Style="{StaticResource SaveButtonStyle}"
                                    Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- REGISTER STATUS (shown when open) -->
                    <Border Visibility="{Binding IsRegisterOpen, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource SummaryBannerStyle}">
                        <StackPanel>
                            <TextBlock Text="Register Open"
                                       Style="{StaticResource SummaryPanelTitleStyle}"
                                       Foreground="{StaticResource FluentSuccess}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Opening"
                                           Style="{StaticResource SummaryBannerLabelTextStyle}"/>
                                <TextBlock Grid.Column="1"
                                           Text="{Binding OpenRegister.OpeningBalance, StringFormat={}{0:C}, Mode=OneWay}"
                                           Style="{StaticResource SummaryValueTextStyle}"/>

                                <TextBlock Grid.Row="2"
                                           Text="Expected Cash"
                                           Style="{StaticResource SummaryBannerLabelTextStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1"
                                           Text="{Binding ExpectedBalance, StringFormat={}{0:C}, Mode=OneWay}"
                                           Style="{StaticResource SummaryAccentValueTextStyle}"/>
                            </Grid>
                            <TextBlock Margin="0,8,0,0"
                                       Text="{Binding OpenRegister.OpenedAt, StringFormat=Opened {0:dd MMM yyyy hh:mm tt}, Mode=OneWay}"
                                       Style="{StaticResource SummaryMetaTextStyle}"/>
                        </StackPanel>
                    </Border>

                    <!-- CASH MOVEMENT (shown when open) -->
                    <Border Visibility="{Binding IsRegisterOpen, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Cash In / Out"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Record petty cash movement and adjustments while the register remains open."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Direction"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          ItemsSource="{Binding Directions}"
                                          SelectedItem="{Binding MovementDirection}"
                                          AutomationProperties.Name="Cash direction"
                                          Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>

                                <TextBlock Grid.Row="2" Text="Amount"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding MovementAmount, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Movement amount"
                                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                         MaxLength="10"
                                         h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                         h:NumericInput.Scope="Number"
                                         h:NumericInput.IsDecimalOnly="True"
                                         h:Watermark.Text="Movement amount"/>

                                <TextBlock Grid.Row="4" Text="Reason"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Row="4" Grid.Column="1"
                                         Text="{Binding MovementReason, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Movement reason"
                                         MaxLength="200"
                                         h:Watermark.Text="Movement reason"/>
                            </Grid>
                            <Button Content="Record Movement" Command="{Binding RecordMovementCommand}"
                                    Style="{StaticResource SaveButtonStyle}"
                                    Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- CLOSE REGISTER (shown when open) -->
                    <Border Visibility="{Binding IsRegisterOpen, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Close Register / Day End"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Capture the counted cash and close the register once trading is complete."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Actual Cash"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Column="1"
                                         Text="{Binding ClosingBalanceInput, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Closing balance"
                                         Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                         MaxLength="10"
                                         h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                         h:NumericInput.Scope="Number"
                                         h:NumericInput.IsDecimalOnly="True"
                                         h:Watermark.Text="Actual cash counted"/>

                                <TextBlock Grid.Row="2" Text="Notes"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Row="2" Grid.Column="1"
                                         Text="{Binding CloseNotes, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource FluentMultilineTextBoxStyle}"
                                         AutomationProperties.Name="Close notes"
                                         MaxLength="500"
                                         h:Watermark.Text="Closing notes (optional)"/>
                            </Grid>
                            <Button Content="Close Register" Command="{Binding CloseRegisterCommand}"
                                    Style="{StaticResource SaveButtonStyle}"
                                    Margin="0,12,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- MOVEMENTS TABLE (shown when open) -->
                    <Border Visibility="{Binding IsRegisterOpen, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource ReadOnlyInspectionSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Today's Movements"
                                       Style="{StaticResource ReadOnlyInspectionSectionTitleStyle}"/>
                            <TextBlock Text="Review recorded cash in and cash out entries before closing the register."
                                       Style="{StaticResource ReadOnlyInspectionSectionDescriptionStyle}"/>
                            <DataGrid ItemsSource="{Binding Movements}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column" CanUserAddRows="False"
                                      MaxHeight="{StaticResource ReadOnlyInspectionGridMaxHeight}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat={}{0:hh:mm tt}}" Width="Auto"/>
                                    <DataGridTextColumn Header="Direction" Binding="{Binding Direction}" Width="Auto"/>
                                    <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right panel: Day-end summary + History -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- DAY-END SUMMARY (shown after close or when viewing history) -->
                    <Border Visibility="{Binding HasDayEndSummary, Converter={StaticResource BoolToVisibility}}"
                            Style="{StaticResource SummaryPanelStyle}">
                        <StackPanel>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Day-End Summary"
                                           Style="{StaticResource SummaryPanelTitleStyle}"/>
                                <Button Grid.Column="1" Content="Close" ToolTip="Close summary"
                                        Command="{Binding DismissSummaryCommand}"
                                        Style="{StaticResource CloseButtonStyle}"/>
                            </Grid>

                            <Grid Margin="0,12,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <TextBlock Text="Opening Balance" Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBlock Grid.Column="1" Text="{Binding DayEndSummary.OpeningBalance, StringFormat={}{0:C}}" Style="{StaticResource SummaryValueTextStyle}"/>

                                <TextBlock Grid.Row="1" Text="Cash Sales" Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding DayEndSummary.TotalCashSales, StringFormat={}{0:C}}" Style="{StaticResource SummaryValueTextStyle}"/>

                                <TextBlock Grid.Row="2" Text="Card Sales" Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding DayEndSummary.TotalCardSales, StringFormat={}{0:C}}" Style="{StaticResource SummaryValueTextStyle}"/>

                                <TextBlock Grid.Row="3" Text="UPI Sales" Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding DayEndSummary.TotalUpiSales, StringFormat={}{0:C}}" Style="{StaticResource SummaryValueTextStyle}"/>

                                <TextBlock Grid.Row="4" Text="Credit Sales" Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding DayEndSummary.TotalCreditSales, StringFormat={}{0:C}}" Style="{StaticResource SummaryValueTextStyle}"/>

                                <TextBlock Grid.Row="5" Text="Cash Returns" Style="{StaticResource SummaryKeyTextStyle}" Foreground="{StaticResource FluentError}"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding DayEndSummary.TotalCashReturns, StringFormat=-{0:C}}" Style="{StaticResource SummaryValueTextStyle}" Foreground="{StaticResource FluentError}"/>

                                <TextBlock Grid.Row="6" Text="Cash In / Out" Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource SummaryValueTextStyle}">
                                    <Run Text="+"/><Run Text="{Binding DayEndSummary.TotalCashIn, StringFormat={}{0:C}, Mode=OneWay}"/>
                                    <Run Text=" / -"/><Run Text="{Binding DayEndSummary.TotalCashOut, StringFormat={}{0:C}, Mode=OneWay}"/>
                                </TextBlock>

                                <Separator Grid.Row="7" Grid.ColumnSpan="2" Margin="0,8"/>

                                <TextBlock Grid.Row="8" Text="Expected Cash" FontWeight="SemiBold" Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding DayEndSummary.ExpectedCash, StringFormat={}{0:C}}" Style="{StaticResource SummaryAccentValueTextStyle}"/>
                            </Grid>

                            <StackPanel Margin="0,12,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Actual Cash"
                                               Style="{StaticResource SummaryKeyTextStyle}"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding DayEndSummary.ActualCash, StringFormat={}{0:C}, Mode=OneWay}"
                                               Style="{StaticResource SummaryValueTextStyle}"/>

                                    <TextBlock Grid.Row="1"
                                               Text="Discrepancy"
                                               Style="{StaticResource SummaryKeyTextStyle}"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                    <TextBlock Grid.Row="1"
                                               Grid.Column="1"
                                               Text="{Binding DayEndSummary.Discrepancy, StringFormat={}{0:C}, Mode=OneWay}"
                                               Style="{StaticResource SummaryAccentValueTextStyle}"/>
                                </Grid>
                                <TextBlock Style="{StaticResource SummaryMetaTextStyle}">
                                    <Run Text="Sales: "/><Run Text="{Binding DayEndSummary.SaleCount, Mode=OneWay}"/>
                                    <Run Text=" - Returns: "/><Run Text="{Binding DayEndSummary.ReturnCount, Mode=OneWay}"/>
                                </TextBlock>

                                <!-- Cash variance alert (#252) -->
                                <Border Visibility="{Binding HasCashVarianceAlert, Converter={StaticResource BoolToVisibility}}"
                                        Style="{StaticResource WarningCalloutCardStyle}">
                                    <TextBlock Text="{Binding CashVarianceAlertMessage}"
                                               Style="{StaticResource WarningCalloutTitleTextStyle}"
                                               TextWrapping="Wrap"/>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- REGISTER HISTORY -->
                    <Border Style="{StaticResource ReadOnlyInspectionSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Register History"
                                       Style="{StaticResource ReadOnlyInspectionSectionTitleStyle}"/>
                            <TextBlock Text="Review previous register sessions and reopen day-end summaries when reconciliation details are needed."
                                       Style="{StaticResource ReadOnlyInspectionSectionDescriptionStyle}"/>
                            <DataGrid ItemsSource="{Binding RegisterHistory}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column" CanUserAddRows="False"
                                      MaxHeight="{StaticResource ReadOnlyInspectionGridMaxHeight}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Date" Binding="{Binding OpenedAt, StringFormat={}{0:dd MMM yyyy}}" Width="*"/>
                                    <DataGridTextColumn Header="Opening" Binding="{Binding OpeningBalance, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                                    <DataGridTextColumn Header="Closing" Binding="{Binding ClosingBalance, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                                    <DataGridTextColumn Header="Discrepancy" Binding="{Binding Discrepancy, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                                    <DataGridTemplateColumn Header="" Width="Auto">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Button Content="Summary"
                                                        Command="{Binding DataContext.ViewDayEndSummaryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource ViewButtonStyle}" Padding="8,2"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Severity="Error"
                              Title="Cash Register"
                              Message="{Binding ErrorMessage}"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Severity="Success"
                              Title="Cash Register"
                              Message="{Binding SuccessMessage}"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Loading register..."/>
    </Grid>
</UserControl>


