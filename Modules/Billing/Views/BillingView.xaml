<UserControl x:Class="StoreAssistantPro.Modules.Billing.Views.BillingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded"
             Unloaded="OnUnloaded">
    <UserControl.InputBindings>
        <KeyBinding Key="F2" Command="{Binding ClearCartCommand}"/>
        <KeyBinding Key="F5" Command="{Binding CompleteSaleCommand}"/>
        <KeyBinding Key="F8" Command="{Binding HoldBillCommand}"/>
        <KeyBinding Key="F9" Command="{Binding NextHeldBillCommand}"/>
        <KeyBinding Key="F9" Modifiers="Shift" Command="{Binding PreviousHeldBillCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding ClearCartCommand}"/>
    </UserControl.InputBindings>
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7BF;"/><Run Text=" Billing"/></TextBlock>

        <!-- Customer selection (#157 / #158) -->
        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Customer:" Style="{StaticResource FormRowLabelStyle}"
                       VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" VerticalAlignment="Center"
                       FontWeight="SemiBold" Margin="{StaticResource InlineControlSpacing}">
                <Run Text="{Binding CustomerDisplayName, Mode=OneWay}"/>
            </TextBlock>
            <Button Grid.Column="2" Content="✕" ToolTip="Clear customer"
                    Command="{Binding ClearCustomerCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Visibility="{Binding HasSelectedCustomer, Converter={StaticResource BoolToVisibility}}"
                    Margin="{StaticResource InlineControlSpacing}" Padding="6,2"/>

            <TextBox Grid.Column="4"
                     Text="{Binding CustomerSearchText, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Customer search"
                     Width="{StaticResource FieldWidthStandard}"
                     h:Watermark.Text="e.g. Ravi Kumar">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCustomersCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
            <Button Grid.Column="5" Content="Find Customer"
                    Command="{Binding SearchCustomersCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"
                    HorizontalAlignment="Left"/>
        </Grid>

        <!-- Customer search results dropdown -->
        <ItemsControl Grid.Row="1" Margin="0,36,0,0"
                      ItemsSource="{Binding CustomerSearchResults}"
                      VerticalAlignment="Top" HorizontalAlignment="Left"
                      Panel.ZIndex="10"
                      Visibility="{Binding HasCustomerSearchResults, Converter={StaticResource BoolToVisibility}}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="{StaticResource FluentSurface}"
                            BorderBrush="{StaticResource FluentStrokeDefault}"
                            BorderThickness="1,0,1,1" Padding="8,4" MinWidth="300">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Phone}" Foreground="{StaticResource FluentTextSecondary}"
                                           FontSize="{StaticResource FontSizeCaption}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Select"
                                    Command="{Binding DataContext.SelectCustomerCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    CommandParameter="{Binding}"
                                    Style="{StaticResource SecondaryButtonStyle}" Padding="8,2"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Search + Barcode row -->
        <Grid Grid.Row="2" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FluentSearchTextBoxStyle}"
                     AutomationProperties.Name="Search products"
                     h:Watermark.Text="e.g. Black T-shirt"/>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchProductsCommand}"
                    Style="{StaticResource SearchButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Grid.Column="2" Content="Add Selected"
                    Command="{Binding AddProductToCartCommand}"
                    CommandParameter="{Binding SelectedSearchResult}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>

            <TextBox Grid.Column="4"
                     Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Barcode input"
                     Width="{StaticResource FieldWidthStandard}"
                     h:Watermark.Text="e.g. 8901234567890"/>
            <Button Grid.Column="5" Content="Scan" Command="{Binding ScanBarcodeCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- Main content: Cart (left) + Payment (right) -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Search results + Cart -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="SearchResultsGrid"
                          AutomationProperties.Name="Product search results"
                          ItemsSource="{Binding SearchResults}"
                          SelectedItem="{Binding SelectedSearchResult}"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column" CanUserAddRows="False"
                          MaxHeight="{StaticResource SearchListMaxHeight}"
                          Margin="{StaticResource ItemSpacing}"
                          Visibility="{Binding HasSearchResults, Converter={StaticResource BoolToVisibility}}"
                          MouseDoubleClick="OnSearchResultsDoubleClick"
                          KeyDown="OnSearchResultsKeyDown">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding SalePrice, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Stock" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <DataGrid AutomationProperties.Name="Cart items" Grid.Row="1"
                          ItemsSource="{Binding CartItems}"
                          SelectedItem="{Binding SelectedCartItem}"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat={}{0:N2}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Disc %" Binding="{Binding ItemDiscountRate}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding LineTotal, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Right: Payment panel -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Totals -->
                <StackPanel Margin="{StaticResource ItemSpacing}">
                    <TextBlock>
                        <Run Text="Subtotal: " FontWeight="SemiBold"/>
                        <Run Text="{Binding Subtotal, StringFormat={}{0:C}, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Foreground="{StaticResource FluentTextSecondary}"
                               FontSize="{StaticResource FontSizeCaption}">
                        <Run Text="CGST: "/>
                        <Run Text="{Binding TotalCgst, StringFormat={}{0:C}, Mode=OneWay}"/>
                        <Run Text="  SGST: "/>
                        <Run Text="{Binding TotalSgst, StringFormat={}{0:C}, Mode=OneWay}"/>
                        <Run Text="  Tax: "/>
                        <Run Text="{Binding TotalTax, StringFormat={}{0:C}, Mode=OneWay}"/>
                        <Run Text="  Cess: "/>
                        <Run Text="{Binding TotalCess, StringFormat={}{0:C}, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock>
                        <Run Text="Discount: " FontWeight="SemiBold"/>
                        <Run Text="{Binding DiscountAmount, StringFormat=-{0:C}, Mode=OneWay}"
                             Foreground="{StaticResource FluentError}"/>
                    </TextBlock>
                    <TextBlock FontSize="{StaticResource FontSizeHeadline}"
                               FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}"
                               Margin="{StaticResource MessageBarSpacing}">
                        <Run Text="Total: "/>
                        <Run Text="{Binding GrandTotal, StringFormat={}{0:C}, Mode=OneWay}"/>
                    </TextBlock>
                </StackPanel>

                <!-- Discount -->
                <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Discount"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                        <ComboBox ItemsSource="{Binding DiscountTypes}"
                                  AutomationProperties.Name="Discount type"
                                  SelectedItem="{Binding SelectedDiscountType}"
                                  Width="{StaticResource FieldWidthCompact}"/>
                        <TextBox Text="{Binding DiscountInput, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Discount value"
                                 Width="{StaticResource FieldWidthCompact}"
                                 Margin="{StaticResource InlineControlSpacing}"
                                 MaxLength="8"/>
                    </StackPanel>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Reason"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding DiscountReason, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Discount reason"
                             MaxLength="200" h:Watermark.Text="e.g. Loyalty adjustment"/>
                </Grid>

                <!-- Payment method -->
                <Grid Grid.Row="2" Margin="{StaticResource StepContentTopSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Pay By"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox Grid.Column="1"
                              ItemsSource="{Binding PaymentMethods}"
                              AutomationProperties.Name="Payment method"
                              SelectedItem="{Binding PaymentMethod}"
                              Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>
                </Grid>

                <!-- Cash details -->
                <Grid Grid.Row="3" Margin="{StaticResource StepContentTopSpacing}"
                      Visibility="{Binding IsCashPayment, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Cash Given"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding CashTendered, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Cash given"
                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                             MaxLength="10"
                             h:Watermark.Text="e.g. 2500"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Change"
                               Style="{StaticResource FormRowLabelStyle}" FontWeight="Bold"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               FontWeight="Bold" Foreground="{StaticResource FluentSuccess}">
                        <Run Text="{Binding ChangeAmount, StringFormat={}{0:C}, Mode=OneWay}"/>
                    </TextBlock>
                </Grid>

                <!-- Split payment lines (#118) -->
                <StackPanel Grid.Row="4" Margin="{StaticResource StepContentTopSpacing}"
                            Visibility="{Binding IsSplitPayment, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Split Payments" FontWeight="SemiBold"
                               Margin="{StaticResource ItemSpacing}"/>
                    <ItemsControl ItemsSource="{Binding SplitPaymentLines}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <ComboBox ItemsSource="{Binding DataContext.SplitPaymentMethodOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                              SelectedItem="{Binding Method}"
                                              Width="{StaticResource FieldWidthCompact}"/>
                                    <TextBox Grid.Column="1"
                                             Text="{Binding Amount, UpdateSourceTrigger=PropertyChanged}"
                                             Width="{StaticResource FieldWidthCompact}"
                                             Margin="{StaticResource InlineControlSpacing}"
                                             AutomationProperties.Name="Split amount"
                                             MaxLength="10"/>
                                    <TextBox Grid.Column="2"
                                             Text="{Binding Reference, UpdateSourceTrigger=PropertyChanged}"
                                             Width="{StaticResource FieldWidthCompact}"
                                             Margin="{StaticResource InlineControlSpacing}"
                                             AutomationProperties.Name="Split reference"
                                             h:Watermark.Text="Ref #"
                                             MaxLength="50"
                                             Visibility="{Binding RequiresReference, Converter={StaticResource BoolToVisibility}}"/>
                                    <Button Grid.Column="3" Content="✕" ToolTip="Remove line"
                                            Command="{Binding DataContext.RemoveSplitLineCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="{StaticResource InlineControlSpacing}"
                                            Padding="6,2"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <Button Content="+ Add Line" Command="{Binding AddSplitLineCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"
                            HorizontalAlignment="Left"
                            Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Reference -->
                <Grid Grid.Row="5" Margin="{StaticResource StepContentTopSpacing}"
                      Visibility="{Binding RequiresPaymentReference, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Ref #"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Column="1"
                             Text="{Binding PaymentReference, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Payment reference"
                             MaxLength="100" h:Watermark.Text="e.g. UPI 835214"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="4" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Severity="Error"
                              Title="Billing issue"
                              Message="{Binding ErrorMessage}"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringToVisibility}}"/>
            <controls:InfoBar Severity="Success"
                              Title="Sale updated"
                              Message="{Binding SuccessMessage}"
                              Visibility="{Binding SuccessMessage, Converter={StaticResource NonEmptyStringToVisibility}}"/>
        </Grid>

        <!-- Action buttons -->
        <Grid Grid.Row="5" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="Cancel Bill" Command="{Binding ClearCartCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"/>

            <Button Grid.Column="1" Command="{Binding HoldBillCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource FluentIconFont}" Text="&#xE785;" Margin="0,0,6,0"/>
                    <TextBlock Text="Hold Bill"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="2" Command="{Binding ToggleHeldBillListCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource FluentIconFont}" Text="&#xE7C3;" Margin="0,0,6,0"/>
                    <TextBlock Text="Recall"/>
                    <TextBlock Text="{Binding HeldBillCount, StringFormat=' ({0})'}"
                               Visibility="{Binding HasHeldBills, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </Button>

            <Button Grid.Column="4" Content="Remove Item" Command="{Binding RemoveCartItemCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Grid.Column="5" Content="Complete Sale" Command="{Binding CompleteSaleCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- Held bill list popup -->
        <Border Grid.Row="3" Grid.RowSpan="3"
                HorizontalAlignment="Left" VerticalAlignment="Bottom"
                Margin="0,0,0,48"
                Background="{StaticResource FluentSurface}"
                BorderBrush="{StaticResource FluentStrokeDefault}"
                BorderThickness="1"
                CornerRadius="{StaticResource CornerRadiusMedium}"
                Padding="{StaticResource DialogPadding}"
                MinWidth="360" MaxHeight="400"
                Visibility="{Binding ShowHeldBillList, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Held Bills" FontWeight="SemiBold"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           Margin="{StaticResource ItemSpacing}"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding HeldBills}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{StaticResource FluentStrokeDefault}"
                                    BorderThickness="0,0,0,1" Padding="4,8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock FontWeight="SemiBold">
                                            <Run Text="{Binding Label, Mode=OneWay}"/>
                                            <Run Text=" · " Foreground="{StaticResource FluentTextTertiary}">
                                                <Run.Style>
                                                    <Style TargetType="Run">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding CustomerTag}" Value="{x:Null}">
                                                                <Setter Property="Text" Value=""/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Run.Style>
                                            </Run>
                                            <Run Text="{Binding CustomerTag, Mode=OneWay}"
                                                 Foreground="{StaticResource FluentAccentDefault}"/>
                                        </TextBlock>
                                        <TextBlock Foreground="{StaticResource FluentTextSecondary}">
                                            <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                                            <Run Text="items ·"/>
                                            <Run Text="{Binding Total, StringFormat={}{0:C}, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Recall"
                                            Command="{Binding DataContext.RecallBillCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="8,0,0,0"/>
                                    <Button Grid.Column="2" Content="✕"
                                            Command="{Binding DataContext.DiscardHeldBillCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Margin="4,0,0,0"
                                            ToolTip="Discard this held bill"
                                            AutomationProperties.Name="Discard this held bill"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing billing..."/>
    </Grid>
</UserControl>
