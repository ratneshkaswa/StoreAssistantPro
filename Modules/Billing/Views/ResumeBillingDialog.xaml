<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Billing.Views.ResumeBillingDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Resume Billing Session"
        ConfirmCommand="{Binding ResumeCommand}">

    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="🧾 Resume Billing Session?" Style="{StaticResource DialogTitleStyle}"/>

        <!-- Session details card -->
        <StackPanel Grid.Row="1" VerticalAlignment="Top">
            <TextBlock Text="A previous billing session was found that did not complete."
                       TextWrapping="Wrap" FontSize="{StaticResource FontSizeBody}"
                       Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource FieldGroupSpacing}"/>

            <Border Style="{StaticResource FormCardStyle}"
                    h:Motion.SlideFadeIn="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Bill started -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Started"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Text="{Binding BillStartTime}"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>

                    <!-- Row 2: User -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="User"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1"
                               Text="{Binding UserDisplay}"
                               FontSize="{StaticResource FontSizeBody}"
                               VerticalAlignment="Center"/>

                    <!-- Row 4: Items -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Items"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBlock Grid.Row="4" Grid.Column="1"
                               FontSize="{StaticResource FontSizeBody}"
                               VerticalAlignment="Center">
                        <Run Text="{Binding ItemCount, Mode=OneWay}"/>
                        <Run Text="product(s) in cart"/>
                    </TextBlock>

                    <!-- Row 6: Elapsed -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Last active"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBlock Grid.Row="6" Grid.Column="1"
                               Text="{Binding ElapsedTime}"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{StaticResource FluentTextTertiary}"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>

            <TextBlock Text="Choose Resume to continue where you left off, or Discard to start fresh."
                       TextWrapping="Wrap" FontSize="{StaticResource FontSizeCaption}"
                       Foreground="{StaticResource FluentTextTertiary}" Margin="{StaticResource MessageBarSpacing}"/>
        </StackPanel>

        <!-- Action buttons — pinned to bottom -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="▶ Resume Billing" Command="{Binding ResumeCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="🗑 Discard" Command="{Binding DiscardCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</core:BaseDialogWindow>
