<UserControl x:Class="StoreAssistantPro.Modules.Billing.Views.SaleHistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE9D9;"/><Run Text=" Sale History"/></TextBlock>
            <TextBlock Text="Review invoice history, narrow the date range, and inspect completed sale totals."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Filters -->
        <Grid Grid.Row="1" Style="{StaticResource PageToolbarHostStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <WrapPanel Style="{StaticResource PageToolbarContentRowStyle}">
                <TextBlock Text="From:" VerticalAlignment="Center" Margin="{StaticResource InlineLabelGap}"/>
                <DatePicker SelectedDate="{Binding DateFrom}"
                            AutomationProperties.Name="From date"
                            Width="{StaticResource FieldWidthCompact}"/>

                <TextBlock Text="To:" VerticalAlignment="Center"
                           Margin="{StaticResource InlineControlSpacing}"/>
                <DatePicker SelectedDate="{Binding DateTo}"
                            AutomationProperties.Name="To date"
                            Width="{StaticResource FieldWidthCompact}"/>

                <TextBox Text="{Binding InvoiceSearch, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FluentSearchTextBoxStyle}"
                         AutomationProperties.Name="Invoice search"
                         Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource InlineControlSpacing}"
                         h:Watermark.Text="Search invoices by invoice number"/>
            </WrapPanel>

            <WrapPanel Grid.Column="1" Style="{StaticResource PageToolbarActionRowStyle}">
                <Button Content="Search" Command="{Binding SearchCommand}"
                        Style="{StaticResource SearchButtonStyle}"/>

                <Button Margin="{StaticResource InlineControlSpacing}"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        ToolTip="Choose columns"
                        AutomationProperties.Name="Choose columns"
                        h:DataGridColumnChooser.Target="{Binding ElementName=SaleHistoryGrid}">
                    <TextBlock Text="&#xE713;"
                               FontFamily="{StaticResource FluentIconFont}"
                               FontSize="14"/>
                </Button>
            </WrapPanel>
        </Grid>

        <!-- Content: Sale list + Detail/Receipt -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sale list -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="SaleHistoryGrid"
                          AutomationProperties.Name="Sale history" ItemsSource="{Binding Sales}"
                          SelectedItem="{Binding SelectedSale}"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          h:DataGridLayoutPersistence.Key="SaleHistoryGrid"
                          h:DataGridEmptyState.Icon="{StaticResource EmptyStateInvoiceIconGlyph}"
                          h:DataGridEmptyState.Title="No completed sales yet"
                          h:DataGridEmptyState.Description="Closed invoices will appear here once checkout activity starts."
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNumber}" Width="*"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat=g}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTemplateColumn Header="Payment" Width="{StaticResource ColumnWidthPrice}" SortMemberPath="PaymentMethod">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SemanticTagChipBorderStyle}"
                                            Background="{Binding PaymentMethod, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Background}"
                                            BorderBrush="{Binding PaymentMethod, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Border}"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding PaymentMethod, TargetNullValue=Unknown}"
                                                   Style="{StaticResource SemanticTagChipTextStyle}"
                                                   Foreground="{Binding PaymentMethod, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Foreground}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1"
                            Style="{StaticResource PaginatorBarStyle}"
                            Visibility="{Binding TotalCount, Converter={StaticResource PositiveToVisibility}}">
                    <Button Content="Prev"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding HasPreviousPage}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding PagingInfo}"
                               VerticalAlignment="Center"
                               Style="{StaticResource PaginatorInfoTextStyle}"/>
                    <Button Content="Next"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNextPage}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Right panel: Detail + Receipt preview -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <controls:ExpandableTextBlock Text="{Binding SaleDetail}"
                                              CollapsedLineCount="3"
                                              Foreground="{StaticResource FluentTextSecondary}"
                                              Margin="{StaticResource ItemSpacing}"/>

                <Button Grid.Row="1" Content="Preview Receipt"
                        Command="{Binding PreviewReceiptCommand}"
                        Style="{StaticResource ViewButtonStyle}"
                        Margin="{StaticResource ItemSpacing}"/>

                <Border Grid.Row="2" Style="{StaticResource ReadOnlyPreviewSurfaceStyle}">
                    <StackPanel>
                        <TextBlock Text="Receipt Preview"
                                   Style="{StaticResource ReadOnlyInspectionSectionTitleStyle}"/>
                        <TextBlock Text="Review the generated receipt content before opening the print workflow."
                                   Style="{StaticResource ReadOnlyInspectionSectionDescriptionStyle}"/>
                        <ScrollViewer Style="{StaticResource ReadOnlyPreviewScrollViewerStyle}">
                            <TextBlock Text="{Binding ReceiptPreview}"
                                       Style="{StaticResource ReadOnlyPreviewTextStyle}"/>
                        </ScrollViewer>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Loading sale history..."/>
    </Grid>
</UserControl>

