<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Billing.Views.SaleHistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="Sale History"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- Filters -->
            <RowDefinition Height="*"/>     <!-- List + Detail -->
            <RowDefinition Height="Auto"/>  <!-- Messages -->
            <RowDefinition Height="Auto"/>  <!-- Close -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource DialogTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE9D9;"/><Run Text=" Sale History"/></TextBlock>

        <!-- Filters -->
        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="From:" VerticalAlignment="Center" Margin="{StaticResource InlineLabelGap}"/>
            <DatePicker Grid.Column="1" SelectedDate="{Binding DateFrom}"
                        Width="{StaticResource FieldWidthCompact}"/>

            <TextBlock Grid.Column="2" Text="To:" VerticalAlignment="Center"
                       Margin="{StaticResource InlineControlSpacing}"/>
            <DatePicker Grid.Column="3" SelectedDate="{Binding DateTo}"
                        Width="{StaticResource FieldWidthCompact}"/>

            <TextBox Grid.Column="4" Text="{Binding InvoiceSearch, UpdateSourceTrigger=PropertyChanged}"
                     Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource InlineControlSpacing}"
                     h:Watermark.Text="Invoice #"/>

            <Button Grid.Column="6" Content="Search" Command="{Binding SearchCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </Grid>

        <!-- Content: Sale list + Detail/Receipt -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sale list -->
            <DataGrid AutomationProperties.Name="Sale history" ItemsSource="{Binding Sales}"
                      SelectedItem="{Binding SelectedSale}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Invoice" Binding="{Binding InvoiceNumber}" Width="*"/>
                    <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat=g}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="Payment" Binding="{Binding PaymentMethod}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="{StaticResource ColumnWidthQty}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Right panel: Detail + Receipt preview -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Sale detail summary -->
                <TextBlock Text="{Binding SaleDetail}" TextWrapping="Wrap"
                           Foreground="{StaticResource FluentTextSecondary}"
                           Margin="{StaticResource ItemSpacing}"/>

                <!-- Preview button -->
                <Button Grid.Row="1" Content="Preview Receipt"
                        Command="{Binding PreviewReceiptCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="{StaticResource ItemSpacing}"/>

                <!-- Receipt preview -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                            h:SmoothScroll.IsEnabled="True">
                    <TextBlock Text="{Binding ReceiptPreview}"
                               FontFamily="{StaticResource FluentFontMono}" FontSize="{StaticResource FontSizeCaption}"
                               Foreground="{StaticResource FluentTextPrimary}"
                               Background="{StaticResource FluentSurfaceElevated}"
                               Padding="{StaticResource SmallCardPadding}" TextWrapping="NoWrap"
                               Margin="{StaticResource ItemSpacing}"/>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasErrorMessage}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccessMessage}"/>
        </Grid>

        <!-- Close -->
        <Grid Grid.Row="4" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Loading sale history..."/>
    </Grid>
</core:BaseDialogWindow>
