<Window x:Class="StoreAssistantPro.Modules.Startup.Views.SetupWizardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="First-Run Setup Wizard"
        Icon="pack://application:,,,/Assets/app.ico"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        Loaded="OnLoaded">

    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Branding -->
            <RowDefinition Height="Auto"/>  <!-- Step indicator -->
            <RowDefinition Height="*"/>     <!-- Step content -->
            <RowDefinition Height="Auto"/>  <!-- Messages -->
            <RowDefinition Height="Auto"/>  <!-- Navigation -->
        </Grid.RowDefinitions>

        <!-- Branding -->
        <controls:AppBranding Grid.Row="0" LogoSize="40"/>

        <!-- Step indicator -->
        <Grid Grid.Row="1" Margin="{StaticResource TitleSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="{Binding StepTitle}"
                       Style="{StaticResource SectionHeaderStyle}"/>
            <TextBlock Grid.Column="1" Text="{Binding StepDisplay}"
                       Foreground="{StaticResource FluentTextTertiary}"
                       FontSize="{StaticResource FontSizeBody}"
                       VerticalAlignment="Center"/>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             Step content (only one visible at a time)
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">

            <!-- Step 1: Firm Setup -->
            <Grid Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Firm Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1"
                         Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="100" h:Watermark.Text="e.g. Sharma Garments"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Address"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="2" Grid.Column="1"
                         Text="{Binding FirmAddress, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="200" h:Watermark.Text="Shop/Street address"/>

                <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="4" Grid.Column="1"
                         Text="{Binding FirmPhone, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                         MaxLength="15" h:Watermark.Text="e.g. 9876543210"/>

                <TextBlock Grid.Row="6" Grid.Column="0" Text="Email"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="6" Grid.Column="1"
                         Text="{Binding FirmEmail, UpdateSourceTrigger=PropertyChanged}"
                         MaxLength="100" h:Watermark.Text="e.g. shop@example.com"/>

                <TextBlock Grid.Row="8" Grid.Column="0" Text="GSTIN"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="8" Grid.Column="1"
                         Text="{Binding FirmGSTIN, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"
                         MaxLength="15" h:Watermark.Text="e.g. 22AAAAA0000A1Z5"/>

                <Button Grid.Row="10" Grid.Column="1"
                        Content="💾 Save Firm Details"
                        Command="{Binding SaveFirmCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Left"/>

                <TextBlock Grid.Row="12" Grid.Column="0" Grid.ColumnSpan="2"
                           Style="{StaticResource HintTextStyle}"
                           Text="Firm name is required. Other fields can be updated later from Firm Management."/>
            </Grid>

            <!-- Step 2: Tax Setup -->
            <Grid Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Inline add form -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Tax Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding TaxName, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                             MaxLength="100" h:Watermark.Text="e.g. GST 5%"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Slab % "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                    </TextBlock>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding SlabPercent, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                             MaxLength="6" h:Watermark.Text="e.g. 5"/>

                    <Button Grid.Row="4" Grid.Column="1"
                            Content="➕ Add Tax"
                            Command="{Binding AddTaxCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left"/>
                </Grid>

                <!-- Tax list -->
                <DataGrid Grid.Row="2"
                          ItemsSource="{Binding Taxes}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Tax Name" Binding="{Binding TaxName}" Width="*"/>
                        <DataGridTextColumn Header="Slab %" Binding="{Binding SlabPercent, StringFormat={}{0:G}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=OneWay}" Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Step 3: Vendor Setup -->
            <Grid Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Hint -->
                <TextBlock Style="{StaticResource HintTextStyle}"
                           Text="Optional — add your key vendors now or skip and add them later."/>

                <!-- Inline add form -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Vendor Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding VendorName, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="200" h:Watermark.Text="e.g. Bombay Textiles"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Phone"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding VendorPhone, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                             MaxLength="15" h:Watermark.Text="e.g. 9876543210"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="City"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1"
                             Text="{Binding VendorCity, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                             MaxLength="100" h:Watermark.Text="e.g. Mumbai"/>

                    <Button Grid.Row="6" Grid.Column="1"
                            Content="➕ Add Vendor"
                            Command="{Binding AddVendorCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left"/>
                </Grid>

                <!-- Vendor list -->
                <DataGrid Grid.Row="4"
                          ItemsSource="{Binding Vendors}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Vendor" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="City" Binding="{Binding City}" Width="{StaticResource ColumnWidthPrice}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Step 4: Product Setup -->
            <Grid Visibility="{Binding IsStep4, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Hint -->
                <TextBlock Style="{StaticResource HintTextStyle}"
                           Text="Optional — add a few products now or skip and add them later from Product Management."/>

                <!-- Inline add form -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Product Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="200" h:Watermark.Text="e.g. Shirt, Pant, Kurta"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Tax"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              ItemsSource="{Binding ProductTaxes}"
                              SelectedItem="{Binding SelectedProductTax}"
                              DisplayMemberPath="TaxName"
                              Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                    <Button Grid.Row="4" Grid.Column="1"
                            Content="➕ Add Product"
                            Command="{Binding AddProductCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"
                            HorizontalAlignment="Left"/>
                </Grid>

                <!-- Product list -->
                <DataGrid Grid.Row="4"
                          ItemsSource="{Binding Products}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Tax" Binding="{Binding Tax.TaxName}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=OneWay}" Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Grid>

        <!-- Messages -->
        <StackPanel Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
                    Margin="{StaticResource MessageBarSpacing}">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                       h:AutoDismiss.IsEnabled="True" h:AutoDismiss.Seconds="4"/>
        </StackPanel>

        <!-- Navigation buttons -->
        <Grid Grid.Row="4" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Content="◀ Back" Command="{Binding BackCommand}"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource SecondaryButtonStyle}"/>

            <Button Grid.Column="2"
                    Content="{Binding NextButtonText}"
                    Command="{Binding NextCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </Grid>
    </Grid>
</Window>
