<UserControl x:Class="StoreAssistantPro.Modules.Payments.Views.PaymentManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="700" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}">
            <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8C7;"/>
            <Run Text=" Payment Management"/>
        </TextBlock>

        <!-- Stat Cards -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="TOTAL AMOUNT" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat='₹{0:N0}'}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentAccentDefault}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="THIS MONTH" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ThisMonthAmount, StringFormat='₹{0:N0}'}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentSuccess}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="TOTAL PAYMENTS" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalPayments}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentAccentDark1}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Style="{StaticResource FormCardStyle}" Margin="{StaticResource ItemSpacing}">
            <StackPanel>
                <TextBlock Text="Record payment" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Customer" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer}"
                                  DisplayMemberPath="Name"
                                  AutomationProperties.Name="Customer"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Amount ₹" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Amount" MaxLength="10"
                                 AutomationProperties.Name="Amount"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding PaymentDate}"
                                    AutomationProperties.Name="Payment date"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Note" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Optional note" MaxLength="500"
                                 AutomationProperties.Name="Note"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="8,0,0,0">
                        <Button Content="Clear" Command="{Binding ClearFormCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     h:Watermark.Text="Search by customer name or note"
                     AutomationProperties.Name="Search payments"/>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- Filter Chips -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="{StaticResource ItemSpacing}">
            <Button Content="All" Command="{Binding SetDateFilterCommand}" CommandParameter="All"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter all"/>
            <Button Content="Today" Command="{Binding SetDateFilterCommand}" CommandParameter="Today"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter today"/>
            <Button Content="This Week" Command="{Binding SetDateFilterCommand}" CommandParameter="Week"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter this week"/>
            <Button Content="This Month" Command="{Binding SetDateFilterCommand}" CommandParameter="Month"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,8,0" AutomationProperties.Name="Filter this month"/>
            <TextBlock Text="{Binding FilterCountText}" FontSize="11"
                       Foreground="{StaticResource FluentTextTertiary}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="5" AutomationProperties.Name="Payment list"
                  ItemsSource="{Binding Payments}" SelectedItem="{Binding SelectedPayment}"
                  Style="{StaticResource EnterpriseDataGridStyle}" HeadersVisibility="Column">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedPayment}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedPayment}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="DATE" Binding="{Binding PaymentDate, StringFormat=dd-MMM-yyyy}"
                                    SortMemberPath="PaymentDate" Width="100"/>
                <DataGridTextColumn Header="CUSTOMER" Binding="{Binding Customer.Name}"
                                    SortMemberPath="Customer.Name" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="AMOUNT" Binding="{Binding Amount, StringFormat='₹{0:N0}'}"
                                    SortMemberPath="Amount" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="NOTE" Binding="{Binding Note}"
                                    SortMemberPath="Note" Width="200"/>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Edit"
                                        AutomationProperties.Name="Edit" Margin="0,0,2,0" Padding="4">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Delete"
                                        AutomationProperties.Name="Delete" Padding="4">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Messages -->
        <Grid Grid.Row="6" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing payment..."/>
    </Grid>
</UserControl>
