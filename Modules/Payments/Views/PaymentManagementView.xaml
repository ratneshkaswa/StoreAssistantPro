<UserControl x:Class="StoreAssistantPro.Modules.Payments.Views.PaymentManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="700" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8C7;"/>
                <Run Text=" Payments"/>
            </TextBlock>
            <TextBlock Text="Record incoming payments, review monthly totals, and reconcile payment activity."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Stat Cards -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL AMOUNT" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalAmount, StringFormat={}{0:C0}}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentAccentDefault}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="THIS MONTH" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding ThisMonthAmount, StringFormat={}{0:C0}}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentSuccess}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL PAYMENTS" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalPayments}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentAccentDark1}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Style="{StaticResource OperationalEditorSectionCardStyle}" Margin="{StaticResource ItemSpacing}">
            <StackPanel>
                <TextBlock Text="Payment Details" Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                <TextBlock Text="Record a customer payment with amount, date, and note details so collections stay traceable."
                           Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Customer" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding Customers}"
                                  SelectedItem="{Binding SelectedCustomer}"
                                  DisplayMemberPath="Name"
                                  AutomationProperties.Name="Customer"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Amount" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                 h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                 h:NumericInput.Scope="Number"
                                 h:NumericInput.IsDecimalOnly="True"
                                 h:Watermark.Text="Amount" MaxLength="10"
                                 AutomationProperties.Name="Amount"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding PaymentDate}"
                                    AutomationProperties.Name="Payment date"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Note" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Note, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FluentMultilineTextBoxStyle}"
                                 h:Watermark.Text="Note (optional)" MaxLength="500"
                                 AutomationProperties.Name="Note"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Style="{StaticResource FormActionRowStyle}" VerticalAlignment="Bottom" Margin="8,0,0,0">
                        <Button Content="Clear" Command="{Binding ClearFormCommand}"
                                Style="{StaticResource UtilityButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                                Style="{StaticResource SaveButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FluentSearchTextBoxStyle}"
                     h:Watermark.Text="Search payments by customer or note"
                     AutomationProperties.Name="Search payments"/>
        </Grid>

        <!-- Filter Chips -->
        <StackPanel Grid.Row="4" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SegmentedFilterHostStyle}">
                <WrapPanel Style="{StaticResource SegmentedFilterButtonRowStyle}">
                    <Button Content="All" Command="{Binding SetDateFilterCommand}" CommandParameter="All"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter all">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveDateFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Today" Command="{Binding SetDateFilterCommand}" CommandParameter="Today"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter today">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveDateFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="This Week" Command="{Binding SetDateFilterCommand}" CommandParameter="Week"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter this week">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveDateFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="This Month" Command="{Binding SetDateFilterCommand}" CommandParameter="Month"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            AutomationProperties.Name="Filter this month">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveDateFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </WrapPanel>
            </Border>
            <WrapPanel Margin="0,8,0,0">
                <Button Content="{Binding ActiveDateFilter, StringFormat=Date: {0}}"
                        Command="{Binding SetDateFilterCommand}"
                        CommandParameter="All">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActiveFilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveDateFilter}" Value="All">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </WrapPanel>
            <TextBlock Text="{Binding FilterCountText}" FontSize="11"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource FluentTextTertiary}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="5" AutomationProperties.Name="Payment list"
                  ItemsSource="{Binding Payments}" SelectedItem="{Binding SelectedPayment}"
                  Style="{StaticResource EnterpriseDataGridStyle}" HeadersVisibility="Column"
                  h:DataGridLayoutPersistence.Key="PaymentsGrid"
                  h:DataGridEmptyState.Icon="{StaticResource EmptyStatePaymentIconGlyph}"
                  h:DataGridEmptyState.Title="No payments found"
                  h:DataGridEmptyState.Description="Record a payment or broaden the current search and date filters to see entries.">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedPayment}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedPayment}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="DATE" Binding="{Binding PaymentDate, StringFormat=dd-MMM-yyyy}"
                                    SortMemberPath="PaymentDate" Width="100"/>
                <DataGridTextColumn Header="CUSTOMER" Binding="{Binding Customer.Name}"
                                    SortMemberPath="Customer.Name" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="AMOUNT" Binding="{Binding Amount, StringFormat={}{0:C0}}"
                                    SortMemberPath="Amount" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="NOTE" Binding="{Binding Note}"
                                    SortMemberPath="Note" Width="200"/>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Style="{StaticResource DataGridRowActionPanelStyle}">
                                <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Edit"
                                        AutomationProperties.Name="Edit" Margin="0,0,2,0" Padding="4">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Delete"
                                        AutomationProperties.Name="Delete" Padding="4">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Messages -->
        <Grid Grid.Row="6" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing payment..."/>
    </Grid>
</UserControl>


