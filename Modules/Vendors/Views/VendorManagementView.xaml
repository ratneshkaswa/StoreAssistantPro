<UserControl x:Class="StoreAssistantPro.Modules.Vendors.Views.VendorManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7B8;"/><Run Text=" Vendors"/></TextBlock>
            <TextBlock Text="Maintain supplier profiles, contact details, and ledger access for purchasing."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Search bar -->
        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FluentSearchTextBoxStyle}"
                     AutomationProperties.Name="Search vendors"
                     h:Watermark.Text="Search vendors by name or GSTIN"/>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}"
                    Style="{StaticResource SearchButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- Two-column layout: list + form -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Vendor list -->
            <DataGrid AutomationProperties.Name="Vendors list" ItemsSource="{Binding Vendors}"
                      SelectedItem="{Binding SelectedVendor}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      h:DataGridLayoutPersistence.Key="VendorsGrid"
                      h:DataGridEmptyState.Icon="&#xE7B8;"
                      h:DataGridEmptyState.Title="No vendors found"
                      h:DataGridEmptyState.Description="Add a vendor to start tracking supplier contacts, ledgers, and purchase activity."
                      HeadersVisibility="Column">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="City" Binding="{Binding City}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTemplateColumn Header="Active" CellTemplate="{StaticResource ActiveToggleCellTemplate}" Width="{StaticResource ColumnWidthQty}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Vendor form -->
            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False"
                          PanningMode="VerticalOnly"
                          Margin="{StaticResource ItemSpacing}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Vendor Name "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding VendorName, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                             AutomationProperties.Name="Vendor name"
                             h:Watermark.Text="Vendor name"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Contact Person" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding ContactPerson, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                             AutomationProperties.Name="Contact person"
                             h:Watermark.Text="Contact person"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Mobile" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1"
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left" MaxLength="15"
                             AutomationProperties.Name="Vendor mobile"
                             h:NumericInput.Scope="TelephoneNumber"
                             h:Watermark.Text="Phone number"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Email" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="6" Grid.Column="1"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                             AutomationProperties.Name="Vendor email"
                             h:Watermark.Text="Email address"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Address" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="8" Grid.Column="1"
                             Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}" MaxLength="300"
                             Style="{StaticResource FluentMultilineTextBoxStyle}"
                             AutomationProperties.Name="Vendor address"
                             h:Watermark.Text="Address line 1"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Address Line 2" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="10" Grid.Column="1"
                             Text="{Binding AddressLine2, UpdateSourceTrigger=PropertyChanged}" MaxLength="300"
                             Style="{StaticResource FluentMultilineTextBoxStyle}"
                             AutomationProperties.Name="Vendor address line 2"
                             h:Watermark.Text="Address line 2 (optional)"/>

                    <TextBlock Grid.Row="12" Grid.Column="0" Text="City" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="12" Grid.Column="1"
                             Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left" MaxLength="100"
                             AutomationProperties.Name="Vendor city"
                             h:Watermark.Text="City"/>

                    <TextBlock Grid.Row="14" Grid.Column="0" Text="State" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="14" Grid.Column="1"
                             Text="{Binding State, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left" MaxLength="50"
                             AutomationProperties.Name="Vendor state"
                             h:Watermark.Text="State"/>

                    <TextBlock Grid.Row="16" Grid.Column="0" Text="Pincode" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="16" Grid.Column="1"
                             Text="{Binding PinCode, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left" MaxLength="6"
                             AutomationProperties.Name="Vendor postal PIN"
                             h:NumericInput.Scope="Digits"
                             h:Watermark.Text="PIN code"/>

                    <TextBlock Grid.Row="18" Grid.Column="0" Text="GSTIN" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="18" Grid.Column="1"
                             Text="{Binding GSTIN, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left" MaxLength="15"
                             AutomationProperties.Name="Vendor GSTIN"
                             h:Watermark.Text="GSTIN"/>

                    <TextBlock Grid.Row="20" Grid.Column="0" Text="PAN" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="20" Grid.Column="1"
                             Text="{Binding PAN, UpdateSourceTrigger=PropertyChanged}"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left" MaxLength="10"
                             AutomationProperties.Name="Vendor PAN"
                             h:Watermark.Text="PAN"/>

                    <TextBlock Grid.Row="22" Grid.Column="0" Text="Transport" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="22" Grid.Column="1"
                             Text="{Binding TransportPreference, UpdateSourceTrigger=PropertyChanged}" MaxLength="100"
                             AutomationProperties.Name="Transport preference"
                             h:Watermark.Text="Preferred transport"/>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="Ledger" Command="{Binding LoadLedgerCommand}"
                    IsEnabled="{Binding IsEditing}"
                    Style="{StaticResource UtilityButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="New Vendor" Command="{Binding NewVendorCommand}"
                    Style="{StaticResource NewButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Save" Command="{Binding SaveCommand}"
                    Style="{StaticResource SaveButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </StackPanel>

        <!-- Ledger overlay panel -->
        <Border Grid.Row="0" Grid.RowSpan="5"
                Background="{StaticResource FluentSolidBackgroundFillColorBase}"
                Visibility="{Binding ShowLedger, Converter={StaticResource BoolToVisibility}}">
            <Grid Margin="{StaticResource PagePadding}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Ledger title -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8A1;"/><Run Text=" Supplier Ledger"/></TextBlock>
                    <Button Grid.Column="1" Content="Close" Command="{Binding CloseLedgerCommand}"
                            Style="{StaticResource CloseButtonStyle}"/>
                </Grid>

                <!-- Summary cards -->
                <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
                    <Border Style="{StaticResource SummaryStatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Opening Balance" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                            <TextBlock Text="{Binding LedgerSummary.OpeningBalance, StringFormat={}{0:C}}" Style="{StaticResource SummaryStatValueTextStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryStatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Total Purchases" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                            <TextBlock Text="{Binding LedgerSummary.TotalPurchases, StringFormat={}{0:C}}" Style="{StaticResource SummaryStatValueTextStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryStatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Total Payments" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                            <TextBlock Text="{Binding LedgerSummary.TotalPayments, StringFormat={}{0:C}}" Style="{StaticResource SummaryStatValueTextStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryStatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Running Balance" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                            <TextBlock Text="{Binding LedgerSummary.RunningBalance, StringFormat={}{0:C}}" Style="{StaticResource SummaryHeadlineValueTextStyle}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SummaryStatCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Credit Limit" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                            <TextBlock Text="{Binding LedgerSummary.CreditLimit, StringFormat={}{0:C}}" Style="{StaticResource SummaryStatValueTextStyle}"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <!-- Ledger entries grid -->
                <DataGrid Grid.Row="2" AutomationProperties.Name="Ledger entries"
                          ItemsSource="{Binding LedgerEntries}"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          HeadersVisibility="Column"
                          IsReadOnly="True"
                          Margin="{StaticResource ItemSpacing}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=dd-MMM-yyyy}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                        <DataGridTextColumn Header="Debit" Binding="{Binding Debit, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Credit" Binding="{Binding Credit, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Balance" Binding="{Binding Balance, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="{StaticResource ColumnWidthPrice}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Messages -->
                <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
                      Margin="{StaticResource FieldLabelSpacing}">
                    <controls:InfoBar Message="{Binding ErrorMessage}"
                                      Severity="Error"
                                      IsOpen="{Binding HasError}"/>
                    <controls:InfoBar Message="{Binding SuccessMessage}"
                                      Severity="Success"
                                      IsOpen="{Binding HasSuccess}"/>
                </Grid>

                <!-- Payment recording form -->
                <Border Grid.Row="4"
                        Style="{StaticResource InlineMoneyActionPanelStyle}"
                        Margin="{StaticResource ItemSpacing}">
                    <StackPanel>
                        <TextBlock Text="Record Payment"
                                   Style="{StaticResource InlineMoneyActionTitleStyle}"/>
                        <WrapPanel Style="{StaticResource InlineMoneyActionCommandRowStyle}">
                            <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="15"
                                     AutomationProperties.Name="Payment amount"
                                     Width="{StaticResource FieldWidthStandard}"
                                     Margin="0,0,8,4"
                                     h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                     h:NumericInput.Scope="Number"
                                     h:NumericInput.IsDecimalOnly="True"
                                     h:Watermark.Text="Payment amount"/>
                            <ComboBox ItemsSource="{Binding PaymentMethods}"
                                      SelectedItem="{Binding PaymentMethod}"
                                      Width="{StaticResource FieldWidthStandard}"
                                      AutomationProperties.Name="Payment method"
                                      Margin="0,0,8,4"/>
                            <Button Content="Record Payment"
                                    Command="{Binding RecordPaymentCommand}"
                                    Style="{StaticResource InlineMoneyActionPrimaryButtonStyle}"/>
                        </WrapPanel>
                        <WrapPanel>
                            <TextBox Text="{Binding PaymentReference, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="100"
                                     AutomationProperties.Name="Payment reference"
                                     Width="{StaticResource FieldWidthStandard}"
                                     Margin="0,0,8,4"
                                     h:Watermark.Text="Payment reference (optional)"/>
                            <TextBox Text="{Binding PaymentNotes, UpdateSourceTrigger=PropertyChanged}"
                                     MaxLength="300"
                                     AutomationProperties.Name="Payment notes"
                                     Width="{StaticResource FieldWidthWide}"
                                     Margin="0,0,0,4"
                                     h:Watermark.Text="Payment notes (optional)"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving vendor changes..."/>
    </Grid>
</UserControl>



