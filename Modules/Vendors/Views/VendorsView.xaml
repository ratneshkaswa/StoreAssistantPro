<UserControl x:Class="StoreAssistantPro.Modules.Vendors.Views.VendorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="OnLoaded">
    <controls:EnterprisePageLayout>

        <!-- ═══ TipBanner ═══ -->
        <controls:EnterprisePageLayout.TipBannerContent>
            <controls:InlineTipBanner
                h:TipBannerAutoState.TipKey="VendorsView.QuickTip"
                h:TipBannerAutoState.ContextKey="Vendors"
                Title="Quick tip"
                TipText="Manage your product vendors. Track GSTIN, payment terms, credit limits and contact details."/>
        </controls:EnterprisePageLayout.TipBannerContent>

        <!-- ═══ Toolbar ═══ -->
        <controls:EnterprisePageLayout.ToolbarContent>
            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="{StaticResource FieldGroupSpacing}">
                <Border Style="{StaticResource SectionCardHeaderStyle}">
                    <WrapPanel>
                        <Button Content="➕ Add Vendor" Command="{Binding ShowAddFormCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" FontWeight="SemiBold"/>
                        <Button Content="✏ Edit" Command="{Binding ShowEditFormCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Button Content="🔄 Toggle Active" Command="{Binding ToggleActiveCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Button Content="🗑 Delete" Command="{Binding DeleteVendorCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Separator Style="{StaticResource FluentSeparatorStyle}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthWide}"
                                 h:Watermark.Text="🔍 Search vendors..."
                                 VerticalContentAlignment="Center"/>
                        <ComboBox SelectedItem="{Binding SelectedActiveFilter, Mode=TwoWay}"
                                  ItemsSource="{Binding ActiveFilterOptions}"
                                  Width="{StaticResource FieldWidthCompact}"
                                  Margin="{StaticResource InlineControlSpacing}"
                                  VerticalAlignment="Center" ToolTip="Filter by status"/>
                        <Button Content="📤 Export" Command="{Binding ExportVendorsCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <TextBlock Text="{Binding VendorCountDisplay}" VerticalAlignment="Center"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   Margin="{StaticResource InlineControlSpacing}"/>
                    </WrapPanel>
                </Border>
            </Border>
        </controls:EnterprisePageLayout.ToolbarContent>

        <!-- ═══ MainContent (star row) · Vendor DataGrid ═══ -->
        <Border Style="{StaticResource SectionCardStyle}" ClipToBounds="True">
            <Grid>
                <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding Vendors}"
                          SelectedItem="{Binding SelectedVendor}"
                          MinHeight="100">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="h:RowHighlight.Level" Value="{Binding HighlightLevel}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="{StaticResource ColumnWidthId}"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Contact" Binding="{Binding ContactPerson}" Width="{StaticResource ColumnWidthStatus}"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="{StaticResource ColumnWidthStatus}"/>
                        <DataGridTextColumn Header="City" Binding="{Binding City}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTemplateColumn Header="GSTIN" Width="{StaticResource ColumnWidthStatus}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding GSTIN}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding GSTIN}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Terms" Binding="{Binding PaymentTerms}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding IsActive, Converter={StaticResource BoolToActiveText}}"
                                            Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <controls:EmptyStateOverlay
                    Icon="🏭"
                    Title="No vendors found"
                    Description="Add your first vendor to track suppliers and purchase terms."
                    ActionText="➕ Add Vendor"
                    ActionCommand="{Binding ShowAddFormCommand}"
                    ItemCount="{Binding Vendors.Count}"/>
            </Grid>
        </Border>

        <!-- ═══ BottomForm ═══ -->
        <controls:EnterprisePageLayout.BottomFormContent>
            <StackPanel>

                <!-- Add Form -->
                <Border Style="{StaticResource FormCardStyle}"
                        Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVisibility}}"
                        h:KeyboardNav.DefaultCommand="{Binding SaveVendorCommand}"
                        h:KeyboardNav.EscapeCommand="{Binding CancelAddCommand}">
                    <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>                            <!-- Header       -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- Name / Contact -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- Phone / Email  -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- GSTIN / Terms  -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- Credit / Bal   -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- Address        -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- City / State   -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- PIN / Notes    -->
                        <RowDefinition Height="Auto"/>                            <!-- Actions        -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                               Text="New Vendor" Style="{StaticResource SectionHeaderStyle}"/>

                    <!-- Name / Contact Person -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Name *"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="2" Grid.Column="1"
                               Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Contact"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="2" Grid.Column="3"
                               Text="{Binding NewContactPerson, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Phone / Email -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="4" Grid.Column="1"
                               Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Email"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="4" Grid.Column="3"
                               Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- GSTIN / Payment Terms -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="GSTIN"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="6" Grid.Column="1" MaxLength="15"
                               Text="{Binding NewGSTIN, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" Text="Pay Terms"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox  Grid.Row="6" Grid.Column="3"
                               SelectedItem="{Binding NewPaymentTerms, Mode=TwoWay}"
                               ItemsSource="{Binding PaymentTermsOptions}"/>

                    <!-- Credit Limit / Opening Balance -->
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Credit Limit"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="8" Grid.Column="1"
                               h:NumericInput.IsDecimalOnly="True"
                               Text="{Binding NewCreditLimit, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="8" Grid.Column="2" Text="Op. Balance"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="8" Grid.Column="3"
                               h:NumericInput.IsDecimalOnly="True"
                               Text="{Binding NewOpeningBalance, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Address (full width) -->
                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Address"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="3"
                               Text="{Binding NewAddress, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- City / State -->
                    <TextBlock Grid.Row="12" Grid.Column="0" Text="City"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="12" Grid.Column="1"
                               Text="{Binding NewCity, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="12" Grid.Column="2" Text="State"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="12" Grid.Column="3"
                               Text="{Binding NewState, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- PIN Code / Notes -->
                    <TextBlock Grid.Row="14" Grid.Column="0" Text="PIN Code"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="14" Grid.Column="1" MaxLength="10"
                               h:NumericInput.IsIntegerOnly="True"
                               Text="{Binding NewPinCode, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="14" Grid.Column="2" Text="Notes"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="14" Grid.Column="3"
                               Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Actions -->
                    <StackPanel Grid.Row="15" Grid.ColumnSpan="4" Orientation="Horizontal"
                                Margin="{StaticResource FormActionBarSpacing}">
                        <Button Content="💾 Save" Command="{Binding SaveVendorCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Content="Cancel" Command="{Binding CancelAddCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Edit Form -->
            <Border Style="{StaticResource FormCardStyle}"
                    Visibility="{Binding IsEditFormVisible, Converter={StaticResource BoolToVisibility}}"
                    h:KeyboardNav.DefaultCommand="{Binding SaveEditCommand}"
                    h:KeyboardNav.EscapeCommand="{Binding CancelEditCommand}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>                            <!-- Header       -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- Name / Contact -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- Phone / Email  -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- GSTIN / Terms  -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- Credit / Bal   -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- Address        -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- City / State   -->
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>                            <!-- PIN / Notes    -->
                        <RowDefinition Height="Auto"/>                            <!-- Actions        -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                               Text="Edit Vendor" Style="{StaticResource SectionHeaderStyle}"/>

                    <!-- Name / Contact Person -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Name *"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="2" Grid.Column="1"
                               Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Contact"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="2" Grid.Column="3"
                               Text="{Binding EditContactPerson, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Phone / Email -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Phone"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="4" Grid.Column="1"
                               Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="Email"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="4" Grid.Column="3"
                               Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- GSTIN / Payment Terms -->
                    <TextBlock Grid.Row="6" Grid.Column="0" Text="GSTIN"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="6" Grid.Column="1" MaxLength="15"
                               Text="{Binding EditGSTIN, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="6" Grid.Column="2" Text="Pay Terms"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <ComboBox  Grid.Row="6" Grid.Column="3"
                               SelectedItem="{Binding EditPaymentTerms, Mode=TwoWay}"
                               ItemsSource="{Binding PaymentTermsOptions}"/>

                    <!-- Credit Limit / Opening Balance -->
                    <TextBlock Grid.Row="8" Grid.Column="0" Text="Credit Limit"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="8" Grid.Column="1"
                               h:NumericInput.IsDecimalOnly="True"
                               Text="{Binding EditCreditLimit, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="8" Grid.Column="2" Text="Op. Balance"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="8" Grid.Column="3"
                               h:NumericInput.IsDecimalOnly="True"
                               Text="{Binding EditOpeningBalance, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Address (full width) -->
                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Address"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="10" Grid.Column="1" Grid.ColumnSpan="3"
                               Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- City / State -->
                    <TextBlock Grid.Row="12" Grid.Column="0" Text="City"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="12" Grid.Column="1"
                               Text="{Binding EditCity, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="12" Grid.Column="2" Text="State"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="12" Grid.Column="3"
                               Text="{Binding EditState, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- PIN Code / Notes -->
                    <TextBlock Grid.Row="14" Grid.Column="0" Text="PIN Code"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="14" Grid.Column="1" MaxLength="10"
                               h:NumericInput.IsIntegerOnly="True"
                               Text="{Binding EditPinCode, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="14" Grid.Column="2" Text="Notes"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox   Grid.Row="14" Grid.Column="3"
                               Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"/>

                    <!-- Actions -->
                    <StackPanel Grid.Row="15" Grid.ColumnSpan="4" Orientation="Horizontal"
                                Margin="{StaticResource FormActionBarSpacing}">
                        <Button Content="💾 Save" Command="{Binding SaveEditCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            </StackPanel>
        </controls:EnterprisePageLayout.BottomFormContent>

    </controls:EnterprisePageLayout>
</UserControl>
