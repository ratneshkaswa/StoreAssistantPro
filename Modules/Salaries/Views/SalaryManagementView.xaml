<UserControl x:Class="StoreAssistantPro.Modules.Salaries.Views.SalaryManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="750" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7EE;"/>
                <Run Text=" Salaries"/>
            </TextBlock>
            <TextBlock Text="Track salary payments, pending payouts, and staff payroll records."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Stat Cards -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL PAID" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalPaid, StringFormat={}{0:C0}}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentSuccess}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="PENDING" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalPending, StringFormat={}{0:C0}}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentWarning}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="UNPAID" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding UnpaidCount}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentError}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalCount}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentAccentDark1}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Style="{StaticResource OperationalEditorSectionCardStyle}" Margin="{StaticResource ItemSpacing}">
            <StackPanel>
                <TextBlock Text="Salary Details" Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                <TextBlock Text="Record salary, attendance, overtime, and incentive details in one payroll editor surface."
                           Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Employee" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EmployeeName, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Employee name" MaxLength="200"
                                 AutomationProperties.Name="Employee name"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Month" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox SelectedIndex="{Binding SelectedMonthIndex}"
                                  AutomationProperties.Name="Month">
                            <ComboBoxItem Content="January"/>
                            <ComboBoxItem Content="February"/>
                            <ComboBoxItem Content="March"/>
                            <ComboBoxItem Content="April"/>
                            <ComboBoxItem Content="May"/>
                            <ComboBoxItem Content="June"/>
                            <ComboBoxItem Content="July"/>
                            <ComboBoxItem Content="August"/>
                            <ComboBoxItem Content="September"/>
                            <ComboBoxItem Content="October"/>
                            <ComboBoxItem Content="November"/>
                            <ComboBoxItem Content="December"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Year" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding YearText, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Salary year" MaxLength="4"
                                 AutomationProperties.Name="Salary year"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Base salary" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding BaseSalaryText, UpdateSourceTrigger=PropertyChanged}"
                                 h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                 h:NumericInput.Scope="Number"
                                 h:NumericInput.IsDecimalOnly="True"
                                 h:Watermark.Text="Base salary" MaxLength="10"
                                 AutomationProperties.Name="Base salary"/>
                    </StackPanel>
                    <StackPanel Grid.Column="8">
                        <TextBlock Text="Advance" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AdvanceText, UpdateSourceTrigger=PropertyChanged}"
                                 h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                 h:NumericInput.Scope="Number"
                                 h:NumericInput.IsDecimalOnly="True"
                                 h:Watermark.Text="Advance amount" MaxLength="10"
                                 AutomationProperties.Name="Advance"/>
                    </StackPanel>
                </Grid>
                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Present" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding PresentDaysText, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Days worked" MaxLength="3"
                                 AutomationProperties.Name="Present days"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Absent" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AbsentDaysText, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Days absent" MaxLength="3"
                                 AutomationProperties.Name="Absent days"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Overtime hours" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding HoursWorkedText, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Hours worked" MaxLength="6"
                                 AutomationProperties.Name="Hours worked"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Incentive" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding IncentiveText, UpdateSourceTrigger=PropertyChanged}"
                                 h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                 h:NumericInput.Scope="Number"
                                 h:NumericInput.IsDecimalOnly="True"
                                 h:Watermark.Text="Incentive amount" MaxLength="10"
                                 AutomationProperties.Name="Incentive"/>
                    </StackPanel>
                    <StackPanel Grid.Column="8" Style="{StaticResource FormActionRowStyle}" VerticalAlignment="Bottom">
                        <Button Content="Clear" Command="{Binding ClearFormCommand}"
                                Style="{StaticResource UtilityButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                                Style="{StaticResource SaveButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FluentSearchTextBoxStyle}"
                     h:Watermark.Text="Search salaries by employee or month"
                     AutomationProperties.Name="Search salaries"/>
        </Grid>

        <!-- Filter Chips -->
        <StackPanel Grid.Row="4" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SegmentedFilterHostStyle}">
                <WrapPanel Style="{StaticResource SegmentedFilterButtonRowStyle}">
                    <Button Content="All" Command="{Binding SetPaidFilterCommand}" CommandParameter="All"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter all">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActivePaidFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Paid" Command="{Binding SetPaidFilterCommand}" CommandParameter="Paid"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter paid">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActivePaidFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Unpaid" Command="{Binding SetPaidFilterCommand}" CommandParameter="Unpaid"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            AutomationProperties.Name="Filter unpaid">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActivePaidFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </WrapPanel>
            </Border>
            <WrapPanel Margin="0,8,0,0">
                <Button Content="{Binding ActivePaidFilter, StringFormat=Status: {0}}"
                        Command="{Binding SetPaidFilterCommand}"
                        CommandParameter="All">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActiveFilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePaidFilter}" Value="All">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </WrapPanel>
            <TextBlock Text="{Binding FilterCountText}" FontSize="11"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource FluentTextTertiary}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="5" AutomationProperties.Name="Salary records"
                  ItemsSource="{Binding Salaries}" SelectedItem="{Binding SelectedSalary}"
                  Style="{StaticResource EnterpriseDataGridStyle}" HeadersVisibility="Column"
                  h:DataGridLayoutPersistence.Key="SalariesGrid"
                  h:DataGridEmptyState.Icon="{StaticResource EmptyStateSalaryIconGlyph}"
                  h:DataGridEmptyState.Title="No salary records found"
                  h:DataGridEmptyState.Description="Create a salary entry or switch the current payment filter to load matching records.">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedSalary}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedSalary}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Mark Paid" Command="{Binding MarkPaidCommand}" CommandParameter="{Binding SelectedSalary}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="EMPLOYEE" Binding="{Binding EmployeeName}"
                                    SortMemberPath="EmployeeName" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="MONTH" Binding="{Binding Month}"
                                    SortMemberPath="Month" Width="90"/>
                <DataGridTextColumn Header="YEAR" Binding="{Binding Year}"
                                    SortMemberPath="Year" Width="60"/>
                <DataGridTextColumn Header="BASE" Binding="{Binding BaseSalary, StringFormat={}{0:C0}}"
                                    SortMemberPath="BaseSalary" Width="90"/>
                <DataGridTextColumn Header="NET PAY" Binding="{Binding NetPay, StringFormat={}{0:C0}}"
                                    SortMemberPath="NetPay" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ABSENT" Binding="{Binding AbsentDays}"
                                    SortMemberPath="AbsentDays" Width="70"/>
                <DataGridTemplateColumn Header="STATUS" Width="80" SortMemberPath="IsPaid">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource BooleanWarningSuccessPillStyle}"
                                    Tag="{Binding IsPaid}"
                                    HorizontalAlignment="Left">
                                <TextBlock Style="{StaticResource PaidStatusPillTextStyle}"
                                           Tag="{Binding IsPaid}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Style="{StaticResource DataGridRowActionPanelStyle}">
                                <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Edit"
                                        AutomationProperties.Name="Edit" Margin="0,0,2,0" Padding="4">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Delete"
                                        AutomationProperties.Name="Delete" Padding="4">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Messages -->
        <Grid Grid.Row="6" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing salary..."/>
    </Grid>
</UserControl>


