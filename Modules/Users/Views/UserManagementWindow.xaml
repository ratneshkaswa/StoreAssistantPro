<Window x:Class="StoreAssistantPro.Modules.Users.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="User Management" Height="480" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Loaded="OnLoaded">
    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="👤 User Management" FontSize="20" FontWeight="Bold" Margin="0,0,0,15"/>

        <!-- User List -->
        <GroupBox Grid.Row="1" Header="Users" Margin="0,0,0,15" Padding="10">
            <DataGrid ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single" Height="100"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Role" Binding="{Binding UserType}" Width="*"/>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                </DataGrid.Columns>
            </DataGrid>
        </GroupBox>

        <!-- Change PIN Form -->
        <GroupBox Grid.Row="2" Header="Change PIN" Margin="0,0,0,10" Padding="10">
            <StackPanel>
                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="New PIN (4 digits)" FontSize="12" Margin="0,0,0,3"/>
                    <PasswordBox x:Name="NewPinBox" MaxLength="4" Padding="6"
                                 PasswordChanged="OnNewPinChanged"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,8">
                    <TextBlock Text="Confirm PIN" FontSize="12" Margin="0,0,0,3"/>
                    <PasswordBox x:Name="ConfirmPinBox" MaxLength="4" Padding="6"
                                 PasswordChanged="OnConfirmPinChanged"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,8"
                            Visibility="{Binding IsMasterPinRequired, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="Master Password (required for Admin)" FontSize="12"
                               Margin="0,0,0,3" Foreground="#D32F2F" FontWeight="SemiBold"/>
                    <PasswordBox x:Name="MasterPinBox" MaxLength="6" Padding="6"
                                 PasswordChanged="OnMasterPinChanged"/>
                </StackPanel>

                <StackPanel Margin="0,0,0,5">
                    <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SuccessMessage}" Foreground="#4CAF50" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                    <Button Content="🔑 Change PIN" Command="{Binding ChangePinCommand}"
                            Padding="16,8" FontSize="13" FontWeight="SemiBold" Margin="0,0,8,0"/>
                    <Button Content="Close" IsCancel="True"
                            Padding="16,8" FontSize="13"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
