<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Users.Views.UsersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="User Management"
        ConfirmCommand="{Binding ChangePinCommand}"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="👤 User Management" Style="{StaticResource DialogTitleStyle}"/>

        <!-- User list — fills available space -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  Margin="{StaticResource ItemSpacing}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="Background"
                            Value="{Binding UserType,
                                    Converter={StaticResource RoleColorConverter},
                                    ConverterParameter=Background}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Role" Binding="{Binding UserType}" Width="*"/>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="{StaticResource ColumnWidthId}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Change PIN — two-column form -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Section header -->
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Change PIN" Style="{StaticResource SectionHeaderStyle}"
                       Margin="0"/>

            <!-- Row 2: New PIN -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="New PIN (4 digits)"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="2" Grid.Column="1"
                         x:Name="NewPinBox" MaxLength="4"
                         PasswordChanged="OnNewPinChanged"/>

            <!-- Row 4: Confirm PIN -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Confirm PIN"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="4" Grid.Column="1"
                         x:Name="ConfirmPinBox" MaxLength="4"
                         PasswordChanged="OnConfirmPinChanged"/>

            <!-- Row 6: Master PIN (conditional) -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Master PIN *"
                       Style="{StaticResource FormRowLabelStyle}"
                       Foreground="{StaticResource FluentError}"
                       Visibility="{Binding IsMasterPinRequired, Converter={StaticResource BoolToVisibility}}"/>
            <PasswordBox Grid.Row="6" Grid.Column="1"
                         x:Name="MasterPinBox" MaxLength="6"
                         PasswordChanged="OnMasterPinChanged"
                         Visibility="{Binding IsMasterPinRequired, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Messages (reserved space prevents layout shift) -->
        <StackPanel Grid.Row="4" MinHeight="{StaticResource MessageAreaMinHeight}"
                    Margin="{StaticResource FieldLabelSpacing}">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                       h:AutoDismiss.IsEnabled="True" h:AutoDismiss.Seconds="4"/>
        </StackPanel>

        <!-- Action buttons — pinned to bottom -->
        <StackPanel Grid.Row="5" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="🔑 Change PIN" Command="{Binding ChangePinCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</core:BaseDialogWindow>
