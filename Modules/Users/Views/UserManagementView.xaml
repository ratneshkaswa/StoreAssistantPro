<UserControl x:Class="StoreAssistantPro.Modules.Users.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE77B;"/><Run Text=" Users"/></TextBlock>
            <TextBlock Text="Control staff accounts, roles, and PIN updates for daily access."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <Grid Grid.Row="1"
              Style="{StaticResource MasterDetailPageGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource MasterDetailListPaneWidth}"/>
                <ColumnDefinition Width="{StaticResource MasterDetailPaneGapWidth}"/>
                <ColumnDefinition Width="{StaticResource MasterDetailEditorPaneWidth}"/>
            </Grid.ColumnDefinitions>

            <!-- User list -->
            <DataGrid AutomationProperties.Name="Users list"
                      Grid.Column="0"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      h:DataGridLayoutPersistence.Key="UsersGrid"
                      h:DataGridEmptyState.Icon="{StaticResource EmptyStateUserIconGlyph}"
                      h:DataGridEmptyState.Title="No users configured"
                      h:DataGridEmptyState.Description="Create staff accounts to manage roles, PIN changes, and access control."
                      HeadersVisibility="Column"
                      Margin="{StaticResource ItemSpacing}">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="Background"
                                Value="{Binding UserType,
                                        Converter={StaticResource RoleColorConverter},
                                        ConverterParameter=Background}"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Role" Binding="{Binding UserType}" Width="*"/>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="{StaticResource ColumnWidthId}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Change PIN editor -->
            <Border Grid.Column="2"
                    Style="{StaticResource OperationalEditorSectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Change PIN"
                               Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                    <TextBlock Text="Update the selected staff member PIN and require the master PIN only when elevated confirmation is needed."
                               Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Text="New PIN (4 digits)"
                                   Style="{StaticResource FormRowLabelStyle}"/>
                        <PasswordBox Grid.Row="0" Grid.Column="1"
                                     AutomationProperties.Name="New PIN"
                                     x:Name="NewPinBox" MaxLength="4"
                                     PasswordChanged="OnNewPinChanged"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Confirm PIN"
                                   Style="{StaticResource FormRowLabelStyle}"/>
                        <PasswordBox Grid.Row="2" Grid.Column="1"
                                     AutomationProperties.Name="Confirm PIN"
                                     x:Name="ConfirmPinBox" MaxLength="4"
                                     PasswordChanged="OnConfirmPinChanged"/>

                        <TextBlock Grid.Row="4" Grid.Column="0"
                                   Style="{StaticResource FormRowLabelStyle}"
                                   Visibility="{Binding IsMasterPinRequired, Converter={StaticResource BoolToVisibility}}">
                            <Run Text="Master PIN "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
                        </TextBlock>
                        <PasswordBox Grid.Row="4" Grid.Column="1"
                                     AutomationProperties.Name="Master PIN"
                                     x:Name="MasterPinBox" MaxLength="6"
                                     PasswordChanged="OnMasterPinChanged"
                                     Visibility="{Binding IsMasterPinRequired, Converter={StaticResource BoolToVisibility}}"/>
                    </Grid>

                    <StackPanel Style="{StaticResource FormActionRowStyle}">
                        <Button Content="Change PIN" Command="{Binding ChangePinCommand}"
                                Style="{StaticResource SaveButtonStyle}"
                                IsDefault="True"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Messages (reserved space prevents layout shift) -->
        <Grid Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Updating user PIN..."/>
    </Grid>
</UserControl>

