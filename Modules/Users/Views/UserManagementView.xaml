<UserControl x:Class="StoreAssistantPro.Modules.Users.Views.UserManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE77B;"/><Run Text=" User Management"/></TextBlock>

        <!-- User list — fills available space -->
        <DataGrid AutomationProperties.Name="Users list" Grid.Row="1"
                  ItemsSource="{Binding Users}"
                  SelectedItem="{Binding SelectedUser}"
                  Style="{StaticResource EnterpriseDataGridStyle}"
                  h:DataGridEmptyState.Icon="👥"
                  h:DataGridEmptyState.Title="No users configured"
                  h:DataGridEmptyState.Description="Create staff accounts to manage roles, PIN changes, and access control."
                  HeadersVisibility="Column"
                  Margin="{StaticResource ItemSpacing}">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                    <Setter Property="Background"
                            Value="{Binding UserType,
                                    Converter={StaticResource RoleColorConverter},
                                    ConverterParameter=Background}"/>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Role" Binding="{Binding UserType}" Width="*"/>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="{StaticResource ColumnWidthId}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Change PIN — two-column form -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Section header -->
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Change PIN" Style="{StaticResource SectionHeaderStyle}"
                       Margin="0"/>

            <!-- Row 2: New PIN -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="New PIN (4 digits)"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="2" Grid.Column="1"
                         AutomationProperties.Name="New PIN"
                         x:Name="NewPinBox" MaxLength="4"
                         PasswordChanged="OnNewPinChanged"/>

            <!-- Row 4: Confirm PIN -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Confirm PIN"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="4" Grid.Column="1"
                         AutomationProperties.Name="Confirm PIN"
                         x:Name="ConfirmPinBox" MaxLength="4"
                         PasswordChanged="OnConfirmPinChanged"/>

            <!-- Row 6: Master PIN (conditional) -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Master PIN *"
                       Style="{StaticResource FormRowLabelStyle}"
                       Foreground="{StaticResource FluentError}"
                       Visibility="{Binding IsMasterPinRequired, Converter={StaticResource BoolToVisibility}}"/>
            <PasswordBox Grid.Row="6" Grid.Column="1"
                         AutomationProperties.Name="Master PIN"
                         x:Name="MasterPinBox" MaxLength="6"
                         PasswordChanged="OnMasterPinChanged"
                         Visibility="{Binding IsMasterPinRequired, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Messages (reserved space prevents layout shift) -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasErrorMessage}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccessMessage}"/>
        </Grid>

        <!-- Action buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="Change PIN" Command="{Binding ChangePinCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Updating user PIN..."/>
    </Grid>
</UserControl>
