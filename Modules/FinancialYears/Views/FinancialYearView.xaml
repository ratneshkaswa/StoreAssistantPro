<UserControl x:Class="StoreAssistantPro.Modules.FinancialYears.Views.FinancialYearView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE787;"/><Run Text=" Financial Year"/></TextBlock>

        <!-- Current year display -->
        <Border Grid.Row="1" Margin="{StaticResource ItemSpacing}"
                Background="{StaticResource FluentSubtleBackground}"
                CornerRadius="{StaticResource CornerRadiusMedium}"
                Padding="{StaticResource CardPadding}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Current Financial Year" Style="{StaticResource FormRowLabelStyle}"/>
                <TextBlock Grid.Row="1" Text="{Binding CurrentYear.Name, FallbackValue='Not set'}"
                           FontSize="{StaticResource FontSizeSubtitle}" FontWeight="SemiBold"
                           Foreground="{StaticResource FluentAccentDefault}"
                           Margin="{StaticResource FieldLabelSpacing}"/>
                <TextBlock Grid.Row="2" Foreground="{StaticResource FluentTextSecondary}"
                           FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource FieldLabelSpacing}">
                    <Run Text="Period: "/>
                    <Run Text="{Binding CurrentYear.StartDate, StringFormat=d, FallbackValue='-'}"/>
                    <Run Text=" to "/>
                    <Run Text="{Binding CurrentYear.EndDate, StringFormat=d, FallbackValue='-'}"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- FY history grid -->
        <DataGrid AutomationProperties.Name="Financial years" Grid.Row="2"
                  ItemsSource="{Binding FinancialYears}"
                  SelectedItem="{Binding SelectedYear}"
                  Style="{StaticResource EnterpriseDataGridStyle}"
                  h:DataGridEmptyState.Icon="📅"
                  h:DataGridEmptyState.Title="No financial years configured"
                  h:DataGridEmptyState.Description="Create a financial year to define accounting periods and switch-over history."
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  Margin="{StaticResource ItemSpacing}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Year" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Start" Binding="{Binding StartDate, StringFormat=d}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridTextColumn Header="End" Binding="{Binding EndDate, StringFormat=d}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridCheckBoxColumn Header="Current" Binding="{Binding IsCurrent, Mode=OneWay}" Width="{StaticResource ColumnWidthQty}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Reset confirmation -->
        <Border Grid.Row="3"
                Visibility="{Binding IsConfirmingReset, Converter={StaticResource BoolToVisibility}}"
                Background="{StaticResource FluentErrorBackground}"
                CornerRadius="{StaticResource CornerRadiusMedium}"
                Padding="{StaticResource CardPadding}"
                Margin="{StaticResource ItemSpacing}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="⚠ Reset Billing Numbers?" FontWeight="SemiBold"
                           Foreground="{StaticResource FluentError}"/>
                <TextBlock Grid.Row="1"
                           Text="This will reset all billing counters for the current year. This cannot be undone."
                           TextWrapping="Wrap" Foreground="{StaticResource FluentTextSecondary}"
                           Margin="{StaticResource FieldLabelSpacing}"/>
                <Grid Grid.Row="2" Margin="{StaticResource FieldLabelSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Confirm Reset" Command="{Binding ConfirmResetCommand}"
                            Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelResetCommand}"
                            Style="{StaticResource SecondaryButtonStyle}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Messages + Buttons -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid MinHeight="{StaticResource MessageAreaMinHeight}"
                  Margin="{StaticResource FieldLabelSpacing}">
                <controls:InfoBar Message="{Binding ErrorMessage}"
                                  Severity="Error"
                                  IsOpen="{Binding HasErrorMessage}"/>
                <controls:InfoBar Message="{Binding SuccessMessage}"
                                  Severity="Success"
                                  IsOpen="{Binding HasSuccessMessage}"/>
            </Grid>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right"
                        Margin="{StaticResource FormActionBarSpacing}">
                <Button Content="Create Next Year" Command="{Binding CreateNewYearCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Content="Set as Current" Command="{Binding SetCurrentCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Content="Reset Billing" Command="{Binding ShowResetConfirmationCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </StackPanel>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Updating financial year..."/>
    </Grid>
</UserControl>
