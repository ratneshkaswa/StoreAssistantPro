<UserControl x:Class="StoreAssistantPro.Modules.FinancialYears.Views.FinancialYearView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE787;"/>
                <Run Text=" Financial Year"/>
            </TextBlock>
            <TextBlock Text="Manage accounting periods, switch the current year, and control year-end billing resets."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Current year display -->
        <Border Grid.Row="1"
                Style="{StaticResource AdminSectionHighlightCardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Current Financial Year"
                               Style="{StaticResource AdminSectionTitleStyle}"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource InlineHelpButtonStyle}"
                            h:HelpHint.HelpText="The current financial year controls which accounting period receives new billing activity. Switch it carefully and use billing reset only when your year-end process requires new counters."/>
                </Grid>
                <TextBlock Grid.Row="1"
                           Text="{Binding CurrentYear.Name, FallbackValue='Not set'}"
                           FontSize="{StaticResource FontSizeSubtitle}"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource FluentAccentDefault}"
                           Margin="0,4,0,0"/>
                <TextBlock Grid.Row="2"
                           Style="{StaticResource AdminSectionDescriptionStyle}">
                    <Run Text="Period: "/>
                    <Run Text="{Binding CurrentYear.StartDate, StringFormat=d, FallbackValue='-'}"/>
                    <Run Text=" to "/>
                    <Run Text="{Binding CurrentYear.EndDate, StringFormat=d, FallbackValue='-'}"/>
                </TextBlock>
            </Grid>
        </Border>

        <!-- FY history grid -->
        <DataGrid AutomationProperties.Name="Financial years" Grid.Row="2"
                  ItemsSource="{Binding FinancialYears}"
                  SelectedItem="{Binding SelectedYear}"
                  Style="{StaticResource EnterpriseDataGridStyle}"
                  h:DataGridLayoutPersistence.Key="FinancialYearsGrid"
                  h:DataGridEmptyState.Icon="{StaticResource EmptyStateCalendarIconGlyph}"
                  h:DataGridEmptyState.Title="No financial years configured"
                  h:DataGridEmptyState.Description="Create a financial year to define accounting periods and switch-over history."
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column"
                  CanUserAddRows="False"
                  Margin="{StaticResource ItemSpacing}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Year" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Start" Binding="{Binding StartDate, StringFormat=d}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridTextColumn Header="End" Binding="{Binding EndDate, StringFormat=d}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridCheckBoxColumn Header="Current" Binding="{Binding IsCurrent, Mode=OneWay}" Width="{StaticResource ColumnWidthQty}"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="3"
                Style="{StaticResource WarningCalloutCardStyle}">
            <Grid>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#xE7BA;"
                               Style="{StaticResource WarningCalloutIconStyle}"/>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Reset billing numbers only as part of the approved year-end workflow."
                                   Style="{StaticResource WarningCalloutTitleTextStyle}"/>
                        <TextBlock Text="The shared confirmation dialog appears before reset continues. This action cannot be undone."
                                   Style="{StaticResource WarningCalloutBodyTextStyle}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Messages + Buttons -->
        <Grid Grid.Row="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid MinHeight="{StaticResource MessageAreaMinHeight}"
                  Margin="{StaticResource FieldLabelSpacing}">
                <controls:InfoBar Message="{Binding ErrorMessage}"
                                  Severity="Error"
                                  IsOpen="{Binding HasError}"/>
                <controls:InfoBar Message="{Binding SuccessMessage}"
                                  Severity="Success"
                                  IsOpen="{Binding HasSuccess}"/>
            </Grid>

            <StackPanel Grid.Row="1"
                        Style="{StaticResource FormActionRowStyle}"
                        Margin="{StaticResource FormActionBarSpacing}">
                <Button Content="Create Next Year"
                        Command="{Binding CreateNewYearCommand}"
                        Style="{StaticResource NewButtonStyle}"
                        Margin="{StaticResource InlineControlSpacing}"/>
                <Button Content="Set as Current"
                        Command="{Binding SetCurrentCommand}"
                        Style="{StaticResource SaveButtonStyle}"
                        Margin="{StaticResource InlineControlSpacing}"/>
                <Button Content="Reset Billing"
                        Command="{Binding ShowResetConfirmationCommand}"
                        Style="{StaticResource DeleteButtonStyle}"
                        Margin="{StaticResource InlineControlSpacing}"/>
            </StackPanel>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Updating financial year..."/>
    </Grid>
</UserControl>

