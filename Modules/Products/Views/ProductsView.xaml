<UserControl x:Class="StoreAssistantPro.Modules.Products.Views.ProductsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Loaded="OnLoaded">
    <UserControl.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding ShowAddFormCommand}"/>
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ShowEditFormCommand}"/>
        <KeyBinding Gesture="Ctrl+D" Command="{Binding DuplicateProductCommand}"/>
        <KeyBinding Gesture="Ctrl+I" Command="{Binding ImportProductsCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding ExportProductsCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding DeleteProductCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+Delete" Command="{Binding BulkDeleteProductsCommand}"/>
        <KeyBinding Gesture="Ctrl+Q" Command="{Binding ShowStockAdjustFormCommand}"/>
    </UserControl.InputBindings>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Title          -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: Tip banner     -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: Toolbar        -->
            <RowDefinition Height="Auto"/>  <!-- Row 3: Add form       -->
            <RowDefinition Height="Auto"/>  <!-- Row 4: Edit form      -->
            <RowDefinition Height="Auto"/>  <!-- Row 5: Stock adjust   -->
            <RowDefinition Height="Auto"/>  <!-- Row 6: Messages       -->
            <RowDefinition Height="*"/>     <!-- Row 7: Data area      -->
        </Grid.RowDefinitions>

        <TextBlock Text="Products" Style="{StaticResource PageTitleStyle}"/>

        <!-- Tip banner — standard slot: top of content, below title -->
        <controls:InlineTipBanner Grid.Row="1"
            h:TipBannerAutoState.TipKey="ProductsView.QuickTip"
            h:TipBannerAutoState.ContextKey="Products"
            Title="Quick tip"
            TipText="Use Ctrl+N to add a product from any screen."/>

        <Grid Grid.Row="2" Margin="{StaticResource ToolbarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource FieldWidthWide}"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Margin="{StaticResource InlineControlSpacing}" Grid.Column="0">
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="🔍 Search by name, barcode, or HSN..."
                         VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
            </Grid>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding StockFilterOptions}"
                      SelectedItem="{Binding SelectedStockFilter}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"/>
            <ComboBox Grid.Column="2"
                      ItemsSource="{Binding ActiveFilterOptions}"
                      SelectedItem="{Binding SelectedActiveFilter}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"/>
            <ComboBox Grid.Column="3"
                      ItemsSource="{Binding BrandFilterOptions}"
                      SelectedItem="{Binding SelectedBrandFilter}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"/>
            <ComboBox Grid.Column="4"
                      ItemsSource="{Binding ColorFilterOptions}"
                      SelectedItem="{Binding SelectedColorFilter}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"/>
            <ComboBox Grid.Column="5"
                      ItemsSource="{Binding TaxProfileFilterOptions}"
                      SelectedItem="{Binding SelectedTaxProfileFilter}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"/>
            <ComboBox Grid.Column="6"
                      ItemsSource="{Binding UomFilterOptions}"
                      SelectedItem="{Binding SelectedUomFilter}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"/>
            <Button Grid.Column="7" Content="➕ Add" Command="{Binding ShowAddFormCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.HelpText="Add a new product to inventory"
                    h:HelpHint.Category="Products"
                    Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVisibility}}"/>
            <Button Grid.Column="8" Content="✏️ Edit" Command="{Binding ShowEditFormCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.ShortcutText="Double-click row"
                    h:HelpHint.HelpText="Edit the selected product"
                    h:HelpHint.Category="Products"
                    Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVisibility}}"/>
            <Button Grid.Column="9" Content="📋 Clone" Command="{Binding DuplicateProductCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.ShortcutText="Ctrl+D"
                    h:HelpHint.HelpText="Duplicate the selected product"
                    h:HelpHint.Category="Products"
                    Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVisibility}}"/>
            <Button Grid.Column="10" Content="📦 Adjust" Command="{Binding ShowStockAdjustFormCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.ShortcutText="Ctrl+Q"
                    h:HelpHint.HelpText="Quick stock adjustment for the selected product"
                    h:HelpHint.Category="Products"
                    Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVisibility}}"/>
            <Button Grid.Column="11" Content="📥 Import" Command="{Binding ImportProductsCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.ShortcutText="Ctrl+I"
                    h:HelpHint.HelpText="Import products from CSV file"
                    h:HelpHint.Category="Products"
                    Visibility="{Binding CanManageProducts, Converter={StaticResource BoolToVisibility}}"/>
            <Button Grid.Column="12" Content="📤 Export" Command="{Binding ExportProductsCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.ShortcutText="Ctrl+Shift+E"
                    h:HelpHint.HelpText="Export all products to CSV"
                    h:HelpHint.Category="Products}"/>
            <Button Grid.Column="13" Content="🗑 Delete" Command="{Binding DeleteProductCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.HelpText="Delete the selected product (requires Master PIN)"
                    h:HelpHint.Category="Products"
                    Visibility="{Binding CanDeleteProducts, Converter={StaticResource BoolToVisibility}}"/>
            <Button Grid.Column="14" Content="⚠ Export Low Stock" Command="{Binding ExportLowStockCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.HelpText="Export only low-stock products to CSV"
                    h:HelpHint.Category="Products"/>
            <Button Grid.Column="15" Content="🗑 Bulk Delete" Command="{Binding BulkDeleteProductsCommand}"
                    Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                    h:HelpHint.ShortcutText="Ctrl+Shift+Del"
                    h:HelpHint.HelpText="Delete all selected products (requires Master PIN)"
                    h:HelpHint.Category="Products"
                    Visibility="{Binding CanDeleteProducts, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Inline Add Product Form -->
        <Border Grid.Row="3" Style="{StaticResource FormCardStyle}"
                Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVisibility}}"
                h:KeyboardNav.DefaultCommand="{Binding SaveProductCommand}"
                h:KeyboardNav.EscapeCommand="{Binding CancelAddCommand}"
                h:Motion.SlideFadeReveal="True">
            <StackPanel>
                <TextBlock Text="New Product" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewProductName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Sale Price" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewProductSalePrice, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsDecimalOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Cost Price" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewProductCostPrice, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsDecimalOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Quantity" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewProductQuantity, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsIntegerOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Tax Profile" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding AvailableTaxProfiles}"
                                  SelectedItem="{Binding NewProductTaxProfile}"
                                  DisplayMemberPath="ProfileName"
                                  Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Brand" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding AvailableBrands}"
                                  SelectedItem="{Binding NewProductBrand}"
                                  DisplayMemberPath="Name"
                                  Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="HSN Code" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewProductHSNCode, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="8"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Barcode" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewProductBarcode, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="50"
                                 Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="UOM" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox Text="{Binding NewProductUOM, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Width="{StaticResource FieldWidthCompact}">
                            <ComboBoxItem Content="pcs"/>
                            <ComboBoxItem Content="meters"/>
                            <ComboBoxItem Content="sets"/>
                            <ComboBoxItem Content="pairs"/>
                            <ComboBoxItem Content="dozen"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Min Stock" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewProductMinStockLevel, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsIntegerOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Max Stock" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewProductMaxStockLevel, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsIntegerOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewProductColor, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="50"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}" VerticalAlignment="Bottom">
                        <CheckBox Content="Tax Inclusive"
                                  IsChecked="{Binding NewProductIsTaxInclusive}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}" VerticalAlignment="Bottom">
                        <CheckBox Content="Active"
                                  IsChecked="{Binding NewProductIsActive}"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Save" Command="{Binding SaveProductCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"/>
                            <Button Content="Cancel" Command="{Binding CancelAddCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Inline Edit Product Form -->
        <Border Grid.Row="4" Style="{StaticResource FormCardStyle}"
                Background="{StaticResource FluentSuccessBackground}"
                Visibility="{Binding IsEditFormVisible, Converter={StaticResource BoolToVisibility}}"
                h:KeyboardNav.DefaultCommand="{Binding SaveEditCommand}"
                h:KeyboardNav.EscapeCommand="{Binding CancelEditCommand}"
                h:Motion.SlideFadeReveal="True">
            <StackPanel>
                <TextBlock Text="Edit Product" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditProductName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Sale Price" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditProductSalePrice, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsDecimalOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Cost Price" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditProductCostPrice, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsDecimalOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Quantity" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditProductQuantity, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsIntegerOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Tax Profile" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding AvailableTaxProfiles}"
                                  SelectedItem="{Binding EditProductTaxProfile}"
                                  DisplayMemberPath="ProfileName"
                                  Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Brand" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox ItemsSource="{Binding AvailableBrands}"
                                  SelectedItem="{Binding EditProductBrand}"
                                  DisplayMemberPath="Name"
                                  Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="HSN Code" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditProductHSNCode, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="8"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Barcode" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditProductBarcode, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="50"
                                 Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="UOM" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox Text="{Binding EditProductUOM, UpdateSourceTrigger=PropertyChanged}"
                                  IsEditable="True"
                                  Width="{StaticResource FieldWidthCompact}">
                            <ComboBoxItem Content="pcs"/>
                            <ComboBoxItem Content="meters"/>
                            <ComboBoxItem Content="sets"/>
                            <ComboBoxItem Content="pairs"/>
                            <ComboBoxItem Content="dozen"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Min Stock" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditProductMinStockLevel, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsIntegerOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Max Stock" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditProductMaxStockLevel, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsIntegerOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Color" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditProductColor, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="50"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}" VerticalAlignment="Bottom">
                        <CheckBox Content="Tax Inclusive"
                                  IsChecked="{Binding EditProductIsTaxInclusive}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}" VerticalAlignment="Bottom">
                        <CheckBox Content="Active"
                                  IsChecked="{Binding EditProductIsActive}"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Update" Command="{Binding SaveEditCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"/>
                            <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Inline Stock Adjustment Form -->
        <Border Grid.Row="5" Style="{StaticResource FormCardStyle}"
                Visibility="{Binding IsStockAdjustFormVisible, Converter={StaticResource BoolToVisibility}}"
                h:KeyboardNav.DefaultCommand="{Binding SaveStockAdjustCommand}"
                h:KeyboardNav.EscapeCommand="{Binding CancelStockAdjustCommand}"
                h:Motion.SlideFadeReveal="True">
            <StackPanel>
                <TextBlock Text="Adjust Stock" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Product" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AdjustStockProductName, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Current Qty" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AdjustStockCurrentQty, Mode=OneWay}"
                                 IsReadOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Adjustment (+/−)" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AdjustStockQty, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthCompact}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Reason" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AdjustStockReason, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Adjust" Command="{Binding SaveStockAdjustCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"/>
                            <Button Content="Cancel" Command="{Binding CancelStockAdjustCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="6" Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorMessageStyle}"/>

        <!-- Data area: star-sized, grid fills remaining space -->
        <ScrollViewer Grid.Row="7" VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Loading Indicator -->
                <TextBlock Grid.Row="0" Text="⏳ Loading..." FontSize="{StaticResource FontSizeSectionHeader}"
                           Foreground="{StaticResource FluentTextTertiary}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

                <DataGrid Grid.Row="0"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding Products}"
                          SelectedItem="{Binding SelectedProduct}"
                          SelectionChanged="OnSelectionChanged"
                          MouseDoubleClick="OnDataGridDoubleClick"
                          Sorting="OnSorting">
                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                            <Setter Property="h:RowHighlight.Level" Value="{Binding HighlightLevel}"/>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" SortMemberPath="Id" Width="{StaticResource ColumnWidthId}"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" SortMemberPath="Name" Width="*"/>
                        <DataGridTemplateColumn Header="Brand" SortMemberPath="Brand" Width="{StaticResource ColumnWidthStatus}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Brand.Name}" VerticalAlignment="Center"
                                               ToolTip="{Binding Brand.ProductCount, StringFormat='{}{0} products in this brand'}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Color" Binding="{Binding Color}" SortMemberPath="Color" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTemplateColumn Header="HSN" SortMemberPath="HSNCode" Width="{StaticResource ColumnWidthId}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding HSNCode}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding HSNCode}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Barcode" SortMemberPath="Barcode" Width="{StaticResource ColumnWidthStatus}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Barcode}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               ToolTip="{Binding Barcode}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Sale Price" Binding="{Binding SalePrice, StringFormat=C}" SortMemberPath="SalePrice" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Cost Price" Binding="{Binding CostPrice, StringFormat=C}" SortMemberPath="CostPrice" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTemplateColumn Header="Qty" SortMemberPath="Quantity" Width="{StaticResource ColumnWidthQty}">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="⚠ " Foreground="{StaticResource FluentWarning}"
                                                           FontWeight="Bold" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsActive}" Value="True"/>
                                                                        <Condition Binding="{Binding IsLowStock}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="⬆ " Foreground="{StaticResource FluentError}"
                                                           FontWeight="Bold" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding IsActive}" Value="True"/>
                                                                        <Condition Binding="{Binding IsOverStock}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </MultiDataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding Quantity}" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                        <DataGridTextColumn Header="UOM" Binding="{Binding UOM}" SortMemberPath="UOM" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Min Stock" Binding="{Binding MinStockLevel}" SortMemberPath="MinStockLevel" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Max Stock" Binding="{Binding MaxStockLevel}" SortMemberPath="MaxStockLevel" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Stock Value" Binding="{Binding StockValue, StringFormat=C}" CanUserSort="False" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Margin" Binding="{Binding Margin, StringFormat=C}" CanUserSort="False" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Margin %" Binding="{Binding MarginPercent, StringFormat='{}{0}%'}" CanUserSort="False" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Retail Value" Binding="{Binding RetailValue, StringFormat=C}" CanUserSort="False" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTemplateColumn Header="Tax Incl" CanUserSort="False" Width="{StaticResource ColumnWidthQty}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="✗"/>
                                                <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsTaxInclusive}" Value="True">
                                                        <Setter Property="Text" Value="✓"/>
                                                        <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                                                        <Setter Property="FontWeight" Value="Bold"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Tax Profile" Binding="{Binding TaxProfile.ProfileName}" CanUserSort="False" Width="{StaticResource ColumnWidthStatus}"/>
                        <DataGridTextColumn Header="Status"
                                            Binding="{Binding IsActive, Converter={StaticResource BoolToActiveText}}"
                                            SortMemberPath="IsActive"
                                            Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <controls:EmptyStateOverlay
                    Icon="📦"
                    Title="No products found"
                    Description="Add your first product to start managing inventory."
                    ActionText="➕ Add Product"
                    ActionCommand="{Binding ShowAddFormCommand}"
                    ItemCount="{Binding Products.Count}"/>

                <!-- Paging Controls -->
                <StackPanel Grid.Row="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" Margin="{StaticResource MessageBarSpacing}">
                    <Button Content="◀ Previous" Command="{Binding PreviousPageCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Padding="{StaticResource PagingButtonPadding}"/>
                    <TextBlock Text="{Binding PageDisplay}" VerticalAlignment="Center"
                               FontSize="{StaticResource FontSizeLabel}"
                               Foreground="{StaticResource FluentTextSecondary}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Content="Next ▶" Command="{Binding NextPageCommand}"
                            Style="{StaticResource ToolbarButtonStyle}"
                            Padding="{StaticResource PagingButtonPadding}" Margin="0"/>
                </StackPanel>

                <!-- Product Detail Panel -->
                <Border Grid.Row="2" Style="{StaticResource DetailPanelStyle}"
                        Visibility="{Binding HasSelectedProduct, Converter={StaticResource BoolToVisibility}}"
                        h:Motion.SlideFadeReveal="True">
                    <StackPanel Margin="{StaticResource CompactItemSpacing}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📦 " FontSize="{StaticResource FontSizeBody}"/>
                            <TextBlock Text="{Binding SelectedProduct.Name}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"/>
                            <TextBlock Text=" — " Foreground="{StaticResource FluentTextTertiary}"/>
                            <TextBlock Text="{Binding SelectedProduct.Brand.Name, TargetNullValue='No Brand'}"
                                       Foreground="{StaticResource FluentTextSecondary}"/>
                            <TextBlock Text=" — " Foreground="{StaticResource FluentTextTertiary}"/>
                            <TextBlock Text="{Binding SelectedProduct.SalePrice, StringFormat=C}"
                                       FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Cost: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"/>
                            <TextBlock Text="{Binding SelectedProduct.CostPrice, StringFormat=C}" FontSize="{StaticResource FontSizeLabel}"/>
                            <TextBlock Text="  Margin: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"/>
                            <TextBlock Text="{Binding SelectedProduct.Margin, StringFormat=C}" FontSize="{StaticResource FontSizeLabel}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedProduct.MarginPercent, StringFormat=' ({0}%)'}" FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextSecondary}"/>
                            <TextBlock Text="  Stock: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"/>
                            <TextBlock Text="{Binding SelectedProduct.Quantity}" FontSize="{StaticResource FontSizeLabel}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectedProduct.UOM, StringFormat=' {0}'}" FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextSecondary}"/>
                            <TextBlock Text="  Value: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"/>
                            <TextBlock Text="{Binding SelectedProduct.StockValue, StringFormat=C}" FontSize="{StaticResource FontSizeLabel}" FontWeight="SemiBold"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="Barcode: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"
                                       Visibility="{Binding SelectedProduct.Barcode, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding SelectedProduct.Barcode}" FontSize="{StaticResource FontSizeLabel}"
                                       Visibility="{Binding SelectedProduct.Barcode, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="  HSN: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"
                                       Visibility="{Binding SelectedProduct.HSNCode, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding SelectedProduct.HSNCode}" FontSize="{StaticResource FontSizeLabel}"
                                       Visibility="{Binding SelectedProduct.HSNCode, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="  Color: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"
                                       Visibility="{Binding SelectedProduct.Color, Converter={StaticResource BoolToVisibility}}"/>
                            <TextBlock Text="{Binding SelectedProduct.Color}" FontSize="{StaticResource FontSizeLabel}"
                                       Visibility="{Binding SelectedProduct.Color, Converter={StaticResource BoolToVisibility}}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</UserControl>
