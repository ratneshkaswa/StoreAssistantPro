<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Products.Views.ProductManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Product Management"
        ConfirmCommand="{Binding SaveCommand}"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="&#x1F455; Product Management" Style="{StaticResource DialogTitleStyle}"/>

        <!-- Product grid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Products}"
                  SelectedItem="{Binding SelectedProduct}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  Margin="{StaticResource ItemSpacing}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Type" Binding="{Binding ProductType}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridTextColumn Header="Category" Binding="{Binding Category.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridTextColumn Header="Brand" Binding="{Binding Brand.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridTextColumn Header="Tax" Binding="{Binding Tax.TaxName}" Width="{StaticResource ColumnWidthPrice}"/>
                <DataGridTemplateColumn Header="Active" CellTemplate="{StaticResource ActiveToggleCellTemplate}" Width="{StaticResource ColumnWidthQty}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Form fields -->
        <Grid Grid.Row="2" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                <Run Text="Product Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
            </TextBlock>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="200" h:Watermark.Text="e.g. Shirt, Pant, Kurta"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Product Type"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                <ComboBox ItemsSource="{Binding ProductTypes}"
                          SelectedItem="{Binding SelectedProductType}"
                          Width="{StaticResource FieldWidthStandard}"/>
                <ComboBox ItemsSource="{Binding ProductUnits}"
                          SelectedItem="{Binding SelectedUnit}"
                          Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource InlineControlSpacing}"/>
            </StackPanel>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Category"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="4" Grid.Column="1"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      DisplayMemberPath="Name"
                      Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Brand"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="6" Grid.Column="1"
                      ItemsSource="{Binding Brands}"
                      SelectedItem="{Binding SelectedBrand}"
                      DisplayMemberPath="Name"
                      Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Vendor"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="8" Grid.Column="1"
                      ItemsSource="{Binding Vendors}"
                      SelectedItem="{Binding SelectedVendor}"
                      DisplayMemberPath="Name"
                      Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="10" Grid.Column="0" Text="Tax Rate"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="10" Grid.Column="1"
                      ItemsSource="{Binding Taxes}"
                      SelectedItem="{Binding SelectedTax}"
                      DisplayMemberPath="TaxName"
                      Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="12" Grid.Column="0" Text="GST Group"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <StackPanel Grid.Row="12" Grid.Column="1" Orientation="Horizontal">
                <ComboBox ItemsSource="{Binding TaxGroups}"
                          SelectedItem="{Binding SelectedTaxGroup}"
                          DisplayMemberPath="Name"
                          Width="{StaticResource FieldWidthStandard}"/>
                <ComboBox ItemsSource="{Binding HSNCodes}"
                          SelectedItem="{Binding SelectedHSNCode}"
                          DisplayMemberPath="Code"
                          Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource InlineControlSpacing}"/>
                <CheckBox Content="Override allowed" IsChecked="{Binding OverrideAllowed}"
                          Margin="{StaticResource InlineControlSpacing}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="14" Grid.Column="0" Text="Attributes"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <WrapPanel Grid.Row="14" Grid.Column="1">
                <CheckBox Content="Colour" IsChecked="{Binding SupportsColour}"
                          Margin="{StaticResource InlineControlSpacing}"/>
                <CheckBox Content="Size" IsChecked="{Binding SupportsSize}"
                          Margin="{StaticResource InlineControlSpacing}"/>
                <CheckBox Content="Pattern" IsChecked="{Binding SupportsPattern}"
                          Margin="{StaticResource InlineControlSpacing}"/>
                <CheckBox Content="Type" IsChecked="{Binding SupportsType}"
                          Margin="{StaticResource InlineControlSpacing}"/>
            </WrapPanel>

            <TextBlock Grid.Row="16" Grid.Column="0" Grid.ColumnSpan="2"
                       Style="{StaticResource HintTextStyle}"
                       Text="Tax Rate is for quick billing. GST Group + HSN enables enterprise price-based slab resolution."/>

            <TextBlock Grid.Row="18" Grid.Column="0" Grid.ColumnSpan="2"
                       Style="{StaticResource HintTextStyle}"
                       Text="Only enabled attributes will appear during inward entry and billing."/>
        </Grid>

        <!-- Messages -->
        <StackPanel Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
                    Margin="{StaticResource FieldLabelSpacing}">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                       h:AutoDismiss.IsEnabled="True" h:AutoDismiss.Seconds="4"/>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="&#x2795; New" Command="{Binding NewProductCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="&#x1F9E9; Variants" Command="{Binding ManageVariantsCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="&#x1F4BE; Save" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</core:BaseDialogWindow>
