<UserControl x:Class="StoreAssistantPro.Modules.Products.Views.ProductManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
          ScrollViewer.PanningMode="VerticalOnly">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE719;"/><Run Text=" Products"/></TextBlock>
            <TextBlock Text="Manage product master data, pricing, stock context, and supplier links."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Search & Filter Toolbar -->
        <Grid Grid.Row="1" Style="{StaticResource PageToolbarHostStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <WrapPanel Style="{StaticResource PageToolbarContentRowStyle}">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FluentSearchTextBoxStyle}"
                         Width="{StaticResource FieldWidthWide}"
                         h:Watermark.Text="Search products by name or barcode"
                         AutomationProperties.Name="Search products"/>
                <ComboBox ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding FilterCategory}"
                          DisplayMemberPath="Name"
                          AutomationProperties.Name="Filter by category"
                          Width="{StaticResource FieldWidthStandard}"
                          Margin="{StaticResource InlineControlSpacing}"/>
                <ComboBox ItemsSource="{Binding Brands}"
                          SelectedItem="{Binding FilterBrand}"
                          DisplayMemberPath="Name"
                          AutomationProperties.Name="Filter by brand"
                          Width="{StaticResource FieldWidthStandard}"
                          Margin="{StaticResource InlineControlSpacing}"/>
                <ComboBox ItemsSource="{Binding StockStatusOptions}"
                          SelectedItem="{Binding FilterStockStatus}"
                          AutomationProperties.Name="Filter by stock"
                          Width="{StaticResource FieldWidthCompact}"
                          Margin="{StaticResource InlineControlSpacing}"/>
            </WrapPanel>
            <WrapPanel Grid.Column="1" Style="{StaticResource PageToolbarActionRowStyle}">
                <TextBlock Text="{Binding FilterCountText}"
                           Style="{StaticResource PageToolbarMetaTextStyle}"
                           Visibility="{Binding FilterCountText, Converter={StaticResource NonEmptyStringToVisibility}}"/>
                <Button Content="Search" Command="{Binding SearchCommand}"
                        Style="{StaticResource SearchButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Margin="{StaticResource InlineControlSpacing}"
                        Style="{StaticResource ToolbarIconButtonStyle}"
                        ToolTip="Choose columns"
                        AutomationProperties.Name="Choose columns"
                        h:DataGridColumnChooser.Target="{Binding ElementName=ProductsGrid}">
                    <TextBlock Text="&#xE713;"
                               FontFamily="{StaticResource FluentIconFont}"
                               FontSize="14"/>
                </Button>
            </WrapPanel>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource ValidationSummaryCardStyle}"
                Visibility="{Binding HasValidationErrors, Converter={StaticResource BoolToVisibility}}">
            <StackPanel>
                <TextBlock Text="Review these items before saving."
                           Style="{StaticResource ValidationSummaryTitleTextStyle}"/>
                <ItemsControl ItemsSource="{Binding ValidationErrors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="- "
                                           Style="{StaticResource ValidationSummaryItemTextStyle}"/>
                                <TextBlock Text="{Binding}"
                                           Style="{StaticResource ValidationSummaryItemTextStyle}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- DataGrid + Form share the * row -->
        <Grid Grid.Row="3">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto" MaxHeight="320"/>
            </Grid.RowDefinitions>

            <!-- Product grid -->
            <DataGrid x:Name="ProductsGrid"
                      AutomationProperties.Name="Products list"
                      ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      h:DataGridLayoutPersistence.Key="ProductsGrid"
                      h:DataGridEmptyState.Icon="{StaticResource EmptyStateProductIconGlyph}"
                      h:DataGridEmptyState.Title="No products found"
                      h:DataGridEmptyState.Description="Add a product or relax the current brand, category, and stock filters to see more items."
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column" CanUserAddRows="False"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      Margin="{StaticResource ItemSpacing}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                    <DataGridTemplateColumn Header="Type" SortMemberPath="ProductType" Width="{StaticResource ColumnWidthPrice}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SemanticTagChipBorderStyle}"
                                        Background="{Binding ProductType, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Background}"
                                        BorderBrush="{Binding ProductType, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Border}"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding ProductType, TargetNullValue=Unspecified}"
                                               Style="{StaticResource SemanticTagChipTextStyle}"
                                               Foreground="{Binding ProductType, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Foreground}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Category" SortMemberPath="Category.Name" Width="{StaticResource ColumnWidthPrice}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SemanticTagChipBorderStyle}"
                                        Background="{Binding Category.Name, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Background}"
                                        BorderBrush="{Binding Category.Name, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Border}"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Category.Name, TargetNullValue=Uncategorized}"
                                               Style="{StaticResource SemanticTagChipTextStyle}"
                                               Foreground="{Binding Category.Name, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Foreground}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Brand" SortMemberPath="Brand.Name" Width="{StaticResource ColumnWidthPrice}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource SemanticTagChipBorderStyle}"
                                        Background="{Binding Brand.Name, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Background}"
                                        BorderBrush="{Binding Brand.Name, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Border}"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="{Binding Brand.Name, TargetNullValue=Unbranded}"
                                               Style="{StaticResource SemanticTagChipTextStyle}"
                                               Foreground="{Binding Brand.Name, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Foreground}"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Sale" Binding="{Binding SalePrice, StringFormat={}{0:C0}}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="Cost" Binding="{Binding CostPrice, StringFormat={}{0:C0}}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                    <DataGridTextColumn Header="Tax" Binding="{Binding Tax.TaxName}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTemplateColumn Header="Active" CellTemplate="{StaticResource ActiveToggleCellTemplate}" Width="{StaticResource ColumnWidthQty}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Form fields (scrollable when clamped) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False"
                          PanningMode="VerticalOnly"
                          Margin="{StaticResource ItemSpacing}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                <Run Text="Product Name "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
            </TextBlock>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding ProductName, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="200"
                     AutomationProperties.Name="Product name"
                     h:Watermark.Text="Product name"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Product Type"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                <ComboBox ItemsSource="{Binding ProductTypes}"
                          SelectedItem="{Binding SelectedProductType}"
                          AutomationProperties.Name="Product type"
                          Width="{StaticResource FieldWidthStandard}"/>
                <ComboBox ItemsSource="{Binding ProductUnits}"
                          SelectedItem="{Binding SelectedUnit}"
                          AutomationProperties.Name="Product unit"
                          Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource InlineControlSpacing}"/>
            </StackPanel>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="Pricing"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <StackPanel Grid.Row="4" Grid.Column="1" Orientation="Horizontal">
                <TextBox Text="{Binding SalePriceText, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="Sale price" MaxLength="10"
                         h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                         h:NumericInput.Scope="Number"
                         AutomationProperties.Name="Sale price"
                         Width="{StaticResource FieldWidthCompact}"/>
                <TextBox Text="{Binding CostPriceText, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="Cost price" MaxLength="10"
                         h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                         h:NumericInput.Scope="Number"
                         AutomationProperties.Name="Cost price"
                         Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource InlineControlSpacing}"/>
                <CheckBox Content="Tax inclusive" IsChecked="{Binding IsTaxInclusive}"
                          VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
            </StackPanel>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="Barcode"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBox Grid.Row="6" Grid.Column="1"
                     Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                     h:Watermark.Text="EAN-13 or Code128" MaxLength="50"
                     AutomationProperties.Name="Barcode"
                     Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="Category"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="8" Grid.Column="1"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      AutomationProperties.Name="Product category"
                      DisplayMemberPath="Name"
                      Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="10" Grid.Column="0" Text="Brand"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="10" Grid.Column="1"
                      ItemsSource="{Binding Brands}"
                      SelectedItem="{Binding SelectedBrand}"
                      AutomationProperties.Name="Product brand"
                      DisplayMemberPath="Name"
                      Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="12" Grid.Column="0" Text="Vendor"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="12" Grid.Column="1"
                      ItemsSource="{Binding Vendors}"
                      SelectedItem="{Binding SelectedVendor}"
                      AutomationProperties.Name="Preferred vendor"
                      DisplayMemberPath="Name"
                      Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="14" Grid.Column="0" Text="Tax Rate"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="14" Grid.Column="1"
                      ItemsSource="{Binding Taxes}"
                      SelectedItem="{Binding SelectedTax}"
                      AutomationProperties.Name="Tax rate"
                      DisplayMemberPath="TaxName"
                      Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

            <TextBlock Grid.Row="16" Grid.Column="0" Text="GST Group"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <StackPanel Grid.Row="16" Grid.Column="1" Orientation="Horizontal">
                <ComboBox ItemsSource="{Binding TaxGroups}"
                          SelectedItem="{Binding SelectedTaxGroup}"
                          AutomationProperties.Name="GST group"
                          DisplayMemberPath="Name"
                          Width="{StaticResource FieldWidthStandard}"/>
                <ComboBox ItemsSource="{Binding HSNCodes}"
                          SelectedItem="{Binding SelectedHSNCode}"
                          AutomationProperties.Name="HSN code"
                          DisplayMemberPath="Code"
                          Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource InlineControlSpacing}"/>
                <CheckBox Content="Override allowed" IsChecked="{Binding OverrideAllowed}"
                          Margin="{StaticResource InlineControlSpacing}" VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock Grid.Row="18" Grid.Column="0" Text="Attributes"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <WrapPanel Grid.Row="18" Grid.Column="1">
                <CheckBox Content="Colour" IsChecked="{Binding SupportsColour}"
                          Margin="{StaticResource InlineControlSpacing}"/>
                <CheckBox Content="Size" IsChecked="{Binding SupportsSize}"
                          Margin="{StaticResource InlineControlSpacing}"/>
                <CheckBox Content="Pattern" IsChecked="{Binding SupportsPattern}"
                          Margin="{StaticResource InlineControlSpacing}"/>
                <CheckBox Content="Type" IsChecked="{Binding SupportsType}"
                          Margin="{StaticResource InlineControlSpacing}"/>
            </WrapPanel>

                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="4" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Severity="Error"
                              Title="Product issue"
                              Message="{Binding ErrorMessage}"
                              IsOpen="{Binding HasError}"
                              AutomationProperties.LiveSetting="Assertive"
                              AutomationProperties.HelpText="{Binding ErrorMessage}"/>
            <controls:InfoBar Severity="Success"
                              Title="Product saved"
                              Message="{Binding SuccessMessage}"
                              IsOpen="{Binding HasSuccess}"
                              AutomationProperties.LiveSetting="Polite"
                              AutomationProperties.HelpText="{Binding SuccessMessage}"/>
        </Grid>

        <!-- Commit actions -->
        <Border Grid.Row="5"
                Style="{StaticResource StickyFooterActionBarStyle}">
            <DockPanel LastChildFill="False">
                <TextBlock DockPanel.Dock="Left"
                           Text="{Binding DirtyStateSummaryText}"
                           Style="{StaticResource DirtyStateHintTextStyle}"
                           Margin="0"
                           VerticalAlignment="Center"/>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="New Product" Command="{Binding NewProductCommand}"
                            Style="{StaticResource NewButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Content="Variants" Command="{Binding ManageVariantsCommand}"
                            Style="{StaticResource ViewButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Content="Save" Command="{Binding SaveCommand}"
                            Style="{StaticResource SaveButtonStyle}"
                            IsEnabled="{Binding IsDirty}"
                            IsDefault="True"
                            Margin="0"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving product changes..."/>
    </Grid>
</UserControl>


