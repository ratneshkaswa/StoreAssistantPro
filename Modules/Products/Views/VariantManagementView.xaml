<UserControl x:Class="StoreAssistantPro.Modules.Products.Views.VariantManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title + Back -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Messages -->
        </Grid.RowDefinitions>

        <!-- Title row with back navigation -->
        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
            <Button Content="Back to Products" Command="{Binding BackToProductsCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
            <TextBlock Style="{StaticResource PageTitleStyle}" VerticalAlignment="Center">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE71D;"/><Run Text=" Variants - "/><Run Text="{Binding Product.Name, FallbackValue='(no product)'}"/>
            </TextBlock>
        </StackPanel>

        <!-- Two-column: left = variant list + form, right = bulk create -->
            <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid AutomationProperties.Name="Variants list" ItemsSource="{Binding Variants}"
                          SelectedItem="{Binding SelectedVariant}"
                          h:DataGridLayoutPersistence.Key="VariantsGrid"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Size" Binding="{Binding Size.Name}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Colour" Binding="{Binding Colour.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Barcode" Binding="{Binding Barcode}" Width="*"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="+/- Price" Binding="{Binding AdditionalPrice, StringFormat={}{0:G}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTemplateColumn Header="Active" CellTemplate="{StaticResource ActiveToggleCellTemplate}" Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Single variant form -->
                <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Size "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
                    </TextBlock>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              AutomationProperties.Name="Variant size"
                              ItemsSource="{Binding Sizes}"
                              SelectedItem="{Binding SelectedSize}"
                              DisplayMemberPath="Name"
                              Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Colour "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
                    </TextBlock>
                    <ComboBox Grid.Row="2" Grid.Column="1"
                              AutomationProperties.Name="Variant colour"
                              ItemsSource="{Binding Colours}"
                              SelectedItem="{Binding SelectedColour}"
                              DisplayMemberPath="Name"
                              Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Barcode"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1"
                             Text="{Binding Barcode, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Variant barcode"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                             MaxLength="50" h:Watermark.Text="Barcode"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Quantity"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="6" Grid.Column="1"
                             Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Variant quantity"
                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                             MaxLength="8" h:Watermark.Text="Stock quantity"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="+/- Price"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="8" Grid.Column="1"
                             Text="{Binding AdditionalPrice, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Variant additional price"
                             Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                             MaxLength="10" h:Watermark.Text="Additional price"/>
                </Grid>

                <!-- Buttons -->
                <Grid Grid.Row="2" Margin="{StaticResource FormActionBarSpacing}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="1" Grid.ColumnSpan="3" Style="{StaticResource FormActionRowStyle}">
                        <Button Content="Clear" Command="{Binding ClearFormCommand}"
                                Style="{StaticResource UtilityButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="Delete" Command="{Binding DeleteCommand}"
                                Style="{StaticResource DeleteButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="Save" Command="{Binding SaveCommand}"
                                Style="{StaticResource SaveButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    </StackPanel>
                </Grid>
            </Grid>            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Bulk Create" Style="{StaticResource SectionHeaderStyle}"/>

                <TextBlock Grid.Row="1" Text="Sizes" Style="{StaticResource FormRowLabelStyle}"
                           Margin="{StaticResource StepContentTopSpacing}"/>
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="False"
                              PanningMode="VerticalOnly">
                    <ItemsControl ItemsSource="{Binding BulkSizes}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected}"
                                          Margin="{StaticResource CheckListItemSpacing}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock Grid.Row="3" Text="Colours" Style="{StaticResource FormRowLabelStyle}"
                           Margin="{StaticResource StepContentTopSpacing}"/>
                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Focusable="False"
                              PanningMode="VerticalOnly">
                    <ItemsControl ItemsSource="{Binding BulkColours}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <CheckBox Content="{Binding DisplayName}"
                                          IsChecked="{Binding IsSelected}"
                                          Margin="{StaticResource CheckListItemSpacing}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Button Grid.Row="5"
                        Content="Bulk Create"
                        Command="{Binding BulkCreateCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Stretch"
                        Margin="{StaticResource FormActionBarSpacing}"/>
            </Grid>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving variants..."/>
    </Grid>
</UserControl>

