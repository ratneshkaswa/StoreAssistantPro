<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Tasks.Views.TaskManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="Task Management"
        ConfirmCommand="{Binding SaveCommand}"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource DialogTitleStyle}">
            <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE9D5;"/>
            <Run Text=" Task Management"/>
        </TextBlock>

        <!-- Stat Cards -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="PENDING" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PendingCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentWarning}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="IN PROGRESS" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding InProgressCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentAccentDefault}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="COMPLETED" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding CompletedCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentSuccess}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="TOTAL" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentAccentDark1}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Style="{StaticResource FormCardStyle}" Margin="{StaticResource ItemSpacing}">
            <StackPanel>
                <TextBlock Text="Add new task" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Title" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding TaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Task title" MaxLength="200"
                                 AutomationProperties.Name="Task title"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Assigned To" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AssignedTo, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Person name" MaxLength="100"
                                 AutomationProperties.Name="Assigned to"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Due Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding DueDate}"
                                    AutomationProperties.Name="Due date"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Priority" Style="{StaticResource FieldLabelStyle}"/>
                        <ComboBox SelectedIndex="{Binding SelectedPriorityIndex}"
                                  AutomationProperties.Name="Priority">
                            <ComboBoxItem Content="Low"/>
                            <ComboBoxItem Content="Medium"/>
                            <ComboBoxItem Content="High"/>
                        </ComboBox>
                    </StackPanel>
                </Grid>
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="Description" Style="{StaticResource FieldLabelStyle}"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Optional description" MaxLength="500"
                             AcceptsReturn="False" TextWrapping="Wrap" MinHeight="48"
                             AutomationProperties.Name="Task description"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Clear" Command="{Binding ClearFormCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     h:Watermark.Text="Search tasks by title, assigned to, or description"
                     AutomationProperties.Name="Search tasks"/>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- Filter Chips -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="{StaticResource ItemSpacing}">
            <Button Content="All" Command="{Binding SetDateFilterCommand}" CommandParameter="All"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter all"/>
            <Button Content="Today" Command="{Binding SetDateFilterCommand}" CommandParameter="Today"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter today"/>
            <Button Content="This Week" Command="{Binding SetDateFilterCommand}" CommandParameter="Week"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter this week"/>
            <Button Content="This Month" Command="{Binding SetDateFilterCommand}" CommandParameter="Month"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,8,0" AutomationProperties.Name="Filter this month"/>
            <Rectangle Width="1" Fill="{StaticResource FluentStrokeDefault}" Margin="4,4"/>
            <Button Content="Pending" Command="{Binding SetStatusFilterCommand}" CommandParameter="Pending"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="8,0,4,0" AutomationProperties.Name="Filter pending"/>
            <Button Content="In Progress" Command="{Binding SetStatusFilterCommand}" CommandParameter="In Progress"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter in progress"/>
            <Button Content="Completed" Command="{Binding SetStatusFilterCommand}" CommandParameter="Completed"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,8,0" AutomationProperties.Name="Filter completed"/>
            <TextBlock Text="{Binding FilterCountText}" FontSize="11"
                       Foreground="{StaticResource FluentTextTertiary}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="5" AutomationProperties.Name="Tasks list"
                  ItemsSource="{Binding Tasks}" SelectedItem="{Binding SelectedTask}"
                  Style="{StaticResource EnterpriseDataGridStyle}" HeadersVisibility="Column">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Copy" Command="{Binding CopyCommand}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE8C8;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedTask}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedTask}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Mark Pending" Command="{Binding MarkPendingCommand}" CommandParameter="{Binding SelectedTask}"/>
                    <MenuItem Header="Mark In Progress" Command="{Binding MarkInProgressCommand}" CommandParameter="{Binding SelectedTask}"/>
                    <MenuItem Header="Mark Completed" Command="{Binding MarkCompletedCommand}" CommandParameter="{Binding SelectedTask}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="CREATED" Binding="{Binding CreatedAt, StringFormat=dd-MMM-yyyy}" Width="100"/>
                <DataGridTextColumn Header="TITLE" Binding="{Binding Title}" Width="*"/>
                <DataGridTextColumn Header="ASSIGNED TO" Binding="{Binding AssignedTo}" Width="120"/>
                <DataGridTextColumn Header="DUE DATE" Binding="{Binding DueDateDisplay}" Width="110"/>
                <DataGridTemplateColumn Header="PRIORITY" Width="90" SortMemberPath="Priority">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource FluentControlFillTertiary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Priority}" Value="High">
                                                <Setter Property="Background" Value="{StaticResource FluentErrorBackground}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Priority}" Value="Medium">
                                                <Setter Property="Background" Value="{StaticResource FluentWarningBackground}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Priority}" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Priority}" Value="High">
                                                    <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="Medium">
                                                    <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Priority}" Value="Low">
                                                    <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="STATUS" Width="110" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource FluentControlFillTertiary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                <Setter Property="Background" Value="{StaticResource FluentWarningBackground}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="In Progress">
                                                <Setter Property="Background" Value="{StaticResource FluentInfoBackground}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                    <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="In Progress">
                                                    <Setter Property="Foreground" Value="{StaticResource FluentInfo}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                    <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Edit"
                                        AutomationProperties.Name="Edit" Margin="0,0,2,0" Padding="4">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Delete"
                                        AutomationProperties.Name="Delete" Padding="4">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Messages -->
        <Grid Grid.Row="6" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <!-- Footer Buttons -->
        <StackPanel Grid.Row="7" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing task..."/>
    </Grid>
</core:BaseDialogWindow>
