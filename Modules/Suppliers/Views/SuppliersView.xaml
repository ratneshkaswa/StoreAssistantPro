<UserControl x:Class="StoreAssistantPro.Modules.Suppliers.Views.SuppliersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="800"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Title          -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: Tip banner     -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: Toolbar        -->
            <RowDefinition Height="Auto"/>  <!-- Row 3: Add form       -->
            <RowDefinition Height="Auto"/>  <!-- Row 4: Edit form      -->
            <RowDefinition Height="Auto"/>  <!-- Row 5: Messages       -->
            <RowDefinition Height="*"/>     <!-- Row 6: Data area      -->
        </Grid.RowDefinitions>

        <TextBlock Text="Suppliers" Style="{StaticResource PageTitleStyle}"/>

        <controls:InlineTipBanner Grid.Row="1"
            h:TipBannerAutoState.TipKey="SuppliersView.QuickTip"
            h:TipBannerAutoState.ContextKey="Suppliers"
            Title="Quick tip"
            TipText="Manage your product suppliers and vendors."/>

        <!-- Toolbar -->
        <WrapPanel Grid.Row="2" Margin="{StaticResource ToolbarSpacing}">
            <Button Content="➕ Add Supplier" Command="{Binding ShowAddFormCommand}"
                    Style="{StaticResource ToolbarButtonStyle}" FontWeight="SemiBold"/>
            <Button Content="✏ Edit" Command="{Binding ShowEditFormCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"/>
            <Button Content="🗑 Delete" Command="{Binding DeleteSupplierCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Width="{StaticResource FieldWidthWide}"
                     h:Watermark.Text="🔍 Search suppliers..."
                     VerticalContentAlignment="Center"/>
            <ComboBox SelectedItem="{Binding SelectedActiveFilter, Mode=TwoWay}"
                      ItemsSource="{Binding ActiveFilterOptions}"
                      Width="{StaticResource FieldWidthCompact}"
                      Margin="{StaticResource InlineControlSpacing}"
                      VerticalAlignment="Center" ToolTip="Filter by status"/>
            <Button Content="📤 Export" Command="{Binding ExportSuppliersCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"/>
        </WrapPanel>

        <!-- Add Form -->
        <Border Grid.Row="3" Style="{StaticResource FormCardStyle}"
                Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVisibility}}"
                h:KeyboardNav.DefaultCommand="{Binding SaveSupplierCommand}"
                h:KeyboardNav.EscapeCommand="{Binding CancelAddCommand}"
                h:Motion.SlideFadeReveal="True">
            <StackPanel>
                <TextBlock Text="New Supplier" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel Margin="{StaticResource ItemSpacing}">
                    <TextBox Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Name *"
                             Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding NewContactPerson, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Contact Person"
                             Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Phone"
                             Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Email"
                             Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding NewGSTIN, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="GSTIN"
                             Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                </WrapPanel>
                <WrapPanel Margin="{StaticResource ItemSpacing}">
                    <TextBox Text="{Binding NewAddress, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Address"
                             Width="{StaticResource FieldWidthWide}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding NewNotes, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Notes"
                             Width="{StaticResource FieldWidthWide}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="{StaticResource ItemSpacing}">
                    <Button Content="💾 Save" Command="{Binding SaveSupplierCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="Cancel" Command="{Binding CancelAddCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Edit Form -->
        <Border Grid.Row="4" Style="{StaticResource FormCardStyle}"
                Visibility="{Binding IsEditFormVisible, Converter={StaticResource BoolToVisibility}}"
                h:KeyboardNav.DefaultCommand="{Binding SaveEditCommand}"
                h:KeyboardNav.EscapeCommand="{Binding CancelEditCommand}"
                h:Motion.SlideFadeReveal="True">
            <StackPanel>
                <TextBlock Text="Edit Supplier" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel Margin="{StaticResource ItemSpacing}">
                    <TextBox Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Name *"
                             Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding EditContactPerson, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Contact Person"
                             Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding EditPhone, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Phone"
                             Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding EditEmail, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Email"
                             Width="{StaticResource FieldWidthStandard}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding EditGSTIN, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="GSTIN"
                             Width="{StaticResource FieldWidthCompact}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                </WrapPanel>
                <WrapPanel Margin="{StaticResource ItemSpacing}">
                    <TextBox Text="{Binding EditAddress, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Address"
                             Width="{StaticResource FieldWidthWide}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                    <TextBox Text="{Binding EditNotes, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Notes"
                             Width="{StaticResource FieldWidthWide}" Margin="{StaticResource WrapFieldGap}" VerticalContentAlignment="Center"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" Margin="{StaticResource ItemSpacing}">
                    <Button Content="💾 Save" Command="{Binding SaveEditCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                    <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                            Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="5" Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorMessageStyle}"/>

        <!-- Data area -->
        <Grid Grid.Row="6">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="⏳ Loading..." FontSize="{StaticResource FontSizeSectionHeader}"
                       Foreground="{StaticResource FluentTextTertiary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <DataGrid Grid.Row="0"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      ItemsSource="{Binding Suppliers}"
                      SelectedItem="{Binding SelectedSupplier}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="{StaticResource ColumnWidthId}"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Contact" Binding="{Binding ContactPerson}" Width="{StaticResource ColumnWidthStatus}"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="{StaticResource ColumnWidthStatus}"/>
                    <DataGridTemplateColumn Header="Email" Width="{StaticResource ColumnWidthStatus}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Email}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding Email}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="GSTIN" Width="{StaticResource ColumnWidthStatus}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding GSTIN}" VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"
                                           ToolTip="{Binding GSTIN}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding IsActive, Converter={StaticResource BoolToActiveText}}"
                                        Width="{StaticResource ColumnWidthQty}"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="0" Text="🏭  No suppliers found"
                       Foreground="{StaticResource FluentTextTertiary}" FontStyle="Italic"
                       FontSize="{StaticResource FontSizeBody}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Margin="{StaticResource EmptyStatePadding}" IsHitTestVisible="False">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Suppliers.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Detail panel -->
            <Border Grid.Row="1" Style="{StaticResource DetailPanelStyle}"
                    Visibility="{Binding HasSelectedSupplier, Converter={StaticResource BoolToVisibility}}"
                    h:Motion.SlideFadeReveal="True">
                <StackPanel Margin="{StaticResource CompactItemSpacing}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🏭 " FontSize="{StaticResource FontSizeBody}"/>
                        <TextBlock Text="{Binding SelectedSupplier.Name}" FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"/>
                        <TextBlock Text=" — " Foreground="{StaticResource FluentTextTertiary}"/>
                        <TextBlock Text="{Binding SelectedSupplier.ContactPerson, TargetNullValue='No contact'}" Foreground="{StaticResource FluentTextSecondary}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="Phone: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"
                                   Visibility="{Binding SelectedSupplier.Phone, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="{Binding SelectedSupplier.Phone}" FontSize="{StaticResource FontSizeLabel}"
                                   Visibility="{Binding SelectedSupplier.Phone, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="  GSTIN: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"
                                   Visibility="{Binding SelectedSupplier.GSTIN, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="{Binding SelectedSupplier.GSTIN}" FontSize="{StaticResource FontSizeLabel}"
                                   Visibility="{Binding SelectedSupplier.GSTIN, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="  Address: " FontSize="{StaticResource FontSizeLabel}" Foreground="{StaticResource FluentTextTertiary}"
                                   Visibility="{Binding SelectedSupplier.Address, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock Text="{Binding SelectedSupplier.Address}" FontSize="{StaticResource FontSizeLabel}"
                                   Visibility="{Binding SelectedSupplier.Address, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
