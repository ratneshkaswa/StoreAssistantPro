<UserControl x:Class="StoreAssistantPro.Modules.Inventory.Views.InventoryManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7B8;"/><Run Text=" Inventory"/></TextBlock>
            <TextBlock Text="Adjust stock, review movement history, and run controlled stock takes."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Tab selector -->
        <WrapPanel Grid.Row="1"
                   Margin="{StaticResource ItemSpacing}">
            <Button Content="Stock Adjust"
                    Command="{Binding SwitchTabCommand}"
                    CommandParameter="0"
                    Style="{StaticResource SegmentedFilterButtonStyle}"
                    Margin="0,0,4,0">
                <Button.Tag>
                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                        <Binding Path="ActiveTab"/>
                        <Binding Source="0"/>
                    </MultiBinding>
                </Button.Tag>
            </Button>
            <Button Content="Adjustment Log"
                    Command="{Binding SwitchTabCommand}"
                    CommandParameter="1"
                    Style="{StaticResource SegmentedFilterButtonStyle}"
                    Margin="0,0,4,0">
                <Button.Tag>
                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                        <Binding Path="ActiveTab"/>
                        <Binding Source="1"/>
                    </MultiBinding>
                </Button.Tag>
            </Button>
            <Button Content="Alerts"
                    Command="{Binding SwitchTabCommand}"
                    CommandParameter="2"
                    Style="{StaticResource SegmentedFilterButtonStyle}"
                    Margin="0,0,4,0">
                <Button.Tag>
                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                        <Binding Path="ActiveTab"/>
                        <Binding Source="2"/>
                    </MultiBinding>
                </Button.Tag>
            </Button>
            <Button Content="Stock Take"
                    Command="{Binding SwitchTabCommand}"
                    CommandParameter="3"
                    Style="{StaticResource SegmentedFilterButtonStyle}">
                <Button.Tag>
                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                        <Binding Path="ActiveTab"/>
                        <Binding Source="3"/>
                    </MultiBinding>
                </Button.Tag>
            </Button>
        </WrapPanel>

        <!-- Tab 0: Stock Adjustment -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabAdjust, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid AutomationProperties.Name="Stock overview" ItemsSource="{Binding Products}"
                      SelectedItem="{Binding SelectedProduct}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      h:DataGridLayoutPersistence.Key="InventoryStockOverviewGrid"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Category" Binding="{Binding Category.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="Current Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                    <DataGridTextColumn Header="Min Stock" Binding="{Binding MinStockLevel}" Width="{StaticResource ColumnWidthQty}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Adjustment form -->
            <Border Grid.Row="1" Grid.RowSpan="2"
                    Margin="{StaticResource StepContentTopSpacing}"
                    Style="{StaticResource OperationalEditorSectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Stock Adjustment Details"
                               Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                    <TextBlock Text="Update quantity, choose a reason, and keep stock movement history tied to a clear adjustment record."
                               Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                            <Run Text="New Quantity "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
                        </TextBlock>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 AutomationProperties.Name="New quantity"
                                 Text="{Binding NewQuantity, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding HasSelectedProduct}"
                                 Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"
                                 MaxLength="8" h:Watermark.Text="Updated quantity"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                            <Run Text="Reason "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
                        </TextBlock>
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  AutomationProperties.Name="Adjustment reason"
                                  ItemsSource="{Binding Reasons}"
                                  SelectedItem="{Binding SelectedReason}"
                                  IsEnabled="{Binding HasSelectedProduct}"
                                  Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>

                        <TextBlock Grid.Row="4" Grid.Column="0" Text="Notes"
                                   Style="{StaticResource FormRowLabelStyle}"/>
                        <TextBox Grid.Row="4" Grid.Column="1"
                                 AutomationProperties.Name="Adjustment notes"
                                 Text="{Binding AdjustmentNotes, UpdateSourceTrigger=PropertyChanged}"
                                 Style="{StaticResource FluentMultilineTextBoxStyle}"
                                 IsEnabled="{Binding HasSelectedProduct}"
                                 MaxLength="300" h:Watermark.Text="Adjustment reason"/>
                    </Grid>

                    <WrapPanel Style="{StaticResource StateTransitionActionBarStyle}">
                        <Button Content="Import CSV" Command="{Binding ImportCsvCommand}"
                                Style="{StaticResource ImportButtonStyle}"/>
                        <Button Content="Export CSV" Command="{Binding ExportCsvCommand}"
                                Style="{StaticResource ExportButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="View History"
                                Command="{Binding LoadMovementHistoryCommand}"
                                CommandParameter="{Binding SelectedProduct}"
                                IsEnabled="{Binding HasSelectedProduct}"
                                Style="{StaticResource ViewButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="Apply Adjustment" Command="{Binding AdjustCommand}"
                                Style="{StaticResource SaveButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>

            <!-- #73: Stock Movement History panel -->
            <Border Grid.Row="3"
                    Visibility="{Binding HasMovementHistory, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource ReadOnlyInspectionSectionCardStyle}"
                    Margin="{StaticResource ItemSpacing}">
                <StackPanel>
                    <TextBlock Text="Stock Movement History"
                               Style="{StaticResource ReadOnlyInspectionSectionTitleStyle}"/>
                    <TextBlock Text="Review recent quantity changes for the selected product before applying the next adjustment."
                               Style="{StaticResource ReadOnlyInspectionSectionDescriptionStyle}"/>
                    <DataGrid AutomationProperties.Name="Stock movement history"
                              ItemsSource="{Binding StockMovementHistory}"
                              Style="{StaticResource EnterpriseDataGridStyle}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              MaxHeight="{StaticResource ReadOnlyInspectionGridMaxHeight}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=g}" Width="Auto"/>
                            <DataGridTextColumn Header="Type" Binding="{Binding Type}" Width="Auto"/>
                            <DataGridTextColumn Header="Change" Binding="{Binding QuantityChange}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Description" Binding="{Binding Description}" Width="*"/>
                            <DataGridTextColumn Header="Ref" Binding="{Binding Reference}" Width="Auto"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tab 1: Adjustment Log -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabLog, Converter={StaticResource BoolToVisibility}}">
            <DataGrid AutomationProperties.Name="Adjustment log" ItemsSource="{Binding AdjustmentLog}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="*"/>
                    <DataGridTextColumn Header="Old Qty" Binding="{Binding OldQuantity}" Width="{StaticResource ColumnWidthQty}"/>
                    <DataGridTextColumn Header="New Qty" Binding="{Binding NewQuantity}" Width="{StaticResource ColumnWidthQty}"/>
                    <DataGridTextColumn Header="Change" Binding="{Binding QuantityChange}" Width="{StaticResource ColumnWidthQty}"/>
                    <DataGridTextColumn Header="Reason" Binding="{Binding Reason}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="Time" Binding="{Binding Timestamp, StringFormat=g}" Width="{StaticResource ColumnWidthPrice}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

        <!-- Tab 2: Alerts -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabAlerts, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Margin="{StaticResource ItemSpacing}">
                <Run Text="Total Inventory Value: " FontWeight="SemiBold"/>
                <Run Text="{Binding TotalStockValue, Mode=OneWay}" Foreground="{StaticResource FluentAccentDefault}"/>
            </TextBlock>

            <Border Grid.Row="1" Grid.RowSpan="2"
                    Margin="{StaticResource StepContentTopSpacing}"
                    Style="{StaticResource OperationalEditorSectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Out of Stock"
                               Style="{StaticResource OperationalEditorSectionTitleStyle}"
                               Foreground="{StaticResource FluentError}"/>
                    <TextBlock Text="Products with zero available quantity that need replenishment before billing or stock movement can continue."
                               Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                    <DataGrid AutomationProperties.Name="Out of stock products"
                              ItemsSource="{Binding OutOfStockProducts}"
                              Style="{StaticResource EnterpriseDataGridStyle}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              Margin="{StaticResource ItemSpacing}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTextColumn Header="Brand" Binding="{Binding Brand.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="3" Grid.RowSpan="2"
                    Margin="{StaticResource StepContentTopSpacing}"
                    Style="{StaticResource OperationalEditorSectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Low Stock Products"
                               Style="{StaticResource OperationalEditorSectionTitleStyle}"
                               Foreground="{StaticResource FluentWarning}"/>
                    <TextBlock Text="Products approaching their minimum threshold so replenishment decisions can happen before stockouts."
                               Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                    <DataGrid AutomationProperties.Name="Low stock products"
                              ItemsSource="{Binding LowStockProducts}"
                              Style="{StaticResource EnterpriseDataGridStyle}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              Margin="{StaticResource ItemSpacing}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Min" Binding="{Binding MinStockLevel}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="5" Grid.RowSpan="2"
                    Margin="{StaticResource StepContentTopSpacing}"
                    Style="{StaticResource OperationalEditorSectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Low Stock Variants"
                               Style="{StaticResource OperationalEditorSectionTitleStyle}"
                               Foreground="{StaticResource FluentWarning}"/>
                    <TextBlock Text="Variant-level stock risks that may be hidden inside otherwise healthy parent products."
                               Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                    <DataGrid AutomationProperties.Name="Low stock variants"
                              ItemsSource="{Binding LowStockVariants}"
                              Style="{StaticResource EnterpriseDataGridStyle}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              Margin="{StaticResource ItemSpacing}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="*"/>
                            <DataGridTextColumn Header="Size" Binding="{Binding Size.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTextColumn Header="Colour" Binding="{Binding Colour.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <Border Grid.Row="7" Grid.RowSpan="2"
                    Margin="{StaticResource StepContentTopSpacing}"
                    Style="{StaticResource OperationalEditorSectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Dead Stock (90+ days no sale)"
                               Style="{StaticResource OperationalEditorSectionTitleStyle}"
                               Foreground="{StaticResource FluentTextSecondary}"/>
                    <TextBlock Text="Products that have not sold recently and may need review, discounting, or a stocking decision."
                               Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                    <DataGrid AutomationProperties.Name="Dead stock products"
                              ItemsSource="{Binding DeadStockProducts}"
                              Style="{StaticResource EnterpriseDataGridStyle}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              Margin="{StaticResource ItemSpacing}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding Name}" Width="*"/>
                            <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Category" Binding="{Binding Category.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tab 3: Stock Take (#69) -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabStockTake, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Start / recent stock takes -->
            <Border Visibility="{Binding NoActiveStockTake, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource ReadOnlyInspectionSectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Recent Stock Takes"
                               Style="{StaticResource ReadOnlyInspectionSectionTitleStyle}"/>
                    <TextBlock Text="Start a new count or reopen a recent stock take to continue discrepancy review and resolution."
                               Style="{StaticResource ReadOnlyInspectionSectionDescriptionStyle}"/>

                    <WrapPanel Style="{StaticResource StateTransitionActionBarStyle}">
                        <TextBox Text="{Binding StockTakeNotes, UpdateSourceTrigger=PropertyChanged}"
                                 AutomationProperties.Name="Stock take notes"
                                 Style="{StaticResource FluentMultilineTextBoxStyle}"
                                 Width="{StaticResource FieldWidthWide}"
                                 h:Watermark.Text="Count notes (optional)"
                                 MaxLength="500"/>
                        <Button Content="Start New Stock Take" Command="{Binding StartStockTakeCommand}"
                                Style="{StaticResource NewButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    </WrapPanel>

                    <DataGrid AutomationProperties.Name="Recent stock takes"
                              ItemsSource="{Binding RecentStockTakes}"
                              Style="{StaticResource EnterpriseDataGridStyle}"
                              h:DataGridLayoutPersistence.Key="RecentStockTakesGrid"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionMode="Single"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              Margin="{StaticResource ItemSpacing}"
                              MaxHeight="{StaticResource ReadOnlyInspectionGridMaxHeight}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Reference" Binding="{Binding Reference}" Width="{StaticResource ColumnWidthPrice}"/>
                            <DataGridTemplateColumn Header="Status" SortMemberPath="Status" Width="{StaticResource ColumnWidthPrice}">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource SemanticStatusPillStyle}"
                                                Tag="{Binding Status, StringFormat={}{0}}"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusDisplayTextConverter}}"
                                                       Style="{StaticResource SemanticStatusPillTextStyle}"
                                                       Tag="{Binding Status, StringFormat={}{0}}"/>
                                        </Border>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Items" Binding="{Binding TotalItems}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Discrepancies" Binding="{Binding DiscrepancyCount}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Started" Binding="{Binding StartedAt, StringFormat=g}" Width="*"/>
                            <DataGridTemplateColumn Header="Action" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="View" Command="{Binding DataContext.LoadStockTakeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource ViewButtonStyle}"
                                                Padding="8,2" Margin="2"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>

            <!-- Active stock take count grid -->
            <Border Visibility="{Binding HasActiveStockTake, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource OperationalEditorSectionCardStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource OperationalEditorSectionTitleStyle}">
                        <Run Text="Stock Take: "/>
                        <Run Text="{Binding ActiveStockTake.Reference, Mode=OneWay}"/>
                    </TextBlock>
                    <TextBlock Text="Save counted quantities as you work, then complete or cancel the active stock take from the same section."
                               Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                    <DataGrid AutomationProperties.Name="Stock take items"
                              ItemsSource="{Binding StockTakeItems}"
                              Style="{StaticResource EnterpriseDataGridStyle}"
                              h:DataGridLayoutPersistence.Key="StockTakeItemsGrid"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              HeadersVisibility="Column" CanUserAddRows="False"
                              Margin="{StaticResource ItemSpacing}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*" IsReadOnly="True"/>
                            <DataGridTextColumn Header="System Qty" Binding="{Binding SystemQuantity}" Width="{StaticResource ColumnWidthQty}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Counted" Binding="{Binding CountedText}" Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Variance" Binding="{Binding Variance}" Width="{StaticResource ColumnWidthQty}" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Save" Width="Auto">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Button Content="Save" Command="{Binding DataContext.SaveCountCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource SaveButtonStyle}"
                                                Padding="8,2" Margin="2"
                                                ToolTip="Save this count"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <WrapPanel Style="{StaticResource StateTransitionActionBarStyle}">
                        <Button Content="Cancel Stock Take" Command="{Binding CancelStockTakeCommand}"
                                Style="{StaticResource DeleteButtonStyle}"/>
                        <Button Content="Complete Stock Take" Command="{Binding CompleteStockTakeCommand}"
                                Style="{StaticResource SaveButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Updating inventory..."/>
    </Grid>
</UserControl>
