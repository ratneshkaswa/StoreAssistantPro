<UserControl x:Class="StoreAssistantPro.Modules.Expenses.Views.ExpenseManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="700" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}">
            <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7BF;"/>
            <Run Text=" Expense Management"/>
        </TextBlock>

        <!-- Stat Cards -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="BALANCE" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Balance, StringFormat='₹{0:N0}'}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentAccentDefault}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="TOTAL IN" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalDeposits, StringFormat='₹{0:N0}'}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentSuccess}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="TOTAL OUT" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalExpenses, StringFormat='₹{0:N0}'}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentError}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="ENTRIES" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ExpenseCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentAccentDark1}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Style="{StaticResource FormCardStyle}" Margin="{StaticResource ItemSpacing}">
            <StackPanel>
                <TextBlock Text="Add expense" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="e.g. Tea, Travel, Stationery" MaxLength="100"
                                 AutomationProperties.Name="Category"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Amount" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Amount" MaxLength="10"
                                 AutomationProperties.Name="Amount"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding ExpenseDate}"
                                    AutomationProperties.Name="Expense date"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Clear" Command="{Binding ClearFormCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     h:Watermark.Text="Search expenses by category"
                     AutomationProperties.Name="Search expenses"/>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- Filter Chips -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="{StaticResource ItemSpacing}">
            <Button Content="All" Command="{Binding SetDateFilterCommand}" CommandParameter="All"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter all"/>
            <Button Content="Today" Command="{Binding SetDateFilterCommand}" CommandParameter="Today"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter today"/>
            <Button Content="This Week" Command="{Binding SetDateFilterCommand}" CommandParameter="Week"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter this week"/>
            <Button Content="This Month" Command="{Binding SetDateFilterCommand}" CommandParameter="Month"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,8,0" AutomationProperties.Name="Filter this month"/>
            <TextBlock Text="{Binding FilterCountText}" FontSize="11"
                       Foreground="{StaticResource FluentTextTertiary}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="5" AutomationProperties.Name="Expense entries"
                  ItemsSource="{Binding Expenses}" SelectedItem="{Binding SelectedExpense}"
                  Style="{StaticResource EnterpriseDataGridStyle}" HeadersVisibility="Column">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedExpense}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedExpense}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat=dd-MMM-yyyy}"
                                    SortMemberPath="Date" Width="100"/>
                <DataGridTextColumn Header="CATEGORY" Binding="{Binding Category}"
                                    SortMemberPath="Category" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="AMOUNT" Binding="{Binding Amount, StringFormat='₹{0:N0}'}"
                                    SortMemberPath="Amount" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ENTRY" Binding="{Binding CreatedAt, StringFormat='dd-MMM  hh:mm tt'}"
                                    SortMemberPath="CreatedAt" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Edit"
                                        AutomationProperties.Name="Edit" Margin="0,0,2,0" Padding="4">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Delete"
                                        AutomationProperties.Name="Delete" Padding="4">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Messages -->
        <Grid Grid.Row="6" Margin="{StaticResource FieldLabelSpacing}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Paging -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,4,0,4"
                        Visibility="{Binding PagingInfo, Converter={StaticResource NonEmptyStringToVisibility}}">
                <Button Content="◀" Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="8,4" Margin="0,0,4,0"
                        IsEnabled="{Binding HasPreviousPage}" AutomationProperties.Name="Previous page"/>
                <TextBlock Text="{Binding PagingInfo}" VerticalAlignment="Center"
                           FontSize="11" Foreground="{StaticResource FluentTextSecondary}" Margin="4,0"/>
                <Button Content="▶" Command="{Binding NextPageCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="8,4" Margin="4,0,0,0"
                        IsEnabled="{Binding HasNextPage}" AutomationProperties.Name="Next page"/>
            </StackPanel>

            <Grid Grid.Row="1" MinHeight="{StaticResource MessageAreaMinHeight}">
                <controls:InfoBar Message="{Binding ErrorMessage}"
                                  Severity="Error"
                                  IsOpen="{Binding HasError}"/>
                <controls:InfoBar Message="{Binding SuccessMessage}"
                                  Severity="Success"
                                  IsOpen="{Binding HasSuccess}"/>
            </Grid>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing expense..."/>
    </Grid>
</UserControl>
