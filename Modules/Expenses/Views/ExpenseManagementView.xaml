<UserControl x:Class="StoreAssistantPro.Modules.Expenses.Views.ExpenseManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="700" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7BF;"/>
                <Run Text=" Expenses"/>
            </TextBlock>
            <TextBlock Text="Record cash movement, categorize expenses, and review the running balance."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Stat Cards -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="BALANCE" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding Balance, StringFormat={}{0:C0}}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentAccentDefault}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL IN" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalDeposits, StringFormat={}{0:C0}}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentSuccess}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL OUT" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalExpenses, StringFormat={}{0:C0}}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentError}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="ENTRIES" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding ExpenseCount}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentAccentDark1}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Style="{StaticResource OperationalEditorSectionCardStyle}" Margin="{StaticResource ItemSpacing}">
            <StackPanel>
                <TextBlock Text="Expense Details" Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                <TextBlock Text="Record an expense with category, amount, and date so operational spending stays searchable and auditable."
                           Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Category" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding Category, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Expense category" MaxLength="100"
                                 AutomationProperties.Name="Category"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Amount" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}"
                                 h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                 h:Watermark.Text="Amount" MaxLength="10"
                                 AutomationProperties.Name="Amount"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding ExpenseDate}"
                                    AutomationProperties.Name="Expense date"/>
                    </StackPanel>
                </Grid>
                <StackPanel Style="{StaticResource FormActionRowStyle}">
                    <Button Content="Clear" Command="{Binding ClearFormCommand}"
                            Style="{StaticResource UtilityButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                            Style="{StaticResource SaveButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FluentSearchTextBoxStyle}"
                     h:Watermark.Text="Search expenses by category or note"
                     AutomationProperties.Name="Search expenses"/>
        </Grid>

        <!-- Filter Chips -->
        <StackPanel Grid.Row="4" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SegmentedFilterHostStyle}">
                <WrapPanel Style="{StaticResource SegmentedFilterButtonRowStyle}">
                    <Button Content="All" Command="{Binding SetDateFilterCommand}" CommandParameter="All"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter all">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveDateFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Today" Command="{Binding SetDateFilterCommand}" CommandParameter="Today"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter today">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveDateFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="This Week" Command="{Binding SetDateFilterCommand}" CommandParameter="Week"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter this week">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveDateFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="This Month" Command="{Binding SetDateFilterCommand}" CommandParameter="Month"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            AutomationProperties.Name="Filter this month">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveDateFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </WrapPanel>
            </Border>

            <WrapPanel Margin="0,8,0,0">
                    <Button Content="{Binding ActiveDateFilter, StringFormat=Date: {0}}"
                            Command="{Binding SetDateFilterCommand}"
                            CommandParameter="All">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource ActiveFilterChipButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ActiveDateFilter}" Value="All">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
            </WrapPanel>

            <TextBlock Text="{Binding FilterCountText}"
                       FontSize="11"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource FluentTextTertiary}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="5" AutomationProperties.Name="Expense entries"
                  ItemsSource="{Binding Expenses}" SelectedItem="{Binding SelectedExpense}"
                  Style="{StaticResource EnterpriseDataGridStyle}" HeadersVisibility="Column"
                  h:DataGridLayoutPersistence.Key="ExpensesGrid"
                  h:DataGridEmptyState.Icon="{StaticResource EmptyStateExpenseIconGlyph}"
                  h:DataGridEmptyState.Title="No expenses found"
                  h:DataGridEmptyState.Description="Record an expense or widen the current date and search filters to see entries.">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedExpense}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedExpense}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat=dd-MMM-yyyy}"
                                    SortMemberPath="Date" Width="100"/>
                <DataGridTemplateColumn Header="CATEGORY" SortMemberPath="Category" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SemanticTagChipBorderStyle}"
                                    Background="{Binding Category, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Background}"
                                    BorderBrush="{Binding Category, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Border}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Category, TargetNullValue=Uncategorized}"
                                           Style="{StaticResource SemanticTagChipTextStyle}"
                                           Foreground="{Binding Category, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Foreground}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="AMOUNT" Binding="{Binding Amount, StringFormat={}{0:C0}}"
                                    SortMemberPath="Amount" Width="120">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{StaticResource FluentError}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ENTRY" Binding="{Binding CreatedAt, StringFormat='dd-MMM  hh:mm tt'}"
                                    SortMemberPath="CreatedAt" Width="140">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Style="{StaticResource DataGridRowActionPanelStyle}">
                                <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Edit"
                                        AutomationProperties.Name="Edit" Margin="0,0,2,0" Padding="4">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Delete"
                                        AutomationProperties.Name="Delete" Padding="4">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Messages -->
        <Grid Grid.Row="6" Margin="{StaticResource FieldLabelSpacing}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Paging -->
            <StackPanel Style="{StaticResource PaginatorRightAlignedBarStyle}"
                        Visibility="{Binding PagingInfo, Converter={StaticResource NonEmptyStringToVisibility}}">
                <Button Content="Prev" Command="{Binding PreviousPageCommand}"
                        Style="{StaticResource PaginatorNavButtonStyle}" Margin="0,0,4,0"
                        IsEnabled="{Binding HasPreviousPage}" AutomationProperties.Name="Previous page"/>
                <TextBlock Text="{Binding PagingInfo}" VerticalAlignment="Center"
                           Style="{StaticResource PaginatorInfoTextStyle}"/>
                <Button Content="Next" Command="{Binding NextPageCommand}"
                        Style="{StaticResource PaginatorNavButtonStyle}" Margin="4,0,0,0"
                        IsEnabled="{Binding HasNextPage}" AutomationProperties.Name="Next page"/>
            </StackPanel>

            <Grid Grid.Row="1" MinHeight="{StaticResource MessageAreaMinHeight}">
                <controls:InfoBar Message="{Binding ErrorMessage}"
                                  Severity="Error"
                                  IsOpen="{Binding HasError}"/>
                <controls:InfoBar Message="{Binding SuccessMessage}"
                                  Severity="Success"
                                  IsOpen="{Binding HasSuccess}"/>
            </Grid>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing expense..."/>
    </Grid>
</UserControl>


