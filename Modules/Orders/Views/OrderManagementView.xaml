<UserControl x:Class="StoreAssistantPro.Modules.Orders.Views.OrderManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="750" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE719;"/>
                <Run Text=" Orders"/>
            </TextBlock>
            <TextBlock Text="Manage order lifecycle, customer commitments, and delivery progress from one view."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Stat Cards -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="PENDING" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding PendingCount}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentWarning}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="ACTIVE" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding ActiveCount}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentAccentDefault}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="DELIVERED" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding DeliveredCount}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentSuccess}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource SummaryStatCardStyle}">
                <StackPanel>
                    <TextBlock Text="TOTAL" Style="{StaticResource SummaryStatLabelTextStyle}"/>
                    <TextBlock Text="{Binding TotalCount}"
                               Style="{StaticResource SummaryStatValueTextStyle}"
                               Foreground="{StaticResource FluentAccentDark1}"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Style="{StaticResource OperationalEditorSectionCardStyle}" Margin="{StaticResource ItemSpacing}">
            <StackPanel>
                <TextBlock Text="Order Details" Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                <TextBlock Text="Capture customer, item, quantity, pricing, and delivery dates from one shared order editor surface."
                           Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Customer" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Customer name" MaxLength="200"
                                 AutomationProperties.Name="Customer name"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Item" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding ItemDescription, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Item description" MaxLength="500"
                                 AutomationProperties.Name="Item description"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Quantity" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Quantity" MaxLength="6"
                                 AutomationProperties.Name="Quantity"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Rate per item" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding RateText, UpdateSourceTrigger=PropertyChanged}"
                                 h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                                 h:NumericInput.Scope="Number"
                                 h:NumericInput.IsDecimalOnly="True"
                                 h:Watermark.Text="Rate per item" MaxLength="10"
                                 AutomationProperties.Name="Rate per item"/>
                    </StackPanel>
                    <StackPanel Grid.Column="8">
                        <TextBlock Text="Order Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding OrderDate}"
                                    AutomationProperties.Name="Order date"/>
                    </StackPanel>
                    <StackPanel Grid.Column="10">
                        <TextBlock Text="Delivery Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding DeliveryDate}"
                                    AutomationProperties.Name="Delivery date"/>
                    </StackPanel>
                </Grid>
                <StackPanel Style="{StaticResource FormActionRowStyle}">
                    <Button Content="Clear" Command="{Binding ClearFormCommand}"
                            Style="{StaticResource UtilityButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                            Style="{StaticResource SaveButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     Style="{StaticResource FluentSearchTextBoxStyle}"
                     h:Watermark.Text="Search orders by customer or item"
                     AutomationProperties.Name="Search orders"/>
        </Grid>

        <!-- Filter Chips -->
        <StackPanel Grid.Row="4" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource SegmentedFilterHostStyle}">
                <WrapPanel Style="{StaticResource SegmentedFilterButtonRowStyle}">
                    <Button Content="All" Command="{Binding SetStatusFilterCommand}" CommandParameter="All"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter all">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveStatusFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Pending" Command="{Binding SetStatusFilterCommand}" CommandParameter="Pending"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter pending">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveStatusFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Active" Command="{Binding SetStatusFilterCommand}" CommandParameter="Active"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            Margin="0,0,4,0" AutomationProperties.Name="Filter active">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveStatusFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Delivered" Command="{Binding SetStatusFilterCommand}" CommandParameter="Delivered"
                            Style="{StaticResource SegmentedFilterButtonStyle}"
                            AutomationProperties.Name="Filter delivered">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActiveStatusFilter"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </WrapPanel>
            </Border>
            <WrapPanel Margin="0,8,0,0">
                <Button Content="{Binding ActiveStatusFilter, StringFormat=Status: {0}}"
                        Command="{Binding SetStatusFilterCommand}"
                        CommandParameter="All">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActiveFilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActiveStatusFilter}" Value="All">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </WrapPanel>
            <TextBlock Text="{Binding FilterCountText}" FontSize="{StaticResource FontSizeLabel}"
                       Margin="0,8,0,0"
                       Foreground="{StaticResource FluentTextTertiary}"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="5" AutomationProperties.Name="Order list"
                  ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}"
                  Style="{StaticResource EnterpriseDataGridStyle}" HeadersVisibility="Column"
                  h:DataGridLayoutPersistence.Key="OrdersGrid"
                  h:DataGridEmptyState.Icon="{StaticResource EmptyStateOrderIconGlyph}"
                  h:DataGridEmptyState.Title="No orders found"
                  h:DataGridEmptyState.Description="Create an order or change the active filters to bring matching work back into view.">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedOrder}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedOrder}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Mark Delivered" Command="{Binding MarkDeliveredCommand}" CommandParameter="{Binding SelectedOrder}"/>
                    <MenuItem Header="Mark Pending" Command="{Binding MarkPendingCommand}" CommandParameter="{Binding SelectedOrder}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat=dd-MMM-yyyy}"
                                    SortMemberPath="Date" Width="100"/>
                <DataGridTextColumn Header="CUSTOMER" Binding="{Binding CustomerName}"
                                    SortMemberPath="CustomerName" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ITEM" Binding="{Binding ItemDescription}"
                                    SortMemberPath="ItemDescription" Width="*"/>
                <DataGridTextColumn Header="QTY" Binding="{Binding Quantity}"
                                    SortMemberPath="Quantity" Width="60"/>
                <DataGridTextColumn Header="AMOUNT" Binding="{Binding Amount, StringFormat={}{0:C0}}"
                                    SortMemberPath="Amount" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="STATUS" Width="100" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource SemanticStatusPillStyle}"
                                    Tag="{Binding Status, StringFormat={}{0}}"
                                    HorizontalAlignment="Left">
                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusDisplayTextConverter}}"
                                           Style="{StaticResource SemanticStatusPillTextStyle}"
                                           Tag="{Binding Status, StringFormat={}{0}}"/>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="DELIVERY" Binding="{Binding DeliveryDate, StringFormat=dd-MMM-yyyy}"
                                    SortMemberPath="DeliveryDate" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                            <Setter Property="FontSize" Value="{StaticResource FontSizeLabel}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Style="{StaticResource DataGridRowActionPanelStyle}">
                                <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Edit"
                                        AutomationProperties.Name="Edit" Margin="0,0,2,0" Padding="4">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Delete"
                                        AutomationProperties.Name="Delete" Padding="4">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Messages -->
        <Grid Grid.Row="6" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing order..."/>
    </Grid>
</UserControl>


