<UserControl x:Class="StoreAssistantPro.Modules.Orders.Views.OrderManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="750" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}">
            <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE719;"/>
            <Run Text=" Order Management"/>
        </TextBlock>

        <!-- Stat Cards -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="PENDING" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding PendingCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentWarning}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="ACTIVE" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding ActiveCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentAccentDefault}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8" Margin="0,0,8,0">
                <StackPanel>
                    <TextBlock Text="DELIVERED" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding DeliveredCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentSuccess}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource CardStyle}" Padding="12,8">
                <StackPanel>
                    <TextBlock Text="TOTAL" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding TotalCount}" FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource FluentAccentDark1}" Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </WrapPanel>

        <!-- Add/Edit Form -->
        <Border Grid.Row="2" Style="{StaticResource FormCardStyle}" Margin="{StaticResource ItemSpacing}">
            <StackPanel>
                <TextBlock Text="Add order" Style="{StaticResource SectionHeaderStyle}" Margin="0,0,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="100"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="130"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Customer" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Customer name" MaxLength="200"
                                 AutomationProperties.Name="Customer name"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Item" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding ItemDescription, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Item description" MaxLength="500"
                                 AutomationProperties.Name="Item description"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4">
                        <TextBlock Text="Qty" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Qty" MaxLength="6"
                                 AutomationProperties.Name="Quantity"/>
                    </StackPanel>
                    <StackPanel Grid.Column="6">
                        <TextBlock Text="Rate ₹" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding RateText, UpdateSourceTrigger=PropertyChanged}"
                                 h:Watermark.Text="Rate" MaxLength="10"
                                 AutomationProperties.Name="Rate"/>
                    </StackPanel>
                    <StackPanel Grid.Column="8">
                        <TextBlock Text="Order Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding OrderDate}"
                                    AutomationProperties.Name="Order date"/>
                    </StackPanel>
                    <StackPanel Grid.Column="10">
                        <TextBlock Text="Delivery Date" Style="{StaticResource FieldLabelStyle}"/>
                        <DatePicker SelectedDate="{Binding DeliveryDate}"
                                    AutomationProperties.Name="Delivery date"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="Clear" Command="{Binding ClearFormCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    <Button Content="{Binding SaveButtonText}" Command="{Binding SaveCommand}"
                            Style="{StaticResource PrimaryButtonStyle}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Search -->
        <Grid Grid.Row="3" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                     h:Watermark.Text="Search orders by customer or item"
                     AutomationProperties.Name="Search orders"/>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- Filter Chips -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="{StaticResource ItemSpacing}">
            <Button Content="All" Command="{Binding SetStatusFilterCommand}" CommandParameter="All"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter all"/>
            <Button Content="Pending" Command="{Binding SetStatusFilterCommand}" CommandParameter="Pending"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter pending"/>
            <Button Content="Active" Command="{Binding SetStatusFilterCommand}" CommandParameter="Active"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,4,0" AutomationProperties.Name="Filter active"/>
            <Button Content="Delivered" Command="{Binding SetStatusFilterCommand}" CommandParameter="Delivered"
                    Style="{StaticResource SecondaryButtonStyle}" FontSize="11" Padding="12,5"
                    Margin="0,0,8,0" AutomationProperties.Name="Filter delivered"/>
            <TextBlock Text="{Binding FilterCountText}" FontSize="11"
                       Foreground="{StaticResource FluentTextTertiary}" VerticalAlignment="Center"/>
        </StackPanel>

        <!-- DataGrid -->
        <DataGrid Grid.Row="5" AutomationProperties.Name="Order list"
                  ItemsSource="{Binding Orders}" SelectedItem="{Binding SelectedOrder}"
                  Style="{StaticResource EnterpriseDataGridStyle}" HeadersVisibility="Column">
            <DataGrid.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Edit" Command="{Binding EditCommand}" CommandParameter="{Binding SelectedOrder}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Delete" Command="{Binding DeleteCommand}" CommandParameter="{Binding SelectedOrder}">
                        <MenuItem.Icon>
                            <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Mark Delivered" Command="{Binding MarkDeliveredCommand}" CommandParameter="{Binding SelectedOrder}"/>
                    <MenuItem Header="Mark Pending" Command="{Binding MarkPendingCommand}" CommandParameter="{Binding SelectedOrder}"/>
                </ContextMenu>
            </DataGrid.ContextMenu>
            <DataGrid.Columns>
                <DataGridTextColumn Header="DATE" Binding="{Binding Date, StringFormat=dd-MMM-yyyy}"
                                    SortMemberPath="Date" Width="100"/>
                <DataGridTextColumn Header="CUSTOMER" Binding="{Binding CustomerName}"
                                    SortMemberPath="CustomerName" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="ITEM" Binding="{Binding ItemDescription}"
                                    SortMemberPath="ItemDescription" Width="*"/>
                <DataGridTextColumn Header="QTY" Binding="{Binding Quantity}"
                                    SortMemberPath="Quantity" Width="60"/>
                <DataGridTextColumn Header="AMOUNT" Binding="{Binding Amount, StringFormat='₹{0:N0}'}"
                                    SortMemberPath="Amount" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="FontWeight" Value="SemiBold"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="STATUS" Width="100" SortMemberPath="Status">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="4" Padding="6,2" HorizontalAlignment="Left">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource FluentControlFillTertiary}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                <Setter Property="Background" Value="{StaticResource FluentWarningBackground}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Active">
                                                <Setter Property="Background" Value="{StaticResource FluentInfoBackground}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="Delivered">
                                                <Setter Property="Background" Value="{StaticResource FluentSuccessBackground}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}" FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="Pending">
                                                    <Setter Property="Foreground" Value="{StaticResource FluentWarning}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Active">
                                                    <Setter Property="Foreground" Value="{StaticResource FluentInfo}"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="Delivered">
                                                    <Setter Property="Foreground" Value="{StaticResource FluentSuccess}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="DELIVERY" Binding="{Binding DeliveryDate, StringFormat=dd-MMM-yyyy}"
                                    SortMemberPath="DeliveryDate" Width="100">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                            <Setter Property="FontSize" Value="11"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTemplateColumn Header="" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <Button Command="{Binding DataContext.EditCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Edit"
                                        AutomationProperties.Name="Edit" Margin="0,0,2,0" Padding="4">
                                    <TextBlock Text="&#xE70F;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                                <Button Command="{Binding DataContext.DeleteCommand, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource FluentSubtleButtonStyle}" ToolTip="Delete"
                                        AutomationProperties.Name="Delete" Padding="4">
                                    <TextBlock Text="&#xE74D;" FontFamily="{StaticResource FluentIconFont}" FontSize="14"/>
                                </Button>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Messages -->
        <Grid Grid.Row="6" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing order..."/>
    </Grid>
</UserControl>
