<UserControl x:Class="StoreAssistantPro.Modules.Settings.Views.SystemSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE713;"/>
                <Run Text=" System Settings"/>
            </TextBlock>
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Focusable="False"
                      PanningMode="Both">
            <StackPanel Margin="{StaticResource ItemSpacing}"
                        MaxWidth="{StaticResource SettingsDialogContentMaxWidth}"
                        HorizontalAlignment="Center">
                <Border Style="{StaticResource FormCardStyle}" Margin="{StaticResource SectionSpacing}">
                    <StackPanel>
                        <TextBlock Text="Backup &amp; Restore" Style="{StaticResource SectionHeaderStyle}"/>

                        <Grid Margin="{StaticResource ItemSpacing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="{StaticResource SetupFormRowSpacing}"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Margin="{StaticResource ItemSpacing}">
                                <TextBlock x:Name="BackupLocationLabel"
                                           Text="Backup Location"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Text="{Binding BackupLocation, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Backup location"
                                         AutomationProperties.LabeledBy="{Binding ElementName=BackupLocationLabel}"
                                         h:Watermark.Text="Default: app folder\Backups"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="{StaticResource ItemSpacing}">
                                <TextBlock x:Name="BackupTimeLabel"
                                           Text="Backup Time"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Text="{Binding BackupTime, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Daily backup time"
                                         Width="{StaticResource FieldWidthCompact}"
                                         HorizontalAlignment="Left"
                                         IsEnabled="{Binding AutoBackupEnabled}"
                                         AutomationProperties.LabeledBy="{Binding ElementName=BackupTimeLabel}"
                                         h:Watermark.Text="HH:mm"/>
                                <TextBlock Text="{Binding BackupScheduleSummary}"
                                           Margin="{StaticResource ValidationHintMargin}"
                                           Style="{StaticResource HintTextStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <Border Grid.Row="1" Grid.ColumnSpan="3"
                                    Style="{StaticResource SectionCardStyle}"
                                    Margin="{StaticResource ItemSpacing}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="{StaticResource SetupFormRowSpacing}"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0"
                                              IsChecked="{Binding AutoBackupEnabled}"
                                              VerticalAlignment="Top"
                                              AutomationProperties.Name="Enable automatic backup"/>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="Run a backup automatically every day"
                                                   Style="{StaticResource FormRowLabelStyle}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <StackPanel Grid.Row="2" Grid.Column="0" Margin="{StaticResource ItemSpacing}">
                                <TextBlock Text="Backup Now"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Create Backup"
                                            Command="{Binding BackupCommand}"
                                            Style="{StaticResource PrimaryButtonStyle}"
                                            AutomationProperties.Name="Create database backup"/>
                                </StackPanel>
                                <TextBlock Text="{Binding LastBackupSummary}"
                                           Margin="{StaticResource ValidationHintMargin}"
                                           Style="{StaticResource HintTextStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2" Margin="{StaticResource ItemSpacing}">
                                <TextBlock x:Name="RestoreFileLabel"
                                           Text="Restore File"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Text="{Binding RestoreFilePath, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Restore file path"
                                         AutomationProperties.LabeledBy="{Binding ElementName=RestoreFileLabel}"
                                         h:Watermark.Text="Path to .bak file"/>
                                <StackPanel Orientation="Horizontal" Margin="{StaticResource ValidationHintMargin}">
                                    <Button Content="Restore Backup"
                                            Command="{Binding RestoreCommand}"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            AutomationProperties.Name="Restore database from backup"/>
                                </StackPanel>
                                <TextBlock Text="{Binding RestoreStatusText}"
                                           Margin="{StaticResource ValidationHintMargin}"
                                           Style="{StaticResource HintTextStyle}"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource FormCardStyle}" Margin="{StaticResource SectionSpacing}">
                    <StackPanel>
                        <TextBlock Text="Workstation Defaults" Style="{StaticResource SectionHeaderStyle}"/>

                        <Grid Margin="{StaticResource ItemSpacing}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="{StaticResource SetupFormRowSpacing}"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="{StaticResource ItemSpacing}">
                                <TextBlock x:Name="DefaultPrinterLabel"
                                           Text="Default Printer"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Text="{Binding DefaultPrinter, UpdateSourceTrigger=PropertyChanged}"
                                         AutomationProperties.Name="Default printer"
                                         AutomationProperties.LabeledBy="{Binding ElementName=DefaultPrinterLabel}"
                                         h:Watermark.Text="System default"/>
                            </StackPanel>

                            <Border Grid.Column="2"
                                    Style="{StaticResource SectionCardStyle}"
                                    Margin="{StaticResource ItemSpacing}">
                                <StackPanel>
                                    <TextBlock Text="Current workstation summary"
                                               Style="{StaticResource FormRowLabelStyle}"/>
                                    <TextBlock Text="{Binding PrinterSummaryText}"
                                               Style="{StaticResource HintTextStyle}"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding BackupScheduleSummary}"
                                               Margin="{StaticResource ValidationHintMargin}"
                                               Style="{StaticResource HintTextStyle}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2"
              MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Severity="Error"
                              Title="Settings issue"
                              Message="{Binding ErrorMessage}"
                              Visibility="{Binding ErrorMessage, Converter={StaticResource NonEmptyStringToVisibility}}"
                              AutomationProperties.LiveSetting="Assertive"
                              AutomationProperties.HelpText="{Binding ErrorMessage}"/>
            <controls:InfoBar Severity="Success"
                              Title="Settings saved"
                              Message="{Binding SuccessMessage}"
                              Visibility="{Binding SuccessMessage, Converter={StaticResource NonEmptyStringToVisibility}}"
                              AutomationProperties.LiveSetting="Polite"
                              AutomationProperties.HelpText="{Binding SuccessMessage}"/>
        </Grid>

        <StackPanel Grid.Row="3"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="Save Settings"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="{StaticResource InlineControlSpacing}"/>
        </StackPanel>

        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving system settings..."/>
    </Grid>
</UserControl>
