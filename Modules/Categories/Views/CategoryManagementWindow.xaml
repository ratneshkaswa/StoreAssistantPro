<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Categories.Views.CategoryManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="Category Management"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="Auto"/>  <!-- Tab buttons -->
            <RowDefinition Height="*"/>     <!-- Tab content -->
            <RowDefinition Height="Auto"/>  <!-- Messages -->
            <RowDefinition Height="Auto"/>  <!-- Close -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource DialogTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8B7;"/><Run Text=" Category Management"/></TextBlock>

        <!-- Tab selector -->
        <WrapPanel Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Button Content="Category Types" Tag="0" Command="{Binding SwitchTabCommand}" CommandParameter="0"
                    Style="{StaticResource SegmentedButtonStyle}"/>
            <Button Content="Categories" Tag="1" Command="{Binding SwitchTabCommand}" CommandParameter="1"
                    Style="{StaticResource SegmentedButtonStyle}"/>
        </WrapPanel>

        <!-- ═══════════════════════════════════════════════════════════
             Tab 0: Category Types
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabTypes, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid AutomationProperties.Name="Category types" ItemsSource="{Binding CategoryTypes}"
                      SelectedItem="{Binding SelectedType}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Type Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTemplateColumn Header="Active" Width="{StaticResource ColumnWidthQty}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                          IsChecked="{Binding IsActive, Mode=OneWay}"
                                          CommandParameter="{Binding}"
                                          Command="{Binding DataContext.ToggleTypeActiveCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Type Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Column="1"
                         AutomationProperties.Name="Category type name"
                         Text="{Binding TypeName, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                         MaxLength="100" h:Watermark.Text="e.g. Men's Wear"/>
            </Grid>

            <Grid Grid.Row="2" Margin="{StaticResource FormActionBarSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Clear" Command="{Binding ClearTypeFormCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Grid.Column="2" Content="Save" Command="{Binding SaveTypeCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </Grid>
        </Grid>

        <!-- ═══════════════════════════════════════════════════════════
             Tab 1: Categories
             ═══════════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabCategories, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Search -->
            <Grid Margin="{StaticResource ItemSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox AutomationProperties.Name="Category search"
                         Text="{Binding CategorySearchText, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="e.g. Shirts"/>
                <Button Grid.Column="1" Content="Search" Command="{Binding SearchCategoriesCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </Grid>

            <DataGrid AutomationProperties.Name="Categories list" Grid.Row="1"
                      ItemsSource="{Binding Categories}"
                      SelectedItem="{Binding SelectedCategory}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Category" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding CategoryType.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTemplateColumn Header="Active" Width="{StaticResource ColumnWidthQty}">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                          IsChecked="{Binding IsActive, Mode=OneWay}"
                                          CommandParameter="{Binding}"
                                          Command="{Binding DataContext.ToggleCategoryActiveCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="2" Margin="{StaticResource StepContentTopSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Category Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1"
                         AutomationProperties.Name="Category name"
                         Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                         MaxLength="100" h:Watermark.Text="e.g. Shirts"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Type"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <ComboBox Grid.Row="2" Grid.Column="1"
                          AutomationProperties.Name="Category type"
                          ItemsSource="{Binding CategoryTypes}"
                          SelectedItem="{Binding SelectedCategoryType}"
                          DisplayMemberPath="Name"
                          Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>
            </Grid>

            <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Clear" Command="{Binding ClearCategoryFormCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Grid.Column="2" Content="Save" Command="{Binding SaveCategoryCommand}"
                        Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </Grid>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasErrorMessage}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccessMessage}"/>
        </Grid>

        <!-- Close -->
        <Grid Grid.Row="4" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving category changes..."/>
    </Grid>
</core:BaseDialogWindow>
