<UserControl x:Class="StoreAssistantPro.Modules.Categories.Views.CategoryManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <CollectionViewSource x:Key="GroupedCategoriesView"
                              Source="{Binding Categories}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="CategoryType.Name" Direction="Ascending"/>
                <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="CategoryType.Name"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8B7;"/><Run Text=" Categories"/></TextBlock>
            <TextBlock Text="Maintain category types and categories so the product catalogue stays structured."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Tab selector -->
        <WrapPanel Grid.Row="1"
                   Margin="{StaticResource ItemSpacing}">
            <Button Content="Category Types"
                    Command="{Binding SwitchTabCommand}"
                    CommandParameter="0"
                    Style="{StaticResource SegmentedFilterButtonStyle}"
                    Margin="0,0,4,0">
                <Button.Tag>
                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                        <Binding Path="ActiveTab"/>
                        <Binding Source="0"/>
                    </MultiBinding>
                </Button.Tag>
            </Button>
            <Button Content="Categories"
                    Command="{Binding SwitchTabCommand}"
                    CommandParameter="1"
                    Style="{StaticResource SegmentedFilterButtonStyle}">
                <Button.Tag>
                    <MultiBinding Converter="{StaticResource EqualityConverter}">
                        <Binding Path="ActiveTab"/>
                        <Binding Source="1"/>
                    </MultiBinding>
                </Button.Tag>
            </Button>
        </WrapPanel>

        <!-- Tab 0: Category Types -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabTypes, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="CategoryTypesGrid"
                      AutomationProperties.Name="Category types" ItemsSource="{Binding CategoryTypes}"
                      SelectedItem="{Binding SelectedType}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      h:DataGridLayoutPersistence.Key="CategoryTypesGrid"
                      h:DataGridEmptyState.Icon="{StaticResource EmptyStateCategoryIconGlyph}"
                      h:DataGridEmptyState.Title="No category types yet"
                      h:DataGridEmptyState.Description="Create a category type first so products can be grouped into a clear catalogue structure."
                      AutoGenerateColumns="False" IsReadOnly="False"
                      SelectionMode="Extended"
                      h:DataGridMultiSelect.IsEnabled="True"
                      BeginningEdit="OnCategoryTypesGridBeginningEdit"
                      CellEditEnding="OnCategoryTypesGridCellEditEnding"
                      PreviewMouseDoubleClick="OnCategoryTypesGridPreviewMouseDoubleClick"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTemplateColumn x:Name="CategoryTypeNameColumn"
                                            Header="Type Name"
                                            SortMemberPath="Name"
                                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="PencilIcon"
                                               Text="&#xE70F;"
                                               FontFamily="{StaticResource FluentIconFont}"
                                               FontSize="{StaticResource FontSizeIconSmall}"
                                               Foreground="{StaticResource FluentTextTertiary}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Opacity="0"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsMouseOver}"
                                                 Value="True">
                                        <Setter TargetName="PencilIcon" Property="Opacity" Value="0.8"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DataGridInlineEditTextBoxStyle}"
                                         MaxLength="100"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Active"
                                            Width="{StaticResource ColumnWidthQty}"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                          IsChecked="{Binding IsActive, Mode=OneWay}"
                                          CommandParameter="{Binding}"
                                          Command="{Binding DataContext.ToggleTypeActiveCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="1" Grid.RowSpan="2"
                    Margin="{StaticResource StepContentTopSpacing}"
                    Style="{StaticResource OperationalEditorSectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Category Type Details"
                               Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                    <TextBlock Text="Create or update a category type so product classification stays clear and grouped consistently."
                               Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                            <Run Text="Type Name "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
                        </TextBlock>
                        <TextBox Grid.Column="1"
                                 AutomationProperties.Name="Category type name"
                                 Text="{Binding TypeName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                                 MaxLength="100" h:Watermark.Text="Type name"/>
                    </Grid>

                    <StackPanel Style="{StaticResource FormActionRowStyle}">
                        <Button Content="Clear" Command="{Binding ClearTypeFormCommand}"
                                Style="{StaticResource UtilityButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="Save" Command="{Binding SaveTypeCommand}"
                                Style="{StaticResource SaveButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Tab 1: Categories -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabCategories, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="{StaticResource ItemSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBox AutomationProperties.Name="Category search"
                         Style="{StaticResource FluentSearchTextBoxStyle}"
                         Text="{Binding CategorySearchText, UpdateSourceTrigger=PropertyChanged}"
                         h:DebouncedSearch.Command="{Binding SearchCategoriesCommand}"
                         h:Watermark.Text="Search categories by name"/>
            </Grid>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid x:Name="CategoriesGrid"
                          AutomationProperties.Name="Categories list"
                          ItemsSource="{Binding Source={StaticResource GroupedCategoriesView}}"
                          SelectedItem="{Binding SelectedCategory}"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          h:DataGridLayoutPersistence.Key="CategoriesGrid"
                          h:DataGridEmptyState.Icon="{StaticResource EmptyStateCategoryIconGlyph}"
                          h:DataGridEmptyState.Title="No categories found"
                          h:DataGridEmptyState.Description="Add a category or clear the current search to populate this list."
                          AutoGenerateColumns="False" IsReadOnly="False"
                          SelectionMode="Extended"
                          h:DataGridMultiSelect.IsEnabled="True"
                          BeginningEdit="OnCategoriesGridBeginningEdit"
                          CellEditEnding="OnCategoriesGridCellEditEnding"
                          PreviewMouseDoubleClick="OnCategoriesGridPreviewMouseDoubleClick"
                          HeadersVisibility="Column" CanUserAddRows="False">
                    <DataGrid.GroupStyle>
                        <GroupStyle ContainerStyle="{StaticResource DataGridGroupItemStyle}"/>
                    </DataGrid.GroupStyle>
                    <DataGrid.Columns>
                        <DataGridTemplateColumn x:Name="CategoryNameColumn"
                                                Header="Category"
                                                SortMemberPath="Name"
                                                Width="*">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <TextBlock Text="{Binding Name}"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock x:Name="PencilIcon"
                                                   Text="&#xE70F;"
                                                   FontFamily="{StaticResource FluentIconFont}"
                                                   FontSize="{StaticResource FontSizeIconSmall}"
                                                   Foreground="{StaticResource FluentTextTertiary}"
                                                   HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Opacity="0"/>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsMouseOver}"
                                                     Value="True">
                                            <Setter TargetName="PencilIcon" Property="Opacity" Value="0.8"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                            <DataGridTemplateColumn.CellEditingTemplate>
                                <DataTemplate>
                                    <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource DataGridInlineEditTextBoxStyle}"
                                             MaxLength="100"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellEditingTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Type"
                                            Binding="{Binding CategoryType.Name}"
                                            Width="{StaticResource ColumnWidthPrice}"
                                            IsReadOnly="True"/>
                        <DataGridTemplateColumn Header="Active"
                                                Width="{StaticResource ColumnWidthQty}"
                                                IsReadOnly="True">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                              IsChecked="{Binding IsActive, Mode=OneWay}"
                                              CommandParameter="{Binding}"
                                              Command="{Binding DataContext.ToggleCategoryActiveCommand,
                                                        RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1"
                            Style="{StaticResource PaginatorRightAlignedBarStyle}"
                            Visibility="{Binding TotalCount, Converter={StaticResource PositiveToVisibility}}">
                    <Button Content="Prev"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding HasPreviousPage}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding PagingInfo}"
                               VerticalAlignment="Center"
                               Style="{StaticResource PaginatorInfoTextStyle}"/>
                    <Button Content="Next"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNextPage}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Grid.RowSpan="2"
                    Margin="{StaticResource StepContentTopSpacing}"
                    Style="{StaticResource OperationalEditorSectionCardStyle}">
                <StackPanel>
                    <TextBlock Text="Category Details"
                               Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                    <TextBlock Text="Maintain category names and assign them to a type so browsing, filtering, and reporting stay consistent."
                               Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                            <Run Text="Category Name "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
                        </TextBlock>
                        <TextBox Grid.Row="0" Grid.Column="1"
                                 AutomationProperties.Name="Category name"
                                 Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                                 MaxLength="100" h:Watermark.Text="Category name"/>

                        <TextBlock Grid.Row="2" Grid.Column="0" Text="Type"
                                   Style="{StaticResource FormRowLabelStyle}"/>
                        <ComboBox Grid.Row="2" Grid.Column="1"
                                  AutomationProperties.Name="Category type"
                                  ItemsSource="{Binding CategoryTypes}"
                                  SelectedItem="{Binding SelectedCategoryType}"
                                  DisplayMemberPath="Name"
                                  Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>
                    </Grid>

                    <StackPanel Style="{StaticResource FormActionRowStyle}">
                        <Button Content="Clear" Command="{Binding ClearCategoryFormCommand}"
                                Style="{StaticResource UtilityButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="Save" Command="{Binding SaveCategoryCommand}"
                                Style="{StaticResource SaveButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving category changes..."/>
    </Grid>
</UserControl>


