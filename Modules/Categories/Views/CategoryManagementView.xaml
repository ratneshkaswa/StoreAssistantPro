<UserControl x:Class="StoreAssistantPro.Modules.Categories.Views.CategoryManagementView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:scm="clr-namespace:System.ComponentModel;assembly=WindowsBase"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <UserControl.Resources>
        <CollectionViewSource x:Key="GroupedCategoriesView"
                              Source="{Binding Categories}">
            <CollectionViewSource.SortDescriptions>
                <scm:SortDescription PropertyName="CategoryType.Name" Direction="Ascending"/>
                <scm:SortDescription PropertyName="Name" Direction="Ascending"/>
            </CollectionViewSource.SortDescriptions>
            <CollectionViewSource.GroupDescriptions>
                <PropertyGroupDescription PropertyName="CategoryType.Name"/>
            </CollectionViewSource.GroupDescriptions>
        </CollectionViewSource>
    </UserControl.Resources>
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE8B7;"/><Run Text=" Category Management"/></TextBlock>

        <!-- Tab selector -->
        <Border Grid.Row="1"
                Margin="{StaticResource ItemSpacing}"
                Style="{StaticResource SegmentedFilterHostStyle}"
                HorizontalAlignment="Left">
            <StackPanel Orientation="Horizontal">
                <Button Content="Category Types"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="0"
                        Style="{StaticResource SegmentedFilterButtonStyle}"
                        Margin="0,0,4,0">
                    <Button.Tag>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding Path="ActiveTab"/>
                            <Binding Source="0"/>
                        </MultiBinding>
                    </Button.Tag>
                </Button>
                <Button Content="Categories"
                        Command="{Binding SwitchTabCommand}"
                        CommandParameter="1"
                        Style="{StaticResource SegmentedFilterButtonStyle}">
                    <Button.Tag>
                        <MultiBinding Converter="{StaticResource EqualityConverter}">
                            <Binding Path="ActiveTab"/>
                            <Binding Source="1"/>
                        </MultiBinding>
                    </Button.Tag>
                </Button>
            </StackPanel>
        </Border>

        <!-- Tab 0: Category Types -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabTypes, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <DataGrid x:Name="CategoryTypesGrid"
                      AutomationProperties.Name="Category types" ItemsSource="{Binding CategoryTypes}"
                      SelectedItem="{Binding SelectedType}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      h:DataGridEmptyState.Icon="🗂"
                      h:DataGridEmptyState.Title="No category types yet"
                      h:DataGridEmptyState.Description="Create a category type first so products can be grouped into a clear catalogue structure."
                      AutoGenerateColumns="False" IsReadOnly="False"
                      SelectionMode="Extended"
                      h:DataGridMultiSelect.IsEnabled="True"
                      BeginningEdit="OnCategoryTypesGridBeginningEdit"
                      CellEditEnding="OnCategoryTypesGridCellEditEnding"
                      PreviewMouseDoubleClick="OnCategoryTypesGridPreviewMouseDoubleClick"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.Columns>
                    <DataGridTemplateColumn x:Name="CategoryTypeNameColumn"
                                            Header="Type Name"
                                            SortMemberPath="Name"
                                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="PencilIcon"
                                               Text="&#xE70F;"
                                               FontFamily="{StaticResource FluentIconFont}"
                                               FontSize="{StaticResource FontSizeIconSmall}"
                                               Foreground="{StaticResource FluentTextTertiary}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Opacity="0"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsMouseOver}"
                                                 Value="True">
                                        <Setter TargetName="PencilIcon" Property="Opacity" Value="0.8"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DataGridInlineEditTextBoxStyle}"
                                         MaxLength="100"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTemplateColumn Header="Active"
                                            Width="{StaticResource ColumnWidthQty}"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                          IsChecked="{Binding IsActive, Mode=OneWay}"
                                          CommandParameter="{Binding}"
                                          Command="{Binding DataContext.ToggleTypeActiveCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Type Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Column="1"
                         AutomationProperties.Name="Category type name"
                         Text="{Binding TypeName, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                         MaxLength="100" h:Watermark.Text="e.g. Men's Wear"/>
            </Grid>

            <Grid Grid.Row="2" Margin="{StaticResource FormActionBarSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Clear" Command="{Binding ClearTypeFormCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Grid.Column="2" Content="Save" Command="{Binding SaveTypeCommand}"
                        Style="{StaticResource SaveButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </Grid>
        </Grid>

        <!-- Tab 1: Categories -->
        <Grid Grid.Row="2"
              Visibility="{Binding IsTabCategories, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Margin="{StaticResource ItemSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox AutomationProperties.Name="Category search"
                         Style="{StaticResource FluentSearchTextBoxStyle}"
                         Text="{Binding CategorySearchText, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="e.g. Shirts"/>
                <Button Grid.Column="1" Content="Search" Command="{Binding SearchCategoriesCommand}"
                        Style="{StaticResource SearchButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </Grid>

            <DataGrid x:Name="CategoriesGrid"
                      AutomationProperties.Name="Categories list" Grid.Row="1"
                      ItemsSource="{Binding Source={StaticResource GroupedCategoriesView}}"
                      SelectedItem="{Binding SelectedCategory}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      h:DataGridEmptyState.Icon="🏷"
                      h:DataGridEmptyState.Title="No categories found"
                      h:DataGridEmptyState.Description="Add a category or clear the current search to populate this list."
                      AutoGenerateColumns="False" IsReadOnly="False"
                      SelectionMode="Extended"
                      h:DataGridMultiSelect.IsEnabled="True"
                      BeginningEdit="OnCategoriesGridBeginningEdit"
                      CellEditEnding="OnCategoriesGridCellEditEnding"
                      PreviewMouseDoubleClick="OnCategoriesGridPreviewMouseDoubleClick"
                      HeadersVisibility="Column" CanUserAddRows="False">
                <DataGrid.GroupStyle>
                    <GroupStyle ContainerStyle="{StaticResource DataGridGroupItemStyle}"/>
                </DataGrid.GroupStyle>
                <DataGrid.Columns>
                    <DataGridTemplateColumn x:Name="CategoryNameColumn"
                                            Header="Category"
                                            SortMemberPath="Name"
                                            Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Grid>
                                    <TextBlock Text="{Binding Name}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock x:Name="PencilIcon"
                                               Text="&#xE70F;"
                                               FontFamily="{StaticResource FluentIconFont}"
                                               FontSize="{StaticResource FontSizeIconSmall}"
                                               Foreground="{StaticResource FluentTextTertiary}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center"
                                               Opacity="0"/>
                                </Grid>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=DataGridCell}, Path=IsMouseOver}"
                                                 Value="True">
                                        <Setter TargetName="PencilIcon" Property="Opacity" Value="0.8"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                         Style="{StaticResource DataGridInlineEditTextBoxStyle}"
                                         MaxLength="100"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Type"
                                        Binding="{Binding CategoryType.Name}"
                                        Width="{StaticResource ColumnWidthPrice}"
                                        IsReadOnly="True"/>
                    <DataGridTemplateColumn Header="Active"
                                            Width="{StaticResource ColumnWidthQty}"
                                            IsReadOnly="True">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox Style="{StaticResource FluentToggleSwitchStyle}"
                                          IsChecked="{Binding IsActive, Mode=OneWay}"
                                          CommandParameter="{Binding}"
                                          Command="{Binding DataContext.ToggleCategoryActiveCommand,
                                                    RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="2" Margin="{StaticResource StepContentTopSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Category Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <TextBox Grid.Row="0" Grid.Column="1"
                         AutomationProperties.Name="Category name"
                         Text="{Binding CategoryName, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                         MaxLength="100" h:Watermark.Text="e.g. Shirts"/>

                <TextBlock Grid.Row="2" Grid.Column="0" Text="Type"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <ComboBox Grid.Row="2" Grid.Column="1"
                          AutomationProperties.Name="Category type"
                          ItemsSource="{Binding CategoryTypes}"
                          SelectedItem="{Binding SelectedCategoryType}"
                          DisplayMemberPath="Name"
                          Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"/>
            </Grid>

            <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="1" Content="Clear" Command="{Binding ClearCategoryFormCommand}"
                        Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                <Button Grid.Column="2" Content="Save" Command="{Binding SaveCategoryCommand}"
                        Style="{StaticResource SaveButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </Grid>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasErrorMessage}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccessMessage}"/>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving category changes..."/>
    </Grid>
</UserControl>
