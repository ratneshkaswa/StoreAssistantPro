<UserControl x:Class="StoreAssistantPro.Modules.SystemSettings.Views.GeneralSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="🏪 General Settings" Style="{StaticResource DialogTitleStyle}"/>

        <!-- Two-column form grid -->
        <Grid Grid.Row="1" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="120"/>
                <ColumnDefinition Width="*" MaxWidth="400"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Firm Name -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Firm Name *"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}"
                     MaxLength="200"/>

            <!-- Row 2: Currency -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Default Currency"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                <ComboBox ItemsSource="{Binding AvailableCurrencies}"
                          SelectedItem="{Binding DefaultCurrency}"
                          Width="{StaticResource FieldWidthCompact}"/>
                <TextBlock VerticalAlignment="Center" Margin="{StaticResource FormColumnGap}"
                           Foreground="{StaticResource FluentTextTertiary}"
                           FontSize="{StaticResource FontSizeCaption}">
                    <Run Text="Preview: 1,234.56"/>
                    <Run Text="{Binding DefaultCurrency, StringFormat=' ({0})', Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>

            <!-- Row 4: Smart Tooltips -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Smart Tooltips"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <CheckBox Grid.Row="4" Grid.Column="1"
                      Content="Show tooltips on hover"
                      IsChecked="{Binding SmartTooltipsEnabled}"
                      Style="{StaticResource FluentCheckBoxStyle}"/>

            <!-- Row 6: Density -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="UI Density"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <ComboBox Grid.Row="6" Grid.Column="1"
                      ItemsSource="{Binding AvailableDensityModes}"
                      SelectedItem="{Binding SelectedDensityMode}"
                      Width="{StaticResource FieldWidthCompact}"
                      HorizontalAlignment="Left"/>

            <!-- Row 8: Messages -->
            <StackPanel Grid.Row="8" Grid.Column="1">
                <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
                <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                           h:AutoDismiss.IsEnabled="True" h:AutoDismiss.Seconds="4"/>
            </StackPanel>
        </Grid>

        <!-- Action button — pinned to bottom -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="💾 Save Settings"
                    Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
