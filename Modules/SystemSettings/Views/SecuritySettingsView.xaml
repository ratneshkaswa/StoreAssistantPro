<UserControl x:Class="StoreAssistantPro.Modules.SystemSettings.Views.SecuritySettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d">
    <Grid Margin="30" h:KeyboardNav.DefaultCommand="{Binding ChangeMasterPinCommand}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0" Text="🔒 Security Settings"
                   FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="Change Master Password (6-digit numeric)"
                   FontSize="13" Foreground="#666" Margin="0,0,0,14"/>

        <!-- Current Master PIN -->
        <StackPanel Grid.Row="2" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left">
            <TextBlock Text="Current Master Password *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="CurrentPinBox" MaxLength="6" Padding="8" FontSize="13"
                         PasswordChanged="CurrentPinBox_PasswordChanged"/>
        </StackPanel>

        <!-- New Master PIN -->
        <StackPanel Grid.Row="3" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left">
            <TextBlock Text="New Master Password *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="NewPinBox" MaxLength="6" Padding="8" FontSize="13"
                         PasswordChanged="NewPinBox_PasswordChanged"/>
        </StackPanel>

        <!-- Confirm New Master PIN -->
        <StackPanel Grid.Row="4" Margin="0,0,0,12" MaxWidth="300" HorizontalAlignment="Left">
            <TextBlock Text="Confirm New Master Password *" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <PasswordBox x:Name="ConfirmPinBox" MaxLength="6" Padding="8" FontSize="13"
                         PasswordChanged="ConfirmPinBox_PasswordChanged"/>
        </StackPanel>

        <!-- Messages -->
        <StackPanel Grid.Row="5" VerticalAlignment="Top" Margin="0,4,0,0">
            <TextBlock Text="{Binding ErrorMessage}" Foreground="Red" TextWrapping="Wrap"/>
            <TextBlock Text="{Binding SuccessMessage}" Foreground="#4CAF50" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- Change PIN Button -->
        <StackPanel Grid.Row="6" Orientation="Horizontal">
            <Button Content="🔑 Change Password" Command="{Binding ChangeMasterPinCommand}"
                    Padding="20,10" FontSize="13" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</UserControl>
