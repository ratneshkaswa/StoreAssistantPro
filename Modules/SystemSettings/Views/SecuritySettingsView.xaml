<UserControl x:Class="StoreAssistantPro.Modules.SystemSettings.Views.SecuritySettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d">
    <Grid Margin="{StaticResource DialogPadding}"
          h:KeyboardNav.DefaultCommand="{Binding ChangeMasterPinCommand}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="🔒 Security Settings" Style="{StaticResource DialogTitleStyle}"/>

        <!-- Two-column form grid -->
        <Grid Grid.Row="1" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="160"/>
                <ColumnDefinition Width="*" MaxWidth="300"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Section description spanning input column -->
            <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                       Text="Change Master Password (6-digit numeric)"
                       Style="{StaticResource CaptionLabelStyle}"
                       HorizontalAlignment="Left" Margin="0,0,0,4"/>

            <!-- Row 2: Current password -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Current Password *"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="2" Grid.Column="1"
                         x:Name="CurrentPinBox" MaxLength="6"
                         PasswordChanged="CurrentPinBox_PasswordChanged"/>

            <!-- Row 4: New password -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="New Password *"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="4" Grid.Column="1"
                         x:Name="NewPinBox" MaxLength="6"
                         PasswordChanged="NewPinBox_PasswordChanged"/>

            <!-- Row 6: Confirm -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Confirm Password *"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <PasswordBox Grid.Row="6" Grid.Column="1"
                         x:Name="ConfirmPinBox" MaxLength="6"
                         PasswordChanged="ConfirmPinBox_PasswordChanged"/>
        </Grid>

        <!-- Messages -->
        <StackPanel Grid.Row="2" VerticalAlignment="Top" Margin="0,8,0,0">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"/>
        </StackPanel>

        <!-- Action button — pinned to bottom -->
        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="🔑 Change Password"
                    Command="{Binding ChangeMasterPinCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
