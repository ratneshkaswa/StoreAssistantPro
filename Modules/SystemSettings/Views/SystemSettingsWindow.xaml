<Window x:Class="StoreAssistantPro.Modules.SystemSettings.Views.SystemSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="⚙ System Settings" Height="520" Width="780"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════ LEFT: Category Navigation ══════ -->
        <Border Grid.Column="0" Background="#2D2D30">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="⚙ Settings"
                           Foreground="White" FontSize="18" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,20,0,10"/>
                <Separator DockPanel.Dock="Top" Background="#3E3E42" Margin="10,0,10,10"/>

                <ListBox DockPanel.Dock="Top"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         Background="Transparent" BorderThickness="0"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="#B0B0B0"/>
                            <Setter Property="FontSize" Value="14"/>
                            <Setter Property="Padding" Value="20,12"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <ContentPresenter
                                                HorizontalAlignment="Left"
                                                VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#3E3E42"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#007ACC"/>
                                                <Setter Property="Foreground" Value="White"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Border/>
            </DockPanel>
        </Border>

        <!-- ══════ RIGHT: Dynamic Content Area ══════ -->
        <Border Grid.Column="1" Background="#FAFAFA">
            <ContentControl Content="{Binding CurrentCategoryView}" Margin="0"/>
        </Border>
    </Grid>
</Window>
