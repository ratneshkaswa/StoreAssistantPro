<UserControl x:Class="StoreAssistantPro.Modules.SystemSettings.Views.AppInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="ℹ Application Info" Style="{StaticResource DialogTitleStyle}"/>

        <!-- Two-column info grid -->
        <Grid Grid.Row="1" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="130"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Row 0: Version -->
            <TextBlock Grid.Row="0" Grid.Column="0" Text="Application Version"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBlock Grid.Row="0" Grid.Column="1"
                       Text="{Binding AppVersion}" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <!-- Row 2: Current User -->
            <TextBlock Grid.Row="2" Grid.Column="0" Text="Current User"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBlock Grid.Row="2" Grid.Column="1"
                       Text="{Binding CurrentUser}" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <!-- Row 4: Firm Name -->
            <TextBlock Grid.Row="4" Grid.Column="0" Text="Firm Name"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <TextBlock Grid.Row="4" Grid.Column="1"
                       Text="{Binding FirmName}" FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

            <!-- Row 6: Database Connection -->
            <TextBlock Grid.Row="6" Grid.Column="0" Text="Database Connection"
                       Style="{StaticResource FormRowLabelStyle}"/>
            <StackPanel Grid.Row="6" Grid.Column="1" Orientation="Horizontal"
                        VerticalAlignment="Center">
                <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="#999"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDatabaseConnected}" Value="True">
                                    <Setter Property="Fill" Value="#4CAF50"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsDatabaseConnected}" Value="False">
                                    <Setter Property="Fill" Value="#F44336"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock Text="{Binding DatabaseStatus}" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Action button -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="🔄 Refresh Connection" Command="{Binding CheckConnectionCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"/>
        </StackPanel>
    </Grid>
</UserControl>
