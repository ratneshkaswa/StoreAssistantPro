<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.SystemSettings.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        Title="⚙ System Settings">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="{StaticResource SidebarNavWidth}"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ══════ LEFT: Category Navigation ══════ -->
        <Border Grid.Column="0" Style="{StaticResource SidebarNavStyle}">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top"
                           Text="⚙ Settings"
                           Foreground="{StaticResource FluentTextPrimary}" FontSize="{StaticResource FontSizeDialogTitle}" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="{StaticResource DialogPadding}"/>
                <Separator DockPanel.Dock="Top" Background="{StaticResource FluentSurfaceStroke}" Margin="{StaticResource PanelPadding}"/>

                <ListBox DockPanel.Dock="Top"
                         ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         Background="Transparent" BorderThickness="0"
                         HorizontalContentAlignment="Stretch">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
                            <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
                            <Setter Property="Padding" Value="{StaticResource SidebarNavItemPadding}"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <Border x:Name="Bd"
                                                Background="Transparent"
                                                Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="3"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Border x:Name="AccentBar" Width="3"
                                                        CornerRadius="1.5" Background="Transparent"
                                                        VerticalAlignment="Stretch" Margin="0,2"/>
                                                <ContentPresenter Grid.Column="1"
                                                    HorizontalAlignment="Left"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                                                <Setter Property="Foreground" Value="{StaticResource FluentTextPrimary}"/>
                                            </Trigger>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource FluentSubtlePressed}"/>
                                                <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                                <Setter TargetName="AccentBar" Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                </ListBox>

                <Border/>
            </DockPanel>
        </Border>

        <!-- ══════ RIGHT: Dynamic Content Area ══════ -->
        <Border Grid.Column="1" Background="{StaticResource FluentBackgroundPrimary}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
                <ContentControl Content="{Binding CurrentCategoryView}" Margin="0"/>
            </ScrollViewer>
        </Border>
    </Grid>
</core:BaseDialogWindow>
