<UserControl x:Class="StoreAssistantPro.Modules.PurchaseOrders.Views.PurchaseOrderView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             x:Name="Root"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7B8;"/><Run Text=" Purchase Orders"/></TextBlock>
            <TextBlock Text="Track supplier orders, build line items, and move open purchase orders through receiving."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Filters -->
        <Grid Grid.Row="1" Style="{StaticResource PageToolbarHostStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <WrapPanel Style="{StaticResource PageToolbarContentRowStyle}">
                <TextBox AutomationProperties.Name="Purchase order search"
                         Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                         Style="{StaticResource FluentSearchTextBoxStyle}"
                         Width="{StaticResource FieldWidthWide}"
                         h:Watermark.Text="Search purchase orders by number or supplier"/>
                <ComboBox ItemsSource="{Binding StatusOptions}"
                          AutomationProperties.Name="Purchase order status filter"
                          SelectedItem="{Binding FilterStatus}"
                          Width="{StaticResource FieldWidthStandard}"
                          Margin="{StaticResource InlineControlSpacing}"/>
            </WrapPanel>
            <WrapPanel Grid.Column="1" Style="{StaticResource PageToolbarActionRowStyle}">
                <Button Content="Search" Command="{Binding SearchCommand}"
                        Style="{StaticResource SearchButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            </WrapPanel>
        </Grid>

        <!-- PO list + detail -->
        <Grid Grid.Row="2"
              Style="{StaticResource MasterDetailPageGridStyle}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{StaticResource MasterDetailListPaneWidth}"/>
                <ColumnDefinition Width="{StaticResource MasterDetailPaneGapWidth}"/>
                <ColumnDefinition Width="{StaticResource MasterDetailEditorPaneWidth}"/>
            </Grid.ColumnDefinitions>

            <!-- PO list -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <DataGrid AutomationProperties.Name="Purchase orders" ItemsSource="{Binding Orders}"
                          SelectedItem="{Binding SelectedOrder}"
                          Style="{StaticResource EnterpriseDataGridStyle}"
                          h:DataGridLayoutPersistence.Key="PurchaseOrdersGrid"
                          h:DataGridEmptyState.Icon="{StaticResource EmptyStatePurchaseDocumentIconGlyph}"
                          h:DataGridEmptyState.Title="No purchase orders found"
                          h:DataGridEmptyState.Description="Create a purchase order or adjust the current search and status filter to see results."
                          AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single"
                          HeadersVisibility="Column" CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="PO#" Binding="{Binding OrderNumber}" Width="*"/>
                        <DataGridTextColumn Header="Supplier" Binding="{Binding Supplier.Name}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding OrderDate, StringFormat=d}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTemplateColumn Header="Status" SortMemberPath="Status" Width="{StaticResource ColumnWidthPrice}">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource SemanticStatusPillStyle}"
                                            Tag="{Binding Status, StringFormat={}{0}}"
                                            HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding Status, Converter={StaticResource StatusDisplayTextConverter}}"
                                                   Style="{StaticResource SemanticStatusPillTextStyle}"
                                                   Tag="{Binding Status, StringFormat={}{0}}"/>
                                    </Border>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat={}{0:C}}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <StackPanel Grid.Row="1"
                            Style="{StaticResource PaginatorBarStyle}"
                            Visibility="{Binding TotalCount, Converter={StaticResource PositiveToVisibility}}">
                    <Button Content="Prev"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding HasPreviousPage}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding PagingInfo}"
                               VerticalAlignment="Center"
                               Style="{StaticResource PaginatorInfoTextStyle}"/>
                    <Button Content="Next"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNextPage}"
                            Style="{StaticResource PaginatorNavButtonStyle}"
                            Margin="8,0,0,0"/>
                </StackPanel>
            </Grid>

            <!-- Right: New PO form -->
            <ScrollViewer Grid.Column="2"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False"
                          Margin="{StaticResource ItemSpacing}">
                <StackPanel>
                    <Border Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="New Purchase Order"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Choose the supplier, expected delivery, and notes before adding line items."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                            <Grid Style="{StaticResource AdminInlineFieldRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Supplier"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <ComboBox Grid.Column="1"
                                          AutomationProperties.Name="Purchase order supplier"
                                          ItemsSource="{Binding Suppliers}"
                                          SelectedItem="{Binding SelectedSupplier}"
                                          DisplayMemberPath="Name"
                                          Style="{StaticResource FluentAutoSuggestComboBoxStyle}"/>
                            </Grid>

                            <Grid Style="{StaticResource AdminInlineFieldRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Expected"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <DatePicker Grid.Column="1"
                                            AutomationProperties.Name="Expected delivery date"
                                            SelectedDate="{Binding ExpectedDate}"/>
                            </Grid>

                            <Grid Style="{StaticResource AdminInlineFieldRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="Notes"
                                           Style="{StaticResource FormRowLabelStyle}"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource FluentMultilineTextBoxStyle}"
                                         AutomationProperties.Name="Purchase order notes"
                                         Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                         MaxLength="500"
                                         h:Watermark.Text="Order note (optional)"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Line Items"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Build the order contents before creating or duplicating the purchase order."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                            <DataGrid AutomationProperties.Name="Order line items"
                                      ItemsSource="{Binding LineItems}"
                                      SelectedItem="{Binding SelectedLineItem}"
                                      AutoGenerateColumns="False"
                                      SelectionMode="Single"
                                      HeadersVisibility="Column"
                                      CanUserAddRows="False"
                                      MaxHeight="{StaticResource EditableGridMaxHeight}">
                                <DataGrid.Columns>
                                    <DataGridTemplateColumn Header="Product" Width="*">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <ComboBox ItemsSource="{Binding DataContext.Products, ElementName=Root}"
                                                          AutomationProperties.Name="Purchase order line product"
                                                          DisplayMemberPath="Name"
                                                          SelectedValuePath="Id"
                                                          SelectedValue="{Binding ProductId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          Style="{StaticResource FluentAutoSuggestComboBoxStyle}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                    <DataGridTextColumn Header="Qty"
                                                        Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="{StaticResource ColumnWidthQty}"/>
                                    <DataGridTextColumn Header="Cost"
                                                        Binding="{Binding UnitCost, UpdateSourceTrigger=PropertyChanged}"
                                                        Width="{StaticResource ColumnWidthPrice}"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <WrapPanel Style="{StaticResource LineItemActionRowStyle}">
                                <Button Content="Add Line"
                                        Command="{Binding AddLineItemCommand}"
                                        Style="{StaticResource InlineCollectionAddButtonStyle}"/>
                                <Button Content="Remove Line"
                                        Command="{Binding RemoveLineItemCommand}"
                                        Style="{StaticResource InlineCollectionRemoveButtonStyle}"/>
                                <controls:SplitButton Content="Create PO"
                                                      Command="{Binding CreateOrderCommand}">
                                    <controls:SplitButton.ContextMenu>
                                        <ContextMenu>
                                            <MenuItem Header="Duplicate selected order"
                                                      Command="{Binding DuplicateOrderCommand}"/>
                                        </ContextMenu>
                                    </controls:SplitButton.ContextMenu>
                                </controls:SplitButton>
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource OperationalEditorSectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="State Actions"
                                       Style="{StaticResource OperationalEditorSectionTitleStyle}"/>
                            <TextBlock Text="Advance the selected purchase order through ordering, receiving, or cancellation from the same action area."
                                       Style="{StaticResource OperationalEditorSectionDescriptionStyle}"/>

                            <WrapPanel Style="{StaticResource StateTransitionActionBarStyle}">
                                <Button Content="Mark Ordered"
                                        Command="{Binding MarkOrderedCommand}"
                                        Style="{StaticResource StateTransitionSecondaryButtonStyle}"/>
                                <Button Content="Receive All"
                                        Command="{Binding ReceiveAllCommand}"
                                        Style="{StaticResource StateTransitionPrimaryButtonStyle}"/>
                                <Button Content="Cancel Purchase Order"
                                        Command="{Binding CancelOrderCommand}"
                                        Style="{StaticResource StateTransitionDestructiveButtonStyle}"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <controls:ErrorStateOverlay Grid.Row="2"
                                    IsOpen="{Binding HasLoadError}"
                                    Icon=":("
                                    Title="Couldn't load purchase order data"
                                    Description="{Binding LoadErrorMessage}"
                                    ActionText="Retry"
                                    ActionCommand="{Binding LoadCommand}"/>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Processing purchase order..."/>
    </Grid>
</UserControl>

