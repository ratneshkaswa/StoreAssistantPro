<UserControl x:Class="StoreAssistantPro.Modules.Reports.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="900" d:DesignWidth="1200"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <StackPanel>
            <TextBlock Style="{StaticResource PageTitleStyle}">
                <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE9F9;"/>
                <Run Text=" Reports"/>
            </TextBlock>
            <TextBlock Text="Review sales, tax, expense, and operational performance for the selected reporting period."
                       Style="{StaticResource PageSubtitleStyle}"/>
        </StackPanel>

        <!-- Date Range Bar -->
        <WrapPanel Grid.Row="1" Style="{StaticResource ReportFilterBarStyle}">
            <Border Style="{StaticResource SegmentedFilterHostStyle}">
                <WrapPanel Style="{StaticResource SegmentedFilterButtonRowStyle}">
                    <Button Content="This Month" Style="{StaticResource SegmentedFilterButtonStyle}"
                            Command="{Binding SetPresetCommand}" CommandParameter="This Month" Margin="0,0,4,0">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActivePreset"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="Last Month" Style="{StaticResource SegmentedFilterButtonStyle}"
                            Command="{Binding SetPresetCommand}" CommandParameter="Last Month" Margin="0,0,4,0">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActivePreset"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="This Quarter" Style="{StaticResource SegmentedFilterButtonStyle}"
                            Command="{Binding SetPresetCommand}" CommandParameter="This Quarter" Margin="0,0,4,0">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActivePreset"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="This Year" Style="{StaticResource SegmentedFilterButtonStyle}"
                            Command="{Binding SetPresetCommand}" CommandParameter="This Year" Margin="0,0,4,0">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActivePreset"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                    <Button Content="All Time" Style="{StaticResource SegmentedFilterButtonStyle}"
                            Command="{Binding SetPresetCommand}" CommandParameter="All Time">
                        <Button.Tag>
                            <MultiBinding Converter="{StaticResource EqualityConverter}">
                                <Binding RelativeSource="{RelativeSource Self}" Path="CommandParameter"/>
                                <Binding Path="ActivePreset"/>
                            </MultiBinding>
                        </Button.Tag>
                    </Button>
                </WrapPanel>
            </Border>

            <controls:DateRangePicker
                                      Margin="16,0,0,0"
                                      Width="{StaticResource ReportDateRangeWidth}"
                                      StartDate="{Binding DateFrom, Mode=TwoWay}"
                                      EndDate="{Binding DateTo, Mode=TwoWay}"
                                      StartHeader="From"
                                      EndHeader="To"/>

            <Button Content="Refresh"
                    Margin="16,0,0,0"
                    Style="{StaticResource RefreshButtonStyle}"
                    Command="{Binding RefreshCommand}"/>
        </WrapPanel>

        <WrapPanel Grid.Row="2"
                   Margin="0,0,0,16">
                <Button Content="{Binding ActivePreset, StringFormat=Preset: {0}}"
                        Command="{Binding SetPresetCommand}"
                        CommandParameter="This Month">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ActiveFilterChipButtonStyle}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ActivePreset}" Value="This Month">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
        </WrapPanel>

        <Border Grid.Row="3" Style="{StaticResource ReportSummaryStripStyle}">
            <WrapPanel>
                <StackPanel Style="{StaticResource ReportSummaryItemHostStyle}">
                    <TextBlock Text="Selected period" Style="{StaticResource ReportSummaryItemLabelStyle}"/>
                    <TextBlock Text="{Binding SelectedPeriodSummary}" Style="{StaticResource ReportSummaryItemValueStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource ReportSummaryItemHostStyle}">
                    <TextBlock Text="Preset" Style="{StaticResource ReportSummaryItemLabelStyle}"/>
                    <TextBlock Text="{Binding SelectedPresetSummary}" Style="{StaticResource ReportSummaryItemValueStyle}"/>
                </StackPanel>
                <StackPanel Style="{StaticResource ReportSummaryItemHostStyle}">
                    <TextBlock Text="Last updated" Style="{StaticResource ReportSummaryItemLabelStyle}"/>
                    <TextBlock Text="{Binding LastUpdatedSummary}" Style="{StaticResource ReportSummaryItemValueStyle}"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Report Sections -->
        <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ═══ TODAY'S SALES SUMMARY ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Today's Sales" Style="{StaticResource ReportSectionTitleStyle}"/>
                        <WrapPanel Margin="0,8,0,0">
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="SALES" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TodaySaleCount}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="REVENUE" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TodayTotalSales, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="RETURNS" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TodayTotalReturns, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentError}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="NET SALES" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TodayNetSales, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentSuccess}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="TAX" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TodayTotalTax, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="DISCOUNT" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TodayTotalDiscount, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentWarning}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ PROFIT SUMMARY ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Profit Summary" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <TextBlock Grid.Column="1" Style="{StaticResource ReportSectionMetaTextStyle}">
                                <Run Text="Selected period •"/>
                                <Run Text="{Binding PeriodSaleCount, Mode=OneWay}"/>
                                <Run Text="sales •"/>
                                <Run Text="{Binding PeriodItemsSold, Mode=OneWay}"/>
                                <Run Text="items"/>
                            </TextBlock>
                        </Grid>
                        <WrapPanel Margin="0,8,0,0">
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="REVENUE" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding GrossRevenue, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="COGS" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding GrossCogs, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="GROSS PROFIT" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding GrossProfit, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentSuccess}"/>
                                    <TextBlock Style="{StaticResource ReportMetricLabelTextStyle}">
                                        <Run Text="Margin:"/>
                                        <Run Text="{Binding GrossMarginPercent, StringFormat='{}{0:N1}%', Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="EXPENSES" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TotalExpensesForProfit, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentError}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="NET PROFIT" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding NetProfit, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentSuccess}"/>
                                    <TextBlock Style="{StaticResource ReportMetricLabelTextStyle}">
                                        <Run Text="Margin:"/>
                                        <Run Text="{Binding NetMarginPercent, StringFormat='{}{0:N1}%', Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ TAX SUMMARY ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Tax Summary (Current Month)" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <Button Grid.Column="1" Content="Export HSN CSV" Style="{StaticResource ReportExportButtonStyle}"
                                    Command="{Binding ExportHsnTaxCsvCommand}"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,0">
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="TOTAL TAX" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TotalTaxCollected, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="CGST" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TotalCgst, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="SGST" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding TotalSgst, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- ═══ BEST SELLING PRODUCTS ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Best Selling Products" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ReportExportButtonStyle}"
                                    Command="{Binding ExportBestSellingCsvCommand}"/>
                        </Grid>
                        <DataGrid ItemsSource="{Binding BestSellingProducts}" AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="{StaticResource ReportAnalyticalGridMaxHeight}"
                                  Margin="0,8,0,0"
                                  h:DataGridEmptyState.Icon="{StaticResource EmptyStateProductIconGlyph}"
                                  h:DataGridEmptyState.Title="No best sellers yet"
                                  h:DataGridEmptyState.Description="This section will fill in once the selected date range has enough completed sales data."
                                  Style="{StaticResource AnalyticalReportDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding ProductId}" Width="{StaticResource ColumnWidthId}"/>
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="HSN" Binding="{Binding HsnCode}" Width="80"/>
                                <DataGridTextColumn Header="Qty Sold" Binding="{Binding TotalQuantitySold}" Width="{StaticResource ColumnWidthQty}"/>
                                <DataGridTextColumn Header="Revenue" Binding="{Binding TotalRevenue, StringFormat={}{0:C0}}" Width="{StaticResource ColumnWidthPrice}"/>
                                <DataGridTextColumn Header="Avg Price" Binding="{Binding AverageSellingPrice, StringFormat={}{0:C0}}" Width="{StaticResource ColumnWidthPrice}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ SLOW MOVING PRODUCTS ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Slow Moving Products" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ReportExportButtonStyle}"
                                    Command="{Binding ExportSlowMovingCsvCommand}"/>
                        </Grid>
                        <DataGrid ItemsSource="{Binding SlowMovingProducts}" AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="{StaticResource ReportAnalyticalGridMaxHeight}"
                                  Margin="0,8,0,0"
                                  h:DataGridEmptyState.Icon="{StaticResource EmptyStateProductIconGlyph}"
                                  h:DataGridEmptyState.Title="No slow movers detected"
                                  h:DataGridEmptyState.Description="Products with weak movement will appear here when the selected period has comparison data."
                                  Style="{StaticResource AnalyticalReportDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="#" Binding="{Binding ProductId}" Width="{StaticResource ColumnWidthId}"/>
                                <DataGridTextColumn Header="Product" Binding="{Binding ProductName}" Width="*"/>
                                <DataGridTextColumn Header="Qty Sold" Binding="{Binding TotalQuantitySold}" Width="{StaticResource ColumnWidthQty}"/>
                                <DataGridTextColumn Header="Revenue" Binding="{Binding TotalRevenue, StringFormat={}{0:C0}}" Width="{StaticResource ColumnWidthPrice}"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ SALES BY PAYMENT METHOD ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sales by Payment Method" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ReportExportButtonStyle}"
                                    Command="{Binding ExportSalesByPaymentMethodCsvCommand}"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding SalesByPaymentMethod}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding PaymentMethod}"
                                                   Style="{StaticResource ReportListPrimaryTextStyle}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SaleCount}"
                                                   Style="{StaticResource ReportListSecondaryTextStyle}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding TotalAmount, StringFormat={}{0:C0}}"
                                                   Style="{StaticResource ReportListValueTextStyle}"/>
                                        <TextBlock Grid.Column="3"
                                                   Style="{StaticResource ReportListMetaTextStyle}">
                                            <Run Text="{Binding Percentage, StringFormat='{}{0:N1}%', Mode=OneWay}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ═══ SALES BY CASHIER ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Sales by Cashier" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ReportExportButtonStyle}"
                                    Command="{Binding ExportSalesByUserCsvCommand}"/>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding SalesByUser}" Margin="0,8,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding CashierRole}"
                                                   Style="{StaticResource ReportListPrimaryTextStyle}"/>
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource ReportListSecondaryTextStyle}">
                                            <Run Text="{Binding SaleCount, Mode=OneWay}"/>
                                            <Run Text="sales"/>
                                        </TextBlock>
                                        <TextBlock Grid.Column="2" Text="{Binding TotalRevenue, StringFormat={}{0:C0}}"
                                                   Style="{StaticResource ReportListValueTextStyle}"/>
                                        <TextBlock Grid.Column="3"
                                                   Style="{StaticResource ReportListMetaTextStyle}">
                                            <Run Text="avg "/>
                                            <Run Text="{Binding AverageSaleValue, StringFormat={}{0:C0}, Mode=OneWay}"/>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <!-- ═══ EXPENSES SECTION ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Expenses" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ReportExportButtonStyle}"
                                    Command="{Binding ExportExpenseCsvCommand}"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="COUNT" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding ExpenseCount}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="TOTAL" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding ExpenseTotal, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- Category breakdown -->
                        <TextBlock Text="By Category"
                                   Style="{StaticResource ReportSubsectionTitleStyle}"/>
                        <ItemsControl ItemsSource="{Binding ExpenseByCategory}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Category}"
                                                   Style="{StaticResource ReportListSecondaryTextStyle}"/>
                                        <Border Grid.Column="1" Height="14" CornerRadius="2"
                                                Background="{StaticResource FluentAccentDefault}"
                                                HorizontalAlignment="Left" Margin="4,0">
                                            <Border.Width>
                                                <Binding Path="Amount" Converter="{x:Null}" FallbackValue="50"/>
                                            </Border.Width>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat={}{0:C0}}"
                                                   Style="{StaticResource ReportListMetaTextStyle}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Recent expenses -->
                        <TextBlock Text="Recent Entries"
                                   Style="{StaticResource ReportSubsectionTitleStyle}"/>
                        <DataGrid ItemsSource="{Binding ExpenseRecent}" AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="{StaticResource ReportOperationalGridMaxHeight}"
                                  h:DataGridEmptyState.Icon="{StaticResource EmptyStateExpenseIconGlyph}"
                                  h:DataGridEmptyState.Title="No recent expenses"
                                  h:DataGridEmptyState.Description="Expense entries will appear here after spending activity is recorded for the chosen date range."
                                  Style="{StaticResource AnalyticalReportDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                                <DataGridTemplateColumn Header="Category" SortMemberPath="Category" Width="*">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SemanticTagChipBorderStyle}"
                                                    Background="{Binding Category, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Background}"
                                                    BorderBrush="{Binding Category, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Border}"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Category, TargetNullValue=Uncategorized}"
                                                           Style="{StaticResource SemanticTagChipTextStyle}"
                                                           Foreground="{Binding Category, Converter={StaticResource TagChipBrushConverter}, ConverterParameter=Foreground}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:C0}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ IRONING SECTION ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ironing" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ReportExportButtonStyle}"
                                    Command="{Binding ExportIroningCsvCommand}"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="COUNT" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding IroningCount}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="TOTAL" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding IroningTotal, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="PAID" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding IroningPaid, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentSuccess}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="UNPAID" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding IroningUnpaid, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentError}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        <DataGrid ItemsSource="{Binding IroningRecent}" AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="{StaticResource ReportOperationalGridMaxHeight}"
                                  h:DataGridEmptyState.Icon="{StaticResource EmptyStateIroningIconGlyph}"
                                  h:DataGridEmptyState.Title="No ironing entries"
                                  h:DataGridEmptyState.Description="Ironing jobs will appear here once activity exists in the selected reporting period."
                                  Style="{StaticResource AnalyticalReportDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:C0}}" Width="100"/>
                                <DataGridCheckBoxColumn Header="Paid" Binding="{Binding IsPaid}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ ORDERS SECTION ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Orders" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ReportExportButtonStyle}"
                                    Command="{Binding ExportOrderCsvCommand}"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="COUNT" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding OrderCount}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="TOTAL" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding OrderTotal, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="DELIVERED" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding OrderDelivered}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentSuccess}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="PENDING" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding OrderPending}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentWarning}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        <DataGrid ItemsSource="{Binding OrderRecent}" AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="{StaticResource ReportOperationalGridMaxHeight}"
                                  h:DataGridEmptyState.Icon="{StaticResource EmptyStateOrderIconGlyph}"
                                  h:DataGridEmptyState.Title="No recent orders"
                                  h:DataGridEmptyState.Description="Order activity will show up here after new orders are created in the selected period."
                                  Style="{StaticResource AnalyticalReportDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat={}{0:C0}}" Width="100"/>
                                <DataGridTemplateColumn Header="Status" SortMemberPath="Status" Width="90">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SemanticStatusPillStyle}"
                                                    Tag="{Binding Status, StringFormat={}{0}}"
                                                    HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Status, Converter={StaticResource StatusDisplayTextConverter}}"
                                                           Style="{StaticResource SemanticStatusPillTextStyle}"
                                                           Tag="{Binding Status, StringFormat={}{0}}"/>
                                            </Border>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ INWARD SECTION ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Inward" Style="{StaticResource ReportSectionTitleStyle}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ReportExportButtonStyle}"
                                    Command="{Binding ExportInwardCsvCommand}"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="COUNT" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding InwardCount}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="TOTAL" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding InwardTotal, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        <DataGrid ItemsSource="{Binding InwardRecent}" AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  MaxHeight="{StaticResource ReportOperationalGridMaxHeight}"
                                  h:DataGridEmptyState.Icon="{StaticResource EmptyStatePurchaseDocumentIconGlyph}"
                                  h:DataGridEmptyState.Title="No inward entries"
                                  h:DataGridEmptyState.Description="Incoming stock receipts will appear here once inward processing starts for the selected dates."
                                  Style="{StaticResource AnalyticalReportDataGridStyle}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding InwardDate, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor.Name}" Width="*"/>
                                <DataGridTextColumn Header="Transport" Binding="{Binding TransportCharges, StringFormat={}{0:C0}}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ DEBTORS SECTION ═══ -->
                <Border Style="{StaticResource ReportSectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Debtors" Style="{StaticResource ReportSectionTitleStyle}"/>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="PENDING" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding DebtorCount}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource ReportMetricTileStyle}">
                                <StackPanel>
                                    <TextBlock Text="OUTSTANDING" Style="{StaticResource ReportMetricLabelTextStyle}"/>
                                    <TextBlock Text="{Binding DebtorOutstanding, StringFormat={}{0:C0}}"
                                               Style="{StaticResource ReportMetricValueTextStyle}"
                                               Foreground="{StaticResource FluentError}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="Top Debtors"
                                   Style="{StaticResource ReportSubsectionTitleStyle}"/>
                        <ItemsControl ItemsSource="{Binding TopDebtors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}"
                                                   Style="{StaticResource ReportListSecondaryTextStyle}"/>
                                        <TextBlock Grid.Column="1"
                                                   Style="{StaticResource ReportListValueTextStyle}"
                                                   Foreground="{StaticResource FluentError}">
                                            <TextBlock.Text>
                                                <Binding Path="Balance" StringFormat="{}{0:C0}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>







