<UserControl x:Class="StoreAssistantPro.Modules.Reports.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             Loaded="OnLoaded">
    <controls:EnterprisePageLayout>

        <controls:EnterprisePageLayout.TipBannerContent>
            <controls:InlineTipBanner
                h:TipBannerAutoState.TipKey="ReportsView.QuickTip"
                h:TipBannerAutoState.ContextKey="Reports"
                Title="Quick tip"
                TipText="View sales reports by day, month, category, and profit/loss. Adjust date range for custom periods."/>
        </controls:EnterprisePageLayout.TipBannerContent>

        <controls:EnterprisePageLayout.ToolbarContent>
            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="{StaticResource FieldGroupSpacing}">
                <Border Style="{StaticResource SectionCardHeaderStyle}">
                    <WrapPanel>
                        <TextBlock Text="Report:" VerticalAlignment="Center"
                                   Margin="{StaticResource InlineControlSpacing}"/>
                        <ComboBox SelectedItem="{Binding SelectedReportType, Mode=TwoWay}"
                                  ItemsSource="{Binding ReportTypes}"
                                  Width="{StaticResource FieldWidthStandard}"
                                  VerticalAlignment="Center"/>
                        <Separator Style="{StaticResource FluentSeparatorStyle}"/>
                        <TextBlock Text="From:" VerticalAlignment="Center"
                                   Margin="{StaticResource InlineControlSpacing}"/>
                        <DatePicker SelectedDate="{Binding DateFrom}" Width="{StaticResource FieldWidthCompact}"/>
                        <TextBlock Text="To:" VerticalAlignment="Center"
                                   Margin="{StaticResource InlineControlSpacing}"/>
                        <DatePicker SelectedDate="{Binding DateTo}" Width="{StaticResource FieldWidthCompact}"/>
                        <Button Content="🔄 Refresh" Command="{Binding RefreshCurrentReportCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Separator Style="{StaticResource FluentSeparatorStyle}"/>
                        <TextBlock VerticalAlignment="Center" Foreground="{StaticResource FluentTextTertiary}"
                                   Margin="{StaticResource InlineControlSpacing}">
                            <Run Text="Today: "/>
                            <Run Text="{Binding TodaysBillCount, Mode=OneWay}"/>
                            <Run Text=" bills · "/>
                            <Run Text="{Binding TodaysSales, Mode=OneWay, StringFormat=C}"/>
                        </TextBlock>
                    </WrapPanel>
                </Border>
            </Border>
        </controls:EnterprisePageLayout.ToolbarContent>

        <Border Style="{StaticResource SectionCardStyle}" ClipToBounds="True">
            <Grid>
                <!-- Day-wise Sales -->
                <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding DaySales}" MinHeight="100"
                          Visibility="{Binding IsDaySales, Converter={StaticResource BoolToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="*"/>
                        <DataGridTextColumn Header="Bills" Binding="{Binding BillCount}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Discount" Binding="{Binding DiscountAmount, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Net" Binding="{Binding NetAmount, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Month-wise Sales -->
                <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding MonthSales}" MinHeight="100"
                          Visibility="{Binding IsMonthSales, Converter={StaticResource BoolToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Month" Binding="{Binding MonthName}" Width="*"/>
                        <DataGridTextColumn Header="Year" Binding="{Binding Year}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Bills" Binding="{Binding BillCount}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Net" Binding="{Binding NetAmount, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Category Sales -->
                <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding CategorySales}" MinHeight="100"
                          Visibility="{Binding IsCategorySales, Converter={StaticResource BoolToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Category" Binding="{Binding CategoryName}" Width="*"/>
                        <DataGridTextColumn Header="Items Sold" Binding="{Binding ItemsSold}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Profit & Loss -->
                <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding ProfitLoss}" MinHeight="100"
                          Visibility="{Binding IsProfitLoss, Converter={StaticResource BoolToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="*"/>
                        <DataGridTextColumn Header="Sales" Binding="{Binding TotalSales, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Cost" Binding="{Binding TotalCost, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Gross Profit" Binding="{Binding GrossProfit, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Discounts" Binding="{Binding DiscountsGiven, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Net Profit" Binding="{Binding NetProfit, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

    </controls:EnterprisePageLayout>
</UserControl>
