<UserControl x:Class="StoreAssistantPro.Modules.Reports.Views.ReportsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="900" d:DesignWidth="1200"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource PageTitleStyle}">
            <Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE9F9;"/>
            <Run Text=" Reports"/>
        </TextBlock>

        <!-- Date Range Bar -->
        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal">
                <Button Content="This Month" Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding SetPresetCommand}" CommandParameter="This Month" Margin="0,0,4,0"/>
                <Button Content="Last Month" Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding SetPresetCommand}" CommandParameter="Last Month" Margin="0,0,4,0"/>
                <Button Content="This Quarter" Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding SetPresetCommand}" CommandParameter="This Quarter" Margin="0,0,4,0"/>
                <Button Content="This Year" Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding SetPresetCommand}" CommandParameter="This Year" Margin="0,0,4,0"/>
                <Button Content="All Time" Style="{StaticResource ToolbarButtonStyle}"
                        Command="{Binding SetPresetCommand}" CommandParameter="All Time"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="16,0,0,0">
                <TextBlock Text="From" VerticalAlignment="Center" Margin="0,0,6,0"
                           Foreground="{StaticResource FluentTextSecondary}"/>
                <DatePicker SelectedDate="{Binding DateFrom}" Width="{StaticResource FieldWidthStandard}"
                            AutomationProperties.Name="Report start date"/>
                <TextBlock Text="To" VerticalAlignment="Center" Margin="10,0,6,0"
                           Foreground="{StaticResource FluentTextSecondary}"/>
                <DatePicker SelectedDate="{Binding DateTo}" Width="{StaticResource FieldWidthStandard}"
                            AutomationProperties.Name="Report end date"/>
            </StackPanel>

            <Button Grid.Column="4" Content="Refresh" Style="{StaticResource PrimaryButtonStyle}"
                    Command="{Binding RefreshCommand}"/>
        </Grid>

        <!-- Report Sections -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <StackPanel>

                <!-- ═══ EXPENSES SECTION ═══ -->
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Expenses" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource FluentTextPrimary}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ToolbarButtonStyle}"
                                    Command="{Binding ExportExpenseCsvCommand}"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="COUNT" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ExpenseCount}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="TOTAL" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding ExpenseTotal, StringFormat='₹{0:N0}'}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <!-- Category breakdown -->
                        <TextBlock Text="By Category" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,4"
                                   Foreground="{StaticResource FluentTextSecondary}"/>
                        <ItemsControl ItemsSource="{Binding ExpenseByCategory}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="80"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Category}" FontSize="12"/>
                                        <Border Grid.Column="1" Height="14" CornerRadius="2"
                                                Background="{StaticResource FluentAccentDefault}"
                                                HorizontalAlignment="Left" Margin="4,0">
                                            <Border.Width>
                                                <Binding Path="Amount" Converter="{x:Null}" FallbackValue="50"/>
                                            </Border.Width>
                                        </Border>
                                        <TextBlock Grid.Column="2" Text="{Binding Amount, StringFormat='₹{0:N0}'}"
                                                   HorizontalAlignment="Right" FontSize="12"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Recent expenses -->
                        <TextBlock Text="Recent Entries" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,4"
                                   Foreground="{StaticResource FluentTextSecondary}"/>
                        <DataGrid ItemsSource="{Binding ExpenseRecent}" AutoGenerateColumns="False"
                                  IsReadOnly="True" MaxHeight="200"
                                  Style="{StaticResource {x:Type DataGrid}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Category" Binding="{Binding Category}" Width="*"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='₹{0:N0}'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ IRONING SECTION ═══ -->
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Ironing" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource FluentTextPrimary}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ToolbarButtonStyle}"
                                    Command="{Binding ExportIroningCsvCommand}"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="COUNT" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding IroningCount}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="TOTAL" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding IroningTotal, StringFormat='₹{0:N0}'}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="PAID" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding IroningPaid, StringFormat='₹{0:N0}'}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource FluentSuccess}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="10,6">
                                <StackPanel>
                                    <TextBlock Text="UNPAID" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding IroningUnpaid, StringFormat='₹{0:N0}'}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource FluentError}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        <DataGrid ItemsSource="{Binding IroningRecent}" AutoGenerateColumns="False"
                                  IsReadOnly="True" MaxHeight="200"
                                  Style="{StaticResource {x:Type DataGrid}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='₹{0:N0}'}" Width="100"/>
                                <DataGridCheckBoxColumn Header="Paid" Binding="{Binding IsPaid}" Width="60"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ ORDERS SECTION ═══ -->
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Orders" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource FluentTextPrimary}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ToolbarButtonStyle}"
                                    Command="{Binding ExportOrderCsvCommand}"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="COUNT" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding OrderCount}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="TOTAL" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding OrderTotal, StringFormat='₹{0:N0}'}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="DELIVERED" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding OrderDelivered}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource FluentSuccess}"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="10,6">
                                <StackPanel>
                                    <TextBlock Text="PENDING" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding OrderPending}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource FluentWarning}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        <DataGrid ItemsSource="{Binding OrderRecent}" AutoGenerateColumns="False"
                                  IsReadOnly="True" MaxHeight="200"
                                  Style="{StaticResource {x:Type DataGrid}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding Date, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Customer" Binding="{Binding CustomerName}" Width="*"/>
                                <DataGridTextColumn Header="Amount" Binding="{Binding Amount, StringFormat='₹{0:N0}'}" Width="100"/>
                                <DataGridTextColumn Header="Status" Binding="{Binding Status}" Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ INWARD SECTION ═══ -->
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Inward" FontSize="16" FontWeight="SemiBold"
                                       Foreground="{StaticResource FluentTextPrimary}"/>
                            <Button Grid.Column="1" Content="Export CSV" Style="{StaticResource ToolbarButtonStyle}"
                                    Command="{Binding ExportInwardCsvCommand}"/>
                        </Grid>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="COUNT" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding InwardCount}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="10,6">
                                <StackPanel>
                                    <TextBlock Text="TOTAL" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding InwardTotal, StringFormat='₹{0:N0}'}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                        <DataGrid ItemsSource="{Binding InwardRecent}" AutoGenerateColumns="False"
                                  IsReadOnly="True" MaxHeight="200"
                                  Style="{StaticResource {x:Type DataGrid}}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Date" Binding="{Binding InwardDate, StringFormat=d}" Width="100"/>
                                <DataGridTextColumn Header="Vendor" Binding="{Binding Vendor.Name}" Width="*"/>
                                <DataGridTextColumn Header="Transport" Binding="{Binding TransportCharges, StringFormat='₹{0:N0}'}" Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>

                <!-- ═══ DEBTORS SECTION ═══ -->
                <Border Style="{StaticResource CardStyle}" Padding="16" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Debtors" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextPrimary}"/>
                        <WrapPanel Margin="0,8,0,8">
                            <Border Style="{StaticResource CardStyle}" Padding="10,6" Margin="0,0,8,0">
                                <StackPanel>
                                    <TextBlock Text="PENDING" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DebtorCount}" FontSize="16" FontWeight="Bold"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Padding="10,6">
                                <StackPanel>
                                    <TextBlock Text="OUTSTANDING" FontSize="10" Foreground="{StaticResource FluentTextTertiary}" FontWeight="SemiBold"/>
                                    <TextBlock Text="{Binding DebtorOutstanding, StringFormat='₹{0:N0}'}" FontSize="16" FontWeight="Bold"
                                               Foreground="{StaticResource FluentError}"/>
                                </StackPanel>
                            </Border>
                        </WrapPanel>

                        <TextBlock Text="Top Debtors" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,4"
                                   Foreground="{StaticResource FluentTextSecondary}"/>
                        <ItemsControl ItemsSource="{Binding TopDebtors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Name}" FontSize="13"/>
                                        <TextBlock Grid.Column="1" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource FluentError}">
                                            <TextBlock.Text>
                                                <Binding Path="Balance" StringFormat="₹{0:N0}"/>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
