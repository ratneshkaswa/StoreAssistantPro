<UserControl x:Class="StoreAssistantPro.Modules.Brands.Views.BrandsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Loaded="OnLoaded">
    <UserControl.InputBindings>
        <KeyBinding Gesture="Ctrl+N" Command="{Binding ShowAddFormCommand}"/>
        <KeyBinding Gesture="Ctrl+E" Command="{Binding ShowEditFormCommand}"/>
        <KeyBinding Gesture="Ctrl+Shift+E" Command="{Binding ExportBrandsCommand}"/>
        <KeyBinding Gesture="Delete" Command="{Binding DeleteBrandCommand}"/>
    </UserControl.InputBindings>
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Row 0: Title     -->
            <RowDefinition Height="Auto"/>  <!-- Row 1: Tip banner -->
            <RowDefinition Height="Auto"/>  <!-- Row 2: Toolbar   -->
            <RowDefinition Height="Auto"/>  <!-- Row 3: Add form  -->
            <RowDefinition Height="Auto"/>  <!-- Row 4: Edit form -->
            <RowDefinition Height="Auto"/>  <!-- Row 5: Messages  -->
            <RowDefinition Height="*"/>     <!-- Row 6: Data area -->
        </Grid.RowDefinitions>

        <TextBlock Text="Brands" Style="{StaticResource PageTitleStyle}"/>

        <!-- Tip banner -->
        <controls:InlineTipBanner Grid.Row="1"
            h:TipBannerAutoState.TipKey="BrandsView.QuickTip"
            h:TipBannerAutoState.ContextKey="Brands"
            Title="Quick tip"
            TipText="Organise your products by brand for easy filtering and reporting."/>

        <!-- Toolbar -->
        <Grid Grid.Row="2" Margin="{StaticResource ToolbarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Grid Margin="{StaticResource InlineControlSpacing}" Grid.Column="0">
                <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         h:Watermark.Text="🔍 Search brands..."
                         VerticalContentAlignment="Center" HorizontalAlignment="Stretch"/>
            </Grid>
            <Button Grid.Column="1" Content="➕ Add" Command="{Binding ShowAddFormCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.ShortcutText="Ctrl+N"
                    h:HelpHint.HelpText="Add a new brand"
                    h:HelpHint.Category="Brands"
                    Visibility="{Binding CanManageBrands, Converter={StaticResource BoolToVisibility}}"/>
            <Button Grid.Column="2" Content="✏️ Edit" Command="{Binding ShowEditFormCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.ShortcutText="Double-click row"
                    h:HelpHint.HelpText="Edit the selected brand"
                    h:HelpHint.Category="Brands"
                    Visibility="{Binding CanManageBrands, Converter={StaticResource BoolToVisibility}}"/>
            <Button Grid.Column="3" Content="📤 Export" Command="{Binding ExportBrandsCommand}"
                    Style="{StaticResource ToolbarButtonStyle}"
                    h:HelpHint.ShortcutText="Ctrl+Shift+E"
                    h:HelpHint.HelpText="Export all brands to CSV"
                    h:HelpHint.Category="Brands"/>
            <Button Grid.Column="4" Content="🗑 Delete" Command="{Binding DeleteBrandCommand}"
                    Style="{StaticResource ToolbarButtonStyle}" Margin="0"
                    h:HelpHint.HelpText="Delete the selected brand (requires Master PIN)"
                    h:HelpHint.Category="Brands"
                    Visibility="{Binding CanDeleteBrands, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>

        <!-- Inline Add Brand Form -->
        <Border Grid.Row="3" Style="{StaticResource FormCardStyle}"
                Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVisibility}}"
                h:KeyboardNav.DefaultCommand="{Binding SaveBrandCommand}"
                h:KeyboardNav.EscapeCommand="{Binding CancelAddCommand}"
                h:Motion.SlideFadeReveal="True">
            <StackPanel>
                <TextBlock Text="New Brand" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding NewBrandName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}" VerticalAlignment="Bottom">
                        <CheckBox Content="Active"
                                  IsChecked="{Binding NewBrandIsActive}"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Save" Command="{Binding SaveBrandCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"/>
                            <Button Content="Cancel" Command="{Binding CancelAddCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- Inline Edit Brand Form -->
        <Border Grid.Row="4" Style="{StaticResource FormCardStyle}"
                Background="{StaticResource FluentSuccessBackground}"
                Visibility="{Binding IsEditFormVisible, Converter={StaticResource BoolToVisibility}}"
                h:KeyboardNav.DefaultCommand="{Binding SaveEditCommand}"
                h:KeyboardNav.EscapeCommand="{Binding CancelEditCommand}"
                h:Motion.SlideFadeReveal="True">
            <StackPanel>
                <TextBlock Text="Edit Brand" Style="{StaticResource SectionHeaderStyle}"/>
                <WrapPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}">
                        <TextBlock Text="Name" Style="{StaticResource FieldLabelStyle}"/>
                        <TextBox Text="{Binding EditBrandName, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthStandard}"/>
                    </StackPanel>
                    <StackPanel Margin="{StaticResource WrapFieldGap}" VerticalAlignment="Bottom">
                        <CheckBox Content="Active"
                                  IsChecked="{Binding EditBrandIsActive}"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Bottom">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="💾 Update" Command="{Binding SaveEditCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}"/>
                            <Button Content="Cancel" Command="{Binding CancelEditCommand}"
                                    Style="{StaticResource ToolbarButtonStyle}" Margin="0"/>
                        </StackPanel>
                    </StackPanel>
                </WrapPanel>
            </StackPanel>
        </Border>

        <TextBlock Grid.Row="5" Text="{Binding ErrorMessage}"
                   Style="{StaticResource ErrorMessageStyle}"/>

        <!-- Data area -->
        <Grid Grid.Row="6">
            <!-- Loading Indicator -->
            <TextBlock Text="⏳ Loading..." FontSize="{StaticResource FontSizeSectionHeader}"
                       Foreground="{StaticResource FluentTextTertiary}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>

            <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                      ItemsSource="{Binding Brands}"
                      SelectedItem="{Binding SelectedBrand}"
                      MouseDoubleClick="OnDataGridDoubleClick">
                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow" BasedOn="{StaticResource {x:Type DataGridRow}}">
                        <Setter Property="h:RowHighlight.Level" Value="{Binding HighlightLevel}"/>
                    </Style>
                </DataGrid.RowStyle>
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="{StaticResource ColumnWidthId}"/>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Products" Binding="{Binding Products.Count}" Width="{StaticResource ColumnWidthQty}"/>
                    <DataGridTextColumn Header="Status"
                                        Binding="{Binding IsActive, Converter={StaticResource BoolToActiveText}}"
                                        Width="{StaticResource ColumnWidthStatus}"/>
                </DataGrid.Columns>
            </DataGrid>

                <controls:EmptyStateOverlay
                    Icon="🏷"
                    Title="No brands found"
                    Description="Organise your products by brand for easy filtering and reporting."
                    ActionText="➕ Add Brand"
                    ActionCommand="{Binding ShowAddFormCommand}"
                    ItemCount="{Binding Brands.Count}"/>
            </Grid>
    </Grid>
</UserControl>
