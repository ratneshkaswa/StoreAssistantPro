<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Brands.Views.BrandManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        Title="Brand Management"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Title -->
            <RowDefinition Height="*"/>     <!-- DataGrid -->
            <RowDefinition Height="Auto"/>  <!-- Form -->
            <RowDefinition Height="Auto"/>  <!-- Buttons -->
            <RowDefinition Height="Auto"/>  <!-- Messages -->
            <RowDefinition Height="Auto"/>  <!-- Close -->
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="&#x1F3F7; Brand Management" Style="{StaticResource DialogTitleStyle}"/>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Brands}"
                  SelectedItem="{Binding SelectedBrand}"
                  AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionMode="Single"
                  HeadersVisibility="Column" CanUserAddRows="False"
                  Margin="{StaticResource ItemSpacing}">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Brand" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="Products" Binding="{Binding ProductCount}" Width="{StaticResource ColumnWidthQty}"/>
                <DataGridCheckBoxColumn Header="Active" Binding="{Binding IsActive, Mode=OneWay}" Width="{StaticResource ColumnWidthQty}"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- Form -->
        <Grid Grid.Row="2" Margin="{StaticResource StepContentTopSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                <Run Text="Brand Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
            </TextBlock>
            <TextBox Grid.Column="1"
                     Text="{Binding BrandName, UpdateSourceTrigger=PropertyChanged}"
                     Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                     MaxLength="100" h:Watermark.Text="e.g. Raymond"/>
        </Grid>

        <!-- Buttons -->
        <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="1" Content="Clear" Command="{Binding ClearFormCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Grid.Column="2" Content="Toggle Active" Command="{Binding ToggleActiveCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Grid.Column="3" Content="&#x1F4BE; Save" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- Messages -->
        <StackPanel Grid.Row="4" MinHeight="{StaticResource MessageAreaMinHeight}"
                    Margin="{StaticResource FieldLabelSpacing}">
            <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"/>
            <TextBlock Text="{Binding SuccessMessage}" Style="{StaticResource SuccessMessageStyle}"
                       h:AutoDismiss.IsEnabled="True" h:AutoDismiss.Seconds="4"/>
        </StackPanel>

        <!-- Close -->
        <Grid Grid.Row="5" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Grid.Column="1" Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </Grid>
    </Grid>
</core:BaseDialogWindow>
