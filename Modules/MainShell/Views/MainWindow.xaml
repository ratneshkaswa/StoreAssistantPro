 <Window x:Class="StoreAssistantPro.Modules.MainShell.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}">

    <!-- InputBindings are generated at runtime by ShortcutService -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP MENU BAR -->
        <Menu Grid.Row="0" Style="{StaticResource FluentMenuBarStyle}"
              ItemContainerStyle="{StaticResource FluentMenuBarItemStyle}"
              h:BillingDimBehavior.DimOnLock="True"
              h:BillingDimBehavior.IsLocked="{Binding FocusLock.IsFocusLocked}">

            <MenuItem Header="_File">
                <MenuItem Header="_Home" Command="{Binding NavigateToMainWorkspaceCommand}"
                          InputGestureText="Ctrl+D"
                          h:SmartTooltip.ContextKey="Home"/>
                <MenuItem Header="_Products" Command="{Binding NavigateToProductsCommand}"
                          InputGestureText="Ctrl+P"
                          h:SmartTooltip.ContextKey="Products"
                          Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="_Brands" Command="{Binding NavigateToBrandsCommand}"
                          h:SmartTooltip.ContextKey="Brands"
                          Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="_Sales" Command="{Binding NavigateToSalesCommand}"
                          InputGestureText="Ctrl+S"
                          h:SmartTooltip.ContextKey="NewBill"
                          Visibility="{Binding IsSalesEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="S_uppliers" Command="{Binding NavigateToSuppliersCommand}"/>
                <Separator/>
                <MenuItem Header="_Logout" Command="{Binding LogoutCommand}"
                          InputGestureText="Ctrl+L"
                          h:SmartTooltip.ContextKey="Logout"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Home" Command="{Binding NavigateToMainWorkspaceCommand}"
                          InputGestureText="Ctrl+D"
                          h:SmartTooltip.ContextKey="Home"/>
                <MenuItem Header="Products" Command="{Binding NavigateToProductsCommand}"
                          InputGestureText="Ctrl+P"
                          h:SmartTooltip.ContextKey="Products"
                          Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="Brands" Command="{Binding NavigateToBrandsCommand}"
                          h:SmartTooltip.ContextKey="Brands"
                          Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="Sales History" Command="{Binding NavigateToSalesCommand}"
                          InputGestureText="Ctrl+S"
                          h:SmartTooltip.ContextKey="NewBill"
                          Visibility="{Binding IsSalesEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="Suppliers" Command="{Binding NavigateToSuppliersCommand}"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="Firm Management" Command="{Binding OpenFirmManagementCommand}"
                          h:SmartTooltip.ContextKey="Firm"
                          Visibility="{Binding IsFirmManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="User Management" Command="{Binding OpenUserManagementCommand}"
                          h:SmartTooltip.ContextKey="Users"
                          Visibility="{Binding IsUserManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="Tax Management" Command="{Binding OpenTaxManagementCommand}"
                          h:SmartTooltip.ContextKey="Tax"
                          Visibility="{Binding IsTaxManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="System Settings" Command="{Binding OpenSystemSettingsCommand}"
                          h:SmartTooltip.ContextKey="Settings"
                          Visibility="{Binding IsSystemSettingsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="Refresh Data" Command="{Binding RefreshCurrentViewCommand}"
                          InputGestureText="F5"
                          h:SmartTooltip.ContextKey="Refresh"/>
            </MenuItem>

            <MenuItem Header="_Billing"
                      Visibility="{Binding IsBillingEnabled, Converter={StaticResource BoolToVisibility}}">
                <MenuItem Header="New Sale" Command="{Binding NavigateToSalesCommand}"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="About Store Assistant Pro" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- QUICK ACTION BAR -->
        <Border Grid.Row="1" Style="{StaticResource FluentToolbarStyle}"
                h:BillingDimBehavior.DimOnLock="True"
                h:BillingDimBehavior.DimOpacity="0.55"
                h:BillingDimBehavior.IsLocked="{Binding FocusLock.IsFocusLocked}">
            <DockPanel>
                <!-- Mode toggle + indicator (right-docked) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="{StaticResource SidebarNavItemPadding}">

                    <!-- Notification bell -->
                    <Grid Margin="{StaticResource FormColumnGap}" VerticalAlignment="Center">
                        <Button x:Name="NotificationBellButton"
                                Command="{Binding ToggleNotificationsPanelCommand}"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="6,4"
                                h:HelpHint.HelpText="View notifications"
                                h:HelpHint.Category="Navigation">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BellBorder" Background="Transparent"
                                            CornerRadius="{StaticResource FluentCornerMedium}"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid h:NotificationBadgeBehavior.Count="{Binding AppState.UnreadNotificationCount}">
                                            <TextBlock Text="🔔" FontSize="{StaticResource FontSizeIconMedium}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                         <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BellBorder" Property="Background"
                                                    Value="{StaticResource FluentSubtleHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="BellBorder" Property="Background"
                                                    Value="{StaticResource FluentSubtlePressed}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Notification popup — anchored below bell, auto-closes on outside click -->
                        <Popup PlacementTarget="{Binding ElementName=NotificationBellButton}"
                               Placement="Bottom" HorizontalOffset="-280"
                               StaysOpen="False" AllowsTransparency="True"
                               IsOpen="{Binding IsNotificationsPanelVisible, Mode=TwoWay}">
                            <Border Width="{StaticResource NotificationPanelWidth}" MaxHeight="400"
                                    Background="{StaticResource FluentSurface}"
                                    BorderBrush="{StaticResource FluentSurfaceStroke}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource FluentCornerLarge}"
                                    SnapsToDevicePixels="True"
                                    Effect="{StaticResource FluentShadowMedium}"
                                    h:Motion.SlideFadeIn="True">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0"
                                            Background="{StaticResource FluentSurfaceElevated}"
                                            CornerRadius="12,12,0,0" Padding="12,8">
                                        <DockPanel>
                                            <TextBlock Text="Notifications"
                                                       FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{StaticResource FluentTextPrimary}"
                                                       VerticalAlignment="Center"
                                                       DockPanel.Dock="Left"/>
                                            <Button Content="Mark all read"
                                                    Style="{StaticResource ToolbarLinkButtonStyle}"
                                                    Foreground="{StaticResource FluentAccentDefault}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding MarkAllNotificationsReadCommand}"/>
                                        </DockPanel>
                                    </Border>

                                    <!-- Notification list -->
                                    <ScrollViewer Grid.Row="1"
                                                  VerticalScrollBarVisibility="Auto"
                                                  HorizontalScrollBarVisibility="Disabled"
                                                  Padding="0">
                                        <ItemsControl ItemsSource="{Binding AppState.Notifications}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="12,8"
                                                            BorderBrush="{StaticResource FluentSurfaceStroke}"
                                                            BorderThickness="0,0,0,1"
                                                            Cursor="Hand"
                                                            Background="Transparent">
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick"
                                                                Command="{Binding DataContext.MarkNotificationReadCommand,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                                        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Level indicator dot -->
                                                            <Ellipse Grid.Column="0" Grid.RowSpan="2"
                                                                     Width="8" Height="8"
                                                                     VerticalAlignment="Top"
                                                                     Margin="0,4,8,0">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Fill" Value="{StaticResource FluentAccentDefault}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                                <Setter Property="Fill" Value="{StaticResource FluentWarning}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                                <Setter Property="Fill" Value="{StaticResource FluentError}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Success">
                                                                                <Setter Property="Fill" Value="{StaticResource FluentSuccess}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>

                                                            <!-- Title + timestamp -->
                                                            <DockPanel Grid.Column="1" Grid.Row="0">
                                                                <TextBlock Text="{Binding Timestamp, StringFormat=HH:mm}"
                                                                           Foreground="{StaticResource FluentTextTertiary}" FontSize="{StaticResource FontSizeStatusBar}"
                                                                           DockPanel.Dock="Right"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeLabel}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </DockPanel>

                                                            <!-- Message -->
                                                            <TextBlock Grid.Column="1" Grid.Row="1"
                                                                       Text="{Binding Message}"
                                                                       Foreground="{StaticResource FluentTextSecondary}" FontSize="{StaticResource FontSizeCaption}"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxHeight="34" Margin="0,2,0,0"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <!-- Empty state (shown when no notifications) -->
                                    <TextBlock Grid.Row="1" Text="No notifications"
                                               Foreground="{StaticResource FluentTextTertiary}"
                                               FontStyle="Italic" FontSize="{StaticResource FontSizeLabel}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Margin="{StaticResource EmptyStatePadding}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AppState.Notifications.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Footer -->
                                    <Border Grid.Row="2" BorderBrush="{StaticResource FluentSurfaceStroke}"
                                            BorderThickness="0,1,0,0" Padding="12,6"
                                            CornerRadius="0,0,6,6">
                                        <Button Content="Clear all"
                                                Style="{StaticResource ToolbarLinkButtonStyle}"
                                                Foreground="{StaticResource FluentError}"
                                                HorizontalAlignment="Center"
                                                Command="{Binding ClearNotificationsCommand}"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>

                    <Border Margin="{StaticResource InlineControlSpacing}"
                            h:StatusPillTransition.AnimateChanges="True">
                        <Border.Style>
                            <Style TargetType="Border" BasedOn="{StaticResource StatusBadgePillStyle}">
                                <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBillingMode}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource FluentSuccess}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontWeight="SemiBold" FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentTextOnAccent}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🏢 MANAGEMENT"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBillingMode}" Value="True">
                                            <Setter Property="Text" Value="🧾 BILLING"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <Button Command="{Binding ToggleBillingModeCommand}"
                            h:BillingFocusBehavior.AllowFocus="True"
                            h:SmartTooltip.ContextKey="StartBilling"
                            h:SmartTooltip.Header="Billing Mode"
                            h:SmartTooltip.Shortcut="F8"
                            VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button"
                                   BasedOn="{StaticResource EnterpriseActionButtonStyle}">
                                <Setter Property="Content" Value="▶ Start Billing"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBillingMode}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource FluentError}"/>
                                        <Setter Property="Content" Value="⏹ Stop Billing"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Quick actions (left, fills remaining space) -->
                <ItemsControl ItemsSource="{Binding QuickActions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding Command}"
                                    Style="{StaticResource QuickActionButtonStyle}"
                                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- BODY: WORKSPACE -->
        <controls:ResponsiveContentControl Grid.Row="2"
            h:BillingFocusBehavior.IsActive="{Binding FocusLock.IsFocusLocked}"
            h:BillingDimBehavior.HighlightOnLock="True"
            h:BillingDimBehavior.IsLocked="{Binding FocusLock.IsFocusLocked}"
            EnableSlideTransition="True"
            Content="{Binding CurrentView}"/>

        <!-- BOTTOM STATUS BAR -->
        <StatusBar Grid.Row="3" Style="{StaticResource FluentStatusBarStyle}"
                   h:BillingDimBehavior.DimOnLock="True"
                   h:BillingDimBehavior.DimOpacity="0.55"
                   h:BillingDimBehavior.IsLocked="{Binding FocusLock.IsFocusLocked}">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <!-- Firm name -->
            <StatusBarItem Grid.Column="0" Style="{StaticResource FluentStatusBarItemStyle}">
                <TextBlock Text="{Binding AppState.FirmName}" FontWeight="SemiBold"
                           Foreground="{StaticResource FluentTextPrimary}"/>
            </StatusBarItem>

            <!-- Vertical divider -->
            <StatusBarItem Grid.Column="1" Style="{StaticResource FluentStatusBarItemStyle}">
                <Border Style="{StaticResource FluentStatusBarSeparatorStyle}"/>
            </StatusBarItem>

            <!-- Current user -->
            <StatusBarItem Grid.Column="2" Style="{StaticResource FluentStatusBarItemStyle}">
                <TextBlock Text="{Binding DashboardSummary.CurrentUser}"
                           Foreground="{StaticResource FluentSuccess}" FontWeight="SemiBold"/>
            </StatusBarItem>

            <!-- Operational mode indicator -->
            <StatusBarItem Grid.Column="3" Style="{StaticResource FluentStatusBarItemStyle}"
                           Margin="{StaticResource StatusBarPillGap}">
                <Border VerticalAlignment="Center"
                        h:StatusPillTransition.AnimateChanges="True">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadgePillStyle}">
                            <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DashboardSummary.IsBillingMode}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentSuccess}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource InlineLabelGap}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🏢"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DashboardSummary.IsBillingMode}" Value="True">
                                            <Setter Property="Text" Value="🧾"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding DashboardSummary.ModeDisplay}"
                                   Foreground="{StaticResource FluentTextOnAccent}"
                                   FontSize="{StaticResource FontSizeStatusBar}" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StatusBarItem>

            <!-- Focus lock indicator -->
            <StatusBarItem Grid.Column="4" Style="{StaticResource FluentStatusBarItemStyle}"
                           Margin="{StaticResource StatusBarPillGap}">
                <Border VerticalAlignment="Center"
                        h:StatusPillTransition.AnimateChanges="True">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadgePillStyle}">
                            <Setter Property="Background" Value="{StaticResource FluentTextTertiary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusLock.IsFocusLocked}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentError}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource InlineLabelGap}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#x1F513;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusLock.IsFocusLocked}" Value="True">
                                            <Setter Property="Text" Value="&#x1F512;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource FluentTextOnAccent}"
                                   FontSize="{StaticResource FontSizeStatusBar}" FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Normal Mode"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusLock.IsFocusLocked}" Value="True">
                                            <Setter Property="Text" Value="Billing Focus Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StatusBarItem>

            <!-- Connectivity indicator -->
            <StatusBarItem Grid.Column="5" Style="{StaticResource FluentStatusBarItemStyle}"
                           Margin="{StaticResource StatusBarPillGap}">
                <Border VerticalAlignment="Center"
                        h:StatusPillTransition.AnimateChanges="True">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadgePillStyle}">
                            <Setter Property="Background" Value="{StaticResource FluentSuccess}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DashboardSummary.IsOfflineMode}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentError}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource InlineLabelGap}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🟢"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DashboardSummary.IsOfflineMode}" Value="True">
                                            <Setter Property="Text" Value="🔴"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource FluentTextOnAccent}"
                                   FontSize="{StaticResource FontSizeStatusBar}" FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Online"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DashboardSummary.IsOfflineMode}" Value="True">
                                            <Setter Property="Text" Value="Offline"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StatusBarItem>

            <!-- Summary stats -->
            <StatusBarItem Grid.Column="6" Style="{StaticResource FluentStatusBarItemStyle}"
                           Margin="{StaticResource StatusBarPillGap}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📦" Margin="{StaticResource InlineLabelGap}"/>
                    <TextBlock Text="{Binding DashboardSummary.ProductCount}"
                               Foreground="{StaticResource FluentKpiGreen}" FontWeight="SemiBold"/>
                    <TextBlock Text="⚠" Margin="{StaticResource StatusBarStatGap}"/>
                    <TextBlock Text="{Binding DashboardSummary.LowStockCount}"
                               Foreground="{StaticResource FluentKpiOrange}" FontWeight="SemiBold"/>
                    <TextBlock Text="🚫" Margin="{StaticResource StatusBarStatGap}"/>
                    <TextBlock Text="{Binding DashboardSummary.OutOfStockCount}"
                               Foreground="{StaticResource FluentKpiRed}" FontWeight="SemiBold"/>
                    <TextBlock Text="🏷" Margin="{StaticResource StatusBarStatGap}"/>
                    <TextBlock Text="{Binding DashboardSummary.InventoryValue, StringFormat=C}"
                               Foreground="{StaticResource FluentKpiTeal}" FontWeight="SemiBold"/>
                    <TextBlock Text="💰" Margin="{StaticResource StatusBarStatGap}"/>
                    <TextBlock Text="{Binding DashboardSummary.TodaysSales, StringFormat=C}"
                               Foreground="{StaticResource FluentKpiBlue}" FontWeight="SemiBold"/>
                    <TextBlock Text="🧾" Margin="{StaticResource StatusBarStatGap}"/>
                    <TextBlock Text="{Binding DashboardSummary.TodaysTransactions}"
                               Foreground="{StaticResource FluentKpiPurple}" FontWeight="SemiBold"/>
                    <TextBlock Text="🔔" Margin="{StaticResource StatusBarStatGap}"/>
                    <TextBlock Text="{Binding DashboardSummary.NotificationCount}"
                               Foreground="{StaticResource FluentAccentDefault}" FontWeight="SemiBold"/>
                </StackPanel>
            </StatusBarItem>

            <!-- Center: status message -->
            <StatusBarItem Grid.Column="7" Style="{StaticResource FluentStatusBarItemStyle}"
                           HorizontalContentAlignment="Center">
                <TextBlock Text="{Binding StatusBar.Message}"
                           Foreground="{StaticResource FluentTextTertiary}"
                           FontStyle="Italic"/>
            </StatusBarItem>

            <!-- Clock -->
            <StatusBarItem Grid.Column="8" Style="{StaticResource FluentStatusBarItemStyle}">
                <TextBlock Text="{Binding DashboardSummary.CurrentTime}"
                           Foreground="{StaticResource FluentTextPrimary}" FontWeight="SemiBold"/>
            </StatusBarItem>

            <!-- Vertical divider -->
            <StatusBarItem Grid.Column="9" Style="{StaticResource FluentStatusBarItemStyle}">
                <Border Style="{StaticResource FluentStatusBarSeparatorStyle}"/>
            </StatusBarItem>

            <!-- Logout -->
            <StatusBarItem Grid.Column="10" Style="{StaticResource FluentStatusBarItemStyle}">
                <Button Content="Logout" Command="{Binding LogoutCommand}"
                        h:BillingFocusBehavior.AllowFocus="True"
                        Style="{StaticResource ToolbarLinkButtonStyle}"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>