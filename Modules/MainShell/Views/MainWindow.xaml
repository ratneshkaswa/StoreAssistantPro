<Window x:Class="StoreAssistantPro.Modules.MainShell.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}">

    <!-- InputBindings are generated at runtime by ShortcutService -->

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP MENU BAR -->
        <Menu Grid.Row="0" Background="#2D2D30" Foreground="#B0B0B0" Padding="4,2">
            <Menu.ItemContainerStyle>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#B0B0B0"/>
                    <Setter Property="Padding" Value="8,4"/>
                </Style>
            </Menu.ItemContainerStyle>

            <MenuItem Header="_File">
                <MenuItem Header="_Home" Command="{Binding NavigateToMainWorkspaceCommand}"
                          InputGestureText="Ctrl+D"/>
                <MenuItem Header="_Products" Command="{Binding NavigateToProductsCommand}"
                          InputGestureText="Ctrl+P"
                          Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="_Sales" Command="{Binding NavigateToSalesCommand}"
                          InputGestureText="Ctrl+S"
                          Visibility="{Binding IsSalesEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="_Logout" Command="{Binding LogoutCommand}"
                          InputGestureText="Ctrl+L"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Home" Command="{Binding NavigateToMainWorkspaceCommand}"/>
                <MenuItem Header="Products" Command="{Binding NavigateToProductsCommand}"
                          Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="Sales History" Command="{Binding NavigateToSalesCommand}"
                          Visibility="{Binding IsSalesEnabled, Converter={StaticResource BoolToVisibility}}"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="Firm Management" Command="{Binding OpenFirmManagementCommand}"
                          Visibility="{Binding IsFirmManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="User Management" Command="{Binding OpenUserManagementCommand}"
                          Visibility="{Binding IsUserManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="Tax Management" Command="{Binding OpenTaxManagementCommand}"
                          Visibility="{Binding IsTaxManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="System Settings" Command="{Binding OpenSystemSettingsCommand}"
                          Visibility="{Binding IsSystemSettingsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="Refresh Data" Command="{Binding RefreshCurrentViewCommand}"
                          InputGestureText="F5"/>
            </MenuItem>

            <MenuItem Header="_Billing"
                      Visibility="{Binding IsBillingEnabled, Converter={StaticResource BoolToVisibility}}">
                <MenuItem Header="New Sale" Command="{Binding NavigateToSalesCommand}"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="About Store Assistant Pro" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- QUICK ACTION BAR -->
        <Border Grid.Row="1" Background="#F5F5F5" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Padding="12,6">
            <DockPanel>
                <!-- Mode toggle + indicator (right-docked) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="12,0,0,0">
                    <Border CornerRadius="4" Padding="8,3" Margin="0,0,8,0">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="#E8EAF6"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBillingMode}" Value="True">
                                        <Setter Property="Background" Value="#C8E6C9"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <TextBlock FontWeight="SemiBold" FontSize="11">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🏢 MANAGEMENT"/>
                                    <Setter Property="Foreground" Value="#3949AB"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsBillingMode}" Value="True">
                                            <Setter Property="Text" Value="🧾 BILLING"/>
                                            <Setter Property="Foreground" Value="#2E7D32"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Border>
                    <Button Command="{Binding ToggleBillingModeCommand}"
                            h:BillingFocusBehavior.AllowFocus="True"
                            Padding="10,4" Cursor="Hand" FontSize="12"
                            FontWeight="SemiBold" VerticalAlignment="Center">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Background" Value="#1976D2"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Content" Value="▶ Start Billing"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    CornerRadius="4"
                                                    Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsBillingMode}" Value="True">
                                        <Setter Property="Background" Value="#E53935"/>
                                        <Setter Property="Content" Value="⏹ Stop Billing"/>
                                    </DataTrigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.85"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>

                <!-- Quick actions (left, fills remaining space) -->
                <ItemsControl ItemsSource="{Binding QuickActions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding Command}"
                                    Style="{StaticResource QuickActionButtonStyle}"
                                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- BODY: SIDEBAR + WORKSPACE -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR NAVIGATION -->
            <Border Grid.Column="0" Background="#2D2D30">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Opacity" Value="1"/>
                        <Setter Property="IsHitTestVisible" Value="True"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding FocusLock.IsFocusLocked}" Value="True">
                                <DataTrigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="0.4" Duration="0:0:0.25"
                                                             EasingFunction="{StaticResource PanelDimEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.EnterActions>
                                <DataTrigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                             To="1.0" Duration="0:0:0.2"
                                                             EasingFunction="{StaticResource PanelDimEase}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </DataTrigger.ExitActions>
                                <Setter Property="IsHitTestVisible" Value="False"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,15,0,0">
                        <TextBlock Text="Store Assistant"
                                   Foreground="White" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Pro"
                                   Foreground="#007ACC" FontSize="12" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <Separator Background="#3E3E42" Margin="10,0,10,10"/>

                        <Button Content="Home"
                                Command="{Binding NavigateToMainWorkspaceCommand}"
                                Tag="MainWorkspace"
                                Style="{StaticResource NavButtonStyle}"/>

                        <Button Content="Products"
                                Command="{Binding NavigateToProductsCommand}"
                                Tag="Products"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>

                        <Button Content="Sales"
                                Command="{Binding NavigateToSalesCommand}"
                                Tag="Sales"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsSalesEnabled, Converter={StaticResource BoolToVisibility}}"/>

                        <Separator Background="#3E3E42" Margin="10,10,10,10"/>

                        <Button Content="Billing"
                                Command="{Binding NavigateToSalesCommand}"
                                Tag="Sales"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsBillingEnabled, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Admin-only management -->
                        <Separator Background="#3E3E42" Margin="10,10,10,10"
                                   Visibility="{Binding IsFirmManagementVisible, Converter={StaticResource BoolToVisibility}}"/>

                        <Button Content="Firm"
                                Command="{Binding OpenFirmManagementCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsFirmManagementVisible, Converter={StaticResource BoolToVisibility}}"/>

                        <Button Content="Users"
                                Command="{Binding OpenUserManagementCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsUserManagementVisible, Converter={StaticResource BoolToVisibility}}"/>

                        <Button Content="Tax"
                                Command="{Binding OpenTaxManagementCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsTaxManagementVisible, Converter={StaticResource BoolToVisibility}}"/>

                        <Separator Background="#3E3E42" Margin="10,10,10,10"/>

                        <Button Content="Settings"
                                Command="{Binding OpenSystemSettingsCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsSystemSettingsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom"
                               Text="v1.0.0" Foreground="#666"
                               FontSize="10" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <Border/>
                </DockPanel>
            </Border>

            <!-- WORKSPACE: Main Content + Side Panels -->
            <Grid Grid.Column="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" MinWidth="400"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="240"
                                      MaxWidth="320"/>
                </Grid.ColumnDefinitions>

                <!-- LEFT: PRIMARY CONTENT (Billing / Pages) -->
                <controls:ResponsiveContentControl Grid.Column="0"
                    h:BillingFocusBehavior.IsActive="{Binding FocusLock.IsFocusLocked}"
                    Content="{Binding CurrentView}"/>

                <!-- SPLITTER -->
                <GridSplitter Grid.Column="1" Width="4"
                              HorizontalAlignment="Center" VerticalAlignment="Stretch"
                              Background="#E0E0E0" ResizeBehavior="PreviousAndNext">
                    <GridSplitter.Style>
                        <Style TargetType="GridSplitter">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusLock.IsFocusLocked}" Value="True">
                                    <Setter Property="IsEnabled" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </GridSplitter.Style>
                </GridSplitter>

                <!-- RIGHT: TASKS + NOTIFICATIONS -->
                <Grid Grid.Column="2">
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Setter Property="Opacity" Value="1"/>
                            <Setter Property="IsHitTestVisible" Value="True"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusLock.IsFocusLocked}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0.4" Duration="0:0:0.25"
                                                                 EasingFunction="{StaticResource PanelDimEase}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1.0" Duration="0:0:0.2"
                                                                 EasingFunction="{StaticResource PanelDimEase}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                    <Setter Property="IsHitTestVisible" Value="False"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" MinHeight="120"/>
                        <RowDefinition Height="*" MinHeight="120"/>
                    </Grid.RowDefinitions>

                    <!-- Tasks Panel -->
                    <Border Grid.Row="0" Background="#F9F9F9"
                            BorderBrush="#E0E0E0" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#E8F5E9" Padding="12,8">
                                <DockPanel>
                                    <TextBlock Text="Tasks" FontWeight="SemiBold" FontSize="13"
                                               DockPanel.Dock="Left"/>
                                    <Button Content="☰" FontSize="11" Padding="4,1"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#888" Cursor="Hand"
                                            HorizontalAlignment="Right"
                                            Command="{Binding ToggleTasksPanelCommand}"/>
                                </DockPanel>
                            </Border>
                            <TextBlock Text="No pending tasks"
                                       Foreground="#999" FontStyle="Italic"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- Notifications Panel -->
                    <Border Grid.Row="1" Background="#F9F9F9"
                            BorderBrush="#E0E0E0" BorderThickness="0">
                        <DockPanel>
                            <Border DockPanel.Dock="Top" Background="#E3F2FD" Padding="12,8">
                                <DockPanel>
                                    <TextBlock Text="Notifications" FontWeight="SemiBold" FontSize="13"
                                               DockPanel.Dock="Left"/>
                                    <TextBlock Text="{Binding AppState.UnreadNotificationCount}"
                                               Foreground="#1976D2" FontWeight="Bold" FontSize="12"
                                               Margin="6,0,0,0" VerticalAlignment="Center"
                                               DockPanel.Dock="Left"/>
                                    <Button Content="☰" FontSize="11" Padding="4,1"
                                            Background="Transparent" BorderThickness="0"
                                            Foreground="#888" Cursor="Hand"
                                            HorizontalAlignment="Right"
                                            Command="{Binding ToggleNotificationsPanelCommand}"/>
                                </DockPanel>
                            </Border>
                            <TextBlock Text="No new notifications"
                                       Foreground="#999" FontStyle="Italic"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>

        <!-- BOTTOM STATUS BAR -->
        <StatusBar Grid.Row="3" Background="#1E1E1E" Foreground="#B0B0B0" Padding="8,4">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding AppState.FirmName}" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="1">
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                    <TextBlock Text="{Binding DashboardSummary.CurrentUser}" Foreground="#4CAF50" FontWeight="SemiBold"/>
                </StackPanel>
            </StatusBarItem>

            <!-- Operational mode indicator -->
            <StatusBarItem Grid.Column="2" Margin="16,0,0,0">
                <Border CornerRadius="3" Padding="10,2" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#3949AB"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DashboardSummary.IsBillingMode}" Value="True">
                                    <Setter Property="Background" Value="#2E7D32"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="11" Margin="0,0,5,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🏢"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DashboardSummary.IsBillingMode}" Value="True">
                                            <Setter Property="Text" Value="🧾"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding DashboardSummary.ModeDisplay}"
                                   Foreground="White" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StatusBarItem>

            <!-- Focus lock indicator -->
            <StatusBarItem Grid.Column="3" Margin="10,0,0,0">
                <Border CornerRadius="3" Padding="8,2" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#37474F"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding FocusLock.IsFocusLocked}" Value="True">
                                    <Setter Property="Background" Value="#B71C1C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="11" Margin="0,0,5,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="&#x1F513;"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusLock.IsFocusLocked}" Value="True">
                                            <Setter Property="Text" Value="&#x1F512;"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Foreground="White" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Normal Mode"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FocusLock.IsFocusLocked}" Value="True">
                                            <Setter Property="Text" Value="Billing Focus Active"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StatusBarItem>

            <!-- Connectivity indicator -->
            <StatusBarItem Grid.Column="4" Margin="10,0,0,0">
                <Border CornerRadius="3" Padding="8,2" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#1B5E20"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DashboardSummary.IsOfflineMode}" Value="True">
                                    <Setter Property="Background" Value="#B71C1C"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock VerticalAlignment="Center" FontSize="11" Margin="0,0,5,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🟢"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DashboardSummary.IsOfflineMode}" Value="True">
                                            <Setter Property="Text" Value="🔴"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Foreground="White" FontSize="10" FontWeight="Bold"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Online Mode"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DashboardSummary.IsOfflineMode}" Value="True">
                                            <Setter Property="Text" Value="Offline Mode (Local Save Active)"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StatusBarItem>

            <!-- Summary stats -->
            <StatusBarItem Grid.Column="5">
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                    <TextBlock Text="📦" Margin="0,0,3,0"/>
                    <TextBlock Text="{Binding DashboardSummary.ProductCount}" Foreground="#81C784"/>
                    <TextBlock Text="⚠" Margin="12,0,3,0"/>
                    <TextBlock Text="{Binding DashboardSummary.LowStockCount}" Foreground="#FFB74D"/>
                    <TextBlock Text="💰" Margin="12,0,3,0"/>
                    <TextBlock Text="{Binding DashboardSummary.TodaysSales, StringFormat=C}" Foreground="#64B5F6"/>
                    <TextBlock Text="🧾" Margin="12,0,3,0"/>
                    <TextBlock Text="{Binding DashboardSummary.TodaysTransactions}" Foreground="#CE93D8"/>
                    <TextBlock Text="🔔" Margin="12,0,3,0"/>
                    <TextBlock Text="{Binding DashboardSummary.NotificationCount}" Foreground="#90CAF9"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="6" HorizontalContentAlignment="Center">
                <TextBlock Text="{Binding StatusBar.Message}" Foreground="#888"/>
            </StatusBarItem>

            <StatusBarItem Grid.Column="7">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="{Binding DashboardSummary.CurrentTime}" Foreground="White" FontWeight="SemiBold"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="8">
                <TextBlock Text="|" Foreground="#555" Margin="0,0,10,0"/>
            </StatusBarItem>

            <StatusBarItem Grid.Column="9">
                <Button Content="Logout" Command="{Binding LogoutCommand}"
                        h:BillingFocusBehavior.AllowFocus="True"
                        Foreground="#B0B0B0" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="4,2" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>