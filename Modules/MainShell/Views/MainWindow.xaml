<Window x:Class="StoreAssistantPro.Modules.MainShell.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}">
    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+D" Command="{Binding NavigateToDashboardCommand}"/>
        <KeyBinding Gesture="Ctrl+P" Command="{Binding NavigateToProductsCommand}"/>
        <KeyBinding Gesture="Ctrl+S" Command="{Binding NavigateToSalesCommand}"/>
        <KeyBinding Gesture="Ctrl+L" Command="{Binding LogoutCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP MENU BAR -->
        <Menu Grid.Row="0" Background="#2D2D30" Foreground="#B0B0B0" Padding="4,2">
            <Menu.ItemContainerStyle>
                <Style TargetType="MenuItem">
                    <Setter Property="Foreground" Value="#B0B0B0"/>
                    <Setter Property="Padding" Value="8,4"/>
                </Style>
            </Menu.ItemContainerStyle>

            <MenuItem Header="_File">
                <MenuItem Header="_Dashboard" Command="{Binding NavigateToDashboardCommand}"
                          InputGestureText="Ctrl+D"/>
                <MenuItem Header="_Products" Command="{Binding NavigateToProductsCommand}"
                          InputGestureText="Ctrl+P"
                          Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="_Sales" Command="{Binding NavigateToSalesCommand}"
                          InputGestureText="Ctrl+S"
                          Visibility="{Binding IsSalesEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="_Logout" Command="{Binding LogoutCommand}"
                          InputGestureText="Ctrl+L"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Dashboard" Command="{Binding NavigateToDashboardCommand}"/>
                <MenuItem Header="Products" Command="{Binding NavigateToProductsCommand}"
                          Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="Sales History" Command="{Binding NavigateToSalesCommand}"
                          Visibility="{Binding IsSalesEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="Notifications" IsCheckable="True"
                          IsChecked="{Binding IsNotificationsPanelVisible}"/>
                <MenuItem Header="Tasks" IsCheckable="True"
                          IsChecked="{Binding IsTasksPanelVisible}"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <MenuItem Header="Firm Management" Command="{Binding OpenFirmManagementCommand}"
                          Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="User Management" Command="{Binding OpenUserManagementCommand}"
                          Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="System Settings" Command="{Binding OpenSystemSettingsCommand}"
                          Visibility="{Binding IsSystemSettingsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                <Separator/>
                <MenuItem Header="Refresh Data" Command="{Binding RefreshCurrentViewCommand}"/>
            </MenuItem>

            <MenuItem Header="_Billing"
                      Visibility="{Binding IsBillingEnabled, Converter={StaticResource BoolToVisibility}}">
                <MenuItem Header="New Sale" Command="{Binding NavigateToSalesCommand}"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="About Store Assistant Pro" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- BODY: SIDEBAR + CONTENT + PANELS -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- SIDEBAR NAVIGATION -->
            <Border Grid.Column="0" Background="#2D2D30">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Top" Margin="0,15,0,0">
                        <TextBlock Text="Store Assistant"
                                   Foreground="White" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,4"/>
                        <TextBlock Text="Pro"
                                   Foreground="#007ACC" FontSize="12" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,0,0,15"/>
                        <Separator Background="#3E3E42" Margin="10,0,10,10"/>

                        <Button Content="Dashboard"
                                Command="{Binding NavigateToDashboardCommand}"
                                Tag="Dashboard"
                                Style="{StaticResource NavButtonStyle}"/>

                        <Button Content="Products"
                                Command="{Binding NavigateToProductsCommand}"
                                Tag="Products"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsProductsEnabled, Converter={StaticResource BoolToVisibility}}"/>

                        <Button Content="Sales"
                                Command="{Binding NavigateToSalesCommand}"
                                Tag="Sales"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsSalesEnabled, Converter={StaticResource BoolToVisibility}}"/>

                        <Separator Background="#3E3E42" Margin="10,10,10,10"/>

                        <Button Content="Billing"
                                Command="{Binding NavigateToSalesCommand}"
                                Tag="Sales"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsBillingEnabled, Converter={StaticResource BoolToVisibility}}"/>

                        <!-- Admin-only management -->
                        <Separator Background="#3E3E42" Margin="10,10,10,10"
                                   Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>

                        <Button Content="Firm"
                                Command="{Binding OpenFirmManagementCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>

                        <Button Content="Users"
                                Command="{Binding OpenUserManagementCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}"/>

                        <Separator Background="#3E3E42" Margin="10,10,10,10"/>

                        <Button Content="Settings"
                                Command="{Binding OpenSystemSettingsCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Visibility="{Binding IsSystemSettingsEnabled, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>

                    <TextBlock DockPanel.Dock="Bottom"
                               Text="v1.0.0" Foreground="#666"
                               FontSize="10" HorizontalAlignment="Center"
                               Margin="0,0,0,12"/>
                    <Border/>
                </DockPanel>
            </Border>

            <!-- MAIN CONTENT AREA -->
            <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>

            <!-- SIDE PANELS (Notifications + Tasks) -->
            <Grid Grid.Column="2" Width="260"
                  Visibility="{Binding IsSidePanelVisible, Converter={StaticResource BoolToVisibility}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#F9F9F9" BorderBrush="#E0E0E0" BorderThickness="1,0,0,1"
                        Visibility="{Binding IsNotificationsPanelVisible, Converter={StaticResource BoolToVisibility}}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#E3F2FD" Padding="12,8">
                            <TextBlock Text="Notifications" FontWeight="SemiBold" FontSize="13"/>
                        </Border>
                        <TextBlock Text="No new notifications"
                                   Foreground="#999" FontStyle="Italic"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <Border Grid.Row="1" Background="#F9F9F9" BorderBrush="#E0E0E0" BorderThickness="1,0,0,0"
                        Visibility="{Binding IsTasksPanelVisible, Converter={StaticResource BoolToVisibility}}">
                    <DockPanel>
                        <Border DockPanel.Dock="Top" Background="#E8F5E9" Padding="12,8">
                            <TextBlock Text="Tasks" FontWeight="SemiBold" FontSize="13"/>
                        </Border>
                        <TextBlock Text="No pending tasks"
                                   Foreground="#999" FontStyle="Italic"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <!-- BOTTOM STATUS BAR -->
        <StatusBar Grid.Row="2" Background="#1E1E1E" Foreground="#B0B0B0" Padding="8,4">
            <StatusBar.ItemsPanel>
                <ItemsPanelTemplate>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </ItemsPanelTemplate>
            </StatusBar.ItemsPanel>

            <StatusBarItem Grid.Column="0">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding AppState.FirmName}" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="1">
                <StackPanel Orientation="Horizontal" Margin="20,0,0,0">
                    <TextBlock Text="{Binding CurrentUserDisplay}" Foreground="#4CAF50" FontWeight="SemiBold"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="2" HorizontalContentAlignment="Center">
                <TextBlock Text="{Binding StatusText}" Foreground="#888"/>
            </StatusBarItem>

            <StatusBarItem Grid.Column="3">
                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                    <TextBlock Text="{Binding AppState.CurrentTime}" Foreground="White" FontWeight="SemiBold"/>
                </StackPanel>
            </StatusBarItem>

            <StatusBarItem Grid.Column="4">
                <TextBlock Text="|" Foreground="#555" Margin="0,0,10,0"/>
            </StatusBarItem>

            <StatusBarItem Grid.Column="5">
                <Button Content="Logout" Command="{Binding LogoutCommand}"
                        Foreground="#B0B0B0" Background="Transparent"
                        BorderThickness="0" Cursor="Hand" Padding="4,2" FontSize="11"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>