 <Window x:Class="StoreAssistantPro.Modules.MainShell.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Background="{StaticResource AppBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <!-- InputBindings are generated at runtime by ShortcutService -->

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Opacity" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsReady}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="{StaticResource FluentDurationPageFade}"
                                                     EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- TOP MENU BAR -->
        <Menu Grid.Row="0"
              Visibility="{Binding AppState.IsLoggedIn, Converter={StaticResource BoolToVisibility}}"
              Margin="{StaticResource ItemSpacing}"
              Style="{StaticResource FluentMenuBarStyle}"
              ItemContainerStyle="{StaticResource FluentMenuBarItemStyle}">

            <MenuItem Header="_File">
                <MenuItem Header="_Home" Command="{Binding NavigateToMainWorkspaceCommand}"
                          InputGestureText="Ctrl+D"
                          h:SmartTooltip.ContextKey="Home"/>
                <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                <MenuItem Header="_Logout" Command="{Binding LogoutCommand}"
                          InputGestureText="Ctrl+L"
                          h:SmartTooltip.ContextKey="Logout"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Home" Command="{Binding NavigateToMainWorkspaceCommand}"
                          InputGestureText="Ctrl+D"
                          h:SmartTooltip.ContextKey="Home"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <!-- Administration -->
                <MenuItem Header="Firm Management" Command="{Binding OpenFirmManagementCommand}"
                          h:SmartTooltip.ContextKey="Firm"
                          Visibility="{Binding IsFirmManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="User Management" Command="{Binding OpenUserManagementCommand}"
                          h:SmartTooltip.ContextKey="Users"
                          Visibility="{Binding IsUserManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>

                <!-- Products & Stock -->
                <MenuItem Header="Products and Stock">
                    <MenuItem Header="Tax Management" Command="{Binding OpenTaxManagementCommand}"
                              h:SmartTooltip.ContextKey="Tax"
                              Visibility="{Binding IsTaxManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Vendor Management" Command="{Binding OpenVendorManagementCommand}"
                              h:SmartTooltip.ContextKey="Vendors"
                              Visibility="{Binding IsVendorManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Product Management" Command="{Binding OpenProductManagementCommand}"
                              h:SmartTooltip.ContextKey="Products"
                              Visibility="{Binding IsProductManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Category Management" Command="{Binding OpenCategoryManagementCommand}"
                              h:SmartTooltip.ContextKey="Categories"
                              Visibility="{Binding IsCategoryManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Brand Management" Command="{Binding OpenBrandManagementCommand}"
                              h:SmartTooltip.ContextKey="Brands"
                              Visibility="{Binding IsBrandManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                    <MenuItem Header="Inventory" Command="{Binding OpenInventoryCommand}"
                              h:SmartTooltip.ContextKey="Inventory"
                              Visibility="{Binding IsInventoryVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Inward Entry" Command="{Binding OpenInwardEntryCommand}"
                              h:SmartTooltip.ContextKey="Inward"
                              Visibility="{Binding IsInwardEntryVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Purchase Orders" Command="{Binding OpenPurchaseOrdersCommand}"
                              h:SmartTooltip.ContextKey="PurchaseOrders"
                              Visibility="{Binding IsPurchaseOrdersVisible, Converter={StaticResource BoolToVisibility}}"/>
                </MenuItem>

                <!-- Sales & Customers -->
                <MenuItem Header="Sales and Customers">
                    <MenuItem Header="Billing" Command="{Binding OpenBillingCommand}"
                              h:SmartTooltip.ContextKey="Billing"
                              Visibility="{Binding IsBillingVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Sale History" Command="{Binding OpenSaleHistoryCommand}"
                              h:SmartTooltip.ContextKey="SaleHistory"
                              Visibility="{Binding IsSaleHistoryVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Customer Management" Command="{Binding OpenCustomerManagementCommand}"
                              h:SmartTooltip.ContextKey="Customers"
                              Visibility="{Binding IsCustomerManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                    <MenuItem Header="Orders" Command="{Binding OpenOrderManagementCommand}"
                              h:SmartTooltip.ContextKey="Orders"
                              Visibility="{Binding IsOrderManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Payments" Command="{Binding OpenPaymentManagementCommand}"
                              h:SmartTooltip.ContextKey="Payments"
                              Visibility="{Binding IsPaymentManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Debtors" Command="{Binding OpenDebtorManagementCommand}"
                              h:SmartTooltip.ContextKey="Debtors"
                              Visibility="{Binding IsDebtorManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                </MenuItem>

                <!-- Accounting & Operations -->
                <MenuItem Header="Accounting and Operations">
                    <MenuItem Header="Expenses" Command="{Binding OpenExpenseManagementCommand}"
                              h:SmartTooltip.ContextKey="Expenses"
                              Visibility="{Binding IsExpenseManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Salaries" Command="{Binding OpenSalaryManagementCommand}"
                              h:SmartTooltip.ContextKey="Salaries"
                              Visibility="{Binding IsSalaryManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Branch Bills" Command="{Binding OpenBranchManagementCommand}"
                              h:SmartTooltip.ContextKey="Branch"
                              Visibility="{Binding IsBranchManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Sales/Purchase Register" Command="{Binding OpenSalesPurchaseCommand}"
                              h:SmartTooltip.ContextKey="SalesPurchase"
                              Visibility="{Binding IsSalesPurchaseVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                    <MenuItem Header="Ironing" Command="{Binding OpenIroningManagementCommand}"
                              h:SmartTooltip.ContextKey="Ironing"
                              Visibility="{Binding IsIroningManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                </MenuItem>

                <!-- Reports -->
                <MenuItem Header="Reports" Command="{Binding OpenReportsCommand}"
                          h:SmartTooltip.ContextKey="Reports"
                          Visibility="{Binding IsReportsVisible, Converter={StaticResource BoolToVisibility}}"/>

                <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                <!-- System -->
                <MenuItem Header="Financial Year" Command="{Binding OpenFinancialYearCommand}"
                          h:SmartTooltip.ContextKey="FinancialYear"
                          Visibility="{Binding IsFinancialYearVisible, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="System Settings" Command="{Binding OpenSystemSettingsCommand}"
                          h:SmartTooltip.ContextKey="Settings"
                          Visibility="{Binding IsSystemSettingsVisible, Converter={StaticResource BoolToVisibility}}"/>
                <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                <MenuItem Header="Refresh Data" Command="{Binding RefreshCurrentViewCommand}"
                          InputGestureText="F5"
                          h:SmartTooltip.ContextKey="Refresh"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="About Store Assistant Pro" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- QUICK ACTION BAR -->
        <Border Grid.Row="1"
                Style="{StaticResource FluentToolbarStyle}"
                Margin="{StaticResource ItemSpacing}"
                Visibility="{Binding AppState.IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <!-- Notification bell + indicators (right-docked) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="{StaticResource SidebarNavItemPadding}">

                    <!-- Notification bell -->
                    <Grid Margin="{StaticResource FormColumnGap}" VerticalAlignment="Center">
                        <Button x:Name="NotificationBellButton"
                                Command="{Binding ToggleNotificationsPanelCommand}"
                                AutomationProperties.Name="Notifications"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="{StaticResource ControlPadding}"
                                h:HelpHint.HelpText="View notifications"
                                h:HelpHint.Category="Navigation">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BellBorder" Background="Transparent"
                                            CornerRadius="{StaticResource FluentCornerMedium}"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid h:NotificationBadgeBehavior.Count="{Binding AppState.UnreadNotificationCount}">
                                            <TextBlock Text="&#xEA8F;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconMedium}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                         <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BellBorder" Property="Background"
                                                    Value="{StaticResource FluentSubtleHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="BellBorder" Property="Background"
                                                    Value="{StaticResource FluentSubtlePressed}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Notification popup â€” anchored below bell, auto-closes on outside click -->
                        <Popup x:Name="NotificationsPopup"
                               PlacementTarget="{Binding ElementName=NotificationBellButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               AllowsTransparency="True"
                               IsOpen="{Binding IsNotificationsPanelVisible, Mode=TwoWay}"
                               Opened="OnNotificationsPopupOpened">
                            <Border x:Name="NotificationsPanel"
                                    Width="{StaticResource NotificationPanelWidth}"
                                    MaxHeight="{StaticResource NotificationPanelMaxHeight}"
                                    Background="{StaticResource FluentSurface}"
                                    BorderBrush="{StaticResource FluentSurfaceStroke}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource FluentCornerLarge}"
                                    SnapsToDevicePixels="True"
                                    Effect="{StaticResource FluentShadowMedium}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0"
                                            Background="{StaticResource FluentSurfaceElevated}"
                                            CornerRadius="{StaticResource FluentCornerLargeTop}" Padding="{StaticResource CardContentPadding}">
                                        <DockPanel>
                                            <TextBlock Text="Notifications"
                                                       FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{StaticResource FluentTextPrimary}"
                                                       VerticalAlignment="Center"
                                                       DockPanel.Dock="Left"/>
                                            <Button Content="Mark all read"
                                                    Style="{StaticResource ToolbarLinkButtonStyle}"
                                                    Foreground="{StaticResource FluentAccentDefault}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding MarkAllNotificationsReadCommand}"/>
                                        </DockPanel>
                                    </Border>

                                    <!-- Notification list -->
                                    <ItemsControl Grid.Row="1"
                                                  ItemsSource="{Binding AppState.Notifications}"
                                                  VirtualizingStackPanel.IsVirtualizing="True"
                                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.CanContentScroll="True">
                                        <ItemsControl.Template>
                                            <ControlTemplate TargetType="ItemsControl">
                                                <ScrollViewer Focusable="False"
                                                              CanContentScroll="True"
                                                              HorizontalScrollBarVisibility="Auto"
                                                              Padding="0">
                                                    <ItemsPresenter/>
                                                </ScrollViewer>
                                            </ControlTemplate>
                                        </ItemsControl.Template>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="{StaticResource CardContentPadding}"
                                                            BorderBrush="{StaticResource FluentSurfaceStroke}"
                                                            BorderThickness="0,0,0,1"
                                                            Cursor="Hand"
                                                            Background="Transparent">
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick"
                                                                Command="{Binding DataContext.MarkNotificationReadCommand,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                                        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Level indicator dot -->
                                                            <Ellipse Grid.Column="0" Grid.RowSpan="2"
                                                                     Width="{StaticResource NotificationDotSize}"
                                                                     Height="{StaticResource NotificationDotSize}"
                                                                     VerticalAlignment="Top"
                                                                     Margin="{StaticResource NotificationDotOffset}">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Fill" Value="{StaticResource FluentAccentDefault}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                                <Setter Property="Fill" Value="{StaticResource FluentWarning}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                                <Setter Property="Fill" Value="{StaticResource FluentError}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Success">
                                                                                <Setter Property="Fill" Value="{StaticResource FluentSuccess}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>

                                                            <!-- Title + timestamp -->
                                                            <DockPanel Grid.Column="1" Grid.Row="0">
                                                                <TextBlock Text="{Binding Timestamp, StringFormat=t}"
                                                                           Foreground="{StaticResource FluentTextTertiary}" FontSize="{StaticResource FontSizeStatusBar}"
                                                                           DockPanel.Dock="Right"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeLabel}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </DockPanel>

                                                            <!-- Message -->
                                                            <TextBlock Grid.Column="1" Grid.Row="1"
                                                                       Text="{Binding Message}"
                                                                       Foreground="{StaticResource FluentTextSecondary}" FontSize="{StaticResource FontSizeCaption}"
                                                                       TextWrapping="WrapWithOverflow"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxHeight="{StaticResource NotificationMessageMaxHeight}" Margin="{StaticResource HintTextSpacing}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    <!-- Empty state (shown when no notifications) -->
                                    <TextBlock Grid.Row="1" Text="No notifications"
                                               Foreground="{StaticResource FluentTextTertiary}"
                                               FontStyle="Italic" FontSize="{StaticResource FontSizeLabel}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Margin="{StaticResource EmptyStatePadding}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AppState.Notifications.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Footer -->
                                    <Border Grid.Row="2" BorderBrush="{StaticResource FluentSurfaceStroke}"
                                            BorderThickness="0,1,0,0" Padding="{StaticResource ButtonPadding}"
                                            CornerRadius="{StaticResource FluentCornerMediumBottom}">
                                        <Button Content="Clear all"
                                                Style="{StaticResource ToolbarLinkButtonStyle}"
                                                Foreground="{StaticResource FluentError}"
                                                HorizontalAlignment="Center"
                                                Command="{Binding ClearNotificationsCommand}"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>

                    </StackPanel>

                    <!-- Quick actions (left, fills remaining space) -->
                <ItemsControl ItemsSource="{Binding QuickActions}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Command="{Binding Command}"
                                    Style="{StaticResource QuickActionButtonStyle}"
                                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}}"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </DockPanel>
        </Border>

        <!-- BODY: WORKSPACE / LOGIN -->
        <Border Grid.Row="2">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Margin" Value="{StaticResource ItemSpacing}"/>
                    <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource FluentSurfaceStroke}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="CornerRadius" Value="{StaticResource FluentCornerXLarge}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AppState.IsLoggedIn}" Value="False">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="CornerRadius" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <controls:ResponsiveContentControl Content="{Binding CurrentView}"/>
        </Border>
        <!-- BOTTOM STATUS BAR -->
        <Border Grid.Row="3"
                Visibility="{Binding AppState.IsLoggedIn, Converter={StaticResource BoolToVisibility}}"
                Margin="{StaticResource ItemSpacing}"
                Background="{StaticResource FluentSurface}"
                BorderBrush="{StaticResource FluentSurfaceStroke}"
                BorderThickness="1"
                CornerRadius="{StaticResource FluentCornerLarge}"
                Padding="{StaticResource ButtonPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="{Binding AppState.FirmName}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource FluentTextPrimary}"/>

                <Border Grid.Column="1"
                        Margin="{StaticResource StatusBarPillGap}">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource StatusBadgePillStyle}">
                            <Setter Property="Background" Value="{StaticResource FluentSuccess}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding DashboardSummary.IsOfflineMode}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentError}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeStatusBar}"
                               FontWeight="SemiBold">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="Online"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding DashboardSummary.IsOfflineMode}" Value="True">
                                        <Setter Property="Text" Value="Offline"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Border>

                <TextBlock Grid.Column="2"
                           Text="{Binding StatusBar.Message}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource FluentTextTertiary}"
                           FontStyle="Italic"/>

                <TextBlock Grid.Column="3"
                           Text="{Binding DashboardSummary.CurrentTime}"
                           Margin="{StaticResource InlineControlSpacing}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource FluentTextPrimary}"
                           FontWeight="SemiBold"/>

                <Button Grid.Column="4"
                        Content="Switch User"
                        Command="{Binding SwitchUserCommand}"
                        Style="{StaticResource ToolbarLinkButtonStyle}"/>
            </Grid>
        </Border>

        <controls:ToastHost Grid.Row="0"
                            Grid.RowSpan="4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="{StaticResource OverlayHostMargin}"
                            Panel.ZIndex="100"
                            Toasts="{Binding ToastService.Toasts}"/>
    </Grid>
</Window>
