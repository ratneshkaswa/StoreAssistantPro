 <Window x:Class="StoreAssistantPro.Modules.MainShell.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        mc:Ignorable="d"
        Title="{Binding WindowTitle}"
        Background="{StaticResource AppBackgroundBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">

    <!-- InputBindings are generated at runtime by ShortcutService -->

    <Window.Resources>
        <Style x:Key="CommandPaletteDismissButtonStyle" TargetType="Button" BasedOn="{x:Null}">
            <Setter Property="Background" Value="{StaticResource SmokeOverlayBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Cursor" Value="Arrow"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommandPaletteResultItemStyle" TargetType="ListBoxItem">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="h:PressStateTracker.IsEnabled" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerLarge}"
                                Padding="14,12"
                                SnapsToDevicePixels="True"
                                UseLayoutRounding="True">
                            <Grid>
                                <Border x:Name="AccentPill"
                                        Width="4"
                                        Margin="0,2,12,2"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch"
                                        Background="{StaticResource FluentAccentDefault}"
                                        CornerRadius="2"
                                        Opacity="0"/>
                                <ContentPresenter Margin="16,0,0,0"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SubtleFillColorSecondary}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource SubtleFillColorTertiary}"/>
                            </Trigger>
                            <Trigger Property="h:PressStateTracker.IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource SubtleFillColorTertiary}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource SubtleFillColorTertiary}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{StaticResource LayerFillColorSecondary}"/>
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource SubtleFillColorTertiary}"/>
                                <Setter TargetName="AccentPill" Property="Opacity" Value="1"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="{StaticResource FluentStrokeFocus}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionOverflowButtonStyle" TargetType="Button" BasedOn="{x:Null}">
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OverflowButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{StaticResource FluentCornerMedium}">
                            <TextBlock Text="&#xE712;"
                                       FontFamily="{StaticResource FluentIconFont}"
                                       FontSize="{StaticResource FontSizeIconSmall}"
                                       Foreground="{StaticResource FluentTextSecondary}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OverflowButtonBorder" Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="OverflowButtonBorder" Property="Background" Value="{StaticResource FluentSubtlePressed}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuickActionOverflowItemStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="40"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="OverflowItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="{StaticResource FluentCornerLarge}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="OverflowItemBorder" Property="Background" Value="{StaticResource SubtleFillColorSecondary}"/>
                                <Setter TargetName="OverflowItemBorder" Property="BorderBrush" Value="{StaticResource SubtleFillColorTertiary}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="OverflowItemBorder" Property="Background" Value="{StaticResource LayerFillColorDefault}"/>
                                <Setter TargetName="OverflowItemBorder" Property="BorderBrush" Value="{StaticResource SubtleFillColorTertiary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="OverflowItemBorder" Property="Opacity" Value="0.4"/>
                            </Trigger>
                            <Trigger Property="Tag" Value="True">
                                <Setter TargetName="OverflowItemBorder" Property="Background" Value="{StaticResource LayerFillColorDefault}"/>
                                <Setter TargetName="OverflowItemBorder" Property="BorderBrush" Value="{StaticResource DividerStrokeColorDefault}"/>
                                <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Style>
            <Style TargetType="Grid">
                <Setter Property="Opacity" Value="0"/>
                <Style.Triggers>
                    <DataTrigger Binding="{Binding IsReady}" Value="True">
                        <DataTrigger.EnterActions>
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                     To="1"
                                                     Duration="{StaticResource FluentDurationPageFade}"
                                                     EasingFunction="{StaticResource FluentEaseDecelerate}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </DataTrigger.EnterActions>
                    </DataTrigger>
                </Style.Triggers>
            </Style>
        </Grid.Style>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.RowSpan="4"
                BorderBrush="{StaticResource WindowEdgeFrameBrush}"
                BorderThickness="1"
                IsHitTestVisible="False"
                UseLayoutRounding="True"
                SnapsToDevicePixels="True"/>

        <!-- TOP MENU BAR -->
        <Menu Grid.Row="0"
              Visibility="{Binding AppState.IsLoggedIn, Converter={StaticResource BoolToVisibility}}"
              Margin="{StaticResource ItemSpacing}"
              Style="{StaticResource FluentMenuBarStyle}"
              ItemContainerStyle="{StaticResource FluentMenuBarItemStyle}">

            <MenuItem Header="_File">
                <MenuItem Header="_Home" Command="{Binding NavigateToMainWorkspaceCommand}"
                          InputGestureText="Ctrl+D"
                          h:SmartTooltip.ContextKey="Home"/>
                <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                <MenuItem Header="_Logout" Command="{Binding LogoutCommand}"
                          InputGestureText="Ctrl+L"
                          h:SmartTooltip.ContextKey="Logout"/>
            </MenuItem>

            <MenuItem Header="_View">
                <MenuItem Header="Home" Command="{Binding NavigateToMainWorkspaceCommand}"
                          InputGestureText="Ctrl+D"
                          h:SmartTooltip.ContextKey="Home"/>
            </MenuItem>

            <MenuItem Header="_Tools">
                <!-- Administration -->
                <MenuItem Header="Firm Management" Command="{Binding OpenFirmManagementCommand}"
                          h:SmartTooltip.ContextKey="Firm"
                          Visibility="{Binding IsFirmManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="User Management" Command="{Binding OpenUserManagementCommand}"
                          h:SmartTooltip.ContextKey="Users"
                          Visibility="{Binding IsUserManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>

                <!-- Products & Stock -->
                <MenuItem Header="Products and Stock">
                    <MenuItem Header="Tax Management" Command="{Binding OpenTaxManagementCommand}"
                              h:SmartTooltip.ContextKey="Tax"
                              Visibility="{Binding IsTaxManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Vendor Management" Command="{Binding OpenVendorManagementCommand}"
                              h:SmartTooltip.ContextKey="Vendors"
                              Visibility="{Binding IsVendorManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Product Management" Command="{Binding OpenProductManagementCommand}"
                              h:SmartTooltip.ContextKey="Products"
                              Visibility="{Binding IsProductManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Category Management" Command="{Binding OpenCategoryManagementCommand}"
                              h:SmartTooltip.ContextKey="Categories"
                              Visibility="{Binding IsCategoryManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Brand Management" Command="{Binding OpenBrandManagementCommand}"
                              h:SmartTooltip.ContextKey="Brands"
                              Visibility="{Binding IsBrandManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                    <MenuItem Header="Inventory" Command="{Binding OpenInventoryCommand}"
                              h:SmartTooltip.ContextKey="Inventory"
                              Visibility="{Binding IsInventoryVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Inward Entry" Command="{Binding OpenInwardEntryCommand}"
                              h:SmartTooltip.ContextKey="Inward"
                              Visibility="{Binding IsInwardEntryVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Purchase Orders" Command="{Binding OpenPurchaseOrdersCommand}"
                              h:SmartTooltip.ContextKey="PurchaseOrders"
                              Visibility="{Binding IsPurchaseOrdersVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Goods Received Notes" Command="{Binding OpenGRNCommand}"
                              h:SmartTooltip.ContextKey="GRN"
                              Visibility="{Binding IsGRNVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                    <MenuItem Header="Barcode Labels" Command="{Binding OpenBarcodeLabelsCommand}"
                              h:SmartTooltip.ContextKey="BarcodeLabels"
                              Visibility="{Binding IsBarcodeLabelsVisible, Converter={StaticResource BoolToVisibility}}"/>
                </MenuItem>

                <!-- Sales & Customers -->
                <MenuItem Header="Sales and Customers">
                    <MenuItem Header="Billing" Command="{Binding OpenBillingCommand}"
                              h:SmartTooltip.ContextKey="Billing"
                              Visibility="{Binding IsBillingVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Sale History" Command="{Binding OpenSaleHistoryCommand}"
                              h:SmartTooltip.ContextKey="SaleHistory"
                              Visibility="{Binding IsSaleHistoryVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Cash Register" Command="{Binding OpenCashRegisterCommand}"
                              h:SmartTooltip.ContextKey="CashRegister"
                              Visibility="{Binding IsCashRegisterVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Customer Management" Command="{Binding OpenCustomerManagementCommand}"
                              h:SmartTooltip.ContextKey="Customers"
                              Visibility="{Binding IsCustomerManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Quotations" Command="{Binding OpenQuotationsCommand}"
                              h:SmartTooltip.ContextKey="Quotations"
                              Visibility="{Binding IsQuotationsVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                    <MenuItem Header="Orders" Command="{Binding OpenOrderManagementCommand}"
                              h:SmartTooltip.ContextKey="Orders"
                              Visibility="{Binding IsOrderManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Payments" Command="{Binding OpenPaymentManagementCommand}"
                              h:SmartTooltip.ContextKey="Payments"
                              Visibility="{Binding IsPaymentManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Debtors" Command="{Binding OpenDebtorManagementCommand}"
                              h:SmartTooltip.ContextKey="Debtors"
                              Visibility="{Binding IsDebtorManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                </MenuItem>

                <!-- Accounting & Operations -->
                <MenuItem Header="Accounting and Operations">
                    <MenuItem Header="Expenses" Command="{Binding OpenExpenseManagementCommand}"
                              h:SmartTooltip.ContextKey="Expenses"
                              Visibility="{Binding IsExpenseManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Salaries" Command="{Binding OpenSalaryManagementCommand}"
                              h:SmartTooltip.ContextKey="Salaries"
                              Visibility="{Binding IsSalaryManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Branch Bills" Command="{Binding OpenBranchManagementCommand}"
                              h:SmartTooltip.ContextKey="Branch"
                              Visibility="{Binding IsBranchManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <MenuItem Header="Sales/Purchase Register" Command="{Binding OpenSalesPurchaseCommand}"
                              h:SmartTooltip.ContextKey="SalesPurchase"
                              Visibility="{Binding IsSalesPurchaseVisible, Converter={StaticResource BoolToVisibility}}"/>
                    <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                    <MenuItem Header="Ironing" Command="{Binding OpenIroningManagementCommand}"
                              h:SmartTooltip.ContextKey="Ironing"
                              Visibility="{Binding IsIroningManagementVisible, Converter={StaticResource BoolToVisibility}}"/>
                </MenuItem>

                <!-- Reports -->
                <MenuItem Header="Reports" Command="{Binding OpenReportsCommand}"
                          h:SmartTooltip.ContextKey="Reports"
                          Visibility="{Binding IsReportsVisible, Converter={StaticResource BoolToVisibility}}"/>

                <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                <!-- System -->
                <MenuItem Header="Financial Year" Command="{Binding OpenFinancialYearCommand}"
                          h:SmartTooltip.ContextKey="FinancialYear"
                          Visibility="{Binding IsFinancialYearVisible, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="System Settings" Command="{Binding OpenSystemSettingsCommand}"
                          h:SmartTooltip.ContextKey="Settings"
                          Visibility="{Binding IsSystemSettingsVisible, Converter={StaticResource BoolToVisibility}}"/>
                <MenuItem Header="Backup and Restore" Command="{Binding OpenBackupRestoreCommand}"
                          h:SmartTooltip.ContextKey="Backup"
                          Visibility="{Binding IsBackupRestoreVisible, Converter={StaticResource BoolToVisibility}}"/>
                <Separator Style="{StaticResource FluentMenuSeparatorStyle}"/>
                <MenuItem Header="Refresh Data" Command="{Binding RefreshCurrentViewCommand}"
                          InputGestureText="F5"
                          h:SmartTooltip.ContextKey="Refresh"/>
            </MenuItem>

            <MenuItem Header="_Help">
                <MenuItem Header="About Store Assistant Pro" Command="{Binding ShowAboutCommand}"/>
            </MenuItem>
        </Menu>

        <!-- QUICK ACTION BAR -->
        <Border Grid.Row="1"
                Style="{StaticResource FluentToolbarStyle}"
                Margin="{StaticResource ItemSpacing}"
                Visibility="{Binding AppState.IsLoggedIn, Converter={StaticResource BoolToVisibility}}">
            <DockPanel>
                <!-- Notification bell + indicators (right-docked) -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="{StaticResource SidebarNavItemPadding}">

                    <!-- Notification bell -->
                    <Grid Margin="{StaticResource FormColumnGap}" VerticalAlignment="Center">
                        <Button x:Name="NotificationBellButton"
                                Command="{Binding ToggleNotificationsPanelCommand}"
                                AutomationProperties.Name="Notifications"
                                Background="Transparent" BorderThickness="0"
                                Cursor="Hand" Padding="{StaticResource ControlPadding}"
                                h:HelpHint.HelpText="View notifications"
                                h:HelpHint.Category="Navigation">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="BellBorder" Background="Transparent"
                                            CornerRadius="{StaticResource FluentCornerMedium}"
                                            Padding="{TemplateBinding Padding}">
                                        <Grid h:NotificationBadgeBehavior.Count="{Binding AppState.UnreadNotificationCount}"
                                              h:NotificationBadgeBehavior.DotOnly="True">
                                            <TextBlock Text="&#xEA8F;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconMedium}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                         <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="BellBorder" Property="Background"
                                                    Value="{StaticResource FluentSubtleHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="BellBorder" Property="Background"
                                                    Value="{StaticResource FluentSubtlePressed}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!-- Notification popup â€” anchored below bell, auto-closes on outside click -->
                        <Popup x:Name="NotificationsPopup"
                               Style="{StaticResource AnchoredFlyoutPopupStyle}"
                               PlacementTarget="{Binding ElementName=NotificationBellButton}"
                               Placement="Bottom"
                               StaysOpen="False"
                               IsOpen="{Binding IsNotificationsPanelVisible, Mode=TwoWay}"
                               Opened="OnNotificationsPopupOpened">
                            <Border x:Name="NotificationsPanel"
                                    Style="{StaticResource FlyoutPopupSurfaceStyle}"
                                    Width="{StaticResource NotificationPanelWidth}"
                                    MaxHeight="{StaticResource NotificationPanelMaxHeight}"
                                    SnapsToDevicePixels="True"
                                    Padding="0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Header -->
                                    <Border Grid.Row="0"
                                            Background="{StaticResource FluentSurfaceElevated}"
                                            CornerRadius="{StaticResource FluentCornerLargeTop}" Padding="{StaticResource CardContentPadding}">
                                        <DockPanel>
                                            <TextBlock Text="Notifications"
                                                       FontWeight="SemiBold" FontSize="{StaticResource FontSizeBody}"
                                                       Foreground="{StaticResource FluentTextPrimary}"
                                                       VerticalAlignment="Center"
                                                       DockPanel.Dock="Left"/>
                                            <Button Content="Mark all read"
                                                    Style="{StaticResource ToolbarLinkButtonStyle}"
                                                    Foreground="{StaticResource FluentAccentDefault}"
                                                    HorizontalAlignment="Right"
                                                    Command="{Binding MarkAllNotificationsReadCommand}"/>
                                        </DockPanel>
                                    </Border>

                                    <!-- Notification list -->
                                    <ItemsControl Grid.Row="1"
                                                  ItemsSource="{Binding AppState.Notifications}"
                                                  VirtualizingStackPanel.IsVirtualizing="True"
                                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                                  ScrollViewer.HorizontalScrollBarVisibility="Auto"
                                                  ScrollViewer.CanContentScroll="True">
                                        <ItemsControl.Template>
                                            <ControlTemplate TargetType="ItemsControl">
                                                <ScrollViewer Focusable="False"
                                                              CanContentScroll="True"
                                                              HorizontalScrollBarVisibility="Auto"
                                                              Padding="0">
                                                    <ItemsPresenter/>
                                                </ScrollViewer>
                                            </ControlTemplate>
                                        </ItemsControl.Template>
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <VirtualizingStackPanel/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Padding="{StaticResource CardContentPadding}"
                                                            BorderBrush="{StaticResource FluentSurfaceStroke}"
                                                            BorderThickness="0,0,0,1"
                                                            Cursor="Hand"
                                                            Background="Transparent">
                                                        <Border.InputBindings>
                                                            <MouseBinding Gesture="LeftClick"
                                                                Command="{Binding DataContext.MarkNotificationReadCommand,
                                                                    RelativeSource={RelativeSource AncestorType=Window}}"
                                                                CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsRead}" Value="False">
                                                                        <Setter Property="Background" Value="{StaticResource FluentSurfaceElevated}"/>
                                                                    </DataTrigger>
                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                        <Setter Property="Background" Value="{StaticResource FluentSubtleHover}"/>
                                                                    </Trigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto"/>
                                                                <RowDefinition Height="Auto"/>
                                                            </Grid.RowDefinitions>

                                                            <!-- Level indicator dot -->
                                                            <Ellipse Grid.Column="0" Grid.RowSpan="2"
                                                                     Width="{StaticResource NotificationDotSize}"
                                                                     Height="{StaticResource NotificationDotSize}"
                                                                     VerticalAlignment="Top"
                                                                     Margin="{StaticResource NotificationDotOffset}">
                                                                <Ellipse.Style>
                                                                    <Style TargetType="Ellipse">
                                                                        <Setter Property="Fill" Value="{StaticResource FluentAccentDefault}"/>
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Warning">
                                                                                <Setter Property="Fill" Value="{StaticResource FluentWarning}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Error">
                                                                                <Setter Property="Fill" Value="{StaticResource FluentError}"/>
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding Level}" Value="Success">
                                                                                <Setter Property="Fill" Value="{StaticResource FluentSuccess}"/>
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </Ellipse.Style>
                                                            </Ellipse>

                                                            <!-- Title + timestamp -->
                                                            <DockPanel Grid.Column="1" Grid.Row="0">
                                                                <TextBlock Text="{Binding Timestamp, Converter={StaticResource RelativeDateTimeConverter}}"
                                                                           ToolTip="{Binding Timestamp, Converter={StaticResource RelativeDateTimeConverter}, ConverterParameter=Full}"
                                                                           Foreground="{StaticResource FluentTextTertiary}" FontSize="{StaticResource FontSizeStatusBar}"
                                                                           DockPanel.Dock="Right"
                                                                           VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Title}"
                                                                           FontWeight="SemiBold" FontSize="{StaticResource FontSizeLabel}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                            </DockPanel>

                                                            <!-- Message -->
                                                            <TextBlock Grid.Column="1" Grid.Row="1"
                                                                       Text="{Binding Message}"
                                                                       Foreground="{StaticResource FluentTextSecondary}" FontSize="{StaticResource FontSizeCaption}"
                                                                       TextWrapping="WrapWithOverflow"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       MaxHeight="{StaticResource NotificationMessageMaxHeight}" Margin="{StaticResource HintTextSpacing}"/>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                    <!-- Empty state (shown when no notifications) -->
                                    <TextBlock Grid.Row="1" Text="No notifications"
                                               Foreground="{StaticResource FluentTextTertiary}"
                                               FontStyle="Italic" FontSize="{StaticResource FontSizeLabel}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" Margin="{StaticResource EmptyStatePadding}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AppState.Notifications.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>

                                    <!-- Footer -->
                                    <Border Grid.Row="2" BorderBrush="{StaticResource FluentSurfaceStroke}"
                                            BorderThickness="0,1,0,0" Padding="{StaticResource ButtonPadding}"
                                            CornerRadius="{StaticResource FluentCornerMediumBottom}">
                                        <Button Content="Clear all"
                                                Style="{StaticResource ToolbarLinkButtonStyle}"
                                                Foreground="{StaticResource FluentError}"
                                                HorizontalAlignment="Center"
                                                Command="{Binding ClearNotificationsCommand}"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </Popup>
                    </Grid>

                    </StackPanel>

                <!-- Quick actions (left, fills remaining space) -->
                <Grid x:Name="QuickActionsViewport"
                      SizeChanged="OnQuickActionsViewportSizeChanged">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <ItemsControl Grid.Column="0"
                                  ItemsSource="{Binding VisibleQuickActions}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding Command}"
                                        Tag="{Binding IsActive}"
                                        Style="{StaticResource QuickActionButtonStyle}"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Grid Grid.Column="1"
                          Margin="6,0,0,0"
                          VerticalAlignment="Center"
                          Visibility="{Binding HasOverflowQuickActions, Converter={StaticResource BoolToVisibility}}">
                        <Button x:Name="QuickActionOverflowButton"
                                Command="{Binding ToggleQuickActionOverflowCommand}"
                                Style="{StaticResource QuickActionOverflowButtonStyle}"
                                AutomationProperties.Name="More actions"
                                ToolTip="More actions"/>

                        <Popup PlacementTarget="{Binding ElementName=QuickActionOverflowButton}"
                               Style="{StaticResource AnchoredFlyoutPopupStyle}"
                               Placement="Bottom"
                               StaysOpen="False"
                               IsOpen="{Binding IsQuickActionOverflowOpen, Mode=TwoWay}"
                               Closed="OnQuickActionOverflowPopupClosed">
                            <Border Width="260"
                                    Style="{StaticResource FlyoutMenuSurfaceStyle}">
                                <ItemsControl ItemsSource="{Binding OverflowQuickActions}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Style="{StaticResource QuickActionOverflowItemStyle}"
                                                    Tag="{Binding IsActive}"
                                                    Command="{Binding Command}"
                                                    Click="OnQuickActionOverflowItemClick">
                                                <DockPanel LastChildFill="True">
                                                    <TextBlock Text="{Binding ShortcutText}"
                                                               DockPanel.Dock="Right"
                                                               FontSize="{StaticResource FontSizeCaption}"
                                                               Foreground="{StaticResource FluentTextTertiary}"
                                                               Visibility="{Binding ShortcutText, Converter={StaticResource NonEmptyStringToVisibility}}"/>
                                                    <StackPanel Orientation="Horizontal">
                                                        <TextBlock Text="{Binding Icon}"
                                                                   Margin="0,0,8,0"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                        <TextBlock Text="{Binding Title}"
                                                                   VerticalAlignment="Center"
                                                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"/>
                                                    </StackPanel>
                                                </DockPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>
            </DockPanel>
        </Border>

        <!-- BODY: WORKSPACE / LOGIN -->
        <Border Grid.Row="2">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Margin" Value="{StaticResource ItemSpacing}"/>
                    <Setter Property="Background" Value="{StaticResource FluentSurface}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource FluentSurfaceStroke}"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="CornerRadius" Value="{StaticResource FluentCornerXLarge}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding AppState.IsLoggedIn}" Value="False">
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="CornerRadius" Value="0"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <controls:ResponsiveContentControl Content="{Binding CurrentView}"/>
        </Border>

        <Grid Grid.Row="0"
              Grid.RowSpan="4"
              Panel.ZIndex="200"
              Visibility="{Binding IsCommandPaletteVisible, Converter={StaticResource BoolToVisibility}}"
              PreviewKeyDown="OnCommandPalettePreviewKeyDown">
            <Button Style="{StaticResource CommandPaletteDismissButtonStyle}"
                    AutomationProperties.Name="Close command palette"
                    Command="{Binding CloseCommandPaletteCommand}"/>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="24,72,24,24"
                    MinWidth="560"
                    MaxWidth="720"
                    Background="{StaticResource LayerFillColorSecondary}"
                    BorderBrush="{StaticResource FluentSurfaceStroke}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource FluentCornerXLarge}"
                    Effect="{StaticResource FluentShadowLarge}"
                    KeyboardNavigation.TabNavigation="Cycle"
                    SnapsToDevicePixels="True"
                    UseLayoutRounding="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="20,20,20,12">
                        <TextBlock Text="Command palette"
                                   FontSize="{StaticResource FontSizeDialogTitle}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextPrimary}"/>
                        <TextBlock Text="Jump to pages, tools, and recent work from one place."
                                   Margin="{StaticResource HintTextSpacing}"
                                   Foreground="{StaticResource FluentTextSecondary}"/>
                    </StackPanel>

                    <TextBox x:Name="CommandPaletteSearchBox"
                             Grid.Row="1"
                             Margin="20,0,20,0"
                             Style="{StaticResource FluentSearchTextBoxStyle}"
                             Text="{Binding CommandPaletteQuery, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Search pages, actions, or shortcuts"/>

                    <Grid Grid.Row="2" Margin="12,12,12,0">
                        <ListBox x:Name="CommandPaletteResultsList"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 h:Motion.StaggerChildren="True"
                                 ItemContainerStyle="{StaticResource CommandPaletteResultItemStyle}"
                                 ItemsSource="{Binding CommandPaletteItems}"
                                 MaxHeight="420"
                                 MouseDoubleClick="OnCommandPaletteResultsMouseDoubleClick"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                                 SelectedItem="{Binding SelectedCommandPaletteItem, Mode=TwoWay}">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasCommandPaletteItems}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="32"
                                                Height="32"
                                                Margin="0,0,12,0"
                                                Background="{StaticResource ChromeAltFillColorSecondary}"
                                                CornerRadius="16"
                                                VerticalAlignment="Top">
                                            <TextBlock Text="{Binding Icon}"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="{StaticResource FontSizeLabel}"/>
                                        </Border>

                                        <StackPanel Grid.Column="1">
                                            <DockPanel LastChildFill="True">
                                                <TextBlock Text="{Binding ShortcutText}"
                                                           DockPanel.Dock="Right"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{StaticResource FluentTextTertiary}"
                                                           Visibility="{Binding HasShortcutText, Converter={StaticResource BoolToVisibility}}"/>

                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource FluentTextPrimary}"/>
                                                    <Border Margin="8,0,0,0"
                                                            Padding="8,2"
                                                            Background="{StaticResource ControlAltFillColorSecondary}"
                                                            CornerRadius="10"
                                                            Visibility="{Binding IsRecent, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="Recent"
                                                                   FontSize="{StaticResource FontSizeCaption}"
                                                                   Foreground="{StaticResource FluentAccentDark2}"/>
                                                    </Border>
                                                </StackPanel>
                                            </DockPanel>

                                            <TextBlock Text="{Binding Description}"
                                                       Margin="{StaticResource HintTextSpacing}"
                                                       Foreground="{StaticResource FluentTextSecondary}"
                                                       TextWrapping="Wrap"
                                                       Visibility="{Binding HasDescription, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Margin="12,0,0,0"
                                                Padding="8,4"
                                                Background="{StaticResource ControlAltFillColorSecondary}"
                                                CornerRadius="10"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="{StaticResource FontSizeCaption}"
                                                       Foreground="{StaticResource FluentTextSecondary}"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Border Background="Transparent">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasCommandPaletteItems}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,36,0,36">
                                <TextBlock Text="&#xE711;"
                                           FontFamily="{StaticResource FluentIconFont}"
                                           FontSize="20"
                                           Foreground="{StaticResource FluentTextTertiary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="No matching commands"
                                           Margin="0,12,0,0"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentTextPrimary}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Try a page name, shortcut, or action keyword."
                                           Margin="{StaticResource HintTextSpacing}"
                                           Foreground="{StaticResource FluentTextSecondary}"
                                           HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Border Grid.Row="3"
                            Margin="20,12,20,20"
                            Padding="0,12,0,0"
                            BorderBrush="{StaticResource DividerStrokeColorDefault}"
                            BorderThickness="0,1,0,0">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Recent actions rise to the top when you open the palette without a query."
                                       Foreground="{StaticResource FluentTextTertiary}"/>
                            <TextBlock DockPanel.Dock="Right"
                                       Text="↑↓ Navigate   Enter Run   Esc Close"
                                       Foreground="{StaticResource FluentTextTertiary}"
                                       FontSize="{StaticResource FontSizeCaption}"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- BOTTOM STATUS BAR -->
        <Border Grid.Row="3"
                Visibility="{Binding AppState.IsLoggedIn, Converter={StaticResource BoolToVisibility}}"
                Margin="{StaticResource ItemSpacing}"
                Background="{StaticResource ChromeAltFillColorSecondary}"
                BorderBrush="{StaticResource DividerStrokeColorDefault}"
                BorderThickness="1"
                CornerRadius="{StaticResource FluentCornerLarge}"
                Padding="{StaticResource ButtonPadding}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32"
                            Height="32"
                            CornerRadius="16"
                            Background="{StaticResource FluentAccentLight2}">
                        <TextBlock Text="{Binding DashboardSummary.CurrentUserInitials}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentAccentDark2}"/>
                    </Border>

                    <StackPanel Margin="10,0,0,0">
                        <TextBlock Text="{Binding AppState.FirmName}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Foreground="{StaticResource FluentTextPrimary}"/>

                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                            <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                <Ellipse.Style>
                                    <Style TargetType="Ellipse">
                                        <Setter Property="Fill" Value="{StaticResource FluentSuccess}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DashboardSummary.IsOfflineMode}" Value="True">
                                                <Setter Property="Fill" Value="{StaticResource FluentError}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Ellipse.Style>
                            </Ellipse>

                            <TextBlock Text="{Binding DashboardSummary.ConnectionStatusText}"
                                       Margin="8,0,0,0"
                                       FontSize="{StaticResource FontSizeStatusBar}"
                                       Foreground="{StaticResource FluentTextSecondary}"/>

                            <TextBlock Text="  "
                                       FontSize="{StaticResource FontSizeStatusBar}"/>

                            <TextBlock Text="{Binding DashboardSummary.ConnectionStatusDetail}"
                                       FontSize="{StaticResource FontSizeStatusBar}"
                                       Foreground="{StaticResource FluentTextTertiary}"/>
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusBar.Message}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource FluentTextTertiary}"
                           FontStyle="Italic"/>

                <TextBlock Grid.Column="2"
                           Text="{Binding DashboardSummary.CurrentTime}"
                           Margin="{StaticResource InlineControlSpacing}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource FluentTextPrimary}"
                           FontWeight="SemiBold"/>

                <Button Grid.Column="3"
                        Content="Switch User"
                        Command="{Binding SwitchUserCommand}"
                        Style="{StaticResource ToolbarLinkButtonStyle}"/>
            </Grid>
        </Border>

        <controls:ToastHost Grid.Row="0"
                            Grid.RowSpan="4"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Margin="{StaticResource OverlayHostMargin}"
                            Panel.ZIndex="100"
                            Toasts="{Binding ToastService.Toasts}"/>
    </Grid>
</Window>
