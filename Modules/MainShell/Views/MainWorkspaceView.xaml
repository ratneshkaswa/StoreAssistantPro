<UserControl x:Class="StoreAssistantPro.Modules.MainShell.Views.MainWorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title bar -->
        <DockPanel Margin="{StaticResource SectionSpacing}">
            <TextBlock Text="Home" Style="{StaticResource PageTitleStyle}" Margin="0"
                       DockPanel.Dock="Left"/>
            <Button Command="{Binding LoadMainWorkspaceCommand}"
                    HorizontalAlignment="Right" Style="{StaticResource PrimaryButtonStyle}"
                    h:HelpHint.HelpText="Reload dashboard data"
                    h:HelpHint.Category="Dashboard">
                <Button.Content>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⏳ " Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
                        <TextBlock>
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="🔄 Refresh"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                            <Setter Property="Text" Value="Loading…"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Button.Content>
            </Button>
        </DockPanel>

        <!-- Row 1: Loading / error feedback -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="⏳ Loading..." FontSize="{StaticResource FontSizeSectionHeader}"
                       Foreground="{StaticResource FluentTextTertiary}"
                       HorizontalAlignment="Center" Margin="{StaticResource ItemSpacing}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Style="{StaticResource ErrorMessageStyle}"/>
        </StackPanel>

        <!-- Row 2: Summary stat cards (wraps to 2 columns on narrow windows) -->
        <ItemsControl Grid.Row="2" Margin="{StaticResource SectionSpacing}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <WrapPanel Orientation="Horizontal"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiGreen}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="0"
                    h:HelpHint.HelpText="Total number of active products in inventory"
                    h:HelpHint.Category="Dashboard">
                <StackPanel>
                    <TextBlock Text="📦 Total Products"
                               Foreground="{StaticResource FluentKpiGreenMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding TotalProducts}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiOrange}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="1"
                    h:HelpHint.HelpText="Products with quantity below the low-stock threshold"
                    h:HelpHint.Category="Dashboard">
                <StackPanel>
                    <TextBlock Text="⚠ Low Stock"
                               Foreground="{StaticResource FluentKpiOrangeMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding LowStockCount}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiRed}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="2"
                    h:HelpHint.HelpText="Active products with zero stock"
                    h:HelpHint.Category="Dashboard">
                <StackPanel>
                    <TextBlock Text="🚫 Out of Stock"
                               Foreground="{StaticResource FluentKpiRedMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding OutOfStockCount}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiOrange}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="3"
                    h:HelpHint.HelpText="Active products exceeding their maximum stock level"
                    h:HelpHint.Category="Dashboard">
                <StackPanel>
                    <TextBlock Text="⬆ Overstock"
                               Foreground="{StaticResource FluentKpiOrangeMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding OverstockCount}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiTeal}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="4"
                    h:HelpHint.HelpText="Total inventory value at cost (Σ CostPrice × Quantity)"
                    h:HelpHint.Category="Dashboard">
                <StackPanel>
                    <TextBlock Text="🏷 Inventory Value"
                               Foreground="{StaticResource FluentKpiTealMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding InventoryValue, StringFormat=C}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiGreen}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="5"
                    h:HelpHint.HelpText="Total inventory value at sale price (Σ SalePrice × Quantity)"
                    h:HelpHint.Category="Dashboard">
                <StackPanel>
                    <TextBlock Text="💲 Retail Value"
                               Foreground="{StaticResource FluentKpiGreenMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding InventoryValueAtSale, StringFormat=C}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiBlue}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="6">
                <StackPanel>
                    <TextBlock Text="💰 Today's Sales"
                               Foreground="{StaticResource FluentKpiBlueMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding TodaysSales, StringFormat=C}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiPurple}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="7">
                <StackPanel>
                    <TextBlock Text="🧾 Transactions"
                               Foreground="{StaticResource FluentKpiPurpleMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding TodaysTransactions}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiBlue}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="8"
                    h:HelpHint.HelpText="Average sale amount today (Total ÷ Transactions)"
                    h:HelpHint.Category="Dashboard">
                <StackPanel>
                    <TextBlock Text="📊 Avg Sale"
                               Foreground="{StaticResource FluentKpiBlueMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding TodaysAverageSale, StringFormat=C}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
            <Border Style="{StaticResource StatCardStyle}"
                    Background="{StaticResource FluentKpiOrange}" Margin="{StaticResource StatCardGap}"
                    MinWidth="180"
                    h:Motion.StaggerIndex="9"
                    h:HelpHint.HelpText="Total discount given today across all sales"
                    h:HelpHint.Category="Dashboard">
                <StackPanel>
                    <TextBlock Text="🏷 Discounts"
                               Foreground="{StaticResource FluentKpiOrangeMuted}"
                               FontSize="{StaticResource FontSizeLabel}"/>
                    <TextBlock Text="{Binding TodaysTotalDiscount, StringFormat=C}"
                               Foreground="{StaticResource FluentTextOnAccent}"
                               FontSize="{StaticResource FontSizeKpi}" FontWeight="Bold" Margin="{StaticResource KpiValueSpacing}"/>
                </StackPanel>
            </Border>
        </ItemsControl>

        <!-- Row 3: Detail panels — fill remaining space -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Recent sales -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}"
                    h:Motion.StaggerIndex="7">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardHeaderStyle}">
                        <TextBlock Text="💰 Recent Sales" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"/>
                    </Border>

                    <!-- Empty state -->
                    <TextBlock Text="No sales recorded today"
                               Foreground="{StaticResource FluentTextTertiary}" FontStyle="Italic"
                               FontSize="{StaticResource FontSizeBody}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="{StaticResource EmptyStatePadding}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding RecentSales.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DataGrid ItemsSource="{Binding RecentSales}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" Background="Transparent"
                              RowHeight="32" FontSize="{StaticResource FontSizeBody}"
                              CanUserReorderColumns="False" CanUserResizeRows="False"
                              SelectionMode="Single"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time"
                                                Binding="{Binding SaleDate, StringFormat=HH:mm}"
                                                Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Amount"
                                                Binding="{Binding TotalAmount, StringFormat=C}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Payment"
                                                Binding="{Binding PaymentMethod}"
                                                Width="{StaticResource ColumnWidthStatus}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Top selling products today -->
            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}"
                    h:Motion.StaggerIndex="12">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardHeaderStyle}">
                        <TextBlock Text="🔥 Top Sellers Today" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"/>
                    </Border>

                    <TextBlock Text="No sales yet today"
                               Foreground="{StaticResource FluentTextTertiary}" FontStyle="Italic"
                               FontSize="{StaticResource FontSizeBody}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="{StaticResource EmptyStatePadding}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding TopSellingProducts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding TopSellingProducts}"
                                  Margin="{StaticResource CompactItemSpacing}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{StaticResource FluentTextSecondary}"
                                               Width="{StaticResource FieldWidthStandard}"/>
                                    <TextBlock FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{StaticResource FluentTextPrimary}"
                                               FontWeight="Bold">
                                        <Run Text="×"/>
                                        <Run Text="{Binding QuantitySold, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Revenue, StringFormat=C}"
                                               FontSize="{StaticResource FontSizeLabel}"
                                               Foreground="{StaticResource FluentAccentDefault}"
                                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Low stock alerts -->
            <Border Grid.Column="4" Style="{StaticResource SectionCardStyle}"
                    h:Motion.StaggerIndex="8">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardHeaderStyle}">
                        <TextBlock Text="⚠ Low Stock Alerts" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"/>
                    </Border>

                    <!-- Empty state -->
                    <TextBlock Text="All products are well stocked"
                               Foreground="{StaticResource FluentTextTertiary}" FontStyle="Italic"
                               FontSize="{StaticResource FontSizeBody}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="{StaticResource EmptyStatePadding}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LowStockProducts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DataGrid ItemsSource="{Binding LowStockProducts}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" Background="Transparent"
                              RowHeight="32" FontSize="{StaticResource FontSizeBody}"
                              CanUserReorderColumns="False" CanUserResizeRows="False"
                              SelectionMode="Single"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"
                                                Binding="{Binding Name}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Qty"
                                                Binding="{Binding Quantity}"
                                                Width="{StaticResource ColumnWidthQty}"/>
                            <DataGridTextColumn Header="Price"
                                                Binding="{Binding SalePrice, StringFormat=C}"
                                                Width="{StaticResource ColumnWidthPrice}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Low stock by brand breakdown -->
                    <ItemsControl DockPanel.Dock="Bottom" ItemsSource="{Binding LowStockByBrand}"
                                  Margin="{StaticResource CompactItemSpacing}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                                    <TextBlock Text="{Binding BrandName}" FontWeight="SemiBold"
                                               FontSize="{StaticResource FontSizeLabel}"
                                               Foreground="{StaticResource FluentTextSecondary}"/>
                                    <TextBlock Text=" — " Foreground="{StaticResource FluentTextTertiary}"
                                               FontSize="{StaticResource FontSizeLabel}"/>
                                    <TextBlock Text="{Binding Count}" FontWeight="Bold"
                                               FontSize="{StaticResource FontSizeLabel}"
                                               Foreground="{StaticResource FluentWarning}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>

        <!-- Row 4: Additional detail panels -->
        <Grid Grid.Row="4" Margin="{StaticResource SectionSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Out of stock products -->
            <Border Grid.Column="0" Style="{StaticResource SectionCardStyle}"
                    h:Motion.StaggerIndex="9">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardHeaderStyle}">
                        <TextBlock Text="🚫 Out of Stock" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"/>
                    </Border>

                    <TextBlock Text="No out-of-stock products"
                               Foreground="{StaticResource FluentTextTertiary}" FontStyle="Italic"
                               FontSize="{StaticResource FontSizeBody}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="{StaticResource EmptyStatePadding}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding OutOfStockProducts.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <DataGrid ItemsSource="{Binding OutOfStockProducts}"
                              AutoGenerateColumns="False" IsReadOnly="True"
                              HeadersVisibility="Column" GridLinesVisibility="Horizontal"
                              BorderThickness="0" Background="Transparent"
                              RowHeight="32" FontSize="{StaticResource FontSizeBody}"
                              CanUserReorderColumns="False" CanUserResizeRows="False"
                              SelectionMode="Single"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Product"
                                                Binding="{Binding Name}"
                                                Width="*"/>
                            <DataGridTextColumn Header="Brand"
                                                Binding="{Binding Brand.Name}"
                                                Width="{StaticResource ColumnWidthStatus}"/>
                            <DataGridTextColumn Header="Price"
                                                Binding="{Binding SalePrice, StringFormat=C}"
                                                Width="{StaticResource ColumnWidthPrice}"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <!-- Today's sales by payment method -->
            <Border Grid.Column="2" Style="{StaticResource SectionCardStyle}"
                    h:Motion.StaggerIndex="10">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardHeaderStyle}">
                        <TextBlock Text="💳 Sales by Payment" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"/>
                    </Border>

                    <TextBlock Text="No sales today"
                               Foreground="{StaticResource FluentTextTertiary}" FontStyle="Italic"
                               FontSize="{StaticResource FontSizeBody}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="{StaticResource EmptyStatePadding}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SalesByPaymentMethod.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding SalesByPaymentMethod}"
                                  Margin="{StaticResource CompactItemSpacing}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="{Binding PaymentMethod}" FontWeight="SemiBold"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{StaticResource FluentTextSecondary}"
                                               Width="{StaticResource FieldWidthCompact}"/>
                                    <TextBlock Text="{Binding Total, StringFormat=C}" FontWeight="Bold"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                    <TextBlock Foreground="{StaticResource FluentTextTertiary}"
                                               FontSize="{StaticResource FontSizeLabel}"
                                               VerticalAlignment="Center" Margin="8,0,0,0">
                                        <Run Text="("/>
                                        <Run Text="{Binding Count, Mode=OneWay}"/>
                                        <Run Text=" txns)"/>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>

            <!-- Inventory value by brand -->
            <Border Grid.Column="4" Style="{StaticResource SectionCardStyle}"
                    h:Motion.StaggerIndex="11">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Style="{StaticResource SectionCardHeaderStyle}">
                        <TextBlock Text="🏷 Inventory by Brand" FontWeight="SemiBold"
                                   FontSize="{StaticResource FontSizeBody}"/>
                    </Border>

                    <TextBlock Text="No inventory data"
                               Foreground="{StaticResource FluentTextTertiary}" FontStyle="Italic"
                               FontSize="{StaticResource FontSizeBody}"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Margin="{StaticResource EmptyStatePadding}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding InventoryValueByBrand.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <ItemsControl ItemsSource="{Binding InventoryValueByBrand}"
                                  Margin="{StaticResource CompactItemSpacing}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="0,2,0,2">
                                    <TextBlock Text="{Binding BrandName}" FontWeight="SemiBold"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{StaticResource FluentTextSecondary}"
                                               Width="{StaticResource FieldWidthCompact}"/>
                                    <TextBlock Text="{Binding Value, StringFormat=C}" FontWeight="Bold"
                                               FontSize="{StaticResource FontSizeBody}"
                                               Foreground="{StaticResource FluentAccentDefault}"/>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
