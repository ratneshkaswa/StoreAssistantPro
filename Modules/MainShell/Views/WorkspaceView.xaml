<UserControl x:Class="StoreAssistantPro.Modules.MainShell.Views.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}">
        <Border Background="{StaticResource FluentSurfaceElevated}"
                BorderBrush="{StaticResource FluentSurfaceStroke}"
                BorderThickness="1"
                CornerRadius="{StaticResource FluentCornerXLarge}"
                Padding="{StaticResource CardPadding}"
                Margin="{StaticResource SectionSpacing}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel>
                        <TextBlock Text="Home"
                                   Style="{StaticResource PageTitleStyle}"
                                   Margin="0"/>
                    </StackPanel>

                    <Border Grid.Column="1"
                            Background="{StaticResource FluentSurface}"
                            BorderBrush="{StaticResource FluentSurfaceStroke}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource FluentCornerLarge}"
                            Padding="{StaticResource CardPadding}">
                        <StackPanel>
                            <TextBlock Text="Session Overview"
                                       Style="{StaticResource SectionHeaderStyle}"/>
                            <TextBlock Text="{Binding DataContext.AppState.FirmName, RelativeSource={RelativeSource AncestorType=Window}}"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource FluentTextPrimary}"/>
                            <TextBlock Text="{Binding DataContext.DashboardSummary.CurrentUser, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Style="{StaticResource HintTextStyle}"
                                       Margin="{StaticResource HeroHintSpacing}"/>
                            <TextBlock Text="{Binding DataContext.DashboardSummary.CurrentTime, RelativeSource={RelativeSource AncestorType=Window}}"
                                       Style="{StaticResource HintTextStyle}"
                                       Margin="{StaticResource HintTextSpacing}"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Grid.Row="1"
                            Margin="{StaticResource HeroSectionTopSpacing}">
                    <TextBlock Text="Start Here"
                               Style="{StaticResource SectionHeaderStyle}"/>
                    <UniformGrid Columns="3"
                                 Margin="{StaticResource StepContentTopSpacing}">
                        <Border Margin="{StaticResource QuickStartCardGap}"
                                Style="{StaticResource SectionCardStyle}"
                                Cursor="Hand"
                                Visibility="{Binding DataContext.IsFirmManagementVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.OpenFirmManagementCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Border.InputBindings>
                            <StackPanel HorizontalAlignment="Center"
                                        Margin="{StaticResource QuickStartCardPadding}">
                                <TextBlock Text="&#xE80F;"
                                           FontFamily="{StaticResource FluentIconFont}"
                                           FontSize="{StaticResource FontSizeIconLarge}"
                                           Foreground="{StaticResource FluentAccentDefault}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Firm"
                                           Style="{StaticResource CardItemTitleStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="{StaticResource QuickStartCardGap}"
                                Style="{StaticResource SectionCardStyle}"
                                Cursor="Hand"
                                Visibility="{Binding DataContext.IsUserManagementVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.OpenUserManagementCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Border.InputBindings>
                            <StackPanel HorizontalAlignment="Center"
                                        Margin="{StaticResource QuickStartCardPadding}">
                                <TextBlock Text="&#xE716;"
                                           FontFamily="{StaticResource FluentIconFont}"
                                           FontSize="{StaticResource FontSizeIconLarge}"
                                           Foreground="{StaticResource FluentAccentDefault}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Users"
                                           Style="{StaticResource CardItemTitleStyle}"/>
                            </StackPanel>
                        </Border>

                        <Border Margin="{StaticResource QuickStartCardGap}"
                                Style="{StaticResource SectionCardStyle}"
                                Cursor="Hand">
                            <Border.InputBindings>
                                <MouseBinding Gesture="LeftClick"
                                              Command="{Binding DataContext.RefreshCurrentViewCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                            </Border.InputBindings>
                            <StackPanel HorizontalAlignment="Center"
                                        Margin="{StaticResource QuickStartCardPadding}">
                                <TextBlock Text="&#xE72C;"
                                           FontFamily="{StaticResource FluentIconFont}"
                                           FontSize="{StaticResource FontSizeIconLarge}"
                                           Foreground="{StaticResource FluentAccentDefault}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Refresh"
                                           Style="{StaticResource CardItemTitleStyle}"/>
                            </StackPanel>
                        </Border>
                    </UniformGrid>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
