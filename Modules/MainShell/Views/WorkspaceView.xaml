<UserControl x:Class="StoreAssistantPro.Modules.MainShell.Views.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title bar -->
        <DockPanel Margin="{StaticResource SectionSpacing}">
            <TextBlock Text="Home" Style="{StaticResource PageTitleStyle}" Margin="0"
                       DockPanel.Dock="Left"/>
        </DockPanel>

        <!-- Row 1: Welcome -->
        <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="Welcome to Store Assistant Pro"
                       FontSize="{StaticResource FontSizeSectionHeader}"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource FluentTextPrimary}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Use the toolbar or menu to manage your firm and users."
                       FontSize="{StaticResource FontSizeBody}"
                       Foreground="{StaticResource FluentTextSecondary}"
                       HorizontalAlignment="Center"
                       Margin="0,8,0,0"/>
        </StackPanel>
    </Grid>
</UserControl>
