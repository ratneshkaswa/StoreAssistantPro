<UserControl x:Class="StoreAssistantPro.Modules.MainShell.Views.WorkspaceView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="960"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title bar -->
        <DockPanel Margin="{StaticResource SectionSpacing}">
            <TextBlock Text="Home" Style="{StaticResource PageTitleStyle}" Margin="0"
                       DockPanel.Dock="Left"/>
        </DockPanel>

        <!-- Row 1: Welcome hero -->
        <Grid Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
              MaxWidth="520" h:Motion.FadeIn="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Hero icon -->
            <TextBlock Grid.Row="0" Text="&#xE719;" FontFamily="{StaticResource FluentIconFont}"
                       FontSize="{StaticResource FontSizeIconHero}"
                       HorizontalAlignment="Center"
                       Margin="{StaticResource CompactItemSpacing}"/>

            <!-- Welcome text -->
            <StackPanel Grid.Row="1" HorizontalAlignment="Center"
                        Margin="{StaticResource CompactItemSpacing}">
                <TextBlock Text="Welcome to Store Assistant Pro"
                           Style="{StaticResource HeroTitleStyle}"/>
                <TextBlock Text="Your enterprise retail management workspace"
                           Style="{StaticResource HeroSubtitleStyle}"/>
            </StackPanel>

            <!-- Quick-start cards -->
            <UniformGrid Grid.Row="2" Columns="3"
                         Margin="{StaticResource HeroSectionTopSpacing}">
                <!-- Firm card -->
                <Border Margin="{StaticResource QuickStartCardGap}" Style="{StaticResource SectionCardStyle}"
                        Cursor="Hand"
                        Visibility="{Binding DataContext.IsFirmManagementVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick"
                                      Command="{Binding DataContext.OpenFirmManagementCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Border.InputBindings>
                    <StackPanel HorizontalAlignment="Center" Margin="{StaticResource QuickStartCardPadding}">
                        <TextBlock Text="&#xE731;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconLarge}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Firm" Style="{StaticResource CardItemTitleStyle}"/>
                        <TextBlock Text="Manage details" Style="{StaticResource CardItemSubtitleStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Users card -->
                <Border Margin="{StaticResource QuickStartCardGap}" Style="{StaticResource SectionCardStyle}"
                        Cursor="Hand"
                        Visibility="{Binding DataContext.IsUserManagementVisible, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick"
                                      Command="{Binding DataContext.OpenUserManagementCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Border.InputBindings>
                    <StackPanel HorizontalAlignment="Center" Margin="{StaticResource QuickStartCardPadding}">
                        <TextBlock Text="&#xE716;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconLarge}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Users" Style="{StaticResource CardItemTitleStyle}"/>
                        <TextBlock Text="Manage team" Style="{StaticResource CardItemSubtitleStyle}"/>
                    </StackPanel>
                </Border>

                <!-- Refresh card -->
                <Border Margin="{StaticResource QuickStartCardGap}" Style="{StaticResource SectionCardStyle}"
                        Cursor="Hand">
                    <Border.InputBindings>
                        <MouseBinding Gesture="LeftClick"
                                      Command="{Binding DataContext.RefreshCurrentViewCommand, RelativeSource={RelativeSource AncestorType=Window}}"/>
                    </Border.InputBindings>
                    <StackPanel HorizontalAlignment="Center" Margin="{StaticResource QuickStartCardPadding}">
                        <TextBlock Text="&#xE72C;" FontFamily="{StaticResource FluentIconFont}" FontSize="{StaticResource FontSizeIconLarge}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="Refresh" Style="{StaticResource CardItemTitleStyle}"/>
                        <TextBlock Text="Reload data" Style="{StaticResource CardItemSubtitleStyle}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Hint -->
            <TextBlock Grid.Row="3"
                       Text="Tip: Use Ctrl+D to return here anytime"
                       Style="{StaticResource HintTextStyle}"
                       HorizontalAlignment="Center"
                       Margin="{StaticResource HeroHintSpacing}"/>
        </Grid>
    </Grid>
</UserControl>
