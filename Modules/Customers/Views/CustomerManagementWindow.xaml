<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Customers.Views.CustomerManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="Customer Management"
        ConfirmCommand="{Binding SaveCommand}"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Style="{StaticResource DialogTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE77B;"/><Run Text=" Customer Management"/></TextBlock>

        <!-- Search bar -->
        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                     AutomationProperties.Name="Search customers"
                     h:Watermark.Text="e.g. Aarav or 9876543210"/>
            <Button Grid.Column="1" Content="Search" Command="{Binding SearchCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
        </Grid>

        <!-- DataGrid + Form share the * row -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto" MaxHeight="280"/>
            </Grid.RowDefinitions>

            <!-- Customer grid -->
            <DataGrid AutomationProperties.Name="Customers list"
                      ItemsSource="{Binding Customers}"
                      SelectedItem="{Binding SelectedCustomer}"
                      Style="{StaticResource EnterpriseDataGridStyle}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      SelectionMode="Single"
                      HeadersVisibility="Column" CanUserAddRows="False"
                      EnableRowVirtualization="True"
                      EnableColumnVirtualization="True"
                      Margin="{StaticResource ItemSpacing}">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTextColumn Header="GSTIN" Binding="{Binding GSTIN}" Width="{StaticResource ColumnWidthPrice}"/>
                    <DataGridTemplateColumn Header="Active" CellTemplate="{StaticResource ActiveToggleCellTemplate}" Width="{StaticResource ColumnWidthQty}"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Form fields (scrollable when clamped) -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          Focusable="False"
                          PanningMode="VerticalOnly"
                          Margin="{StaticResource ItemSpacing}"
                          h:SmoothScroll.IsEnabled="True">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                        <Run Text="Name "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                    </TextBlock>
                    <TextBox Grid.Row="0" Grid.Column="1"
                             Text="{Binding CustomerName, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="200"
                             AutomationProperties.Name="Customer name"
                             h:Watermark.Text="e.g. Amit Sharma"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Phone"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Text="{Binding Phone, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Customer phone"
                             Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                             MaxLength="15"
                             h:Watermark.Text="e.g. 9876543210"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Email"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1"
                             Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="200"
                             AutomationProperties.Name="Customer email"
                             h:Watermark.Text="e.g. amit@example.com"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Address"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="6" Grid.Column="1"
                             Text="{Binding Address, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="500"
                             AutomationProperties.Name="Customer address"
                             h:Watermark.Text="e.g. 24 MI Road, Jaipur"/>

                    <TextBlock Grid.Row="8" Grid.Column="0" Text="GSTIN"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="8" Grid.Column="1"
                             Text="{Binding GSTIN, UpdateSourceTrigger=PropertyChanged}"
                             AutomationProperties.Name="Customer GSTIN"
                             Width="{StaticResource FieldWidthWide}" HorizontalAlignment="Left"
                             MaxLength="15"
                             h:Watermark.Text="e.g. 08ABCDE1234F1Z5"/>

                    <TextBlock Grid.Row="10" Grid.Column="0" Text="Notes"
                               Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="10" Grid.Column="1"
                             Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                             MaxLength="500"
                             AutomationProperties.Name="Customer notes"
                             h:Watermark.Text="e.g. Prefers WhatsApp updates"/>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- Messages -->
        <Grid Grid.Row="3" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasErrorMessage}"
                              AutomationProperties.LiveSetting="Assertive"
                              AutomationProperties.HelpText="{Binding ErrorMessage}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccessMessage}"
                              AutomationProperties.LiveSetting="Polite"
                              AutomationProperties.HelpText="{Binding SuccessMessage}"/>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right"
                    Margin="{StaticResource FormActionBarSpacing}">
            <Button Content="New" Command="{Binding NewCustomerCommand}"
                    Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Save" Command="{Binding SaveCommand}"
                    Style="{StaticResource PrimaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
            <Button Content="Close" IsCancel="True"
                    Style="{StaticResource SecondaryButtonStyle}"/>
        </StackPanel>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving customer changes..."/>
    </Grid>
</core:BaseDialogWindow>
