<UserControl x:Class="StoreAssistantPro.Modules.Customers.Views.CustomersView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             Loaded="OnLoaded">
    <controls:EnterprisePageLayout>

        <controls:EnterprisePageLayout.TipBannerContent>
            <controls:InlineTipBanner
                h:TipBannerAutoState.TipKey="CustomersView.QuickTip"
                h:TipBannerAutoState.ContextKey="Customers"
                Title="Quick tip"
                TipText="Manage your customer base. Track purchases, loyalty points, and GSTIN for B2B invoicing."/>
        </controls:EnterprisePageLayout.TipBannerContent>

        <controls:EnterprisePageLayout.ToolbarContent>
            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="{StaticResource FieldGroupSpacing}">
                <Border Style="{StaticResource SectionCardHeaderStyle}">
                    <WrapPanel>
                        <Button Content="➕ Add Customer" Command="{Binding ShowAddFormCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" FontWeight="SemiBold"/>
                        <Button Content="🗑 Delete" Command="{Binding DeleteCustomerCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Separator Style="{StaticResource FluentSeparatorStyle}"/>
                        <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Width="{StaticResource FieldWidthWide}"
                                 h:Watermark.Text="🔍 Search customers..."
                                 VerticalContentAlignment="Center"/>
                        <TextBlock Text="{Binding CountDisplay}" VerticalAlignment="Center"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   Margin="{StaticResource InlineControlSpacing}"/>
                    </WrapPanel>
                </Border>
            </Border>
        </controls:EnterprisePageLayout.ToolbarContent>

        <Border Style="{StaticResource SectionCardStyle}" ClipToBounds="True">
            <Grid>
                <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding Customers}"
                          SelectedItem="{Binding SelectedCustomer}"
                          MinHeight="100">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="{StaticResource ColumnWidthId}"/>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*"/>
                        <DataGridTextColumn Header="Phone" Binding="{Binding Phone}" Width="{StaticResource ColumnWidthStatus}"/>
                        <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="{StaticResource ColumnWidthStatus}"/>
                        <DataGridTextColumn Header="GSTIN" Binding="{Binding GSTIN}" Width="{StaticResource ColumnWidthStatus}"/>
                        <DataGridTextColumn Header="Visits" Binding="{Binding VisitCount}" Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Total Purchases" Binding="{Binding TotalPurchaseAmount, StringFormat=C}" Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Points" Binding="{Binding LoyaltyPoints}" Width="{StaticResource ColumnWidthQty}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <controls:EmptyStateOverlay
                    Icon="👤"
                    Title="No customers found"
                    Description="Add your first customer to track purchases and loyalty."
                    ActionText="➕ Add Customer"
                    ActionCommand="{Binding ShowAddFormCommand}"
                    ItemCount="{Binding Customers.Count}"/>
            </Grid>
        </Border>

        <controls:EnterprisePageLayout.BottomFormContent>
            <Border Style="{StaticResource FormCardStyle}"
                    Visibility="{Binding IsAddFormVisible, Converter={StaticResource BoolToVisibility}}"
                    h:KeyboardNav.DefaultCommand="{Binding SaveCustomerCommand}"
                    h:KeyboardNav.EscapeCommand="{Binding CancelAddCommand}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto" MinWidth="100"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="{StaticResource FormRowSpacing}"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.ColumnSpan="4"
                               Text="New Customer" Style="{StaticResource SectionHeaderStyle}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Name *" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="Phone" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="2" Grid.Column="3" Text="{Binding NewPhone, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Email" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding NewEmail, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBlock Grid.Row="4" Grid.Column="2" Text="GSTIN" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="4" Grid.Column="3" Text="{Binding NewGSTIN, UpdateSourceTrigger=PropertyChanged}"/>

                    <TextBlock Grid.Row="6" Grid.Column="0" Text="Address" Style="{StaticResource FormRowLabelStyle}"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Grid.ColumnSpan="3" Text="{Binding NewAddress, UpdateSourceTrigger=PropertyChanged}"/>

                    <StackPanel Grid.Row="7" Grid.ColumnSpan="4" Orientation="Horizontal"
                                HorizontalAlignment="Right" Margin="{StaticResource FormActionBarSpacing}">
                        <TextBlock Text="{Binding ErrorMessage}" Style="{StaticResource ErrorMessageStyle}"
                                   VerticalAlignment="Center" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="Cancel" Command="{Binding CancelAddCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" Margin="{StaticResource InlineControlSpacing}"/>
                        <Button Content="💾 Save" Command="{Binding SaveCustomerCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </controls:EnterprisePageLayout.BottomFormContent>

    </controls:EnterprisePageLayout>
</UserControl>
