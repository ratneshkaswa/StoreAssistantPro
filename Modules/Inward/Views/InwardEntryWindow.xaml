<core:BaseDialogWindow x:Class="StoreAssistantPro.Modules.Inward.Views.InwardEntryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:core="clr-namespace:StoreAssistantPro.Core"
        xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
        xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
        Title="Inward Entry"
        ConfirmCommand="{Binding ConfirmStepCommand}"
        Loaded="OnLoaded">
    <Grid Margin="{StaticResource DialogPadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title + step indicator -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Style="{StaticResource DialogTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7B8;"/><Run Text=" Inward Entry"/></TextBlock>

            <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="{StaticResource ItemSpacing}" Width="{StaticResource StepIndicatorWidth}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Step 1 -->
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <Ellipse Width="{StaticResource StepDotSize}" Height="{StaticResource StepDotSize}" HorizontalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource FluentAccentDefault}"/>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Parcels" HorizontalAlignment="Center"
                               FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource StepLabelSpacing}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="1" Height="{StaticResource StepConnectorHeight}" VerticalAlignment="Top" Margin="{StaticResource StepConnectorTopOffset}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource FluentStrokeDefault}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep1}" Value="False">
                                    <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Step 2 -->
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <Ellipse Width="{StaticResource StepDotSize}" Height="{StaticResource StepDotSize}" HorizontalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource FluentStrokeDefault}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep1}" Value="False">
                                        <Setter Property="Fill" Value="{StaticResource FluentAccentDefault}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Transport" HorizontalAlignment="Center"
                               FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource StepLabelSpacing}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>

                <Border Grid.Column="3" Height="{StaticResource StepConnectorHeight}" VerticalAlignment="Top" Margin="{StaticResource StepConnectorTopOffset}">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource FluentStrokeDefault}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <!-- Step 3 -->
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <Ellipse Width="{StaticResource StepDotSize}" Height="{StaticResource StepDotSize}" HorizontalAlignment="Center">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource FluentStrokeDefault}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource FluentAccentDefault}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    <TextBlock Text="Products" HorizontalAlignment="Center"
                               FontSize="{StaticResource FontSizeCaption}" Margin="{StaticResource StepLabelSpacing}">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Foreground" Value="{StaticResource FluentTextTertiary}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                        <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>

        <!-- Row 1: Step content -->
        <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">

            <!-- Step 1: Select parcel count -->
            <Grid Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Number of Parcels "/><Run Text="*" Foreground="{StaticResource FluentError}"/>
                </TextBlock>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          AutomationProperties.Name="Number of parcels"
                          ItemsSource="{Binding ParcelCounts}"
                          SelectedItem="{Binding ParcelCount}"
                          Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>

            </Grid>

            <!-- Step 2: Transport charges -->
            <Grid Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Transport Charges (₹)"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         AutomationProperties.Name="Transport charges"
                         Text="{Binding TransportCharges, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                         h:Watermark.Text="e.g. 250"/>

            </Grid>

            <!-- Step 3: Parcels with products -->
            <ScrollViewer Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}"
                          AutomationProperties.Name="Parcel entry list"
                          Focusable="False"
                          h:SmoothScroll.IsEnabled="True"
                          PanningMode="VerticalOnly"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding Parcels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="{StaticResource ItemSpacing}"
                                    Background="{StaticResource FluentSubtleBackground}"
                                    CornerRadius="{StaticResource CornerRadiusMedium}"
                                    Padding="{StaticResource CardPadding}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Parcel header -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource FluentAccentDefault}">
                                            <Run Text="Parcel "/>
                                            <Run Text="{Binding ParcelNumber, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Button Grid.Column="1"
                                                Content="Add Row"
                                                Command="{Binding AddProductRowCommand}"
                                                Style="{StaticResource SecondaryButtonStyle}"/>
                                    </Grid>

                                    <!-- Vendor selection -->
                                    <Grid Grid.Row="1" Margin="{StaticResource FieldLabelSpacing}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Vendor" Style="{StaticResource FormRowLabelStyle}"/>
                                        <ComboBox Grid.Column="1"
                                                  AutomationProperties.Name="Parcel vendor"
                                                  ItemsSource="{Binding DataContext.Vendors, RelativeSource={RelativeSource AncestorType=Window}}"
                                                  SelectedItem="{Binding SelectedVendor}"
                                                  DisplayMemberPath="Name"/>
                                    </Grid>

                                    <!-- Product rows -->
                                    <Grid Grid.Row="2" Margin="{StaticResource FieldLabelSpacing}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Margin="{StaticResource FieldLabelSpacing}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto" MinWidth="{StaticResource FieldWidthCompact}"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Product"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="1" Text="Qty"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="2" Text="Colour"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="3" Text="Size"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="4" Text="Pattern"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="5" Text="Type"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                        </Grid>

                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ProductRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="{StaticResource FieldLabelSpacing}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto" MinWidth="{StaticResource FieldWidthCompact}"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox ItemsSource="{Binding DataContext.Products, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  AutomationProperties.Name="Parcel product"
                                                                  SelectedItem="{Binding SelectedProduct}"
                                                                  DisplayMemberPath="Name"/>
                                                        <TextBox Grid.Column="1"
                                                                 AutomationProperties.Name="Parcel quantity"
                                                                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding HasSelectedProduct}"
                                                                 Margin="{StaticResource InlineControlSpacing}" MaxLength="8"
                                                                 h:Watermark.Text="e.g. 12"/>
                                                        <ComboBox Grid.Column="2"
                                                                  AutomationProperties.Name="Parcel colour"
                                                                  ItemsSource="{Binding DataContext.Colours, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding SelectedColour}"
                                                                  IsEnabled="{Binding CanSelectColour}"
                                                                  DisplayMemberPath="Name" Margin="{StaticResource InlineControlSpacing}"/>
                                                        <ComboBox Grid.Column="3"
                                                                  AutomationProperties.Name="Parcel size"
                                                                  ItemsSource="{Binding DataContext.Sizes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding SelectedSize}"
                                                                  IsEnabled="{Binding CanSelectSize}"
                                                                  DisplayMemberPath="Name" Margin="{StaticResource InlineControlSpacing}"/>
                                                        <ComboBox Grid.Column="4"
                                                                  AutomationProperties.Name="Parcel pattern"
                                                                  ItemsSource="{Binding DataContext.Patterns, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding SelectedPattern}"
                                                                  IsEnabled="{Binding CanSelectPattern}"
                                                                  DisplayMemberPath="Name" Margin="{StaticResource InlineControlSpacing}"/>
                                                        <ComboBox Grid.Column="5"
                                                                  AutomationProperties.Name="Parcel variant type"
                                                                  ItemsSource="{Binding DataContext.VariantTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                  SelectedItem="{Binding SelectedVariantType}"
                                                                  IsEnabled="{Binding CanSelectVariantType}"
                                                                  DisplayMemberPath="Name" Margin="{StaticResource InlineControlSpacing}"/>
                                                        <Button Grid.Column="6"
                                                                Content="Remove"
                                                                Command="{Binding DataContext.RemoveProductRowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource SecondaryButtonStyle}"
                                                                Margin="{StaticResource InlineControlSpacing}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Row 2: Messages -->
        <Grid Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasErrorMessage}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccessMessage}"/>
        </Grid>

        <!-- Row 3: Navigation buttons -->
        <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&#x2190; Back" Command="{Binding BackCommand}"
                    Style="{StaticResource SecondaryButtonStyle}"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibility}}"/>

            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="Next &#x2192;" Command="{Binding NextCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="{StaticResource InlineControlSpacing}"
                        Visibility="{Binding CanGoNext, Converter={StaticResource BoolToVisibility}}"/>
                <Button Grid.Column="1" Content="Save Entry" Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Margin="{StaticResource InlineControlSpacing}"
                        Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVisibility}}"/>
                <Button Grid.Column="2" Content="Close" IsCancel="True"
                        Style="{StaticResource SecondaryButtonStyle}"/>
            </Grid>
        </Grid>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving inward entry..."/>
    </Grid>
</core:BaseDialogWindow>
