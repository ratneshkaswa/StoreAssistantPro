<UserControl x:Class="StoreAssistantPro.Modules.Inward.Views.InwardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900"
             Loaded="OnLoaded">
    <controls:EnterprisePageLayout>

        <!-- ═══ TipBanner ═══ -->
        <controls:EnterprisePageLayout.TipBannerContent>
            <controls:InlineTipBanner
                h:TipBannerAutoState.TipKey="InwardView.QuickTip"
                h:TipBannerAutoState.ContextKey="Inward"
                Title="Quick tip"
                TipText="Record parcels received at the shop. Each parcel gets auto-numbered (MM-NN). Transport charges are tracked as expenses."/>
        </controls:EnterprisePageLayout.TipBannerContent>

        <!-- ═══ Toolbar ═══ -->
        <controls:EnterprisePageLayout.ToolbarContent>
            <Border Style="{StaticResource SectionCardStyle}"
                    Margin="{StaticResource FieldGroupSpacing}">
                <Border Style="{StaticResource SectionCardHeaderStyle}">
                    <WrapPanel>
                        <Button Content="?? New Inward Entry" Command="{Binding ShowEntryFormCommand}"
                                Style="{StaticResource ToolbarButtonStyle}" FontWeight="SemiBold"/>
                        <Button Content="🗑 Delete Selected" Command="{Binding DeleteEntryCommand}"
                                Style="{StaticResource ToolbarButtonStyle}"/>
                        <Separator Style="{StaticResource FluentSeparatorStyle}"/>
                        <TextBlock Text="Next:" VerticalAlignment="Center"
                                   Foreground="{StaticResource FluentTextTertiary}" Margin="{StaticResource InlineLeftGap}"/>
                        <TextBlock Text="{Binding NextParcelPreview}" VerticalAlignment="Center"
                                   FontWeight="Bold" Foreground="{StaticResource FluentAccentDefault}" Margin="{StaticResource FormColumnGap}"/>
                    </WrapPanel>
                </Border>
            </Border>
        </controls:EnterprisePageLayout.ToolbarContent>

        <!-- ═══ MainContent (star row) · Inward History DataGrid ═══ -->
        <Border Style="{StaticResource SectionCardStyle}" ClipToBounds="True">
            <Grid>
                <DataGrid Style="{StaticResource EnterpriseDataGridStyle}"
                          ItemsSource="{Binding InwardEntries}"
                          SelectedItem="{Binding SelectedEntry}"
                          MinHeight="100">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Inward #" Binding="{Binding InwardNumber}"
                                            Width="{StaticResource ColumnWidthId}"/>
                        <DataGridTextColumn Header="Date" Binding="{Binding InwardDate, StringFormat='{}{0:dd-MM-yyyy}'}"
                                            Width="{StaticResource ColumnWidthStatus}"/>
                        <DataGridTextColumn Header="Parcels" Binding="{Binding ParcelCount}"
                                            Width="{StaticResource ColumnWidthQty}"/>
                        <DataGridTextColumn Header="Transport ?" Binding="{Binding TransportCharges, StringFormat='{}{0:N2}'}"
                                            Width="{StaticResource ColumnWidthPrice}"/>
                        <DataGridTextColumn Header="Notes" Binding="{Binding Notes}" Width="*"/>
                    </DataGrid.Columns>

                    <DataGrid.RowDetailsTemplate>
                        <DataTemplate>
                            <Border Background="{StaticResource FluentBackgroundSecondary}"
                                    Padding="{StaticResource CardContentPadding}" Margin="{StaticResource DashboardListItemSpacing}"
                                    CornerRadius="{StaticResource FluentCornerSmall}">
                                <ItemsControl ItemsSource="{Binding Parcels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" Margin="{StaticResource DashboardListItemSpacing}">
                                                <TextBlock Text="{Binding ParcelNumber}" FontWeight="SemiBold"
                                                           Foreground="{StaticResource FluentAccentDefault}"
                                                           MinWidth="60"/>
                                                <TextBlock Text="{Binding Category.Name, FallbackValue='-'}"
                                                           MinWidth="120"/>
                                                <TextBlock Text="{Binding Vendor.Name, FallbackValue='-'}"
                                                           MinWidth="120"/>
                                                <TextBlock Text="{Binding Description}"
                                                           Foreground="{StaticResource FluentTextTertiary}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </DataTemplate>
                    </DataGrid.RowDetailsTemplate>
                </DataGrid>

                <controls:EmptyStateOverlay
                    Icon="??"
                    Title="No inward entries yet"
                    Description="Record your first parcel receipt to start tracking stock inward."
                    ActionText="?? New Inward Entry"
                    ActionCommand="{Binding ShowEntryFormCommand}"
                    ItemCount="{Binding InwardEntries.Count}"/>
            </Grid>
        </Border>

        <!-- ═══ BottomForm ═══ -->
        <controls:EnterprisePageLayout.BottomFormContent>
            <Border Style="{StaticResource FormCardStyle}"
                    Visibility="{Binding IsEntryFormVisible, Converter={StaticResource BoolToVisibility}}"
                    h:KeyboardNav.DefaultCommand="{Binding SaveInwardCommand}"
                    h:KeyboardNav.EscapeCommand="{Binding CancelEntryCommand}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Row 0: Date + Parcel Count -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Inward Date"
                                   Style="{StaticResource FormRowLabelStyle}"/>
                        <DatePicker Grid.Column="1"
                                    SelectedDate="{Binding InwardDate}"
                                    Width="{StaticResource FieldWidthStandard}"
                                    Margin="{StaticResource FormColumnGap}"/>

                        <TextBlock Grid.Column="2" Text="No. of Parcels"
                                   Style="{StaticResource FormRowLabelStyle}"/>
                        <TextBox Grid.Column="3"
                                 Text="{Binding ParcelCount, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsIntegerOnly="True"
                                 Width="{StaticResource FieldWidthCompact}"
                                 MaxLength="3"/>
                    </Grid>

                    <!-- Row 1: Dynamic parcel rows -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding ParcelRows}"
                                  Margin="{StaticResource MessageBarSpacing}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource FluentBackgroundSecondary}"
                                        CornerRadius="{StaticResource FluentCornerSmall}"
                                        Padding="{StaticResource CardContentPadding}" Margin="{StaticResource FieldLabelSpacing}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="70"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding ParcelNumber}"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource FluentAccentDefault}"
                                                   VerticalAlignment="Center"
                                                   Margin="{StaticResource InlineControlSpacing}"/>
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding DataContext.Categories, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding SelectedCategory}"
                                                  DisplayMemberPath="Name"
                                                  Margin="{StaticResource InlineControlSpacing}"/>
                                        <ComboBox Grid.Column="2"
                                                  ItemsSource="{Binding DataContext.Vendors, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                  SelectedItem="{Binding SelectedVendor}"
                                                  DisplayMemberPath="Name"
                                                  Margin="{StaticResource InlineControlSpacing}"/>
                                        <TextBox Grid.Column="3"
                                                 Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}"
                                                 h:Watermark.Text="Description (optional)"
                                                 MaxLength="300"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Row 2: Transport charges + Notes -->
                    <Grid Grid.Row="2" Margin="{StaticResource MessageBarSpacing}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto" MinWidth="100"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Transport ?"
                                   Style="{StaticResource FormRowLabelStyle}"/>
                        <TextBox Grid.Column="1"
                                 Text="{Binding TransportCharges, UpdateSourceTrigger=PropertyChanged}"
                                 h:NumericInput.IsDecimalOnly="True"
                                 Width="{StaticResource FieldWidthStandard}"
                                 Margin="{StaticResource FormColumnGap}"/>

                        <TextBlock Grid.Column="2" Text="Notes"
                                   Style="{StaticResource FormRowLabelStyle}"/>
                        <TextBox Grid.Column="3"
                                 Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                 MaxLength="500"/>
                    </Grid>

                    <!-- Row 3: Form actions -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal"
                                Margin="{StaticResource FormActionBarSpacing}">
                        <Button Content="?? Save Inward" Command="{Binding SaveInwardCommand}"
                                Style="{StaticResource PrimaryButtonStyle}"/>
                        <Button Content="Cancel" Command="{Binding CancelEntryCommand}"
                                Style="{StaticResource SecondaryButtonStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </controls:EnterprisePageLayout.BottomFormContent>

    </controls:EnterprisePageLayout>
</UserControl>
