<UserControl x:Class="StoreAssistantPro.Modules.Inward.Views.InwardEntryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             x:Name="Root"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}"
          TextOptions.TextFormattingMode="Display"
          TextOptions.TextRenderingMode="ClearType"
          KeyboardNavigation.TabNavigation="Continue"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
          ScrollViewer.PanningMode="VerticalOnly">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Title + step indicator -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource PageTitleStyle}"><Run FontFamily="{StaticResource FluentIconFont}" Text="&#xE7B8;"/><Run Text=" Inward Entry"/></TextBlock>
                <TextBlock Text="Capture parcel intake, transport charges, and received products in a guided flow."
                           Style="{StaticResource PageSubtitleStyle}"/>
            </StackPanel>

            <Grid Grid.Row="1"
                  HorizontalAlignment="Center"
                  Margin="0,12,0,0"
                  Width="336">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="Step1Segment"
                        Grid.Column="0"
                        Height="8"
                        CornerRadius="4"
                        Background="{StaticResource FluentAccentDefault}"/>

                <Border x:Name="Step2Segment"
                        Grid.Column="2"
                        Height="8"
                        CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource ChromeAltFillColorSecondary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep1}" Value="False">
                                    <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Border x:Name="Step3Segment"
                        Grid.Column="4"
                        Height="8"
                        CornerRadius="4">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource ChromeAltFillColorSecondary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,8,0,0"
                           Text="Parcels"
                           TextAlignment="Center"
                           FontSize="{StaticResource FontSizeCaption}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep1}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Row="1"
                           Grid.Column="2"
                           Margin="0,8,0,0"
                           Text="Transport"
                           TextAlignment="Center"
                           FontSize="{StaticResource FontSizeCaption}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep1}" Value="False">
                                    <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsStep2}" Value="True">
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>

                <TextBlock Grid.Row="1"
                           Grid.Column="4"
                           Margin="0,8,0,0"
                           Text="Products"
                           TextAlignment="Center"
                           FontSize="{StaticResource FontSizeCaption}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{StaticResource FluentTextSecondary}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsStep3}" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource FluentAccentDefault}"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </Grid>

        <!-- Row 1: Step content -->
        <Grid Grid.Row="1" Margin="{StaticResource StepContentTopSpacing}">

            <!-- Step 1: Select parcel count -->
            <Grid Visibility="{Binding IsStep1, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FormRowLabelStyle}">
                    <Run Text="Number of Parcels "/><Run Text="*" Style="{StaticResource RequiredFieldIndicatorRunStyle}"/>
                </TextBlock>
                <ComboBox Grid.Row="0" Grid.Column="1"
                          AutomationProperties.Name="Number of parcels"
                          ItemsSource="{Binding ParcelCounts}"
                          SelectedItem="{Binding ParcelCount}"
                          Width="{StaticResource FieldWidthCompact}" HorizontalAlignment="Left"/>

            </Grid>

            <!-- Step 2: Transport charges -->
            <Grid Visibility="{Binding IsStep2, Converter={StaticResource BoolToVisibility}}"
                  VerticalAlignment="Top">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Transport charges"
                           Style="{StaticResource FormRowLabelStyle}"/>
                <TextBox Grid.Row="0" Grid.Column="1"
                         AutomationProperties.Name="Transport charges"
                         Text="{Binding TransportCharges, UpdateSourceTrigger=PropertyChanged}"
                         Width="{StaticResource FieldWidthStandard}" HorizontalAlignment="Left"
                         h:TextBoxAdornment.PrefixText="{Binding CurrencySymbol}"
                         h:NumericInput.Scope="Number"
                         h:NumericInput.IsDecimalOnly="True"
                         h:Watermark.Text="Transport charges"/>

            </Grid>

            <!-- Step 3: Parcels with products -->
            <ScrollViewer Visibility="{Binding IsStep3, Converter={StaticResource BoolToVisibility}}"
                          AutomationProperties.Name="Parcel entry list"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Focusable="False"
                          PanningMode="VerticalOnly">
                <ItemsControl ItemsSource="{Binding Parcels}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="{StaticResource ItemSpacing}"
                                    Background="{StaticResource FluentSubtleBackground}"
                                    CornerRadius="{StaticResource CornerRadiusMedium}"
                                    Padding="{StaticResource CardPadding}">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <!-- Parcel header -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock FontWeight="SemiBold" Foreground="{StaticResource FluentAccentDefault}">
                                            <Run Text="Parcel "/>
                                            <Run Text="{Binding ParcelNumber, Mode=OneWay}"/>
                                        </TextBlock>
                                        <Button Grid.Column="1"
                                                Content="Add Row"
                                                Command="{Binding AddProductRowCommand}"
                                                Style="{StaticResource InlineCollectionAddButtonStyle}"/>
                                    </Grid>

                                    <!-- Vendor selection -->
                                    <Grid Grid.Row="1" Margin="{StaticResource FieldLabelSpacing}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" MinWidth="{StaticResource FormLabelColumnMinWidth}"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Vendor" Style="{StaticResource FormRowLabelStyle}"/>
                                        <ComboBox Grid.Column="1"
                                                  AutomationProperties.Name="Parcel vendor"
                                                  ItemsSource="{Binding DataContext.Vendors, ElementName=Root}"
                                                  SelectedItem="{Binding SelectedVendor}"
                                                  DisplayMemberPath="Name"
                                                  Style="{StaticResource FluentAutoSuggestComboBoxStyle}"/>
                                    </Grid>

                                    <!-- Product rows -->
                                    <Grid Grid.Row="2" Margin="{StaticResource FieldLabelSpacing}">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Grid Margin="{StaticResource FieldLabelSpacing}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto" MinWidth="{StaticResource FieldWidthCompact}"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Product"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="1" Text="Qty"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="2" Text="Colour"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="3" Text="Size"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="4" Text="Pattern"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                            <TextBlock Grid.Column="5" Text="Type"
                                                       Style="{StaticResource FormRowLabelStyle}"/>
                                        </Grid>

                                        <ItemsControl Grid.Row="1" ItemsSource="{Binding ProductRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="{StaticResource FieldLabelSpacing}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto" MinWidth="{StaticResource FieldWidthCompact}"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ComboBox ItemsSource="{Binding DataContext.Products, ElementName=Root}"
                                                                  AutomationProperties.Name="Parcel product"
                                                                  SelectedItem="{Binding SelectedProduct}"
                                                                  DisplayMemberPath="Name"
                                                                  Style="{StaticResource FluentAutoSuggestComboBoxStyle}"/>
                                                        <TextBox Grid.Column="1"
                                                                 AutomationProperties.Name="Parcel quantity"
                                                                 Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsEnabled="{Binding HasSelectedProduct}"
                                                                 Margin="{StaticResource InlineControlSpacing}" MaxLength="8"
                                                                 h:Watermark.Text="Parcel count"/>
                                                        <ComboBox Grid.Column="2"
                                                                  AutomationProperties.Name="Parcel colour"
                                                                  ItemsSource="{Binding DataContext.Colours, ElementName=Root}"
                                                                  SelectedItem="{Binding SelectedColour}"
                                                                  IsEnabled="{Binding CanSelectColour}"
                                                                  DisplayMemberPath="Name" Margin="{StaticResource InlineControlSpacing}"
                                                                  Style="{StaticResource FluentAutoSuggestComboBoxStyle}"/>
                                                        <ComboBox Grid.Column="3"
                                                                  AutomationProperties.Name="Parcel size"
                                                                  ItemsSource="{Binding DataContext.Sizes, ElementName=Root}"
                                                                  SelectedItem="{Binding SelectedSize}"
                                                                  IsEnabled="{Binding CanSelectSize}"
                                                                  DisplayMemberPath="Name" Margin="{StaticResource InlineControlSpacing}"
                                                                  Style="{StaticResource FluentAutoSuggestComboBoxStyle}"/>
                                                        <ComboBox Grid.Column="4"
                                                                  AutomationProperties.Name="Parcel pattern"
                                                                  ItemsSource="{Binding DataContext.Patterns, ElementName=Root}"
                                                                  SelectedItem="{Binding SelectedPattern}"
                                                                  IsEnabled="{Binding CanSelectPattern}"
                                                                  DisplayMemberPath="Name" Margin="{StaticResource InlineControlSpacing}"
                                                                  Style="{StaticResource FluentAutoSuggestComboBoxStyle}"/>
                                                        <ComboBox Grid.Column="5"
                                                                  AutomationProperties.Name="Parcel variant type"
                                                                  ItemsSource="{Binding DataContext.VariantTypes, ElementName=Root}"
                                                                  SelectedItem="{Binding SelectedVariantType}"
                                                                  IsEnabled="{Binding CanSelectVariantType}"
                                                                  DisplayMemberPath="Name" Margin="{StaticResource InlineControlSpacing}"
                                                                  Style="{StaticResource FluentAutoSuggestComboBoxStyle}"/>
                                                        <Button Grid.Column="6"
                                                                Content="Remove"
                                                                Command="{Binding DataContext.RemoveProductRowCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}"
                                                                Style="{StaticResource InlineCollectionRemoveButtonStyle}"
                                                                Margin="{StaticResource InlineControlSpacing}"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <!-- Row 2: Messages -->
        <Grid Grid.Row="2" MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"/>
            <controls:InfoBar Message="{Binding SuccessMessage}"
                              Severity="Success"
                              IsOpen="{Binding HasSuccess}"/>
        </Grid>

        <!-- Row 3: Navigation buttons -->
        <Grid Grid.Row="3" Margin="{StaticResource FormActionBarSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="&#x2190; Back" Command="{Binding BackCommand}"
                    Style="{StaticResource BackButtonStyle}"
                    Visibility="{Binding CanGoBack, Converter={StaticResource BoolToVisibility}}"/>

            <Grid Grid.Column="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Button Content="Next &#x2192;" Command="{Binding NextCommand}"
                        Style="{StaticResource NextButtonStyle}"
                        Margin="{StaticResource InlineControlSpacing}"
                        Visibility="{Binding CanGoNext, Converter={StaticResource BoolToVisibility}}"/>
                <Button Grid.Column="1" Content="Save" Command="{Binding SaveCommand}"
                        Style="{StaticResource SaveButtonStyle}"
                        Margin="{StaticResource InlineControlSpacing}"
                        Visibility="{Binding IsLastStep, Converter={StaticResource BoolToVisibility}}"/>
            </Grid>
        </Grid>
        <controls:ErrorStateOverlay Grid.Row="1"
                                    IsOpen="{Binding HasLoadError}"
                                    Icon=":("
                                    Title="Couldn't load inward entry data"
                                    Description="{Binding LoadErrorMessage}"
                                    ActionText="Retry"
                                    ActionCommand="{Binding LoadCommand}"/>
        <controls:LoadingOverlay IsActive="{Binding IsBusy}"
                                 Message="Saving inward entry..."/>
    </Grid>
</UserControl>

