<UserControl x:Class="StoreAssistantPro.Modules.BarcodeLabels.Views.BarcodeLabelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="900"
             d:DesignWidth="1200"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Barcode Labels"
                           Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Build a print queue, adjust label settings, and print barcode sheets from one compact tool surface."
                           Style="{StaticResource PageSubtitleStyle}"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Print Labels"
                    Command="{Binding PrintLabelsCommand}"
                    Style="{StaticResource PrintButtonStyle}"
                    MinWidth="148"/>
        </Grid>

        <Grid Grid.Row="1" Margin="{StaticResource ItemSpacing}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource AdminSectionCardStyle}" Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Products"
                                   Style="{StaticResource AdminSectionTitleStyle}"/>

                        <Button Grid.Column="1"
                                Content="Add All"
                                Style="{StaticResource UtilityButtonStyle}"
                                Command="{Binding AddAllToBatchCommand}"/>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="Search products and add them into the current label print queue."
                               Style="{StaticResource AdminSectionDescriptionStyle}"/>

                    <TextBox Grid.Row="2"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource FluentSearchTextBoxStyle}"
                             AutomationProperties.Name="Search products"
                             h:Watermark.Text="Search products by name, barcode, or SKU"
                             Margin="0,8,0,0"/>

                    <Grid Grid.Row="3" Margin="0,8,0,0">
                        <DataGrid ItemsSource="{Binding Products}"
                                  Style="{StaticResource EnterpriseDataGridStyle}"
                                  AutomationProperties.Name="Products"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="Column"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  h:DataGridEmptyState.IsEnabled="False">
                            <DataGrid.InputBindings>
                                <MouseBinding MouseAction="LeftDoubleClick"
                                              Command="{Binding AddToBatchCommand}"
                                              CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataGrid.InputBindings>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PRODUCT"
                                                    Binding="{Binding Name}"
                                                    Width="*"/>
                                <DataGridTextColumn Header="BARCODE"
                                                    Binding="{Binding Barcode}"
                                                    Width="140"/>
                                <DataGridTextColumn Header="PRICE"
                                                    Binding="{Binding SalePrice, StringFormat=N2}"
                                                    Width="100"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <controls:EmptyStateOverlay Icon="📦"
                                                    Title="No products found"
                                                    Description="Add products with barcodes to generate labels."
                                                    ItemCount="{Binding Products.Count}"/>
                    </Grid>
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Style="{StaticResource AdminSectionCardStyle}"
                    Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Print Queue"
                                   Style="{StaticResource AdminSectionTitleStyle}"/>

                        <Button Grid.Column="1"
                                Content="Clear"
                                Style="{StaticResource UtilityButtonStyle}"
                                Command="{Binding ClearBatchCommand}"/>
                    </Grid>

                    <TextBlock Grid.Row="1"
                               Text="Adjust quantities before printing the current batch of labels."
                               Style="{StaticResource AdminSectionDescriptionStyle}"/>

                    <Grid Grid.Row="2" Margin="0,8,0,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding BatchItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource DividerStrokeColorDefault}"
                                                BorderThickness="0,0,0,1"
                                                Padding="0,6">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel>
                                                    <TextBlock Text="{Binding ProductName}"
                                                               Style="{StaticResource ReportListPrimaryTextStyle}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Barcode}"
                                                               Style="{StaticResource ReportListSecondaryTextStyle}"
                                                               Margin="0,2,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="1"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            Margin="8,0,0,0">
                                                    <TextBlock Text="x"
                                                               VerticalAlignment="Center"
                                                               Foreground="{StaticResource FluentTextTertiary}"
                                                               Margin="0,0,4,0"/>
                                                    <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="48"
                                                             h:NumericInput.IsIntegerOnly="True"
                                                             TextAlignment="Center"/>
                                                </StackPanel>

                                                <Button Grid.Column="2"
                                                        Content="Remove"
                                                        Style="{StaticResource UtilityButtonStyle}"
                                                        Command="{Binding DataContext.RemoveFromBatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="Remove label from batch"
                                                        AutomationProperties.Name="Remove label from batch"
                                                        Margin="8,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <controls:EmptyStateOverlay Icon="🏷"
                                                    Title="No labels queued"
                                                    Description="Double-click products to add them to the print queue."
                                                    ItemCount="{Binding BatchItems.Count}"/>
                    </Grid>

                    <Border Grid.Row="3"
                            Style="{StaticResource SummaryPanelStyle}"
                            Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock Text="Batch Summary"
                                       Style="{StaticResource SummaryPanelTitleStyle}"/>
                            <TextBlock Text="{Binding TotalLabelsLabel}"
                                       Style="{StaticResource SummaryMetaTextStyle}"
                                       Margin="0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Grid.Column="4"
                    Style="{StaticResource AdminSectionCardStyle}"
                    Margin="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Label Template"
                               Style="{StaticResource AdminSectionTitleStyle}"/>

                    <TextBlock Grid.Row="1"
                               Text="Choose which fields appear and how labels are arranged on each page."
                               Style="{StaticResource AdminSectionDescriptionStyle}"/>

                    <StackPanel Grid.Row="2" Margin="0,8,0,0">
                        <CheckBox Content="Product name"
                                  IsChecked="{Binding ShowProductName}"
                                  Margin="0,4"/>
                        <CheckBox Content="Sale price"
                                  IsChecked="{Binding ShowSalePrice}"
                                  Margin="0,4"/>
                        <CheckBox Content="MRP"
                                  IsChecked="{Binding ShowMRP}"
                                  Margin="0,4"/>
                        <CheckBox Content="Barcode"
                                  IsChecked="{Binding ShowBarcode}"
                                  Margin="0,4"/>
                        <CheckBox Content="Size and color"
                                  IsChecked="{Binding ShowSizeColor}"
                                  Margin="0,4"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="0,16,0,0">
                        <TextBlock Text="Sheet Layout"
                                   Style="{StaticResource AdminSectionTitleStyle}"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="8"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Label width"
                                           Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBox Text="{Binding LabelWidth, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,0"
                                         h:NumericInput.Scope="Number"
                                         h:TextBoxAdornment.SuffixText="mm"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Label height"
                                           Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBox Text="{Binding LabelHeight, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,0"
                                         h:NumericInput.Scope="Number"
                                         h:TextBoxAdornment.SuffixText="mm"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Columns"
                                           Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBox Text="{Binding ColumnsPerSheet, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,0"
                                         h:NumericInput.IsIntegerOnly="True"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="2">
                                <TextBlock Text="Rows"
                                           Style="{StaticResource SummaryKeyTextStyle}"/>
                                <TextBox Text="{Binding RowsPerSheet, UpdateSourceTrigger=PropertyChanged}"
                                         Margin="0,4,0,0"
                                         h:NumericInput.IsIntegerOnly="True"/>
                            </StackPanel>

                            <StackPanel Grid.Row="4" Grid.ColumnSpan="3">
                                <TextBlock Text="Labels per sheet"
                                           Style="{StaticResource SummaryMetaTextStyle}"
                                           Margin="0"/>
                                <TextBlock Style="{StaticResource SummaryAccentValueTextStyle}"
                                           Margin="0,4,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} x {1} = {2}">
                                            <Binding Path="ColumnsPerSheet"/>
                                            <Binding Path="RowsPerSheet"/>
                                            <Binding Path="TotalLabelCount" FallbackValue="0"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="0,16,0,0">
                        <TextBlock Text="Preview"
                                   Style="{StaticResource AdminSectionTitleStyle}"
                                   Margin="0,0,0,8"/>

                        <Border Style="{StaticResource SummaryPanelStyle}"
                                Margin="0"
                                MinHeight="100">
                            <TextBlock Text="{Binding PreviewText}"
                                       FontFamily="Consolas"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource FluentTextPrimary}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <controls:LoadingOverlay Grid.ColumnSpan="5"
                                     IsActive="{Binding IsLoading}"
                                     Message="Loading products..."/>
        </Grid>

        <Grid Grid.Row="2"
              MinHeight="{StaticResource MessageAreaMinHeight}"
              Margin="{StaticResource FieldLabelSpacing}">
            <controls:InfoBar Title="Barcode Labels"
                              Message="{Binding ErrorMessage}"
                              Severity="Error"
                              IsOpen="{Binding HasError}"
                              Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"/>
        </Grid>
    </Grid>
</UserControl>
