<UserControl x:Class="StoreAssistantPro.Modules.BarcodeLabels.Views.BarcodeLabelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:controls="clr-namespace:StoreAssistantPro.Core.Controls"
             xmlns:h="clr-namespace:StoreAssistantPro.Core.Helpers"
             mc:Ignorable="d"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True"
             d:DesignHeight="900"
             d:DesignWidth="1200"
             Loaded="OnLoaded">
    <Grid Margin="{StaticResource PagePadding}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>
                <TextBlock Text="Barcode Labels"
                           Style="{StaticResource PageTitleStyle}"/>
                <TextBlock Text="Generate and print barcode labels for your products."
                           Margin="0,4,0,0"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{StaticResource FluentTextSecondary}"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                <Button Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding PrintLabelsCommand}"
                        MinWidth="120">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource FluentIconFont}"
                                   Text="&#xE749;"
                                   Margin="0,0,8,0"/>
                        <TextBlock Text="Print Labels"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main content: 3-column layout -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="320"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Product list -->
            <Border Style="{StaticResource CardStyle}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Products"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextPrimary}"/>

                        <Button Grid.Column="1"
                                Content="Add All"
                                Style="{StaticResource ToolbarLinkButtonStyle}"
                                Command="{Binding AddAllToBatchCommand}"/>
                    </Grid>

                    <TextBox Grid.Row="1"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             h:Watermark.Text="Search by name, barcode, or SKU…"
                             Margin="0,8,0,0"/>

                    <DataGrid Grid.Row="2"
                              ItemsSource="{Binding Products}"
                              Style="{StaticResource EnterpriseDataGridStyle}"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              Margin="0,8,0,0"
                              h:DataGridEmptyState.IsEnabled="False">
                        <DataGrid.InputBindings>
                            <MouseBinding MouseAction="LeftDoubleClick"
                                          Command="{Binding AddToBatchCommand}"
                                          CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                        </DataGrid.InputBindings>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="PRODUCT"
                                                Binding="{Binding Name}"
                                                Width="*"/>
                            <DataGridTextColumn Header="BARCODE"
                                                Binding="{Binding Barcode}"
                                                Width="140"/>
                            <DataGridTextColumn Header="PRICE"
                                                Binding="{Binding SalePrice, StringFormat=N2}"
                                                Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <controls:EmptyStateOverlay Grid.Row="2"
                                                Icon="📦"
                                                Title="No products found"
                                                Description="Add products with barcodes to generate labels."
                                                ItemCount="{Binding Products.Count}"/>
                </Grid>
            </Border>

            <!-- Center: Batch queue (#382) -->
            <Border Grid.Column="2"
                    Style="{StaticResource CardStyle}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="Print Queue"
                                   FontSize="{StaticResource FontSizeBody}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource FluentTextPrimary}"/>

                        <Button Grid.Column="1"
                                Content="Clear"
                                Style="{StaticResource ToolbarLinkButtonStyle}"
                                Command="{Binding ClearBatchCommand}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,8,0,0">
                        <ItemsControl ItemsSource="{Binding BatchItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{StaticResource DividerStrokeColorDefault}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,6">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <StackPanel>
                                                <TextBlock Text="{Binding ProductName}"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource FluentTextPrimary}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Barcode}"
                                                           FontSize="{StaticResource FontSizeCaption}"
                                                           Foreground="{StaticResource FluentTextSecondary}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal"
                                                        VerticalAlignment="Center" Margin="8,0,0,0">
                                                <TextBlock Text="×" VerticalAlignment="Center"
                                                           Foreground="{StaticResource FluentTextTertiary}"
                                                           Margin="0,0,4,0"/>
                                                <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}"
                                                         Width="40"
                                                         h:NumericInput.IsIntegerOnly="True"
                                                         TextAlignment="Center"/>
                                            </StackPanel>

                                            <Button Grid.Column="2"
                                                    Content="✕"
                                                    Style="{StaticResource ToolbarLinkButtonStyle}"
                                                    Command="{Binding DataContext.RemoveFromBatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="8,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <controls:EmptyStateOverlay Grid.Row="1"
                                                Icon="🏷"
                                                Title="No labels queued"
                                                Description="Double-click products to add them to the print queue."
                                                ItemCount="{Binding BatchItems.Count}"/>

                    <Border Grid.Row="2"
                            Background="{StaticResource LayerFillColorSecondary}"
                            CornerRadius="6"
                            Padding="12,8"
                            Margin="0,8,0,0">
                        <TextBlock Text="{Binding TotalLabelsLabel}"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentTextSecondary}"
                                   FontWeight="SemiBold"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Right: Template settings (#377) + Preview -->
            <Border Grid.Column="4"
                    Style="{StaticResource CardStyle}"
                    Padding="{StaticResource CardPadding}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Label Template"
                               FontSize="{StaticResource FontSizeBody}"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource FluentTextPrimary}"/>

                    <!-- Toggle options -->
                    <StackPanel Grid.Row="1" Margin="0,12,0,0">
                        <CheckBox Content="Product name (#378)"
                                  IsChecked="{Binding ShowProductName}"
                                  Margin="0,4"/>
                        <CheckBox Content="Sale price (#379)"
                                  IsChecked="{Binding ShowSalePrice}"
                                  Margin="0,4"/>
                        <CheckBox Content="MRP (#380)"
                                  IsChecked="{Binding ShowMRP}"
                                  Margin="0,4"/>
                        <CheckBox Content="Barcode"
                                  IsChecked="{Binding ShowBarcode}"
                                  Margin="0,4"/>
                    </StackPanel>

                    <!-- Sheet layout (#445) -->
                    <StackPanel Grid.Row="2" Margin="0,16,0,0">
                        <TextBlock Text="SHEET LAYOUT"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   Margin="0,0,0,8"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <StackPanel>
                                <TextBlock Text="Columns"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource FluentTextSecondary}"/>
                                <TextBox Text="{Binding ColumnsPerSheet, UpdateSourceTrigger=PropertyChanged}"
                                         h:NumericInput.IsIntegerOnly="True"
                                         Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Rows"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource FluentTextSecondary}"/>
                                <TextBox Text="{Binding RowsPerSheet, UpdateSourceTrigger=PropertyChanged}"
                                         h:NumericInput.IsIntegerOnly="True"
                                         Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.ColumnSpan="3" Margin="0,8,0,0">
                                <TextBlock Text="Labels per sheet"
                                           FontSize="{StaticResource FontSizeCaption}"
                                           Foreground="{StaticResource FluentTextTertiary}"/>
                                <TextBlock FontSize="{StaticResource FontSizeBody}"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource FluentAccentDefault}"
                                           Margin="0,4,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} × {1} = {2}">
                                            <Binding Path="ColumnsPerSheet"/>
                                            <Binding Path="RowsPerSheet"/>
                                            <Binding Path="TotalLabelCount" FallbackValue="0"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>

                    <!-- Label preview -->
                    <StackPanel Grid.Row="3" Margin="0,16,0,0">
                        <TextBlock Text="PREVIEW"
                                   FontSize="{StaticResource FontSizeCaption}"
                                   Foreground="{StaticResource FluentTextTertiary}"
                                   Margin="0,0,0,8"/>

                        <Border Background="{StaticResource LayerFillColorSecondary}"
                                BorderBrush="{StaticResource DividerStrokeColorDefault}"
                                BorderThickness="1"
                                CornerRadius="4"
                                MinHeight="100"
                                Padding="12,8">
                            <TextBlock Text="{Binding PreviewText}"
                                       FontFamily="Consolas"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       TextAlignment="Center"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{StaticResource FluentTextPrimary}"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <controls:LoadingOverlay Grid.ColumnSpan="5"
                                     IsActive="{Binding IsLoading}"
                                     Message="Loading products…"/>
        </Grid>

        <!-- Messages -->
        <controls:InfoBar Grid.Row="0"
                          Title="Error"
                          Message="{Binding ErrorMessage}"
                          Severity="Error"
                          IsOpen="{Binding HasError}"
                          Visibility="{Binding HasError, Converter={StaticResource BoolToVisibility}}"
                          VerticalAlignment="Bottom"
                          Margin="0,8,0,0"/>
    </Grid>
</UserControl>
