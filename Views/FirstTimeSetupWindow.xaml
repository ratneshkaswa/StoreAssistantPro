<Window x:Class="StoreAssistantPro.Views.FirstTimeSetupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Store Assistant Pro — First Time Setup"
        Height="420" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="First Time Setup" FontSize="20" FontWeight="Bold" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Margin="0,0,0,10">
            <TextBlock Text="Firm Name" FontSize="12" Margin="0,0,0,3"/>
            <TextBox Text="{Binding FirmName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" MaxLength="200"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,10">
            <TextBlock Text="Admin PIN (4 digits)" FontSize="12" Margin="0,0,0,3"/>
            <TextBox Text="{Binding AdminPin, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" MaxLength="4"/>
        </StackPanel>

        <StackPanel Grid.Row="3" Margin="0,0,0,10">
            <TextBlock Text="Manager PIN (4 digits)" FontSize="12" Margin="0,0,0,3"/>
            <TextBox Text="{Binding ManagerPin, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" MaxLength="4"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Margin="0,0,0,10">
            <TextBlock Text="User PIN (4 digits)" FontSize="12" Margin="0,0,0,3"/>
            <TextBox Text="{Binding UserPin, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" MaxLength="4"/>
        </StackPanel>

        <StackPanel Grid.Row="5" Margin="0,0,0,10">
            <TextBlock Text="Master Password (6 digits)" FontSize="12" Margin="0,0,0,3"/>
            <TextBox Text="{Binding MasterPin, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6" MaxLength="6"/>
        </StackPanel>

        <TextBlock Grid.Row="6" Text="{Binding ErrorMessage}" Foreground="Red"
                   TextWrapping="Wrap" Margin="0,0,0,10"/>

        <Button Grid.Row="7" Content="Complete Setup" Command="{Binding SaveCommand}"
                Padding="12,8" FontSize="14" FontWeight="SemiBold"
                HorizontalAlignment="Stretch"/>
    </Grid>
</Window>
