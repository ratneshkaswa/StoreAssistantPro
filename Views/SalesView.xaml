<UserControl x:Class="StoreAssistantPro.Views.SalesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="550" d:DesignWidth="800"
             Loaded="OnLoaded">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Sales" FontSize="24" FontWeight="Bold" Margin="0,0,0,10"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
            <Button Content="🛒 New Sale" Command="{Binding ShowNewSaleCommand}"
                    Padding="10,5" Margin="0,0,15,0" FontWeight="SemiBold"/>
            <TextBlock Text="From:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker SelectedDate="{Binding FilterFrom}" Width="130" Margin="0,0,10,0"/>
            <TextBlock Text="To:" VerticalAlignment="Center" Margin="0,0,5,0"/>
            <DatePicker SelectedDate="{Binding FilterTo}" Width="130" Margin="0,0,10,0"/>
            <Button Content="Filter" Command="{Binding FilterByDateCommand}" Padding="10,5" Margin="0,0,5,0"/>
            <Button Content="Load All" Command="{Binding LoadSalesCommand}" Padding="10,5"/>
        </StackPanel>

        <!-- New Sale Form -->
        <Border Grid.Row="2" Background="#F5F5F5" CornerRadius="6" Padding="15" Margin="0,0,0,10"
                Visibility="{Binding IsNewSaleVisible, Converter={StaticResource BoolToVisibility}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="New Sale" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"
                           Grid.ColumnSpan="2"/>

                <!-- Product picker -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,8" Grid.ColumnSpan="2">
                    <ComboBox ItemsSource="{Binding AvailableProducts}"
                              SelectedItem="{Binding SelectedProduct}"
                              DisplayMemberPath="Name" Width="200" Margin="0,0,8,0"/>
                    <TextBlock Text="Qty:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Text="{Binding CartQuantity, UpdateSourceTrigger=PropertyChanged}"
                             Width="50" Padding="4" Margin="0,0,8,0" VerticalContentAlignment="Center"/>
                    <Button Content="Add to Cart" Command="{Binding AddToCartCommand}" Padding="10,4"/>
                </StackPanel>

                <!-- Cart -->
                <DataGrid Grid.Row="2" Grid.ColumnSpan="2" Margin="0,0,0,8"
                          ItemsSource="{Binding CartItems}"
                          AutoGenerateColumns="False" IsReadOnly="True"
                          MaxHeight="150" SelectionMode="Single"
                          CanUserAddRows="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product" Binding="{Binding Product.Name}" Width="*"/>
                        <DataGridTextColumn Header="Price" Binding="{Binding UnitPrice, StringFormat=C}" Width="80"/>
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" Width="50"/>
                        <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=C}" Width="90"/>
                        <DataGridTemplateColumn Header="" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="✕" Padding="4,1"
                                            Command="{Binding DataContext.RemoveFromCartCommand,
                                                RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            BorderThickness="0" Background="Transparent"
                                            Foreground="Red" Cursor="Hand"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Footer -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" Grid.ColumnSpan="2">
                    <TextBlock Text="Payment:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox ItemsSource="{Binding PaymentMethods}"
                             SelectedItem="{Binding PaymentMethod}" Width="100" Margin="0,0,15,0"/>
                    <TextBlock VerticalAlignment="Center" Margin="0,0,15,0" FontSize="16" FontWeight="Bold">
                        <Run Text="Total: "/>
                        <Run Text="{Binding CartTotal, StringFormat=C, Mode=OneWay}"/>
                    </TextBlock>
                    <Button Content="✅ Complete Sale" Command="{Binding CompleteSaleCommand}"
                            Padding="12,5" Margin="0,0,5,0" FontWeight="SemiBold"/>
                    <Button Content="Cancel" Command="{Binding CancelNewSaleCommand}" Padding="10,5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Sales history -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Sales}"
                  SelectedItem="{Binding SelectedSale}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                <DataGridTextColumn Header="Date" Binding="{Binding SaleDate, StringFormat=g}" Width="160"/>
                <DataGridTextColumn Header="Total" Binding="{Binding TotalAmount, StringFormat=C}" Width="120"/>
                <DataGridTextColumn Header="Payment" Binding="{Binding PaymentMethod}" Width="120"/>
                <DataGridTextColumn Header="Items" Binding="{Binding Items.Count}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
