<Window x:Class="StoreAssistantPro.Views.UserSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Store Assistant Pro — Select User"
        Height="300" Width="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Select User" FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1" VerticalAlignment="Center">
            <Button Content="👤  Admin" Command="{Binding SelectAdminCommand}"
                    Padding="15,12" FontSize="15" Margin="0,0,0,10"/>
            <Button Content="👤  Manager" Command="{Binding SelectManagerCommand}"
                    Padding="15,12" FontSize="15" Margin="0,0,0,10"/>
            <Button Content="👤  User" Command="{Binding SelectUserCommand}"
                    Padding="15,12" FontSize="15"/>
        </StackPanel>
    </Grid>
</Window>
