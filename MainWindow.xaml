<Window x:Class="StoreAssistantPro.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Store Assistant Pro" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar Navigation -->
        <Border Background="#2D2D30">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Margin="0,20,0,0">
                    <TextBlock Text="Store Assistant"
                               Foreground="White" FontSize="18" FontWeight="Bold"
                               HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Text="Pro"
                               Foreground="#007ACC" FontSize="12" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,0,0,15"/>
                    <Separator Background="#3E3E42" Margin="10,0,10,15"/>

                    <Button Content="🏠  Dashboard"
                            Command="{Binding NavigateToDashboardCommand}"
                            Style="{StaticResource NavButtonStyle}"/>

                    <Button Content="📦  Products"
                            Command="{Binding NavigateToProductsCommand}"
                            Style="{StaticResource NavButtonStyle}"/>

                    <Button Content="💰  Sales"
                            Command="{Binding NavigateToSalesCommand}"
                            Style="{StaticResource NavButtonStyle}"/>
                </StackPanel>

                <TextBlock DockPanel.Dock="Bottom"
                           Text="v1.0.0" Foreground="#666"
                           FontSize="10" HorizontalAlignment="Center"
                           Margin="0,0,0,12"/>
                <Border/>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <ContentControl Grid.Column="1" Content="{Binding CurrentView}"/>
    </Grid>
</Window>
