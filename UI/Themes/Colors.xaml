<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══════════════════════════════════════════════════════════════
         ENTERPRISE COLOR PALETTE
         
         Professional enterprise colors for use alongside the existing
         Fluent 2 design system (Core/Styles/DesignSystem.xaml).
         
         NOTE: AppBackgroundBrush is also defined in DesignSystem.xaml
         with the same value. The Core/Styles version takes precedence
         when this dictionary is merged before it.
         ═══════════════════════════════════════════════════════════════ -->

    <!-- Primary brand accent -->
    <SolidColorBrush x:Key="PrimaryBrush"         Color="#2563EB"/>

    <!-- Application background -->
    <SolidColorBrush x:Key="AppBackgroundBrush"    Color="#FFFFFF"/>

    <!-- Card / surface fill -->
    <SolidColorBrush x:Key="CardBrush"             Color="#FFFFFF"/>

    <!-- Borders and dividers -->
    <SolidColorBrush x:Key="BorderBrush"           Color="#E5E7EB"/>

    <!-- Primary text -->
    <SolidColorBrush x:Key="TextBrush"             Color="#111827"/>

    <!-- Secondary / muted text -->
    <SolidColorBrush x:Key="SecondaryTextBrush"    Color="#6B7280"/>

</ResourceDictionary>
